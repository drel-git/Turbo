|              https://www.github.com/drel-git/TurboLoot
|                       TurboGive.mac v1.9.5 for TurboLoot 3.8
| @version TurboGive.mac 1.10.0
| Companion to TurboLoot - item redistribution between characters
|
| =========================================================================================
|
| Usage: /mac TurboGive                 (give to group + each group bot gives theirs)
|        /mac TurboGive all              (give to all in zone + each e3 bot gives theirs)
|        /mac TurboGive CHARNAME        (give my items to a specific character)
|        /mac TurboGive CHARNAME #      (give up to # total items to character)
|        /mac TurboGive CHARNAME cash [#] (give plat; omit or 0 = all plat+gp+sp+cp; aliases: plat, pp)
|        /mac TurboGive CHARNAME dc [#] (give Diamond Coin to character)
|        /mac TurboGive send CHAR QTY Item Name...   (give QTY of item to CHAR from my bags)
|        /mac TurboGive send CHAR QTY id ITEMID      (same, by item id — preferred for scripting)
|        /mac TurboGive hand COUNT      (pick up item, give COUNT to each group member)
|        /mac TurboGive collect          (collect items from group)
|        /mac TurboGive collect #        (collect up to # total items)
|        /mac TurboGive collect raid     (collect from all e3 bots)
|        /mac TurboGive collect cash [#] [all]  (collect plat from group; omit or 0 = all plat+gp+sp+cp; aliases: plat, pp)
|        /mac TurboGive collect dc [#] [all]    (collect Diamond Coin from group)
|        /mac TurboGive bank             (tell group to pull from bank; runner does not pull)
|        /mac TurboGive bank solo        (pull my own items from bank only)
|        /mac TurboGive bank all         (tell all e3 bots to pull; runner does not pull)
|        /mac TurboGive bank pull        (pull my bank for others; or run when told)
|        /mac TurboGive bank CHARNAME    (I pull CHARNAME's items from my bank)
|        /mac TurboGive bank tell CHARNAME (tell CHARNAME to pull their own from their bank)
|        /mac TurboGive convert aa [#]   (AA -> DC at NPC; PoK or Temple of Marr)
|        /mac TurboGive convert dc [#]   (DC -> AA at NPC)
|        /mac TurboGive convert exchange (alt-currency DC -> inventory DC)
|        /mac TurboGive convert all      (convert my AA -> DC + broadcast group)
|        /mac TurboGive convert dc all   (convert my DC -> AA + broadcast group)
|        /mac TurboGive handin "Item" [#] [destroy]  (hand item/coin to NPC)
|        /mac TurboGive handin pp|gp|sp|cp #         (hand coin to NPC)
|        /mac TurboGive handin tell CHARNAME "Item" [#] [destroy]
|        /mac TurboGive tell CHARNAME       (tell CHARNAME to distribute their items)
|        /mac TurboGive collect tell CHARNAME [all] (tell CHARNAME to collect)
|        /mac TurboGive hand tell CHARNAME COUNT ItemName [all] (tell CHARNAME to hand out)
|        /mac TurboGive add CHARNAME     (add cursor item to character's want-list)
|        /mac TurboGive list CHARNAME    (show character's want-list)
|        /mac TurboGive help             (show commands)
|
| INI FORMAT (in turboloot.ini [GiveList] section):
|   Exact items:  ItemName=CharName      (give all stacks / copies while trading)
|                 ItemName=CharName 5    (give up to 5 total copies / stack units)
|                 ItemName=CharName N     (give at most N of that item to CharName; same idea as ItemLimits #)
|   Prefixes:     _prefix1=CharName:Spell:*   _prefix2=CharName:*Oleander  (up to 30)
|   Wildcards:    _wildcards=CharName|OtherChar  (uses shared [Wildcards] rules)
|   Exclusions:   [GiveExclude] _list=Exact Name,Other Name  (blocks prefix/wildcard only; exact ItemName= lines still give)
|
| ============================================================================================
#turbo 100

| =====================================================================
| SEND DONE TO ORCHESTRATOR — used when bot finishes a broadcast task
| Works whether grouped or not, leader or not. Orchestrator receives via e3bc.
| =====================================================================
Sub SendDoneToOrchestrator
    | Echo theme: ${tgTag} then \ar[DONE]\ar / \ar[SIGNAL_DONE]\ar (red; names + -> plain for #event captures).
    | Always /echo locally first: Stock Up / Collect DC on THIS box must see [DONE]
    | even when /squelch /e3bc suppresses the sender's own e3bc line.
    /if (!${Defined[tgTag]}) /declare tgTag string local \at[turboGive]
    /echo ${tgTag} \ar[DONE]\aw ${Me.Name}->LOCAL
    /if (${Me.Grouped} && ${Group.Leader.Name.Length} && !${Group.Leader.Name.Equal[NULL]} && !${Group.Leader.Name.Equal[${Me.Name}]}) {
        /squelch /e3bc /echo ${tgTag} \ar[DONE]\aw ${Me.Name}->${Group.Leader.Name}
        /squelch /e3bct ${Group.Leader.Name} /echo ${tgTag} \ar[SIGNAL_DONE]\aw ${Me.Name}
    } else {
        | Not grouped, or we're group leader — broadcast to ALL so orchestrator receives it
        /squelch /e3bc /echo ${tgTag} \ar[DONE]\aw ${Me.Name}->ALL
    }
/return

| Pause/resume the active combat bot on a REMOTE box. The target runs
| turbo_bot_pause locally so RGMercs vs E3 is decided on that client
| (not on the giver). Based on Hazado's RGMercs integration.
Sub RemotePauseBot(string targetName)
    /if (!${targetName.Length} || ${targetName.Equal[NULL]}) /return
    /squelch /e3bct ${targetName} /squelch /lua run turbo_bot_pause pause
/return

Sub RemoteResumeBot(string targetName)
    /if (!${targetName.Length} || ${targetName.Equal[NULL]}) /return
    /squelch /e3bct ${targetName} /squelch /lua run turbo_bot_pause resume
/return

| =====================================================================
| EVENT HANDLERS
| =====================================================================
| #*# allows match with or without MQ color codes (red \ar[DONE] / \ar[SIGNAL_DONE] wrappers)
| v1.8.7-diag: brackets in pattern are LITERAL — they must match the
| brackets in the echo, otherwise #*# matches empty between SIGNAL_DONE
| and #1#, and "]\aw " gets captured into the sender name as "] Shortheels"
| instead of "Shortheels". MQ2 #event brackets have no special meaning
| (not regex character classes); they are matched verbatim.
#event CharDone "#*#[SIGNAL_DONE]#*##1#"
#event CharDoneBC "#*#[DONE]#*##1#->#2#"
#event CharDoneTell "#1# tells you, 'Done sending you items'"
#event TradeCancelled "Trade cancelled."
#event TradeComplete "The trade has been completed."
#event TooFar "You are too far away from #1# to trade."
#event HandinNotWanted "#*#I have no need for this #*#"
#event HandinNoItems "#*#Invalid item slot #*#"

| =====================================================================
| GIVE LIST VALUE: optional "CharName N" max count (trailing space + positive int)
| Sets outer giveListParsedName / giveListParsedQty (0 = no per-item cap)
| =====================================================================
Sub LastSpacePos(string s)
    /declare best int local 0
    /declare k int local 1
    /declare slen int local ${s.Length}
    /if (!${slen}) /return 0
    /for k 1 to ${slen}
        /if (${s.Mid[${k},1].Equal[ ]}) /varset best ${k}
    /next k
    /return ${best}

Sub ParseGiveListIniValue(string raw)
    /if (!${Defined[giveListParsedQty]}) /declare giveListParsedQty int outer 0
    /if (!${Defined[giveListParsedName]}) /declare giveListParsedName string outer
    /varset giveListParsedQty 0
    /varset giveListParsedName ""
    /if (!${raw.Length} || ${raw.Equal[NULL]}) /return
    /declare s string local ${raw}
    /if (${s.Find[;]}) /varset s ${s.Left[${Math.Calc[${s.Find[;]}-1]}]}
    /varset giveListParsedName ${s}
    /declare ls int local
    /call LastSpacePos "${s}"
    /varset ls ${Macro.Return}
    /if (${ls} < 1) /return
    /declare lhs string local ${s.Left[${Math.Calc[${ls}-1]}]}
    /declare rhs string local ${s.Mid[${Math.Calc[${ls}+1]},${Math.Calc[${s.Length}-${ls}]}]}
    /if (!${lhs.Length} || !${rhs.Length}) /return
    /declare n int local ${Int[${rhs.Replace[ ,]}]}
    /if (${n} < 1) /return
    /varset giveListParsedName ${lhs}
    /varset giveListParsedQty ${n}
/return

| =====================================================================
| MULTI-RECIPIENT GIVE LIST MATCHER (1.9.0)
| Splits rawVal on pipe, runs single-recipient parse on each token,
| first match wins. Backward compatible: a value with no pipe is one
| token and behaves exactly as in 1.8.9 and earlier.
|
| Examples of supported INI values (right side of [GiveList] entries):
|   Bob                              -> always-give to Bob (no per-give cap)
|   Bob 10                           -> always-give up to 10 to Bob
|   Bob 10|John 10|Sally 10          -> give up to 10 each to Bob, John, Sally
|   Bob 10 | John 5 | Sally 20       -> mixed quantities, whitespace OK
|   Bob 10|John                      -> Bob capped at 10, John no cap
|
| First-match-wins on duplicate names:
|   Bob 10|Bob 5                     -> Bob gets 10; the second Bob 5 is
|                                       ignored and the player is warned
|                                       once per call.
|
| Empty tokens are silently skipped (e.g. a stray "Bob 10||John 10").
| =====================================================================
Sub GiveListIniValueMatchesChar(string rawVal, string charName)
    | Outer var declarations match ParseGiveListIniValue's contract, in
    | case this sub is called before that one in the macro lifecycle.
    /if (!${Defined[giveListParsedQty]}) /declare giveListParsedQty int outer 0
    /if (!${Defined[giveListParsedName]}) /declare giveListParsedName string outer
    /varset giveListParsedQty 0
    /varset giveListParsedName ""

    /if (!${rawVal.Length} || ${rawVal.Equal[NULL]}) /return FALSE

    | 1.9.1: bots receiving a give-broadcast skip multi-recipient entries
    | so only the originator distributes them. Prevents trade collisions
    | where Bopp tries to give Discord the item AND vice versa simultaneously.
    | Single-recipient entries (no pipe) bypass this gate entirely — bots
    | continue to distribute their own single-recipient items as before.
    | Defensive: tgIsBroadcastGiver should always be defined by Sub Main,
    | but guard against direct sub-call paths just in case.
    /if (${Defined[tgIsBroadcastGiver]} && ${tgIsBroadcastGiver} && ${rawVal.Find[|]}) /return FALSE

    /declare cnUp string local ${charName.Upper.Replace[ ,]}
    /if (!${cnUp.Length}) /return FALSE

    | Single-token fast path: no pipe, behave exactly like 1.8.9.
    /if (!${rawVal.Find[|]}) {
        /call ParseGiveListIniValue "${rawVal}"
        /declare pn0 string local ${giveListParsedName.Upper.Replace[ ,]}
        /if (${pn0.Equal[${cnUp}]}) /return TRUE
        /varset giveListParsedQty 0
        /varset giveListParsedName ""
        /return FALSE
    }

    | Multi-token path: walk the rawVal, splitting on '|'. We do NOT use
    | string.Split because MQ2 macro string methods don't include one;
    | manual cursor walk via .Find[|] + .Mid is the standard pattern in
    | this codebase (see giveLimitLog handling in GiveLimitMapGet/Set).
    |
    | seenNames is a |-bracketed map of normalized recipient names we've
    | already parsed THIS CALL, so we can warn on duplicates exactly once
    | per call. Format: |BOB|JOHN|SALLY|
    /declare seenNames string local |
    /declare warnedDup bool local FALSE
    /declare matched bool local FALSE
    /declare matchedQty int local 0
    /declare matchedName string local
    /declare cursor int local 1
    /declare rawLen int local ${rawVal.Length}
    /declare token string local
    /declare tokLen int local
    /declare nextPipe int local
    /declare tokTrim string local
    /declare tokNameUp string local
    | Loop-scoped vars MUST be declared before the goto-loop, then
    | /varset inside, or MQ throws "variable already in use" on the
    | second iteration when /declare runs again.
    /declare slice string local
    /declare needle string local

    :tokenLoop
    /if (${cursor} > ${rawLen}) /goto :tokenLoopEnd

    | Find next pipe in the remaining slice. .Find returns position
    | RELATIVE TO THE SLICE (1-based), or 0 if not present.
    /varset slice ${rawVal.Mid[${cursor},${Math.Calc[${rawLen}-${cursor}+1]}]}
    /varset nextPipe ${slice.Find[|]}
    /if (${nextPipe} > 0) {
        /varset tokLen ${Math.Calc[${nextPipe}-1]}
        /if (${tokLen} > 0) {
            /varset token ${slice.Left[${tokLen}]}
        } else {
            /varset token
        }
        /varset cursor ${Math.Calc[${cursor}+${nextPipe}]}
    } else {
        | Last token (no trailing pipe).
        /varset token ${slice}
        /varset cursor ${Math.Calc[${rawLen}+1]}
    }

    | Skip empty tokens (e.g. from a "Bob||John" double-pipe). Trim only
    | leading/trailing spaces by leaning on ParseGiveListIniValue's own
    | tolerance for trailing/leading whitespace via its LastSpacePos walk.
    | We do an explicit empty check here to avoid a useless parse call.
    /varset tokTrim ${token}
    :trimLeading
    /if (${tokTrim.Length} > 0 && ${tokTrim.Left[1].Equal[ ]}) {
        /varset tokTrim ${tokTrim.Mid[2,${Math.Calc[${tokTrim.Length}-1]}]}
        /goto :trimLeading
    }
    :trimTrailing
    /if (${tokTrim.Length} > 0 && ${tokTrim.Right[1].Equal[ ]}) {
        /varset tokTrim ${tokTrim.Left[${Math.Calc[${tokTrim.Length}-1]}]}
        /goto :trimTrailing
    }
    /if (!${tokTrim.Length}) /goto :tokenLoop

    | Parse this token using the existing single-recipient parser. It
    | sets giveListParsedName / giveListParsedQty as a side effect.
    /call ParseGiveListIniValue "${tokTrim}"
    /if (!${giveListParsedName.Length}) /goto :tokenLoop

    /varset tokNameUp ${giveListParsedName.Upper.Replace[ ,]}

    | Duplicate-name detection on this call. seenNames bracketing:
    | |BOB| is in |BOB|JOHN| but |BO| is not, by virtue of the bookend
    | pipes on both the haystack and the needle.
    /varset needle |${tokNameUp}|
    /if (${seenNames.Find[${needle}]}) {
        /if (!${warnedDup} && ${showDebug}) {
            /echo ${tgTag} \ayDuplicate recipient '\ag${giveListParsedName}\ay' in [GiveList] entry — using first quantity, ignoring later token.\ax
            /varset warnedDup TRUE
        } else /if (!${warnedDup}) {
            | Even when debug is off, warn once visibly so the player
            | knows the second Bob 5 in "Bob 10|Bob 5" is being ignored.
            /echo ${tgTag} \ayDuplicate recipient '\ag${giveListParsedName}\ay' in [GiveList] entry — using first quantity, ignoring later token. Clean up the INI to remove this warning.\ax
            /varset warnedDup TRUE
        }
        /goto :tokenLoop
    }
    /varset seenNames ${seenNames}${tokNameUp}|

    | First-match-wins: capture the first recipient whose name matches
    | charName, but keep walking so we can detect duplicates that come
    | LATER in the value. Don't overwrite matchedQty on later duplicates.
    /if (!${matched} && ${tokNameUp.Equal[${cnUp}]}) {
        /varset matched TRUE
        /varset matchedQty ${giveListParsedQty}
        /varset matchedName ${giveListParsedName}
    }

    /goto :tokenLoop

    :tokenLoopEnd

    /if (${matched}) {
        | Restore the matched recipient's parsed values into the outer
        | vars, since later-token parses may have clobbered them while
        | we were walking the duplicate-detection list.
        /varset giveListParsedName ${matchedName}
        /varset giveListParsedQty ${matchedQty}
        /return TRUE
    }
    /varset giveListParsedQty 0
    /varset giveListParsedName ""
/return FALSE

Sub GiveLimitMapGet(string map, string itemU)
    /declare tag string local |${itemU}=
    /declare p int local ${map.Find[${tag}]}
    /if (!${p}) /return 0
    /declare i int local ${Math.Calc[${p}+${tag.Length}]}
    /declare tail string local ${map.Mid[${i},24]}
    /declare bar int local ${tail.Find[|]}
    /declare rawVal string local
    /declare outVal int local 0
    /if (${bar} > 0) {
        /varset rawVal ${tail.Left[${Math.Calc[${bar}-1]}]}
    } else {
        /varset rawVal ${tail}
    }
    /varset outVal ${Int[${rawVal}]}
    /return ${outVal}

Sub GiveLimitMapSet(string map, string itemU, int value)
    /declare src string local ${map}
    /declare tag string local |${itemU}=
    /declare p int local ${src.Find[${tag}]}
    /if (!${p}) /return ${src}${tag}${value}|
    /declare head string local ${src.Left[${Math.Calc[${p}-1]}]}
    /declare rest string local ${src.Mid[${Math.Calc[${p}+${tag.Length}]},4000]}
    /declare bar int local ${rest.Find[|]}
    /declare tail string local |
    /if (${bar} > 0) {
        /varset tail ${rest.Mid[${bar},4000]}
    }
    /return ${head}${tag}${value}${tail}

Sub GiveLimitMapAdd(string map, string itemU, int delta)
    /declare cur int local 0
    /declare nextVal int local 0
    /call GiveLimitMapGet "${map}" "${itemU}"
    /varset cur ${Macro.Return}
    /varcalc nextVal ${cur}+${delta}
    /call GiveLimitMapSet "${map}" "${itemU}" ${nextVal}
    /return ${Macro.Return}

Sub CountGiveTally(string log, string itemU)
    /declare c int local 0
    /declare work string local ${log}|
    /declare pat string local |${itemU}|
    /declare f int local 0
    :ctLoop
    /varset f ${work.Find[${pat}]}
    /if (!${f}) /return ${c}
    /varcalc c ${c}+1
    /varset work ${work.Mid[${Math.Calc[${f}+${pat.Length}]},5000]}
    /goto :ctLoop

| Count total units of an item across bags and cursor.
Sub CountInventoryItemUnits(string itemName)
    /declare ciuTotal int local 0
    /declare ciuPack int local
    /declare ciuSlot int local
    /declare ciuMax int local
    /declare ciuStack int local

    /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /return 0

    /if (${Cursor.ID} && ${Cursor.Name.Equal[${itemName}]}) {
        /varset ciuStack ${Cursor.Stack}
        /if (${ciuStack} <= 0) /varset ciuStack 1
        /varcalc ciuTotal ${ciuTotal}+${ciuStack}
    }

    /for ciuPack 1 to 10
        /varset ciuMax ${Me.Inventory[pack${ciuPack}].Container}
        /if (${ciuMax} == 0) /continue
        /for ciuSlot 1 to ${ciuMax}
            /if (!${Me.Inventory[pack${ciuPack}].Item[${ciuSlot}].ID}) /continue
            /if (!${Me.Inventory[pack${ciuPack}].Item[${ciuSlot}].Name.Equal[${itemName}]}) /continue
            /varset ciuStack ${Me.Inventory[pack${ciuPack}].Item[${ciuSlot}].Stack}
            /if (${ciuStack} <= 0) /varset ciuStack 1
            /varcalc ciuTotal ${ciuTotal}+${ciuStack}
        /next ciuSlot
    /next ciuPack

    /return ${ciuTotal}

| =====================================================================
| TRADE TARGET HELPERS (v1.7) — prevents plat going to wrong characters
| =====================================================================
| AcquireTradeTarget: hardened target acquisition.
|   - Clears current target first (prevents sticking on nearby PC/NPC)
|   - Tries /target pc, then /target by name (illusion fallback)
|   - Verifies Target.Type == PC AND name matches exactly
|   - Sets outer _tradeTargetID on success, 0 on fail
| =====================================================================
Sub AcquireTradeTarget(string wantName)
    /if (!${Defined[_tradeTargetID]}) {
        /declare _tradeTargetID int outer 0
    } else {
        /varset _tradeTargetID 0
    }
    /if (!${wantName.Length} || ${wantName.Equal[NULL]}) /return

    | Clear existing target to prevent sticking on a nearby entity
    /squelch /target clear
    /delay 2

    | Primary: /target pc (filter to PCs only)
    /target pc ${wantName}
    /delay 8 ${Target.ID} && ${Target.Type.Equal[PC]} && ${Target.CleanName.Equal[${wantName}]}

    | Fallback: /target by name (handles illusion/morph edge cases)
    /if (!${Target.ID} || !${Target.Type.Equal[PC]} || !${Target.CleanName.Equal[${wantName}]}) {
        /squelch /target clear
        /delay 2
        /target ${wantName}
        /delay 8 ${Target.ID} && ${Target.Type.Equal[PC]} && ${Target.CleanName.Equal[${wantName}]}
    }

    /if (${Target.ID} && ${Target.Type.Equal[PC]} && ${Target.CleanName.Equal[${wantName}]}) {
        /varset _tradeTargetID ${Target.ID}
    }
/return

| =====================================================================
| VerifyTradeTarget: call immediately before any trade-opening click.
|   - If target has drifted (death, zone, auto-target, etc.), tries to
|     re-acquire via cached _tradeTargetID (stable ID, survives illusion)
|   - Returns TRUE only if current target matches cached ID and name
|   - Returns FALSE if re-acquire fails — caller must abort
| =====================================================================
Sub VerifyTradeTarget(string wantName)
    /if (!${Defined[_tradeTargetID]} || ${_tradeTargetID} == 0) /return FALSE
    /if (!${wantName.Length} || ${wantName.Equal[NULL]}) /return FALSE

    | Fast path: target still correct
    /if (${Target.ID} == ${_tradeTargetID} && ${Target.CleanName.Equal[${wantName}]}) /return TRUE

    | Drift detected — attempt re-acquire via cached stable ID
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Target drift detected (have ${Target.CleanName}, want ${wantName}) — re-acquiring ID ${_tradeTargetID}"
    /squelch /target clear
    /delay 2
    /squelch /target id ${_tradeTargetID}
    /delay 8 ${Target.ID} == ${_tradeTargetID}

    /if (${Target.ID} == ${_tradeTargetID} && ${Target.CleanName.Equal[${wantName}]}) /return TRUE
/return FALSE

| =====================================================================
| OpenTradeWindow: safe trade initiation.
|   - Verifies target just before the click (drift guard)
|   - Uses TargetWindow_HP click (illusion-safe, per GiveToTarget pattern)
|   - Falls back to /click left target if TargetWindow click fails
|   - Returns TRUE if TradeWnd open with correct target, FALSE otherwise
| =====================================================================
Sub OpenTradeWindow(string wantName)
    /call VerifyTradeTarget "${wantName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[SAFETY]\aw Target verification failed for ${wantName} — refusing to open trade.
        /if (${logToFile}) /call LogError "Trade aborted: target drifted from ${wantName}"
        /return FALSE
    }

    /face fast
    /delay 2

    | Primary: TargetWindow HP bar click (illusion-safe)
    /notify TargetWindow Target_HP leftmouseup
    /delay 10 ${Window[TradeWnd].Open}

    | Fallback: /click left target (verify again first — click uses current target)
    /if (!${Window[TradeWnd].Open}) {
        /call VerifyTradeTarget "${wantName}"
        /if (!${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ar[SAFETY]\aw Target drifted before fallback click — aborting trade with ${wantName}.
            /return FALSE
        }
        /nomodkey /click left target
        /delay 12 ${Window[TradeWnd].Open}
    }

    /if (${Window[TradeWnd].Open}) /return TRUE
/return FALSE

| =====================================================================
| SET QUANTITY WINDOW VALUE (v1.8.5) — reliable keyboard-input method
| /notify QuantityWnd QTYW_slider newvalue # is flaky on many clients
| (slider stays at default -> full stack grabbed). This clears the input
| field via backspace and types the desired number digit-by-digit.
| Requires QuantityWnd to already be open. Leaves window open.
| Catch credit: tester regression patch on v1.8.3.
| =====================================================================
Sub SetQuantityWndValue(int desired)
    /if (!${Window[QuantityWnd].Open}) /return
    /if (${desired} <= 0) /return
    /declare sqvDesiredStr string local ${desired}
    /declare sqvClearTry int local 0
    /declare sqvCurLen int local
    /declare sqvI int local

    | First try the slider notification as a fast path — harmless if it fails.
    /notify QuantityWnd QTYW_Slider newvalue ${desired}
    /delay 2

    | Clear whatever is currently in the input field (backspace until empty).
    :sqvClearLoop
    /varset sqvCurLen ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Length}
    /if (${sqvCurLen} <= 0) /goto :sqvTypeValue
    /nomodkey /keypress backspace chat
    /delay 2 ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Length} < ${sqvCurLen}
    /varcalc sqvClearTry ${sqvClearTry}+1
    /if (${sqvClearTry} > 20) /goto :sqvTypeValue
    /goto :sqvClearLoop

    :sqvTypeValue
    /for sqvI 1 to ${sqvDesiredStr.Length}
        /nomodkey /keypress ${sqvDesiredStr.Mid[${sqvI},1]} chat
        /delay 2
    /next sqvI
    /delay 2
/return

| =====================================================================
| PICKUP HELPER (v1.8) — multi-stack aware pickup for HandOutToGroup
| =====================================================================
| PickupMultiStack: pick up exactly wantCount of itemName across multiple stacks.
|   - Sums stacks across all bags, picks from one slot at a time
|   - Relies on MQ2 cursor-merge: picking up identical items merges on cursor
|   - Uses QuantityWnd when picking a partial amount from a stack
|   - Clears cursor on entry; never trusts leftover same-item cursor state
|   - Returns TRUE only if cursor holds exactly wantCount, FALSE on any failure
|   - On failure, caller is responsible for returning cursor to inventory
| =====================================================================
Sub PickupMultiStack(string itemName, int wantCount)
    /declare pmsPack int local
    /declare pmsSlot int local
    /declare pmsMaxSlots int local
    /declare pmsStack int local
    /declare pmsPick int local
    /declare pmsOnCursor int local 0
    /declare pmsTry int local

    /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /return FALSE
    /if (${wantCount} <= 0) /return FALSE

    | Always start from a clean cursor. Reusing leftover same-item stacks can
    | over-deliver to the first recipient in hand / exact-quantity flows.
    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${Cursor.ID}) /return FALSE
    }

    /for pmsPack 1 to 10
        /if (${pmsOnCursor} >= ${wantCount}) /break
        /varset pmsMaxSlots ${Me.Inventory[pack${pmsPack}].Container}
        /if (${pmsMaxSlots} == 0) /continue
        /for pmsSlot 1 to ${pmsMaxSlots}
            /if (${pmsOnCursor} >= ${wantCount}) /break
            /if (!${Me.Inventory[pack${pmsPack}].Item[${pmsSlot}].ID}) /continue
            /if (!${Me.Inventory[pack${pmsPack}].Item[${pmsSlot}].Name.Equal[${itemName}]}) /continue

            /varset pmsStack ${Me.Inventory[pack${pmsPack}].Item[${pmsSlot}].Stack}
            /if (${pmsStack} <= 0) /varset pmsStack 1
            /varset pmsPick ${Math.Calc[${wantCount} - ${pmsOnCursor}].Int}
            /if (${pmsPick} > ${pmsStack}) /varset pmsPick ${pmsStack}

            /if (${pmsPick} < ${pmsStack}) {
                /varset pmsTry 0
                :pmsPartialRetry
                /nomodkey /itemnotify in pack${pmsPack} ${pmsSlot} leftmouseup
                /delay 10 ${Window[QuantityWnd].Open} || ${Cursor.ID}

                /if (${Window[QuantityWnd].Open}) {
                    /call SetQuantityWndValue ${pmsPick}
                    /notify QuantityWnd QTYW_Accept_Button leftmouseup
                    /delay 5 !${Window[QuantityWnd].Open}
                    /if (${Window[QuantityWnd].Open}) {
                        /notify QuantityWnd AcceptButton leftmouseup
                        /delay 5 !${Window[QuantityWnd].Open}
                    }
                    /if (${Window[QuantityWnd].Open}) {
                        /keypress ENTER
                        /delay 5 !${Window[QuantityWnd].Open}
                    }
                    /delay 3 ${Cursor.ID}
                } else {
                    | v1.8.4: was `} elseif (${Cursor.ID}) {` — elseif is not MQ2 syntax;
                    | the safety branch silently never ran (branch A fell through to a
                    | plain retry that didn't clear cursor between attempts). Restructured
                    | to nested /if for standard MQ2 conditional chaining.
                    /if (${Cursor.ID}) {
                        | Safety: partial wanted, but MQ picked a whole stack without QuantityWnd.
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] PickupMultiStack: quantity window did not open for partial pickup (${pmsPick}/${pmsStack}) at pack${pmsPack} slot${pmsSlot}"
                        /autoinventory
                        /delay 5 !${Cursor.ID}
                        /if (${Cursor.ID}) /call ForceClearCursor
                        /varcalc pmsTry ${pmsTry}+1
                        /if (${pmsTry} < 3) /goto :pmsPartialRetry
                        /return FALSE
                    } else {
                        /varcalc pmsTry ${pmsTry}+1
                        /if (${pmsTry} < 3) /goto :pmsPartialRetry
                        /return FALSE
                    }
                }
            } else {
                /nomodkey /shift /itemnotify in pack${pmsPack} ${pmsSlot} leftmouseup
                /delay 10 ${Cursor.ID}
            }

            /if (${Cursor.ID} && ${Cursor.Name.Equal[${itemName}]}) {
                /varset pmsOnCursor ${Cursor.Stack}
                /if (${pmsOnCursor} <= 0) /varset pmsOnCursor 1
            } else {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] PickupMultiStack: pickup failed at pack${pmsPack} slot${pmsSlot}"
                /return FALSE
            }
        /next pmsSlot
    /next pmsPack

    /if (${pmsOnCursor} == ${wantCount}) /return TRUE
/return FALSE

| =====================================================================
| EXACT PICKUP HELPER — prefer a direct QuantityWnd pickup from the first
| matching stack, then fall back to PickupMultiStack for multi-stack totals.
| Used by hand/distribute flows where over-delivering is worse than failing.
| =====================================================================
Sub PickupExactItemCount(string itemName, int wantCount)
    /declare peiPack int local 0
    /declare peiSlot int local 0
    /declare peiMaxSlots int local 0
    /declare peiFindPack int local
    /declare peiFindSlot int local
    /declare peiStack int local 0
    /declare peiTry int local 0
    /declare peiPicked int local 0

    /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /return FALSE
    /if (${wantCount} <= 0) /return FALSE

    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${Cursor.ID}) /return FALSE
    }

    /for peiFindPack 1 to 10
        /varset peiMaxSlots ${Me.Inventory[pack${peiFindPack}].Container}
        /if (${peiMaxSlots} == 0) /continue
        /for peiFindSlot 1 to ${peiMaxSlots}
            /if (!${Me.Inventory[pack${peiFindPack}].Item[${peiFindSlot}].ID}) /continue
            /if (!${Me.Inventory[pack${peiFindPack}].Item[${peiFindSlot}].Name.Equal[${itemName}]}) /continue
            /varset peiPack ${peiFindPack}
            /varset peiSlot ${peiFindSlot}
            /varset peiStack ${Me.Inventory[pack${peiFindPack}].Item[${peiFindSlot}].Stack}
            /if (${peiStack} <= 0) /varset peiStack 1
            /goto :peiFound
        /next peiFindSlot
    /next peiFindPack
    /return FALSE

:peiFound

    /if (${wantCount} > ${peiStack}) {
        /call PickupMultiStack "${itemName}" ${wantCount}
        /return ${Macro.Return}
    }

    /if (${wantCount} < ${peiStack}) {
        :peiRetryQty
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
            /if (${Cursor.ID}) /return FALSE
        }
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }

        /nomodkey /itemnotify in pack${peiPack} ${peiSlot} leftmouseup
        /delay 15 ${Window[QuantityWnd].Open} || ${Cursor.ID}

        /if (!${Window[QuantityWnd].Open}) {
            | Safety: if MQ grabbed a full stack without opening QuantityWnd, do
            | not trade it. Clear cursor and retry a few times, then fail safe.
            /if (${Cursor.ID}) {
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
            }
            /varcalc peiTry ${peiTry}+1
            /if (${peiTry} < 3) /goto :peiRetryQty
            /return FALSE
        }

        /call SetQuantityWndValue ${wantCount}
        /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5 !${Window[QuantityWnd].Open}
        /if (${Window[QuantityWnd].Open}) {
            /notify QuantityWnd AcceptButton leftmouseup
            /delay 5 !${Window[QuantityWnd].Open}
        }
        /if (${Window[QuantityWnd].Open}) {
            /keypress ENTER
            /delay 5 !${Window[QuantityWnd].Open}
        }
        /delay 3 ${Cursor.ID}
    } else {
        /nomodkey /shift /itemnotify in pack${peiPack} ${peiSlot} leftmouseup
        /delay 10 ${Cursor.ID}
    }

    /if (!${Cursor.ID}) /return FALSE
    /if (!${Cursor.Name.Equal[${itemName}]}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /return FALSE
    }

    /varset peiPicked ${Cursor.Stack}
    /if (${peiPicked} <= 0) /varset peiPicked 1
    /if (${peiPicked} != ${wantCount}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /return FALSE
    }

    /return TRUE

| =====================================================================
| DC TRADE SESSION HELPER (v1.8.1) — shared by GiveDC and SendMyDC
| =====================================================================
| FillAndFinalizeDCTrade: run one trade session to a verified target.
|   - Picks up first DC stack, THEN opens trade (matches GiveCash pattern
|     where /click left target both opens trade AND drops held item).
|   - Subsequent stacks: shift-click to cursor, /click left target drops
|     into the already-open TradeWnd.
|   - Per-slot cap: 7 stacks (1 buffer of 8 slots).
|   - Per-click confirmation: after /click left target, cursor must clear.
|     If not → target's bags are full → finalize partial + stop.
|   - Returns actual DC count traded this session.
|   - Sets outer _dcTradeAborted = TRUE on clean-abort conditions.
|   - Sets outer _dcAbortReceiverFull = TRUE when the receiver has no room.
|
| NOTE: As of 1.8.1, uses cursor-clear as sole drop-confirmation signal
| (TradeWnd slot accessor unconfirmed on MQ Next). May over-count if
| cursor clears without item actually landing in trade window. Revisit
| in 1.8.2 if diagnostic echoes show that pattern.
| =====================================================================
Sub FillAndFinalizeDCTrade(string targetName, int maxThisSession)
    /if (!${Defined[_dcTradeAborted]}) {
        /declare _dcTradeAborted bool outer FALSE
    } else {
        /varset _dcTradeAborted FALSE
    }
    /if (!${Defined[_dcAbortReceiverFull]}) {
        /declare _dcAbortReceiverFull bool outer FALSE
    } else {
        /varset _dcAbortReceiverFull FALSE
    }

    /declare fftSlotsUsed int local 0
    /declare fftTraded int local 0
    /declare fftPack int local
    /declare fftSlot int local
    /declare fftThisStack int local
    /declare fftSlotsCap int local 7
    /declare fftTradeOpened bool local FALSE
    /declare fftWantThisPick int local 0
    /declare fftRemainingCap int local 0

    :fftFillLoop
    /if (${fftSlotsUsed} >= ${fftSlotsCap}) /goto :fftFinalize
    /if (${FindItemCount[=Diamond Coin]} <= 0) /goto :fftFinalize
    /if (${maxThisSession} > 0 && ${fftTraded} >= ${maxThisSession}) /goto :fftFinalize

    | Locate next DC stack — re-read every iteration (state changes)
    /varset fftPack ${Math.Calc[${FindItem[=Diamond Coin].ItemSlot}-22].Int}
    /varset fftSlot ${Math.Calc[${FindItem[=Diamond Coin].ItemSlot2}+1].Int}
    /if (${fftPack} <= 0 || ${fftSlot} <= 0) {
        /if (${showDebug}) /echo ${tgTag} \ay[DC TRADE DEBUG]\aw Invalid slot coords (ItemSlot=${FindItem[=Diamond Coin].ItemSlot} ItemSlot2=${FindItem[=Diamond Coin].ItemSlot2}) - stopping fill.
        /goto :fftFinalize
    }

    /varset fftThisStack ${FindItem[=Diamond Coin].Stack}
    /if (${fftThisStack} <= 0) /varset fftThisStack 1

    | v1.8.3: when maxThisSession caps us below stack size, pick partial
    | amount via QuantityWnd (matches GiveCash 'cash N' pattern).
    | Otherwise shift-click whole stack for speed.
    /varset fftWantThisPick ${fftThisStack}
    /varset fftRemainingCap 0
    /if (${maxThisSession} > 0) {
        /varset fftRemainingCap ${Math.Calc[${maxThisSession} - ${fftTraded}].Int}
        /if (${fftRemainingCap} < ${fftThisStack}) /varset fftWantThisPick ${fftRemainingCap}
    }
    /if (${fftWantThisPick} <= 0) /goto :fftFinalize

    /if (${fftWantThisPick} < ${fftThisStack}) {
        | Partial pickup path: unshift-click opens QuantityWnd
        /nomodkey /itemnotify in pack${fftPack} ${fftSlot} leftmouseup
        /delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}

        /if (${Window[QuantityWnd].Open}) {
            /call SetQuantityWndValue ${fftWantThisPick}
            /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 5 !${Window[QuantityWnd].Open}
            /if (${Window[QuantityWnd].Open}) {
                /notify QuantityWnd AcceptButton leftmouseup
                /delay 5 !${Window[QuantityWnd].Open}
            }
            /if (${Window[QuantityWnd].Open}) {
                /keypress ENTER
                /delay 5 !${Window[QuantityWnd].Open}
            }
            /delay 3 ${Cursor.ID}
        }

        /if (!${Cursor.ID}) {
            /if (${showDebug}) /echo ${tgTag} \ay[DC TRADE DEBUG]\aw Partial pickup of ${fftWantThisPick} from pack${fftPack} slot${fftSlot} failed.
            /goto :fftFinalize
        }
        | Record actual amount picked (cursor stack is truth)
        /if (${Cursor.Stack} > 0) /varset fftWantThisPick ${Cursor.Stack}
    } else {
        | Whole-stack path: shift-click picks up entire stack
        /nomodkey /shift /itemnotify in pack${fftPack} ${fftSlot} leftmouseup
        /delay 10 ${Cursor.ID}
        /if (!${Cursor.ID}) {
            /if (${showDebug}) /echo ${tgTag} \ay[DC TRADE DEBUG]\aw Shift-click pack${fftPack} slot${fftSlot} failed to put DC on cursor.
            /goto :fftFinalize
        }
    }

    | Drift guard before each click-to-target
    /call VerifyTradeTarget "${targetName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[DC TRADE]\ay [SAFETY]\aw Target drift mid-session - returning stack.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /varset _dcTradeAborted TRUE
        /goto :fftFinalize
    }

    | First click: opens trade window AND drops stack (classic EQ behavior).
    | Subsequent clicks: drops stack into already-open trade window.
    /click left target
    /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}

    | After first click, confirm trade window actually opened
    /if (!${fftTradeOpened}) {
        /if (!${Window[TradeWnd].Open}) {
            /echo ${tgTag} \ar[DC TRADE]\aw Trade window did not open after first click - aborting.
            /if (${Cursor.ID}) {
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
            }
            /varset _dcTradeAborted TRUE
            /goto :fftFinalize
        }
        /varset fftTradeOpened TRUE
        /delay 5 !${Cursor.ID}
    }

    | Cursor must clear to confirm stack landed in trade window.
    | If cursor still holds DC, target's bags/trade window is full.
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ay[DC TRADE]\aw Target bags/trade full - finalizing with ${fftSlotsUsed} stack(s) delivered.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${Cursor.ID}) {
            /echo ${tgTag} \ar[DC TRADE]\aw Diamond Coin is still on cursor and could not be returned to inventory. Stopping DC trade before more sessions.
        }
        /varset _dcAbortReceiverFull TRUE
        /varset _dcTradeAborted TRUE
        /goto :fftFinalize
    }

    /varcalc fftSlotsUsed ${fftSlotsUsed}+1
    /varcalc fftTraded ${fftTraded}+${fftWantThisPick}
    /goto :fftFillLoop

    :fftFinalize
    | Nothing made it in — close window cleanly, no finalize
    /if (${fftSlotsUsed} <= 0) {
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Cancel_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
        /return 0
    }

    | Finalize trade — match SendMyDC 1.7.1 retry pattern
    /delay 10 ${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open} && !${Cursor.ID}) {
        /notify TradeWnd TRDW_Trade_Button leftmouseup
    }
    /squelch /e3bct ${targetName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
    /delay 30 !${Window[TradeWnd].Open}

    /if (${Window[TradeWnd].Open}) {
        /squelch /e3bct ${targetName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
        /delay 30 !${Window[TradeWnd].Open}
    }

    /if (${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[DC TRADE]\ay [SAFETY]\aw Trade window stuck open - aborting session.
        /varset _dcTradeAborted TRUE
    }

/return ${fftTraded}

| =====================================================================
| MAIN
| =====================================================================
Sub Main(string modeIn, string argIn)
    /declare mode string local ${modeIn}
    /declare arg string local ${argIn}
    /declare modeUpper string local ${mode.Upper.Replace[ ,]}

    /if (${modeUpper.Equal[HELP]} || ${modeUpper.Equal[COMMANDS]}) {
        /call PrintHelp
        /return
    }

    | Tag matches TurboLoot tlTag: teal bracket label, no \ax (next token sets color)
    /if (!${Defined[tgTag]}) {
        /declare tgTag string outer \at[turboGive]
    }

    | =====================================================================
    | 1.9.1: Broadcast-giver detection for multi-recipient skip rule.
    | When the user types /mac turbogive directly, mode is empty (default
    | DeliverEveryone GROUP) or a charname/keyword. Bots that received the
    | broadcast see mode=GROUP or mode=ZONE — those are the modes where a
    | bot is acting as a give-side broadcast-receiver. The matcher reads
    | this flag and skips multi-recipient INI entries on bots to prevent
    | trade collisions (the originator handles those entries instead).
    |
    | If new broadcast-receive modes are added to TurboGive in the future,
    | extend this detection list.
    |
    | Outer scope so GiveListIniValueMatchesChar can read it. Reset to
    | FALSE on every Sub Main entry so a previous broadcast invocation
    | cannot leak its TRUE state into a fresh user-typed run.
    | =====================================================================
    /if (!${Defined[tgIsBroadcastGiver]}) /declare tgIsBroadcastGiver bool outer FALSE
    /varset tgIsBroadcastGiver FALSE
    /if (${modeUpper.Equal[ZONE]}) /varset tgIsBroadcastGiver TRUE
    /if (${modeUpper.Equal[GROUP]}) /varset tgIsBroadcastGiver TRUE

    /if (!${Defined[iniFile]}) {
        /declare iniFile string outer ../Config/turboloot.ini
    } else {
        /varset iniFile ../Config/turboloot.ini
    }
    /declare tgIniProfile string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /if (${tgIniProfile.Length} && !${tgIniProfile.Equal[NULL]} && !${tgIniProfile.Equal[null]}) {
        /if (${Ini.File[../Config/${tgIniProfile}].Exists}) {
            /varset iniFile ../Config/${tgIniProfile}
        } else /if (${Ini.File[../Macros/${tgIniProfile}].Exists}) {
            /varset iniFile ../Macros/${tgIniProfile}
        }
    }
    /if (!${Ini.File[${iniFile}].Exists}) {
        /varset iniFile ../Config/turboloot.ini
    }
    /if (!${Ini.File[${iniFile}].Exists}) {
        /varset iniFile ../Macros/turboloot.ini
    }
    /if (!${Ini.File[${iniFile}].Exists}) {
        /echo ${tgTag} \arERROR: Cannot find turboloot.ini in Config or Macros folder.
        /return
    }

    /if (!${Defined[showDebug]}) {
        /declare showDebug bool outer FALSE
    } else {
        /varset showDebug FALSE
    }
    /if (!${Defined[logToFile]}) {
        /declare logToFile bool outer FALSE
    } else {
        /varset logToFile FALSE
    }
    /declare debugSetting string local ${Ini[${iniFile},Settings,debug]}
    /if (${debugSetting.Length} && !${debugSetting.Equal[NULL]}) {
        /declare debugUpper string local ${debugSetting.Upper.Replace[ ,]}
        /if (${debugUpper.Equal[ON]} || ${debugUpper.Equal[TRUE]} || ${debugUpper.Equal[YES]} || ${debugUpper.Equal[1]}) {
            /varset showDebug TRUE
        }
    }
    /declare logSetting string local ${Ini[${iniFile},Settings,logToFile]}
    /if (${logSetting.Length} && !${logSetting.Equal[NULL]}) {
        /declare logUpper string local ${logSetting.Upper.Replace[ ,]}
        /if (${logUpper.Equal[ON]} || ${logUpper.Equal[TRUE]} || ${logUpper.Equal[YES]} || ${logUpper.Equal[1]}) {
            /varset logToFile TRUE
        }
    }
    /if (!${Defined[logLevel]}) {
        /declare logLevel int outer 1
    } else {
        /varset logLevel 1
    }
    /declare logLevelSetting string local ${Ini[${iniFile},Settings,logLevel]}
    /if (${logLevelSetting.Length} && !${logLevelSetting.Equal[NULL]}) {
        /declare logLevelUpper string local ${logLevelSetting.Upper.Replace[ ,]}
        /if (${logLevelUpper.Equal[DEBUG]}) /varset logLevel 0
        /if (${logLevelUpper.Equal[INFO]}) /varset logLevel 1
        /if (${logLevelUpper.Equal[WARN]}) /varset logLevel 2
        /if (${logLevelUpper.Equal[ERROR]}) /varset logLevel 3
    }

    /if (!${Defined[announceMethod]}) {
        /declare announceMethod string outer e3bc
    } else {
        /varset announceMethod e3bc
    }
    /declare announceSetting string local ${Ini[${iniFile},Settings,announceDefaultTo]}
    /if (${announceSetting.Length} && !${announceSetting.Equal[NULL]}) {
        /varset announceMethod ${announceSetting}
    }

    | Declare quantity limit (0 = unlimited, used by give/collect/bank/currency subs)
    /if (!${Defined[_giveLimit]}) {
        /declare _giveLimit int outer 0
    } else {
        /varset _giveLimit 0
    }

    | ---- CONVERT (AA/DC NPC conversion) ----
    /if (${modeUpper.Equal[CONVERT]}) {
        /declare convType string local ${arg.Upper.Replace[ ,]}
        /declare convAmount int local 0
        /declare convBroadcast bool local FALSE
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset convAmount ${Int[${Param2}]}
        | v1.7.1: detect "convert <type> all" broadcast form (Param2 is literal "all", not a number)
        /if (${Param2.Length} && ${Param2.Upper.Equal[ALL]}) /varset convBroadcast TRUE

        /if (${convType.Equal[AA]} && ${convBroadcast}) {
            /echo ${tgTag} \am[CONVERT]\aw Converting AA -> DC locally + broadcasting to group...
            /call ConvertCurrency "AA" 0
            /squelch /e3bcga /mac turbogive convert aa
        } else /if (${convType.Equal[DC]} && ${convBroadcast}) {
            /echo ${tgTag} \am[CONVERT]\aw Converting DC -> AA locally + broadcasting to group...
            /call ConvertCurrency "DC" 0
            /squelch /e3bcga /mac turbogive convert dc
        } else /if (${convType.Equal[AA]}) {
            /call ConvertCurrency "AA" ${convAmount}
        } else /if (${convType.Equal[DC]}) {
            /call ConvertCurrency "DC" ${convAmount}
        } else /if (${convType.Equal[EXCHANGE]}) {
            /call ConvertAltDC2Currency
        } else /if (${convType.Equal[ALL]}) {
            | v1.7.1: legacy "convert all" — same as "convert aa all", runner ALSO converts
            /echo ${tgTag} \am[CONVERT]\aw Converting AA -> DC locally + broadcasting to group...
            /call ConvertCurrency "AA" 0
            /squelch /e3bcga /mac turbogive convert aa
        } else {
            /echo ${tgTag} \arUsage: /mac turbogive convert aa \aw[\agamount\aw]\ax
            /echo ${tgTag} \aw       /mac turbogive convert dc \aw[\agamount\aw]\ax
            /echo ${tgTag} \aw       /mac turbogive convert exchange\ax
            /echo ${tgTag} \aw       /mac turbogive convert all \aw(AA -> DC self + broadcast group)\ax
            /echo ${tgTag} \aw       /mac turbogive convert dc all \aw(DC -> AA self + broadcast group)\ax
        }
        /return
    }

    | ---- ADD ----
    /if (${modeUpper.Equal[ADD]}) {
        /if (${arg.Length} && !${arg.Equal[NULL]}) {
            /if (${arg.Upper.Equal[TARGET]}) {
                /if (${Target.ID} && ${Target.Type.Equal[PC]}) {
                    /call AddItemToGiveList "${Target.CleanName}"
                } else {
                    /echo ${tgTag} \arNo valid PC target selected.
                }
            } else {
                /call AddItemToGiveList "${arg}"
            }
        } else {
            /if (${Target.ID} && ${Target.Type.Equal[PC]}) {
                /call AddItemToGiveList "${Target.CleanName}"
            } else {
                /echo ${tgTag} \arUsage: /mac turbogive add CHARNAME  (or target a PC)
            }
        }
        /return
    }

    | ---- LIST ----
    /if (${modeUpper.Equal[LIST]}) {
        /if (${arg.Length} && !${arg.Equal[NULL]}) {
            /if (${arg.Upper.Equal[TARGET]} || ${arg.Upper.Equal[T]}) {
                /if (${Target.ID} && ${Target.Type.Equal[PC]}) {
                    /call PrintGiveList "${Target.CleanName}"
                } else {
                    /echo ${tgTag} \arNo valid PC target selected.
                }
            } else {
                /call PrintGiveList "${arg}"
            }
        } else {
            /call PrintGiveList "${Me.Name}"
        }
        /return
    }

    | ---- COLLECT ----
    /if (${modeUpper.Equal[COLLECT]}) {
        /declare argUp string local ${arg.Upper.Replace[ ,]}
        | Currency collect: cash/plat/pp/dc
        /if (${argUp.Equal[CASH]} || ${argUp.Equal[PLAT]} || ${argUp.Equal[PP]}) {
            /declare cashScope string local GROUP
            /declare cashAmt int local 0
            /if (${Param2.Length} && ${Param2.Upper.Equal[ALL]}) {
                /varset cashScope ALL
                /if (${Param3.Length} && ${Int[${Param3}]} > 0) /varset cashAmt ${Int[${Param3}]}
            } else /if (${Param2.Length} && ${Int[${Param2}]} > 0) {
                /varset cashAmt ${Int[${Param2}]}
            }
            /call CollectCash "${cashScope}" ${cashAmt}
            /return
        }
        /if (${argUp.Equal[DC]}) {
            /declare dcScope string local GROUP
            /declare dcAmt int local 0
            /if (${Param2.Length} && ${Param2.Upper.Equal[ALL]}) {
                /varset dcScope ALL
                /if (${Param3.Length} && ${Int[${Param3}]} > 0) /varset dcAmt ${Int[${Param3}]}
            } else /if (${Param2.Length} && ${Int[${Param2}]} > 0) {
                /varset dcAmt ${Int[${Param2}]}
            }
            /call CollectDC "${dcScope}" ${dcAmt}
            /return
        }
        /if (${argUp.Equal[TELL]}) {
            /if (!${Param2.Length} || ${Param2.Equal[NULL]}) {
                /echo ${tgTag} \arUsage: /mac turbogive collect tell CHARNAME \aw[\agall\aw]\ax
                /return
            }
            /declare collectTellTarget string local ${Param2}
            /declare collectScope string local
            | Check if Param3 is a currency keyword for tell-based currency collect
            /if (${Param3.Length} && (${Param3.Upper.Equal[CASH]} || ${Param3.Upper.Equal[PLAT]} || ${Param3.Upper.Equal[PP]})) {
                /declare tellCashAmt int local 0
                /if (${Param4.Length} && ${Int[${Param4}]} > 0) /varset tellCashAmt ${Int[${Param4}]}
                /echo ${tgTag} \ao[COLLECT]\aw Telling \ag${collectTellTarget}\aw to collect cash...
                /if (${tellCashAmt} > 0) {
                    /squelch /e3bct ${collectTellTarget} /mac turbogive collect cash ${tellCashAmt}
                } else {
                    /squelch /e3bct ${collectTellTarget} /mac turbogive collect cash
                }
                /return
            }
            /if (${Param3.Length} && ${Param3.Upper.Equal[DC]}) {
                /declare tellDcAmt int local 0
                /if (${Param4.Length} && ${Int[${Param4}]} > 0) /varset tellDcAmt ${Int[${Param4}]}
                /echo ${tgTag} \ao[COLLECT]\aw Telling \ag${collectTellTarget}\aw to collect DC...
                /if (${tellDcAmt} > 0) {
                    /squelch /e3bct ${collectTellTarget} /mac turbogive collect dc ${tellDcAmt}
                } else {
                    /squelch /e3bct ${collectTellTarget} /mac turbogive collect dc
                }
                /return
            }
            /if (${Param3.Length} && (${Param3.Upper.Equal[ALL]} || ${Param3.Upper.Equal[RAID]})) /varset collectScope all
            /if (${collectScope.Length}) {
                /echo ${tgTag} \ao[COLLECT]\aw Telling \ag${collectTellTarget}\aw to collect from all e3 bots...
                /squelch /e3bct ${collectTellTarget} /mac turbogive collect all
            } else {
                /echo ${tgTag} \ao[COLLECT]\aw Telling \ag${collectTellTarget}\aw to collect from group...
                /squelch /e3bct ${collectTellTarget} /mac turbogive collect
            }
        } else /if (${arg.Length} && ${Int[${arg}]} > 0) {
            | Quantity limit for item collect
            /varset _giveLimit ${Int[${arg}]}
            /call CollectFromGroup ""
        } else {
            /call CollectFromGroup "${arg}"
        }
        /return
    }

    | ---- ALL (deliver to all in zone + tell all e3 bots to deliver) ----
    /if (${modeUpper.Equal[ALL]} || ${modeUpper.Equal[DISTRIBUTEALL]}) {
        /call DeliverEveryone "ALL"
        /return
    }

    | ---- ZONE (deliver to all in zone, no group filter — used internally) ----
    /if (${modeUpper.Equal[ZONE]}) {
        /call DeliverAll
        /call SendDoneToOrchestrator
        /return
    }

    | ---- GROUP (deliver to group only — used internally by broadcast) ----
    /if (${modeUpper.Equal[GROUP]}) {
        /call DeliverAll "GROUP"
        /call SendDoneToOrchestrator
        /return
    }

    | ---- STATUS ----
    /if (${modeUpper.Equal[STATUS]}) {
        /call PrintStatus
        /return
    }

    | ---- HAND ----
    /if (${modeUpper.Equal[HAND]} || ${modeUpper.Equal[HANDOUT]} || ${modeUpper.Equal[DISTRIBUTE]}) {
        /if (${arg.Upper.Equal[TELL]} && ${Param2.Length} && !${Param2.Equal[NULL]} && ${Int[${Param3}]} > 0) {
            /declare handTellTarget string local ${Param2}
            /declare handTellCount int local ${Int[${Param3}]}
            /declare handTellItemArg string local
            /declare handTellScope string local
            /declare hpIdx int local
            /for hpIdx 4 to 9
                /if (${Param${hpIdx}.Length} && !${Param${hpIdx}.Equal[NULL]}) {
                    /if (${Param${hpIdx}.Upper.Equal[ALL]}) {
                        /varset handTellScope all
                    } else {
                        /if (${handTellItemArg.Length}) {
                            /varset handTellItemArg ${handTellItemArg} ${Param${hpIdx}}
                        } else {
                            /varset handTellItemArg ${Param${hpIdx}}
                        }
                    }
                }
            /next hpIdx
            /if (${handTellItemArg.Length}) {
                /if (${handTellScope.Length}) {
                    /echo ${tgTag} \ag[HAND]\aw Telling \ag${handTellTarget}\aw to hand \ag${handTellCount}\aw x \at${handTellItemArg}\aw to all...
                    /squelch /e3bct ${handTellTarget} /mac turbogive hand ${handTellCount} ${handTellItemArg} all
                } else {
                    /echo ${tgTag} \ag[HAND]\aw Telling \ag${handTellTarget}\aw to hand \ag${handTellCount}\aw x \at${handTellItemArg}\aw to group...
                    /squelch /e3bct ${handTellTarget} /mac turbogive hand ${handTellCount} ${handTellItemArg}
                }
            } else {
                /echo ${tgTag} \arUsage: /mac turbogive hand tell CHARNAME COUNT ItemName \aw(e.g. hand tell Drel 5 Diamond)\ax
                /echo ${tgTag} \awAdd \agall\aw at end for zone-wide: hand tell Drel 5 Diamond all\ax
            }
        } else /if (${arg.Length} && !${arg.Equal[NULL]} && ${Int[${arg}]} > 0) {
            /declare handItemArg string local
            /declare handScope string local GROUP
            /declare pIdx int local
            /for pIdx 2 to 9
                /if (${Param${pIdx}.Length} && !${Param${pIdx}.Equal[NULL]}) {
                    /if (${handItemArg.Length}) {
                        /varset handItemArg ${handItemArg} ${Param${pIdx}}
                    } else {
                        /varset handItemArg ${Param${pIdx}}
                    }
                }
            /next pIdx
            /if (${handItemArg.Length} > 4 && ${handItemArg.Right[4].Upper.Equal[ ALL]}) {
                /varset handItemArg ${handItemArg.Left[${Math.Calc[${handItemArg.Length}-4]}]}
                /varset handScope ALL
            } else /if (${handItemArg.Upper.Equal[ALL]}) {
                /varset handItemArg
                /varset handScope ALL
            }
            /call HandOutToGroup ${Int[${arg}]} "${handItemArg}" "${handScope}"
        } else {
            /echo ${tgTag} \arUsage: Pick up an item, then: /mac turbogive hand COUNT
            /echo ${tgTag} \awOr: /mac turbogive hand COUNT Item Name Here
            /echo ${tgTag} \awOr: /mac turbogive hand COUNT Item Name all (zone-wide)
            /echo ${tgTag} \awOr: /mac turbogive hand tell CHARNAME COUNT ItemName [all]
            /echo ${tgTag} \awExample: /mac turbogive hand 6
            /echo ${tgTag} \awExample: /mac turbogive hand tell Drel 5 Diamond all
        }
        /return
    }

    | ---- BANK (pull items from bank to inventory) ----
    /if (${modeUpper.Equal[BANK]}) {
        /if (${arg.Length} && !${arg.Equal[NULL]}) {
            /declare argUpper string local ${arg.Upper.Replace[ ,]}
            /if (${argUpper.Equal[ALL]}) {
                /call BankAllBots "ALL"
            } else /if (${argUpper.Equal[SOLO]}) {
                /call BankPullAll TRUE
            } else /if (${argUpper.Equal[PULL]}) {
                /call BankPullAll FALSE
                /call SendDoneToOrchestrator
            } else /if (${argUpper.Equal[TELL]}) {
                /declare tellTarget string local ${Param2}
                /if (${tellTarget.Length} && !${tellTarget.Equal[NULL]}) {
                    /echo ${tgTag} \ap[BANK]\aw Telling \ag${tellTarget}\aw to pull their items from bank...
                    /squelch /e3bct ${tellTarget} /mac turbogive bank solo
                } else {
                    /echo ${tgTag} \arUsage: /mac turbogive bank tell CHARNAME \aw(e.g. bank tell Drel)
                }
            } else {
                /call BankPull "${arg}"
            }
        } else {
            /call BankAllBots "GROUP"
        }
        /return
    }

    | ---- SOLO (only I deliver, no broadcast to bots) ----
    /if (${modeUpper.Equal[SOLO]}) {
        /if (${arg.Length} && !${arg.Equal[NULL]} && ${arg.Upper.Equal[ALL]}) {
            /call DeliverAll
        } else {
            /call DeliverAll "GROUP"
        }
        /return
    }

    | ---- TELL ----
    /if (${modeUpper.Equal[TELL]}) {
        /if (${arg.Length} && !${arg.Equal[NULL]}) {
            /echo ${tgTag} \ag[DISTRIBUTE]\aw Telling \ag${arg}\aw to give their items...
            /squelch /e3bct ${arg} /mac turbogive
        } else {
            /echo ${tgTag} \arUsage: /mac turbogive tell CHARNAME
        }
        /return
    }

    | ---- HANDIN (NPC hand-in) ----
    /if (${modeUpper.Equal[HANDIN]}) {
        /declare hiArgUp string local ${arg.Upper.Replace[ ,]}
        | Parse: handin tell CHARNAME "item" # [destroy]
        /if (${hiArgUp.Equal[TELL]}) {
            /if (!${Param2.Length} || ${Param2.Equal[NULL]}) {
                /echo ${tgTag} \arUsage: /mac turbogive handin tell CHARNAME "Item Name" [#] [destroy]\ax
                /return
            }
            /declare hiTellTarget string local ${Param2}
            /declare hiTellArgs string local
            /declare hiPIdx int local
            /for hiPIdx 3 to 9
                /if (${Param${hiPIdx}.Length} && !${Param${hiPIdx}.Equal[NULL]}) {
                    /if (${hiTellArgs.Length}) {
                        /varset hiTellArgs ${hiTellArgs} ${Param${hiPIdx}}
                    } else {
                        /varset hiTellArgs ${Param${hiPIdx}}
                    }
                }
            /next hiPIdx
            | Hard-block (1.8.9): also check on the sender side so the user
            | gets the warning where they typed the command. Param3 is the
            | item name in the `handin tell CHARNAME "Item"` form.
            /if (${Param3.Length} && !${Param3.Equal[NULL]}) {
                /call IsHardBlocked "${Param3}"
                /if (${Macro.Return.Equal[TRUE]}) {
                    /echo ${tgTag} \ar[HANDIN]\aw Refusing to tell \ag${hiTellTarget}\aw to hand in \ay${Param3}\aw - this item is on TurboGive's hardcoded always-skip list.\ax
                    /return
                }
            }
            /echo ${tgTag} \ay[HANDIN]\aw Telling \ag${hiTellTarget}\aw to hand in: ${hiTellArgs}
            /squelch /e3bct ${hiTellTarget} /mac turbogive _handin ${hiTellArgs}
            /return
        }
        | Parse: handin "item" # [destroy]  or  handin pp|gp|sp|cp #
        /declare hiItem string local ${arg}
        /declare hiAmount int local 0
        /declare hiDestroy string local
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) {
            /varset hiAmount ${Int[${Param2}]}
            /if (${Param3.Length} && ${Param3.Upper.Equal[DESTROY]}) /varset hiDestroy DESTROY
        } else /if (${Param2.Length} && ${Param2.Upper.Equal[DESTROY]}) {
            /varset hiDestroy DESTROY
        }
        /call HandinToNPC "${hiItem}" ${hiAmount} "${hiDestroy}"
        /return
    }

    | ---- INTERNAL: _HANDIN (broadcast target does NPC hand-in) ----
    /if (${modeUpper.Equal[_HANDIN]}) {
        /declare ihItem string local ${arg}
        /declare ihAmount int local 0
        /declare ihDestroy string local
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) {
            /varset ihAmount ${Int[${Param2}]}
            /if (${Param3.Length} && ${Param3.Upper.Equal[DESTROY]}) /varset ihDestroy DESTROY
        } else /if (${Param2.Length} && ${Param2.Upper.Equal[DESTROY]}) {
            /varset ihDestroy DESTROY
        }
        /call HandinToNPC "${ihItem}" ${ihAmount} "${ihDestroy}"
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _SENDCASH (broadcast target sends cash to collector) ----
    /if (${modeUpper.Equal[_SENDCASH]}) {
        /declare sendCashAmt int local 0
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendCashAmt ${Int[${Param2}]}
        /call SendMyCash "${arg}" ${sendCashAmt}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _SENDDC (broadcast target sends DC to collector) ----
    /if (${modeUpper.Equal[_SENDDC]}) {
        /declare sendDcAmt int local 0
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendDcAmt ${Int[${Param2}]}
        /call SendMyDC "${arg}" ${sendDcAmt}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _SENDITEM (source pushes ONE gear item to a named recipient) ----
    | Invoked by TurboGear "Give now": /mac turbogive _senditem <recipient> <itemID>
    | Item name is resolved from the ID locally to avoid cross-box quoting of
    | names with spaces. arg = recipient, Param2 = item ID.
    /if (${modeUpper.Equal[_SENDITEM]}) {
        /declare sendItemId int local 0
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendItemId ${Int[${Param2}]}
        /call SendMyItem "${arg}" ${sendItemId}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _SENDSTACK (source pushes QTY of item id to recipient) ----
    | /mac turbogive _sendstack <recipient> <itemID> <qty>
    | /mac turbogive _sendstack <recipient> <qty> id <itemID>   (same order as send)
    | Param indexing: mode=Param0, recipient=arg/Param1, then Param2+.
    /if (${modeUpper.Equal[_SENDSTACK]}) {
        /declare sendStackId int local 0
        /declare sendStackQty int local 0
        /if (${Param2.Length} && ${Param2.Upper.Equal[ID]} && ${Param3.Length} && ${Int[${Param3}]} > 0) {
            | _sendstack CHAR id ITEMID QTY  (rare)
            /varset sendStackId ${Int[${Param3}]}
            /if (${Param4.Length} && ${Int[${Param4}]} > 0) /varset sendStackQty ${Int[${Param4}]}
        } else /if (${Param3.Length} && ${Param3.Upper.Equal[ID]} && ${Param4.Length} && ${Int[${Param4}]} > 0) {
            | _sendstack CHAR QTY id ITEMID  (mirrors send)
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendStackQty ${Int[${Param2}]}
            /varset sendStackId ${Int[${Param4}]}
        } else {
            | _sendstack CHAR ITEMID QTY
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendStackId ${Int[${Param2}]}
            /if (${Param3.Length} && ${Int[${Param3}]} > 0) /varset sendStackQty ${Int[${Param3}]}
        }
        /if (${sendStackId} <= 0 || ${sendStackQty} <= 0) {
            /echo ${tgTag} \arUsage: /mac turbogive _sendstack CHAR ITEMID QTY\ax
            /echo ${tgTag} \ar   or: /mac turbogive _sendstack CHAR QTY id ITEMID\ax
            /return
        }
        /call SendMyStack "${arg}" ${sendStackId} ${sendStackQty}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- SEND: /mac turbogive send <recipient> <qty> <item name...>
    |      or   /mac turbogive send <recipient> <qty> id <itemID>
    /if (${modeUpper.Equal[SEND]}) {
        /declare sendTo string local ${arg}
        /declare sendQty int local 0
        /declare sendItemName string local
        /declare sendById int local 0
        /declare sendPi int local
        /if (!${sendTo.Length} || ${sendTo.Equal[NULL]}) {
            /echo ${tgTag} \arUsage: /mac turbogive send CHAR QTY Item Name\ax
            /echo ${tgTag} \ar   or: /mac turbogive send CHAR QTY id ITEMID\ax
            /return
        }
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset sendQty ${Int[${Param2}]}
        /if (${sendQty} <= 0) {
            /echo ${tgTag} \ar[SEND]\aw Qty must be > 0.
            /return
        }
        /if (${Param3.Length} && ${Param3.Upper.Equal[ID]} && ${Param4.Length} && ${Int[${Param4}]} > 0) {
            /varset sendById ${Int[${Param4}]}
            /call SendMyStack "${sendTo}" ${sendById} ${sendQty}
            /call SendDoneToOrchestrator
            /return
        }
        /for sendPi 3 to 15
            /if (${Param${sendPi}.Length} && !${Param${sendPi}.Equal[NULL]}) {
                /if (${sendItemName.Length}) {
                    /varset sendItemName ${sendItemName} ${Param${sendPi}}
                } else {
                    /varset sendItemName ${Param${sendPi}}
                }
            }
        /next sendPi
        /if (!${sendItemName.Length}) {
            /echo ${tgTag} \ar[SEND]\aw Missing item name. Example: send Krel 5 Draught of Fleeting Fortitude I
            /return
        }
        /call SendMyStackByName "${sendTo}" "${sendItemName}" ${sendQty}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _BANKSENDITEM (source pulls ONE bank item, then gives it) ----
    | Invoked by TurboGear "Bank + Give": /mac turbogive _banksenditem <recipient> <itemID>
    | Runtime verifies the bank item by exact ID before moving anything.
    /if (${modeUpper.Equal[_BANKSENDITEM]}) {
        /declare bankSendItemId int local 0
        /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset bankSendItemId ${Int[${Param2}]}
        /call BankSendMyItem "${arg}" ${bankSendItemId}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- INTERNAL: _BANKSENDSTACK (pull QTY from bank, then SendMyStack) ----
    | /mac turbogive _banksendstack <recipient> <itemID> <qty>
    | /mac turbogive _banksendstack <recipient> <qty> id <itemID>
    /if (${modeUpper.Equal[_BANKSENDSTACK]}) {
        /declare bankStackId int local 0
        /declare bankStackQty int local 0
        /if (${Param2.Length} && ${Param2.Upper.Equal[ID]} && ${Param3.Length} && ${Int[${Param3}]} > 0) {
            /varset bankStackId ${Int[${Param3}]}
            /if (${Param4.Length} && ${Int[${Param4}]} > 0) /varset bankStackQty ${Int[${Param4}]}
        } else /if (${Param3.Length} && ${Param3.Upper.Equal[ID]} && ${Param4.Length} && ${Int[${Param4}]} > 0) {
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset bankStackQty ${Int[${Param2}]}
            /varset bankStackId ${Int[${Param4}]}
        } else {
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset bankStackId ${Int[${Param2}]}
            /if (${Param3.Length} && ${Int[${Param3}]} > 0) /varset bankStackQty ${Int[${Param3}]}
        }
        /if (${bankStackId} <= 0 || ${bankStackQty} <= 0) {
            /echo ${tgTag} \arUsage: /mac turbogive _banksendstack CHAR ITEMID QTY\ax
            /echo ${tgTag} \ar   or: /mac turbogive _banksendstack CHAR QTY id ITEMID\ax
            /return
        }
        /call BankSendMyStack "${arg}" ${bankStackId} ${bankStackQty}
        /call SendDoneToOrchestrator
        /return
    }

    | ---- GIVE (CHARNAME [cash|dc|plat|pp] [amount] or CHARNAME [amount]) ----
    /if (${mode.Length} && !${mode.Equal[NULL]}) {
        /declare giveArgUp string local ${arg.Upper.Replace[ ,]}
        | Check if arg is a currency keyword
        /if (${giveArgUp.Equal[CASH]} || ${giveArgUp.Equal[PLAT]} || ${giveArgUp.Equal[PP]}) {
            /declare giveCashAmt int local 0
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset giveCashAmt ${Int[${Param2}]}
            /call GiveCash "${mode}" ${giveCashAmt}
            /return
        }
        /if (${giveArgUp.Equal[DC]}) {
            /declare giveDcAmt int local 0
            /if (${Param2.Length} && ${Int[${Param2}]} > 0) /varset giveDcAmt ${Int[${Param2}]}
            /call GiveDC "${mode}" ${giveDcAmt}
            /return
        }
        | Check if arg is a numeric quantity limit for item give
        /if (${arg.Length} && ${Int[${arg}]} > 0) {
            /varset _giveLimit ${Int[${arg}]}
        }
        /if (${Defined[_batchMode]}) /varset _batchMode FALSE
        /call GiveToTarget "${mode}"
        /return
    }

    /call DeliverEveryone "GROUP"
/return

| =====================================================================
| DELIVER ALL — scan inventory, discover recipients, give to each
| =====================================================================
Sub DeliverAll(string scopeParam)
    /declare deliverScope string local ${scopeParam.Upper.Replace[ ,]}
    /declare groupOnly bool local FALSE
    /if (${deliverScope.Equal[GROUP]}) /varset groupOnly TRUE

    /echo ${tgTag} \ag[DELIVER ALL]\aw Scanning inventory for items to distribute${If[${groupOnly}, (group only),]}...

    | Check feign death
    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned. Stand up first.
        /return
    }

    | Pause E3 and follow for the duration of delivery
    /declare wasFollowingDA bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingDA TRUE
        /squelch /afollow pause
    }

    /declare recipients string local |
    /declare recipientCount int local 0

    /declare keyIdx int local
    /declare keyName string local
    /declare keyVal string local
    /for keyIdx 1 to 200
        /varset keyName ${Ini[${iniFile},GiveList].Arg[${keyIdx},|]}
        /if (!${keyName.Length} || ${keyName.Equal[NULL]}) /break
        /if (${keyName.Left[1].Equal[_]}) /continue
        /varset keyVal ${Ini[${iniFile},GiveList,${keyName}]}
        /if (!${keyVal.Length} || ${keyVal.Equal[NULL]}) /continue
        /if (${keyVal.Find[*]} || ${keyVal.Find[:]}) /continue
        /call ParseGiveListIniValue "${keyVal}"
        /if (!${giveListParsedName.Length}) /continue
        /if (!${recipients.Find[|${giveListParsedName}|]}) {
            /varset recipients ${recipients}${giveListParsedName}|
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Discovered recipient from INI: ${giveListParsedName}"
        }
    /next keyIdx

    /declare pIdx int local
    /declare pVal string local
    /declare pColonPos int local 0
    /declare pChar string local

    /for pIdx 1 to 30
        /varset pVal ${Ini[${iniFile},GiveList,_prefix${pIdx}]}
        /if (!${pVal.Length} || ${pVal.Equal[NULL]}) /continue
        /varset pColonPos ${pVal.Find[:]}
        /if (!${pColonPos}) /continue
        /varset pChar ${pVal.Left[${Math.Calc[${pColonPos}-1]}]}

        /if (${pChar.Length} && !${recipients.Find[|${pChar}|]}) {
            /varset recipients ${recipients}${pChar}|
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Discovered recipient from _prefix${pIdx}: ${pChar}"
        }
    /next pIdx

    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /declare wRemaining string local ${wildcardsRaw}
        /declare wPipePos int local 0
        /declare wChar string local

:nextWildcardRecipient
        /if (!${wRemaining.Length}) /goto :doneWildcardRecipients

        /varset wPipePos ${wRemaining.Find[|]}
        /if (${wPipePos}) {
            /varset wChar ${wRemaining.Left[${Math.Calc[${wPipePos}-1]}]}
            /varset wRemaining ${wRemaining.Mid[${Math.Calc[${wPipePos}+1]},2048]}
        } else {
            /varset wChar ${wRemaining}
            /varset wRemaining
        }

        /if (${wChar.Length} && !${recipients.Find[|${wChar}|]}) {
            /varset recipients ${recipients}${wChar}|
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Discovered recipient from _wildcards: ${wChar}"
        }
        /goto :nextWildcardRecipient
:doneWildcardRecipients
    }

    /if (${recipients.Equal[|]}) {
        /echo ${tgTag} \awNo recipients found in [GiveList]. Nothing to deliver.
        /echo ${tgTag} \awUse \ag/mac turbogive add CHARNAME\aw (with item on cursor) or \ag/mac turbogive help\aw.
        /if (${wasFollowingDA}) /squelch /afollow unpause
        /return
    }

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] All discovered recipients: ${recipients}"

    /declare remaining string local ${recipients}
    /declare pipePos int local
    /declare recipName string local
    /declare recipList string local
    /declare skippedList string local
    /declare isInGroup bool local FALSE
    /declare gIdx int local

    /varset remaining ${recipients.Right[-1]}
    /if (${remaining.Left[1].Equal[|]}) /varset remaining ${remaining.Right[-1]}

:countRecipients
    /if (!${remaining.Length}) /goto :doneCountRecipients

    /varset pipePos ${remaining.Find[|]}
    /if (${pipePos}) {
        /varset recipName ${remaining.Left[${Math.Calc[${pipePos}-1]}]}
        /varset remaining ${remaining.Mid[${Math.Calc[${pipePos}+1]},2048]}
    } else {
        /varset recipName ${remaining}
        /varset remaining
    }

    /if (!${recipName.Length}) /goto :countRecipients

    /if (${SpawnCount[pc ${recipName}]} || ${Spawn[${recipName}].ID}) {
        | If group-only mode, check group membership
        /if (${groupOnly}) {
            /varset isInGroup FALSE
            /for gIdx 1 to ${Group.Members}
                /if (${Group.Member[${gIdx}].Name.Equal[${recipName}]}) {
                    /varset isInGroup TRUE
                    /break
                }
            /next gIdx
            /if (!${isInGroup}) {
                /goto :countRecipients
            }
        }
        /varcalc recipientCount ${recipientCount}+1
        /if (${recipList.Length}) {
            /varset recipList ${recipList}, \ag${recipName}\aw
        } else {
            /varset recipList \ag${recipName}\aw
        }
    } else {
        /if (${skippedList.Length}) {
            /varset skippedList ${skippedList}, \ay${recipName}\aw
        } else {
            /varset skippedList \ay${recipName}\aw
        }
    }
    /goto :countRecipients

:doneCountRecipients
    /if (${recipientCount} == 0) {
        /echo ${tgTag} \awNo recipients in zone. Check group/raid or run \ag/mac turbogive status\aw to see who's expected.
        /if (${skippedList.Length}) /echo ${tgTag} \awNot in zone: ${skippedList}
        /if (${wasFollowingDA}) /squelch /afollow unpause
        /return
    }

    /echo ${tgTag} \awDelivering to \ag${recipientCount}\aw recipient(s): ${recipList}
    /if (${logToFile}) /call LogInfo "DeliverAll: ${recipientCount} recipient(s): ${recipList}"
    /if (${skippedList.Length}) /echo ${tgTag} \awSkipping (not in zone): ${skippedList}

    /varset remaining ${recipients.Right[-1]}
    /if (${remaining.Left[1].Equal[|]}) /varset remaining ${remaining.Right[-1]}
    /declare deliverIdx int local 0

:deliverNextRecipient
    /if (!${remaining.Length}) /goto :doneDeliverAll

    /varset pipePos ${remaining.Find[|]}
    /if (${pipePos}) {
        /varset recipName ${remaining.Left[${Math.Calc[${pipePos}-1]}]}
        /varset remaining ${remaining.Mid[${Math.Calc[${pipePos}+1]},2048]}
    } else {
        /varset recipName ${remaining}
        /varset remaining
    }

    /if (!${recipName.Length}) /goto :deliverNextRecipient

    /if (!${SpawnCount[pc ${recipName}]} && !${Spawn[${recipName}].ID}) /goto :deliverNextRecipient
    /if (${recipName.Equal[${Me.Name}]}) /goto :deliverNextRecipient

    /if (${groupOnly}) {
        /varset isInGroup FALSE
        /for gIdx 1 to ${Group.Members}
            /if (${Group.Member[${gIdx}].Name.Equal[${recipName}]}) {
                /varset isInGroup TRUE
                /break
            }
        /next gIdx
        /if (!${isInGroup}) /goto :deliverNextRecipient
    }

    /varcalc deliverIdx ${deliverIdx}+1
    /echo ${tgTag} \au---- Delivering to \ag${recipName}\au (${deliverIdx}/${recipientCount}) ----
    /if (!${Defined[_batchMode]}) {
        /declare _batchMode bool outer TRUE
    } else {
        /varset _batchMode TRUE
    }
    /call GiveToTarget "${recipName}"
    /delay 3

    /goto :deliverNextRecipient

:doneDeliverAll
    /if (${Defined[_batchMode]}) /varset _batchMode FALSE
    /echo ${tgTag} \ag${Me.Name}\aw deliveries complete.
    /if (${wasFollowingDA}) /squelch /afollow unpause
/return

| =====================================================================
| DELIVER EVERYONE — deliver my items, then broadcast to all bots to deliver theirs
| Scope GROUP: e3bcgz (group in zone); Scope ALL: e3bc (all e3 bots)
| Parallel broadcast: all bots run at once, wait for all DONE (like bank)
| =====================================================================
Sub DeliverEveryone(string scopeParam)
    /declare scope string local ${scopeParam.Upper.Replace[ ,]}
    /declare isAllMode bool local FALSE
    /if (${scope.Equal[ALL]}) /varset isAllMode TRUE

    /if (${isAllMode}) {
        /echo ${tgTag} \ag[ALL]\aw Starting full distribution (all bots in zone)...
    } else {
        /echo ${tgTag} \ag[GROUP]\aw Starting group distribution...
    }

    | Check feign death
    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned. Stand up first.
        /return
    }

    /echo ${tgTag} \au---- Step 1: Delivering my own items ----
    /if (${isAllMode}) {
        /call DeliverAll
    } else {
        /call DeliverAll "GROUP"
    }

    /echo ${tgTag} \au---- Step 2: Telling bots to deliver their items ----

    /declare myName string local ${Me.Name}
    /declare expectedDone int local 0

    /if (${isAllMode}) {
        /declare clientList string local ${MQ2Mono.Query[e3,E3Bots.ConnectedClients]}
        /if (!${clientList.Length} || ${clientList.Equal[NULL]}) {
            /echo ${tgTag} \ayNo connected E3 bots found. Skipping Step 2.
            /goto :doneDeliverEveryone
        }
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Connected e3 bots: ${clientList}"
        /declare clientRemaining string local ${clientList}
        /declare commaPos int local 0
        /declare botName string local
        /while (${clientRemaining.Length}) {
            /varset commaPos ${clientRemaining.Find[,]}
            /if (${commaPos}) {
                /varset botName ${clientRemaining.Left[${Math.Calc[${commaPos}-1]}]}
                /varset clientRemaining ${clientRemaining.Mid[${Math.Calc[${commaPos}+1]},2048]}
            } else {
                /varset botName ${clientRemaining}
                /varset clientRemaining
            }
            /if (!${botName.Length}) /continue
            /if (${botName.Equal[${myName}]}) /continue
            /if (${Spawn[pc ${botName}].ID} || ${Spawn[${botName}].ID}) /varcalc expectedDone ${expectedDone}+1
        }
    } else {
        /if (!${Me.Grouped}) {
            /echo ${tgTag} \ayNot in a group. Use "turbogive all" for all e3 bots.
            /goto :doneDeliverEveryone
        }
        /declare memberIdx int local
        /declare memberName string local
        /for memberIdx 1 to ${Group.Members}
            /varset memberName ${Group.Member[${memberIdx}].Name}
            /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
            /if (${memberName.Equal[${myName}]}) /continue
            /if (${Spawn[pc ${memberName}].ID} || ${Spawn[${memberName}].ID}) /varcalc expectedDone ${expectedDone}+1
        /next memberIdx
    }

    /if (${expectedDone} == 0) {
        /echo ${tgTag} \awNo bots in zone to tell.
        /goto :doneDeliverEveryone
    }

    /if (!${Defined[_bankBroadcastMode]}) {
        /declare _bankBroadcastMode bool outer FALSE
    }
    /if (!${Defined[_bankExpectedDone]}) {
        /declare _bankExpectedDone int outer 0
    }
    /if (!${Defined[_bankReceivedFrom]}) {
        /declare _bankReceivedFrom string outer
    }
    /if (!${Defined[_bankReceivedCount]}) {
        /declare _bankReceivedCount int outer 0
    }
    /if (!${Defined[charDone]}) {
        /declare charDone bool outer FALSE
    }
    /varset _bankBroadcastMode TRUE
    /varset _bankExpectedDone ${expectedDone}
    /varset _bankReceivedFrom |
    /varset _bankReceivedCount 0
    /varset charDone FALSE

    /if (${isAllMode}) {
        /squelch /e3bc /mac turbogive zone
    } else {
        /squelch /e3bcgz /mac turbogive group
    }

    /declare waitTicks int local 0
    /declare maxWait int local 600
    /while (!${charDone} && ${waitTicks} < ${maxWait}) {
        /doevents
        /delay 1
        /varcalc waitTicks ${waitTicks}+1
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Trade_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
        /if (${waitTicks} > 0 && ${Math.Calc[${waitTicks}%100]} == 0 && ${_bankReceivedCount} < ${_bankExpectedDone}) {
            /echo ${tgTag} \awWaiting... \ag${_bankReceivedCount}\aw/\ag${_bankExpectedDone}\aw bot(s) done.
        }
    }

    /varset _bankBroadcastMode FALSE

    /if (!${charDone}) {
        /echo ${tgTag} \ayTimed out (60s). \ag${_bankReceivedCount}\aw/\ag${_bankExpectedDone}\aw bot(s) finished.
    } else {
        /echo ${tgTag} \agAll \ag${_bankExpectedDone}\aw bot(s) deliveries complete.
    }

:doneDeliverEveryone
    /declare finalMsg string local
    /if (${expectedDone} > 0) {
        /if (${isAllMode}) {
            /varset finalMsg ${tgTag} \ag[ALL BOTS DELIVERED]\aw ${_bankReceivedCount}/${expectedDone} bot(s) finished.
        } else {
            /varset finalMsg ${tgTag} \ag[ALL BOTS DELIVERED]\aw ${_bankReceivedCount}/${expectedDone} group bot(s) finished.
        }
    } else {
        /varset finalMsg ${tgTag} \ag[DELIVER COMPLETE]\aw (no bots to tell)
    }
    /doevents
    /delay 5
    /doevents
    /echo ${finalMsg}
    /call Announce "${announceMethod}" "${finalMsg}"
/return

| =====================================================================
| HAND OUT TO GROUP
| =====================================================================
Sub HandOutToGroup(int countPerMember, string itemNameParam, string scopeParam)
    /declare handItemName string local
    /declare handAllMode bool local FALSE
    /declare handWantThisRecip int local 0
    /declare handGiveCount int local 0
    /declare handUnitsLeft int local 0
    /declare handInventoryWasOpen bool local FALSE
    /declare handAnyBagOpen bool local FALSE
    /declare handOpenedAnyBag bool local FALSE
    /declare handOpenIdx int local
    /if (${scopeParam.Length} && ${scopeParam.Upper.Equal[ALL]}) /varset handAllMode TRUE

    /if (${itemNameParam.Length} && !${itemNameParam.Equal[NULL]}) {
        /varset handItemName ${itemNameParam}
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Hand item from param: ${handItemName}"
        /if (!${FindItemCount[=${handItemName}]}) {
            /echo ${tgTag} \arCould not find \at${handItemName}\ar in inventory.
            /return
        }
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
        }
    } else {
        | Use cursor item
        /varset handItemName ${Cursor.Name}
        /if (!${Cursor.ID} || !${handItemName.Length} || ${handItemName.Equal[NULL]}) {
            /echo ${tgTag} \arNo item specified and nothing on cursor.
            /echo ${tgTag} \awUsage: Pick up an item then /mac turbogive hand COUNT
            /echo ${tgTag} \awOr: /mac turbogive hand COUNT Item Name Here
            /return
        }
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Hand item from cursor: ${handItemName}"
        /autoinventory
        /delay 5 !${Cursor.ID}
    }

    /if (!${handAllMode}) {
        /if (!${Me.Grouped} || ${Group.Members} < 1) {
            /echo ${tgTag} \arYou are not in a group.
            /return
        }
    }

    | Check feign death
    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned. Stand up first.
        /return
    }

    /if (${Window[InventoryWindow].Open}) /varset handInventoryWasOpen TRUE
    /for handOpenIdx 1 to 10
        /if (${Window[pack${handOpenIdx}].Open}) /varset handAnyBagOpen TRUE
    /next handOpenIdx

    /call OpenInventoryWindowForTrade
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \arCould not open inventory for handout.
        /return
    }

    | Open all bag windows before scanning/picking up. Hand itemnotify flows are
    | more reliable when the container windows are already open.
    /for handOpenIdx 1 to 10
        /if (${Me.Inventory[pack${handOpenIdx}].ID} && ${Me.Inventory[pack${handOpenIdx}].Container} > 0) {
            /if (!${Window[pack${handOpenIdx}].Open}) {
                /nomodkey /itemnotify pack${handOpenIdx} rightmouseup
                /delay 1 ${Window[pack${handOpenIdx}].Open}
                /if (${Window[pack${handOpenIdx}].Open}) /varset handOpenedAnyBag TRUE
            }
        }
    /next handOpenIdx

    /declare recipList string local |
    /declare recipCount int local 0
    /declare memberIdx int local
    /declare memberName string local

    /if (${handAllMode}) {
        /declare clientList string local ${MQ2Mono.Query[e3,E3Bots.ConnectedClients]}
        /if (!${clientList.Length} || ${clientList.Equal[NULL]}) {
            /echo ${tgTag} \arNo connected E3 bots found.
            /return
        }
        /declare clientRemaining string local ${clientList}
        /declare commaPos int local

        /while (${clientRemaining.Length}) {
            /varset commaPos ${clientRemaining.Find[,]}
            /if (${commaPos}) {
                /varset memberName ${clientRemaining.Left[${Math.Calc[${commaPos}-1]}]}
                /varset clientRemaining ${clientRemaining.Mid[${Math.Calc[${commaPos}+1]},2048]}
            } else {
                /varset memberName ${clientRemaining}
                /varset clientRemaining
            }
            /if (!${memberName.Length}) /continue
            /if (${memberName.Equal[${Me.Name}]}) /continue
            /if (!${Spawn[pc ${memberName}].ID} && !${Spawn[${memberName}].ID}) /continue
            /varset recipList ${recipList}${memberName}|
            /varcalc recipCount ${recipCount}+1
        }
    } else {
        /for memberIdx 1 to ${Group.Members}
            /varset memberName ${Group.Member[${memberIdx}].Name}
            /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
            /if (${memberName.Equal[${Me.Name}]}) /continue
            /if (!${Spawn[pc ${memberName}].ID} && !${Spawn[${memberName}].ID}) /continue
            /varset recipList ${recipList}${memberName}|
            /varcalc recipCount ${recipCount}+1
        /next memberIdx
    }

    /if (${recipCount} == 0) {
        /echo ${tgTag} \arNo recipients found${If[${handAllMode}, in zone, in group]}.
        /return
    }

    /declare totalHave int local 0
    /declare totalNeed int local ${Math.Calc[${countPerMember} * ${recipCount}]}
    /call CountInventoryItemUnits "${handItemName}"
    /varset totalHave ${Macro.Return}

    /echo ${tgTag} \ag[HANDOUT]\aw Distributing \ag${countPerMember}\aw x \at${handItemName}\aw to \ag${recipCount}\aw ${If[${handAllMode},bot(s) in zone,group member(s)]}
    /echo ${tgTag} \awNeed \ag${totalNeed}\aw total, have \ag${totalHave}\aw in inventory.

    /if (${totalHave} < ${totalNeed}) {
        /echo ${tgTag} \arWARNING: Not enough ${handItemName}! Need ${totalNeed} but only have ${totalHave}. Will give what I can.
    }

    /declare wasFollowingHO bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingHO TRUE
        /squelch /afollow pause
    }

    /declare membersGiven int local 0
    /declare remaining string local ${recipList.Right[-1]}
    /if (${remaining.Left[1].Equal[|]}) /varset remaining ${remaining.Right[-1]}
    /declare pipePos int local
    /declare recipName string local

:nextHandRecip
    /if (!${remaining.Length}) /goto :doneHandout

    /varset pipePos ${remaining.Find[|]}
    /if (${pipePos}) {
        /varset recipName ${remaining.Left[${Math.Calc[${pipePos}-1]}]}
        /varset remaining ${remaining.Mid[${Math.Calc[${pipePos}+1]},2048]}
    } else {
        /varset recipName ${remaining}
        /varset remaining
    }

    /if (!${recipName.Length}) /goto :nextHandRecip

    /call CountInventoryItemUnits "${handItemName}"
    /varset handUnitsLeft ${Macro.Return}
    /if (${handUnitsLeft} <= 0) {
        /echo ${tgTag} \arOut of ${handItemName}. Stopping handout.
        /goto :doneHandout
    }

    /varset handWantThisRecip ${countPerMember}
    /if (${handUnitsLeft} < ${handWantThisRecip}) /varset handWantThisRecip ${handUnitsLeft}
    /if (${handWantThisRecip} <= 0) /goto :doneHandout

    /call AcquireTradeTarget "${recipName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \arCould not target ${recipName} as a PC - skipping.
        /goto :nextHandRecip
    }

    /if (${Target.Distance} > 15) {
        /face fast
        /if (${Navigation.PathExists[id ${_tradeTargetID}]}) {
            /nav id ${_tradeTargetID} distance=10
            /delay 150 !${Navigation.Active} || ${Target.Distance} <= 15
            /if (${Navigation.Active}) /squelch /nav stop
        } else {
            /moveto id ${_tradeTargetID} dist 10
            /delay 100 ${Target.Distance} <= 15
        }
    }
    /face fast

    /if (${Target.Distance} > 30) {
        /echo ${tgTag} \arCould not reach ${recipName} (${Target.Distance} ft) - skipping.
        /goto :nextHandRecip
    }

    /if (${Cursor.ID} && !${Cursor.Name.Equal[${handItemName}]}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
    }

    /call PickupExactItemCount "${handItemName}" ${handWantThisRecip}
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ag[HANDOUT]\ar Could not pick up ${handWantThisRecip}x ${handItemName} - skipping ${recipName}.
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
        }
        /goto :nextHandRecip
    }

    /if (!${Cursor.ID}) {
        /echo ${tgTag} \arFailed to pick up ${handItemName} - skipping ${recipName}.
        /goto :nextHandRecip
    }
    /varset handGiveCount ${Cursor.Stack}
    /if (${handGiveCount} <= 0) /varset handGiveCount 1

    /call RemotePauseBot "${recipName}"

    /face fast
    /delay 1
    | v1.7: verify target before each trade-open click (drift guard)
    /call VerifyTradeTarget "${recipName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ag[HANDOUT]\ay [SAFETY]\aw Target drift before handout click — returning stack and skipping ${recipName}.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /call RemoteResumeBot "${recipName}"
        /goto :nextHandRecip
    }
    /notify TargetWindow Target_HP leftmouseup
    /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
    /if (${Cursor.ID} && !${Window[TradeWnd].Open}) {
        /call VerifyTradeTarget "${recipName}"
        /if (!${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ag[HANDOUT]\ay [SAFETY]\aw Target drift before fallback click — returning stack and skipping ${recipName}.
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
            /call RemoteResumeBot "${recipName}"
            /goto :nextHandRecip
        }
        /click left target
        /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
    }

    /if (${Cursor.ID}) {
        /echo ${tgTag} \ayCould not place ${handItemName} in trade window for ${recipName}. Returning to inventory.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /call RemoteResumeBot "${recipName}"
        /goto :nextHandRecip
    }

    /call ExecuteTrade "${recipName}"
    /varcalc membersGiven ${membersGiven}+1
    /echo ${tgTag} \ag[HANDOUT]\aw Gave \ag${handGiveCount}\aw x \at${handItemName}\aw to \ag${recipName}

    /goto :nextHandRecip

:doneHandout
    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
    }
    /if (${handOpenedAnyBag}) {
        /for handOpenIdx 1 to 10
            /if (${Window[pack${handOpenIdx}].Open}) /nomodkey /itemnotify pack${handOpenIdx} rightmouseup
        /next handOpenIdx
    }
    /if (!${handInventoryWasOpen} && !${handAnyBagOpen} && ${Window[InventoryWindow].Open}) {
        /nomodkey /notify InventoryWindow DoneButton leftmouseup
    }

    /echo ${tgTag} \ag[HANDOUT COMPLETE]\aw Gave \at${handItemName}\aw to \ag${membersGiven}\aw of \ag${recipCount}\aw ${If[${handAllMode},bot(s),group member(s)]}.
    /call Announce "${announceMethod}" "${tgTag} \ag[HANDOUT COMPLETE]\aw Distributed ${handItemName} to ${membersGiven} ${If[${handAllMode},bot(s),group member(s)]}."
    /if (${wasFollowingHO}) /squelch /afollow unpause
/return

| =====================================================================
| BANK PULL
| =====================================================================
Sub BankPull(string targetName)
    /declare charName string local ${targetName}

    /if (${charName.Equal[${Me.Name}]}) {
        | Called for self — valid when bank solo; BankPullAll(TRUE) includes self
        /echo ${tgTag} \ag[BANK]\aw Pulling my items from bank...
    } else {
        /echo ${tgTag} \ag[BANK]\aw Pulling items from bank for \ag${charName}\aw...
    }

    /declare wasFollowingBP bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingBP TRUE
        /squelch /afollow pause
    }

    /if (!${Window[BigBankWnd].Open}) {
        /call FindAndOpenBank
        /if (!${Window[BigBankWnd].Open}) {
            /echo ${tgTag} \arCould not open bank window. Target a banker manually and try again.
            /if (${wasFollowingBP}) /squelch /afollow unpause
            /return
        }
    }

    /if (!${Defined[prefixList]}) {
        /declare prefixList string outer
    } else {
        /varset prefixList
    }
    /call LoadPrefixesForChar "${charName}"

    /declare useWildcards bool local FALSE
    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /declare wcSearch string local |${wildcardsRaw.Upper}|
        /if (${wcSearch.Find[|${charName.Upper}|]}) {
            /varset useWildcards TRUE
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] WILDCARDS enabled for ${charName} (bank pull)"
        }
    }
    /if (${useWildcards}) {
        /call LoadWildcards
    }
    /call LoadGiveExclude

    /declare itemsPulled int local 0
    /declare bankNum int local
    /declare slotNum int local
    /declare maxSlots int local
    /declare itemName string local
    /declare itemNameUpper string local
    /declare iniLookup string local
    /declare iniLookupUpper string local
    /declare matched bool local
    /declare bankNoMatch string local |
    /declare bankYesMatch string local |

    /for bankNum 1 to 24
        /if (!${Window[BigBankWnd].Open}) {
            /echo ${tgTag} \arBank window closed during scan! Pulled \ag${itemsPulled}\aw item(s) before stopping.
            /if (${wasFollowingBP}) /squelch /afollow unpause
            /return
        }

        /if (!${Me.Bank[${bankNum}].ID}) /continue
        /varset maxSlots ${Me.Bank[${bankNum}].Container}
        /if (!${maxSlots}) {
            /varset itemName ${Me.Bank[${bankNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            /varset itemNameUpper ${itemName.Upper}

            | Fast skip/match from cache (uppercased for case-insensitive matching)
            /if (${bankNoMatch.Find[|${itemNameUpper}|]}) /continue
            /varset matched FALSE
            /if (${bankYesMatch.Find[|${itemNameUpper}|]}) {
                /varset matched TRUE
            } else {
                /call CheckBankItemMatch "${charName}" "${itemName}" ${useWildcards}
                /if (${Macro.Return.Equal[TRUE]}) {
                    /varset matched TRUE
                    /if (${bankYesMatch.Length} > 2000) /varset bankYesMatch |
                    /varset bankYesMatch ${bankYesMatch}${itemNameUpper}|
                } else {
                    /if (${bankNoMatch.Length} > 2000) /varset bankNoMatch |
                    /varset bankNoMatch ${bankNoMatch}${itemNameUpper}|
                }
            }
            /if (${matched}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Bank pull: ${itemName} from bank slot ${bankNum}"
                /nomodkey /itemnotify bank${bankNum} leftmouseup
                /delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
                /call HandleBankQuantityWindow
                /if (${Cursor.ID}) {
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (!${Cursor.ID}) {
                        /varcalc itemsPulled ${itemsPulled}+1
                        /echo ${tgTag} \ap[BANK]\aw Pulled ${itemName} for \ag${charName}
                    }
                }
            }
            /continue
        }

        /doevents
        /for slotNum 1 to ${maxSlots}
            /if (!${Me.Bank[${bankNum}].Item[${slotNum}].ID}) /continue
            /varset itemName ${Me.Bank[${bankNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            /varset itemNameUpper ${itemName.Upper}

            | Fast skip/match from cache (uppercased for case-insensitive matching)
            /if (${bankNoMatch.Find[|${itemNameUpper}|]}) /continue
            /varset matched FALSE
            /if (${bankYesMatch.Find[|${itemNameUpper}|]}) {
                /varset matched TRUE
            } else {
                /call CheckBankItemMatch "${charName}" "${itemName}" ${useWildcards}
                /if (${Macro.Return.Equal[TRUE]}) {
                    /varset matched TRUE
                    /if (${bankYesMatch.Length} > 2000) /varset bankYesMatch |
                    /varset bankYesMatch ${bankYesMatch}${itemNameUpper}|
                } else {
                    /if (${bankNoMatch.Length} > 2000) /varset bankNoMatch |
                    /varset bankNoMatch ${bankNoMatch}${itemNameUpper}|
                }
            }

            /if (!${matched}) /continue

            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Bank pull: ${itemName} from bank${bankNum} slot ${slotNum}"
            /nomodkey /itemnotify in bank${bankNum} ${slotNum} leftmouseup
            /delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
            /call HandleBankQuantityWindow
            /if (${Cursor.ID}) {
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) {
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                }
                /if (!${Cursor.ID}) {
                    /varcalc itemsPulled ${itemsPulled}+1
                    /echo ${tgTag} \ap[BANK]\aw Pulled ${itemName} for \ag${charName}
                } else {
                    /call ForceClearCursor
                    /if (${Cursor.ID}) {
                        /echo ${tgTag} \arFailed to autoinventory ${itemName}. Cursor stuck.
                        /if (${wasFollowingBP}) /squelch /afollow unpause
                        /return
                    }
                }
            }
            /if (!${Me.FreeInventory}) {
                /echo ${tgTag} \ayInventory full. Stopping bank pull.
                /goto :bankPullDone
            }
        /next slotNum
    /next bankNum

:bankPullDone

    /if (!${Me.FreeInventory}) {
        /echo ${tgTag} \ayWarning: Inventory is full. Some items may not have been pulled.
    }

    /if (${itemsPulled} > 0) {
        /echo ${tgTag} \ag[BANK COMPLETE]\aw Pulled \ag${itemsPulled}\aw item(s) from bank for \ag${charName}\aw.
        /call Announce "${announceMethod}" "${tgTag} \ag[BANK COMPLETE]\aw Pulled \ag${itemsPulled}\aw item(s) from bank for \ag${charName}\aw."
    } else {
        /echo ${tgTag} \awNo matching items found in bank for \ag${charName}\aw.
    }
    /declare isBankBatch bool local FALSE
    /if (${Defined[_bankBatchMode]} && ${_bankBatchMode}) /varset isBankBatch TRUE
    /if (!${isBankBatch}) {
        /if (${Window[BigBankWnd].Open}) {
            /notify BigBankWnd DoneButton leftmouseup
            /delay 5 !${Window[BigBankWnd].Open}
        }
    }
    /if (${wasFollowingBP}) /squelch /afollow unpause
/return

| =====================================================================
| BANK PULL ALL
| =====================================================================
Sub BankPullAll(bool includeSelf)
    /declare pullForSelf bool local FALSE
    /if (${includeSelf}) /varset pullForSelf TRUE

    /echo ${tgTag} \ag[BANK ALL]\aw Scanning bank for all give-list items${If[${pullForSelf}, (including my items), (others only)]}...

    /declare wasFollowingBA bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingBA TRUE
        /squelch /afollow pause
    }

    /if (!${Window[BigBankWnd].Open}) {
        /call FindAndOpenBank
        /if (!${Window[BigBankWnd].Open}) {
            /echo ${tgTag} \arCould not open bank window. Target a banker manually and try again.
            /if (${wasFollowingBA}) /squelch /afollow unpause
            /return
        }
    }

    /declare recipients string local |
    /declare keyIdx int local
    /declare keyName string local
    /declare keyVal string local
    /for keyIdx 1 to 200
        /varset keyName ${Ini[${iniFile},GiveList].Arg[${keyIdx},|]}
        /if (!${keyName.Length} || ${keyName.Equal[NULL]}) /break
        /if (${keyName.Left[1].Equal[_]}) /continue
        /varset keyVal ${Ini[${iniFile},GiveList,${keyName}]}
        /if (!${keyVal.Length} || ${keyVal.Equal[NULL]}) /continue
        /if (${keyVal.Find[*]} || ${keyVal.Find[:]}) /continue
        /call ParseGiveListIniValue "${keyVal}"
        /if (!${giveListParsedName.Length}) /continue
        /if (!${recipients.Find[|${giveListParsedName}|]}) {
            /varset recipients ${recipients}${giveListParsedName}|
        }
    /next keyIdx

    /declare pIdx int local
    /declare pVal string local
    /declare pColonPos int local 0
    /declare pChar string local

    /for pIdx 1 to 30
        /varset pVal ${Ini[${iniFile},GiveList,_prefix${pIdx}]}
        /if (!${pVal.Length} || ${pVal.Equal[NULL]}) /continue
        /varset pColonPos ${pVal.Find[:]}
        /if (!${pColonPos}) /continue
        /varset pChar ${pVal.Left[${Math.Calc[${pColonPos}-1]}]}
        /if (${pChar.Length} && !${recipients.Find[|${pChar}|]}) /varset recipients ${recipients}${pChar}|
    /next pIdx

    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /declare wRemaining string local ${wildcardsRaw}
        /declare wPipePos int local 0
        /declare wChar string local

:nextWCRecipBank
        /if (!${wRemaining.Length}) /goto :doneWCRecipBank
        /varset wPipePos ${wRemaining.Find[|]}
        /if (${wPipePos}) {
            /varset wChar ${wRemaining.Left[${Math.Calc[${wPipePos}-1]}]}
            /varset wRemaining ${wRemaining.Mid[${Math.Calc[${wPipePos}+1]},2048]}
        } else {
            /varset wChar ${wRemaining}
            /varset wRemaining
        }
        /if (${wChar.Length} && !${recipients.Find[|${wChar}|]}) /varset recipients ${recipients}${wChar}|
        /goto :nextWCRecipBank
:doneWCRecipBank
    }

    /if (${recipients.Equal[|]}) {
        /echo ${tgTag} \awNo give-list recipients found. Nothing to pull from bank.
        /if (${wasFollowingBA}) /squelch /afollow unpause
        /return
    }

    /if (!${Defined[_bankBatchMode]}) {
        /declare _bankBatchMode bool outer TRUE
    } else {
        /varset _bankBatchMode TRUE
    }

    /declare remaining string local ${recipients.Right[-1]}
    /if (${remaining.Left[1].Equal[|]}) /varset remaining ${remaining.Right[-1]}
    /declare pipePos int local
    /declare recipName string local

:bankNextRecip
    /if (!${remaining.Length}) /goto :doneBankAll

    /varset pipePos ${remaining.Find[|]}
    /if (${pipePos}) {
        /varset recipName ${remaining.Left[${Math.Calc[${pipePos}-1]}]}
        /varset remaining ${remaining.Mid[${Math.Calc[${pipePos}+1]},2048]}
    } else {
        /varset recipName ${remaining}
        /varset remaining
    }

    /if (!${recipName.Length}) /goto :bankNextRecip

    /if (!${pullForSelf} && ${recipName.Equal[${Me.Name}]}) /goto :bankNextRecip

    /if (!${Window[BigBankWnd].Open}) {
        /echo ${tgTag} \arBank window closed. Stopping.
        /if (${wasFollowingBA}) /squelch /afollow unpause
        /return
    }

    /echo ${tgTag} \au---- Pulling bank items for \ag${recipName}\au ----
    /call BankPull "${recipName}"

    /goto :bankNextRecip

:doneBankAll
    /if (${Defined[_bankBatchMode]}) /varset _bankBatchMode FALSE
    /if (${Window[BigBankWnd].Open}) {
        /notify BigBankWnd DoneButton leftmouseup
        /delay 5 !${Window[BigBankWnd].Open}
    }
    /if (${wasFollowingBA}) /squelch /afollow unpause
/return

| =====================================================================
| BANK ALL BOTS
| =====================================================================
Sub BankAllBots(string scopeParam)
    /declare scope string local ${scopeParam.Upper.Replace[ ,]}
    /declare isAllMode bool local FALSE
    /if (${scope.Equal[ALL]}) /varset isAllMode TRUE
    /declare myName string local ${Me.Name}

    /if (${Me.Grouped} && !${Group.Leader.Name.Equal[${myName}]}) {
        /echo ${tgTag} \ayNote: You are not group leader. Bots will signal the leader; you may not see completion.
    }

    | Compute expected DONE count (bots we'll broadcast to)
    /declare expectedDone int local 0

    /if (${isAllMode}) {
        /declare clientList string local ${MQ2Mono.Query[e3,E3Bots.ConnectedClients]}
        /if (!${clientList.Length} || ${clientList.Equal[NULL]}) {
            /echo ${tgTag} \ayNo connected E3 bots found.
            /return
        }
        /declare clientRemaining string local ${clientList}
        /declare commaPos int local 0
        /declare botName string local
        /while (${clientRemaining.Length}) {
            /varset commaPos ${clientRemaining.Find[,]}
            /if (${commaPos}) {
                /varset botName ${clientRemaining.Left[${Math.Calc[${commaPos}-1]}]}
                /varset clientRemaining ${clientRemaining.Mid[${Math.Calc[${commaPos}+1]},2048]}
            } else {
                /varset botName ${clientRemaining}
                /varset clientRemaining
            }
            /if (!${botName.Length}) /continue
            /if (${botName.Equal[${myName}]}) /continue
            /if (${Spawn[pc ${botName}].ID} || ${Spawn[${botName}].ID}) /varcalc expectedDone ${expectedDone}+1
        }
    } else {
        /if (!${Me.Grouped}) {
            /echo ${tgTag} \ayNot in a group. Use "bank all" for all e3 bots, "bank solo" to pull your own items, or "bank pull" to pull your bank for others.
            /return
        }
        /declare memberIdx int local
        /declare memberName string local
        /for memberIdx 1 to ${Group.Members}
            /varset memberName ${Group.Member[${memberIdx}].Name}
            /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
            /if (${memberName.Equal[${myName}]}) /continue
            /if (${Spawn[pc ${memberName}].ID} || ${Spawn[${memberName}].ID}) /varcalc expectedDone ${expectedDone}+1
        /next memberIdx
    }

    /if (${expectedDone} == 0) {
        /echo ${tgTag} \awNo bots in zone to tell. Use "bank pull" to pull your own bank for others.
        /return
    }

    /if (${isAllMode}) {
        /echo ${tgTag} \ag[BANK ALL]\aw Telling all e3 bots in zone to pull from bank...
        /if (${logToFile}) /call LogInfo "BANK ALL: Telling ${expectedDone} e3 bot(s) to pull from bank"
    } else {
        /echo ${tgTag} \ag[BANK GROUP]\aw Telling group members in zone to pull from bank...
        /if (${logToFile}) /call LogInfo "BANK GROUP: Telling ${expectedDone} group member(s) to pull from bank"
    }

    /if (!${Defined[_bankBroadcastMode]}) {
        /declare _bankBroadcastMode bool outer FALSE
    }
    /if (!${Defined[_bankExpectedDone]}) {
        /declare _bankExpectedDone int outer 0
    }
    /if (!${Defined[_bankReceivedFrom]}) {
        /declare _bankReceivedFrom string outer
    }
    /if (!${Defined[_bankReceivedCount]}) {
        /declare _bankReceivedCount int outer 0
    }
    /if (!${Defined[charDone]}) {
        /declare charDone bool outer FALSE
    }
    /varset _bankBroadcastMode TRUE
    /varset _bankExpectedDone ${expectedDone}
    /varset _bankReceivedFrom |
    /varset _bankReceivedCount 0
    /varset charDone FALSE

    /if (${isAllMode}) {
        /squelch /e3bc /mac turbogive bank pull
    } else {
        /squelch /e3bcgz /mac turbogive bank pull
    }

    /declare waitTicks int local 0
    /declare maxWait int local 600
    /while (!${charDone} && ${waitTicks} < ${maxWait}) {
        /doevents
        /delay 1
        /varcalc waitTicks ${waitTicks}+1
        /if (${waitTicks} > 0 && ${Math.Calc[${waitTicks}%100]} == 0 && ${_bankReceivedCount} < ${_bankExpectedDone}) {
            /echo ${tgTag} \awWaiting... \ag${_bankReceivedCount}\aw/\ag${_bankExpectedDone}\aw bot(s) done.
        }
    }

    /varset _bankBroadcastMode FALSE

    /if (!${charDone}) {
        /echo ${tgTag} \ayTimed out (60s). \ag${_bankReceivedCount}\aw/\ag${_bankExpectedDone}\aw bot(s) finished. Some may still be pulling.
        /if (${logToFile}) /call LogWarn "Bank broadcast timed out: ${_bankReceivedCount}/${_bankExpectedDone} bot(s) done"
    } else {
        /echo ${tgTag} \ag[BANK COMPLETE]\aw All \ag${_bankExpectedDone}\aw bot(s) finished pulling from bank.
        /if (${logToFile}) /call LogInfo "Bank broadcast complete: all ${_bankExpectedDone} bot(s) finished"
    }
    /doevents
    /delay 5
    /doevents
/return

| =====================================================================
| FIND AND OPEN BANK
| =====================================================================
Sub FindAndOpenBank
    /echo ${tgTag} \ayBank window not open - looking for a banker...

    /declare dropLevSetting string local ${Ini[${iniFile},Settings,dropLevBeforeNav]}
    /if (${dropLevSetting.Length} && !${dropLevSetting.Equal[NULL]}) {
        /declare dropUpper string local ${dropLevSetting.Upper.Replace[ ,]}
        /if ((${dropUpper.Equal[ON]} || ${dropUpper.Equal[TRUE]} || ${dropUpper.Equal[YES]} || ${dropUpper.Equal[1]}) && ${Me.Levitating}) {
            /removelev
            /delay 10 !${Me.Levitating}
        }
    }

    /target clear
    /delay 1

    | PoK has some bankers that are targetable but not nav-friendly from common
    | locations. Dogle Pitt is reachable, so prefer him before generic banker scan.
    /declare preferredBanker string local
    /if (${Zone.ShortName.Equal[poknowledge]}) /varset preferredBanker Dogle
    /if (${preferredBanker.Length}) {
        /target ${preferredBanker}
        /delay 10 ${Target.ID}
        /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Banker]} || ${Target.Type.Equal[NPC]})) {
            /echo ${tgTag} \ayPreferred banker: \aw${Target.CleanName}
        } else {
            /target clear
            /delay 1
        }
    }

    /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Banker]} || ${Target.Type.Equal[NPC]})) {
        /if (${Target.Distance} <= 10) {
            /click right target
            /delay 100 ${Window[BigBankWnd].Open}
            /doevents
            /if (${Window[BigBankWnd].Open}) {
                /echo ${tgTag} \agBank window opened.
                /return
            }
        }
    }

    /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Banker]} && ${Target.Type.NotEqual[NPC]})) {
        /target npc banker
        /delay 1
    }
    /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Banker]} && ${Target.Type.NotEqual[NPC]})) {
        /if (${SpawnCount[npc banker radius 200]} > 0) {
            /target npc banker radius 200
            /delay 1
        }
    }

    /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Banker]} && ${Target.Type.NotEqual[NPC]})) {
        /echo ${tgTag} \arNo banker found nearby.
        /return
    }

    /echo ${tgTag} \ayFound banker: \aw${Target.CleanName} \ay(distance: \aw${Target.Distance}\ay)

    /if (${Target.Distance} > 10) {
        /declare bankerID int local ${Target.ID}
        /echo ${tgTag} \ayNavigating to banker (distance: \aw${Target.Distance}\ay)...
        /echo ${tgTag} \ayCancel: \aw/endmacro\ay or TurboGear \awStop Nav\ay (also \aw/nav stop\ay).
        /call NavToIDWithDoorsAndNudges ${bankerID} 10 900

        /if (!${Target.ID} || ${Target.ID} != ${bankerID}) {
            /echo ${tgTag} \arLost banker target during navigation.
            /return
        }

        /if (${Target.Distance} <= 10) {
            /echo ${tgTag} \agReached banker (distance: \aw${Target.Distance}\ag)
        } else {
            /echo ${tgTag} \ayWARNING: Could not fully reach banker (distance: \aw${Target.Distance}\ay) - trying to open anyway
        }
    }

    /face fast
    /delay 1
    /click right target
    /delay 100 ${Window[BigBankWnd].Open}
    /doevents

    /if (${Window[BigBankWnd].Open}) {
        /echo ${tgTag} \agBank window opened.
    } else {
        /echo ${tgTag} \arFailed to open bank window. Try targeting the banker manually.
    }
/return

| =====================================================================
| CHECK BANK ITEM MATCH
| =====================================================================
Sub CheckBankItemMatch(string charName, string itemName, bool useWildcards)
    | Hard-block (1.8.9): always FALSE for items on the hardcoded skip list,
    | regardless of GiveList / prefix / wildcard configuration.
    /call IsHardBlocked "${itemName}"
    /if (${Macro.Return.Equal[TRUE]}) /return FALSE

    /declare iniLookup string local ${Ini[${iniFile},GiveList,${itemName}]}
    /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
        /varset iniLookup ${Ini[${iniFile},GiveList,${itemName.Upper}]}
    }
    /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
        /varset iniLookup ${Ini[${iniFile},GiveList,${itemName.Lower}]}
    }
    /if (${iniLookup.Length} && !${iniLookup.Equal[NULL]}) {
        /call GiveListIniValueMatchesChar "${iniLookup}" "${charName}"
        /if (${Macro.Return.Equal[TRUE]}) /return TRUE
    }

    /if (${prefixList.Length}) {
        /call IsGivePrefix "${itemName}"
        /if (${Macro.Return.Equal[TRUE]}) {
            /call IsGiveExcluded "${itemName}"
            /if (${Macro.Return.Equal[TRUE]}) /return FALSE
            /return TRUE
        }
    }

    /if (${useWildcards} && ${Defined[wildcardPrefixes]} && ${wildcardPrefixes.Length}) {
        /call IsWildcardItem "${itemName}"
        /if (${Macro.Return.Equal[TRUE]}) {
            /call IsGiveExcluded "${itemName}"
            /if (${Macro.Return.Equal[TRUE]}) /return FALSE
            /return TRUE
        }
    }

/return FALSE

| =====================================================================
| HANDLE BANK QUANTITY WINDOW
| =====================================================================
Sub HandleBankQuantityWindow
    /if (!${Window[QuantityWnd].Open}) /return
    /notify QuantityWnd QTYW_Accept_Button leftmouseup
    /delay 5 !${Window[QuantityWnd].Open}
    /if (${Window[QuantityWnd].Open}) {
        /notify QuantityWnd AcceptButton leftmouseup
        /delay 5 !${Window[QuantityWnd].Open}
    }
    /if (${Window[QuantityWnd].Open}) {
        /keypress ENTER
        /delay 5 !${Window[QuantityWnd].Open}
    }
    /delay 3 ${Cursor.ID}
/return

| =====================================================================
| GIVE TO TARGET
| =====================================================================
Sub GiveToTarget(string targetName)
    /declare charName string local ${targetName}

    | v1.8.5: hoisted to top so early-exit paths can safely /goto :cleanupGive.
    | :cleanupGive is the single source of truth for firing the DONE signal,
    | guaranteeing the collector never hangs 60s on an early-exit bot.
    /declare isBatch bool local FALSE
    /if (${Defined[_batchMode]} && ${_batchMode}) /varset isBatch TRUE
    /declare wasFollowing bool local FALSE

    /echo ${tgTag} \awPreparing to give items to \ag${charName}\aw...

    | Can't trade with yourself — DONE still fires via :cleanupGive so any
    | collector that accidentally asked us for items won't hang.
    /if (${charName.Equal[${Me.Name}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Skipping ${charName} - that's me"
        /goto :cleanupGive
    }

    | Verify the target character exists in zone (try pc first, fallback for illusions)
    /if (!${SpawnCount[pc ${charName}]} && !${Spawn[${charName}].ID}) {
        /echo ${tgTag} \ar${charName} is not in the current zone.
        /goto :cleanupGive
    }

    | Check feign death
    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned. Stand up first.
        /goto :cleanupGive
    }

    | Load prefix rules for this character from _prefix1 through _prefix30
    | Format: _prefix1=CharName:Spell:*  _prefix2=CharName:*Oleander
    /if (!${Defined[prefixList]}) {
        /declare prefixList string outer
    } else {
        /varset prefixList
    }
    /call LoadPrefixesForChar "${charName}"

    | Load wildcard flag for this character from _wildcards key
    | Format: _wildcards=CharName|OtherChar
    /declare useWildcards bool local FALSE
    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /declare wcSearch string local |${wildcardsRaw.Upper}|
        /if (${wcSearch.Find[|${charName.Upper}|]}) {
            /varset useWildcards TRUE
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] WILDCARDS enabled for ${charName}"
        }
    }

    | Load shared wildcards if needed
    /if (${useWildcards}) {
        /call LoadWildcards
    }
    /call LoadGiveExclude

    /if (${showDebug} || ${logToFile}) {
        /call LogDebug "[turboGive] Prefix patterns for ${charName}: ${prefixList}"
        /call LogDebug "[turboGive] Use shared wildcards: ${useWildcards}"
    }

    | Skip own afollow management if called from DeliverAll (which handles it)
    /if (!${isBatch}) {
        /if (${AdvPath.Following}) {
            /varset wasFollowing TRUE
            /squelch /afollow pause
        }
    }

    | Tell target to stop moving
    /squelch /e3bct ${charName} /squelch /afollow pause

    | Target the character (try pc first, fallback to name for illusions)
    /target pc ${charName}
    /delay 5 ${Target.ID} && ${Target.CleanName.Equal[${charName}]}
    /if (!${Target.ID} || !${Target.CleanName.Equal[${charName}]}) {
        | Fallback: target by name without pc filter (handles illusions)
        /target ${charName}
        /delay 5 ${Target.ID} && ${Target.CleanName.Equal[${charName}]}
    }
    /if (!${Target.ID} || !${Target.CleanName.Equal[${charName}]}) {
        /echo ${tgTag} \arCould not target ${charName}.
        /goto :cleanupGive
    }

    | Navigate to target
    /declare targetNavID int local ${Target.ID}
    /if (${Target.Distance} > 15) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Navigating to ${charName} (distance: ${Target.Distance})"
        /call NavToIDWithDoorsAndNudges ${targetNavID} 10 600
    }
    /face fast

    /if (${Target.Distance} > 30) {
        /echo ${tgTag} \arCould not get close enough to ${charName} (${Target.Distance} ft). Aborting.
        /goto :cleanupGive
    }

    | Scan inventory — for each bag item, check all match rules
    /declare itemsGiven int local 0
    /declare itemsInBatch int local 0
    /declare tradesCompleted int local 0
    /declare packNum int local
    /declare slotNum int local
    /declare maxSlots int local
    /declare itemName string local
    /declare itemNameUpper string local
    /declare iniLookup string local
    /declare iniLookupUpper string local
    /declare matched bool local
    | Track items we've already checked and found NO match — skip on re-encounter
    /declare noMatchCache string local |
    | Track items we've already matched — skip INI/prefix checks, go straight to trade
    /declare matchCache string local |
    | Per-item max from [GiveList] "Char N" (exact lines only); tally is total units given this run
    /declare giveLimitLog string local |
    /declare giveTallyQtyMap string local |
    /declare itemQLimit int local 0
    /declare itemQTally int local 0
    /declare itemQRemain int local 0
    /declare itemQWant int local 0
    /declare itemQAvail int local 0
    /declare giveQtyPicked int local 0

    /echo ${tgTag} \awScanning inventory for items to give \ag${charName}\aw...

    | Open all bag windows before scanning (itemnotify is more reliable when bag is open)
    /declare openIdx int local
    /for openIdx 1 to 10
        /if (${Me.Inventory[pack${openIdx}].ID} && ${Me.Inventory[pack${openIdx}].Container} > 0) {
            /if (!${Window[pack${openIdx}].Open}) {
                /nomodkey /itemnotify pack${openIdx} rightmouseup
                /delay 1 ${Window[pack${openIdx}].Open}
            }
        }
    /next openIdx

    /for packNum 1 to 10
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} == 0) /continue
        /doevents
        /for slotNum 1 to ${maxSlots}
            /if (!${Me.Inventory[pack${packNum}].Item[${slotNum}].ID}) /continue
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue

            /varset itemNameUpper ${itemName.Upper}

            | Hard-block (1.8.9): items on the hardcoded always-skip list
            | are filtered out BEFORE any GiveList / prefix / wildcard
            | check, so an explicit ItemName=Char line in the INI cannot
            | override the block. Logged to noMatchCache so future stacks
            | of the same item in this run also fast-skip.
            /call IsHardBlocked "${itemName}"
            /if (${Macro.Return.Equal[TRUE]}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] HARD-BLOCK: refusing to give ${itemName} (hardcoded always-skip)"
                /if (${noMatchCache.Length} > 2000) /varset noMatchCache |
                /varset noMatchCache ${noMatchCache}${itemNameUpper}|
                /continue
            }

            | Fast skip: already checked this item name and it didn't match
            /if (${noMatchCache.Find[|${itemNameUpper}|]}) /continue

            | Fast path: already matched this item name before — skip checks, go to trade
            /if (${matchCache.Find[|${itemNameUpper}|]}) /goto :doTrade

            /varset matched FALSE

            | Check 1: Direct INI lookup — ItemName=CharName (exact, upper, lower fallback)
            /varset iniLookup ${Ini[${iniFile},GiveList,${itemName}]}
            /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
                /varset iniLookup ${Ini[${iniFile},GiveList,${itemNameUpper}]}
            }
            /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
                /varset iniLookup ${Ini[${iniFile},GiveList,${itemName.Lower}]}
            }
            /if (${iniLookup.Length} && !${iniLookup.Equal[NULL]}) {
                /call GiveListIniValueMatchesChar "${iniLookup}" "${charName}"
                /if (${Macro.Return.Equal[TRUE]}) {
                    /varset matched TRUE
                    /if (${giveListParsedQty} > 0 && !${giveLimitLog.Find[|${itemNameUpper}=]}) {
                        /varset giveLimitLog ${giveLimitLog}|${itemNameUpper}=${giveListParsedQty}
                    }
                }
            }

            | Check 2: Give-list prefix/suffix/contains patterns
            /if (!${matched} && ${prefixList.Length}) {
                /call IsGivePrefix "${itemName}"
                /if (${Macro.Return.Equal[TRUE]}) {
                    /call IsGiveExcluded "${itemName}"
                    /if (!${Macro.Return.Equal[TRUE]}) /varset matched TRUE
                }
            }

            | Check 3: Shared wildcards from [Wildcards] section
            /if (!${matched} && ${useWildcards} && ${Defined[wildcardPrefixes]} && ${wildcardPrefixes.Length}) {
                /call IsWildcardItem "${itemName}"
                /if (${Macro.Return.Equal[TRUE]}) {
                    /call IsGiveExcluded "${itemName}"
                    /if (!${Macro.Return.Equal[TRUE]}) /varset matched TRUE
                }
            }

            | Cache the result (uppercased for case-insensitive matching)
            /if (!${matched}) {
                /if (${noMatchCache.Length} > 2000) /varset noMatchCache |
                /varset noMatchCache ${noMatchCache}${itemNameUpper}|
                /continue
            }

            | Cache as matched for future stacks of the same item
            /if (${matchCache.Length} > 2000) /varset matchCache |
            /varset matchCache ${matchCache}${itemNameUpper}|

            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Match: ${itemName} -> ${charName}"

:doTrade
            | ---- Quantity limit check (total items, not per-name) ----
            /if (${_giveLimit} > 0 && ${itemsGiven} >= ${_giveLimit}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Give limit reached (${itemsGiven}/${_giveLimit}), stopping"
                /goto :abortGive
            }

            | ---- Per-item cap from [GiveList] exact line (CharName N) ----
            /varset itemQLimit 0
            /varset itemQTally 0
            /call GiveLimitMapGet "${giveLimitLog}" "${itemNameUpper}"
            /varset itemQLimit ${Macro.Return}
            /call GiveLimitMapGet "${giveTallyQtyMap}" "${itemNameUpper}"
            /varset itemQTally ${Macro.Return}
            /varcalc itemQRemain ${itemQLimit}-${itemQTally}
            /if (${itemQLimit} > 0 && ${itemQTally} >= ${itemQLimit}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] GiveList max (${itemQTally}/${itemQLimit}) for ${itemName} — skipping"
                /continue
            }
            /varset itemQWant ${itemQRemain}

            | ---- Found a match — pick it up and trade it ----

            | Make sure target is still valid
            /if (!${Target.ID} || !${Target.CleanName.Equal[${charName}]}) {
                /target pc ${charName}
                /delay 5 ${Target.ID} && ${Target.CleanName.Equal[${charName}]}
                /if (!${Target.ID} || !${Target.CleanName.Equal[${charName}]}) {
                    /target ${charName}
                    /delay 5 ${Target.ID} && ${Target.CleanName.Equal[${charName}]}
                }
                /if (!${Target.ID}) {
                    /echo ${tgTag} \arLost target ${charName} during trade. Aborting.
                    /goto :abortGive
                }
            }

            | Clear cursor if something is on it (TurboLoot IW_CharacterView method)
            /if (${Cursor.ID}) {
                /if (!${Window[InventoryWindow].Open}) /keypress i
                /delay 5 ${Window[InventoryWindow].Open}
                /if (${Window[InventoryWindow].Open}) {
                    /notify InventoryWindow IW_CharacterView leftmouseup
                    /delay 5 !${Cursor.ID}
                }
                /if (${Cursor.ID}) {
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                }
                /if (${Cursor.ID}) /continue
            }

            /varset giveQtyPicked 0

            | Exact GiveList caps for stackables should pick only the remaining units,
            | not dump the whole stack into trade. If fewer than requested remain,
            | give the remainder instead of skipping the recipient.
            /if (${itemQLimit} > 0 && ${itemQRemain} > 0 && ${Me.Inventory[pack${packNum}].Item[${slotNum}].Stackable}) {
                /call CountInventoryItemUnits "${itemName}"
                /varset itemQAvail ${Macro.Return}
                /if (${itemQAvail} < ${itemQWant}) /varset itemQWant ${itemQAvail}
                /if (${itemQWant} <= 0) /continue

                /call PickupMultiStack "${itemName}" ${itemQWant}
                /if (!${Macro.Return.Equal[TRUE]}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Partial pickup failed for ${itemName} (${itemQWant} wanted, ${itemQAvail} available)"
                    /continue
                }
                /if (${Cursor.ID} && ${Cursor.Name.Equal[${itemName}]}) {
                    /varset giveQtyPicked ${Cursor.Stack}
                }
            } else {
                | Pick up the item (shift modifier for trade operations)
                /nomodkey /shift /itemnotify in pack${packNum} ${slotNum} leftmouseup
                /delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}

                | Handle quantity window for stackable items (accept full stack)
                /if (${Window[QuantityWnd].Open}) {
                    /notify QuantityWnd QTYW_Accept_Button leftmouseup
                    /delay 5 !${Window[QuantityWnd].Open}
                    /if (${Window[QuantityWnd].Open}) {
                        /notify QuantityWnd AcceptButton leftmouseup
                        /delay 5 !${Window[QuantityWnd].Open}
                    }
                    /if (${Window[QuantityWnd].Open}) {
                        /keypress ENTER
                        /delay 5 !${Window[QuantityWnd].Open}
                    }
                    /delay 3 ${Cursor.ID}
                }

                | Retry pickup if first attempt failed
                /if (!${Cursor.ID}) {
                    /nomodkey /shift /itemnotify in pack${packNum} ${slotNum} leftmouseup
                    /delay 10 ${Cursor.ID}
                }
            }

            /if (!${Cursor.ID}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Failed to pick up ${itemName} from pack${packNum} ${slotNum}"
                /continue
            }

            | Verify we picked up the right item
            /if (${Cursor.Name.NotEqual[${itemName}]}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Wrong item on cursor: expected ${itemName}, got ${Cursor.Name}"
                /autoinventory
                /delay 5 !${Cursor.ID}
                /continue
            }

            /if (${giveQtyPicked} <= 0) {
                /varset giveQtyPicked ${Cursor.Stack}
                /if (${giveQtyPicked} <= 0) /varset giveQtyPicked 1
            }

            | Place it in the trade window
            | Primary: click target HP bar in target window (reliable with illusions)
            | Secondary: /click left target (standard method)
            /if (!${Window[TradeWnd].Open}) {
                /face fast
                /delay 1
            }
            /notify TargetWindow Target_HP leftmouseup
            /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
            /if (${Cursor.ID} && !${Window[TradeWnd].Open}) {
                | Fallback: try /click left target
                /click left target
                /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
            }

            | If cursor still has item, trade window may not have opened
            /if (${Cursor.ID}) {
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) {
                    /echo ${tgTag} \ayCould not place ${itemName} in trade window. Returning to inventory and continuing.
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) {
                        /call ForceClearCursor
                        /if (${Cursor.ID}) {
                            /echo ${tgTag} \arCursor stuck with ${itemName}. Aborting.
                            /if (${logToFile}) /call LogError "Cursor stuck with ${itemName} during give to ${charName}"
                            /goto :abortGive
                        }
                    }
                    /continue
                }
            }

            /varcalc itemsGiven ${itemsGiven}+${giveQtyPicked}
            /varcalc itemsInBatch ${itemsInBatch}+1
            /if (${itemQLimit} > 0) {
                /call GiveLimitMapAdd "${giveTallyQtyMap}" "${itemNameUpper}" ${giveQtyPicked}
                /varset giveTallyQtyMap ${Macro.Return}
            }

            | Pause target's combat bot when first item goes in (prevents premature auto-accept)
            /if (${itemsInBatch} == 1) {
                /call RemotePauseBot "${charName}"
            }

            /echo ${tgTag} \ag[GIVE]\aw ${itemName} \atto ${charName} \aw(${itemsInBatch}/8 in batch)

            | Trade window holds 8 items — execute trade when full
            /if (${itemsInBatch} >= 8) {
                /call ExecuteTrade "${charName}"
                /varset itemsInBatch 0
                /varcalc tradesCompleted ${tradesCompleted}+1
            }
        /next slotNum
    /next packNum

    | Execute final partial batch if any items are pending
    /if (${itemsInBatch} > 0 && ${Window[TradeWnd].Open}) {
        /call ExecuteTrade "${charName}"
        /varcalc tradesCompleted ${tradesCompleted}+1
    }

    | Summary
    /if (${itemsGiven} > 0) {
        /echo ${tgTag} \agDone!\aw Gave \ag${itemsGiven}\aw item(s) to \ag${charName}\aw in \ag${tradesCompleted}\aw trade(s).
        /call Announce "${announceMethod}" "${tgTag} \agDone!\aw Gave \ag${itemsGiven}\aw item(s) to \ag${charName}\aw in \ag${tradesCompleted}\aw trade(s)."
    } else {
        /if (!${isBatch}) {
            /echo ${tgTag} \awNo matching items found for \ag${charName}\aw.
        }
    }

    /goto :cleanupGive

:abortGive
    /echo ${tgTag} \arGive aborted. Gave \ag${itemsGiven}\aw item(s) before stopping.
    /if (${Window[TradeWnd].Open}) {
        /notify TradeWnd TRDW_Cancel_Button leftmouseup
        /delay 10 !${Window[TradeWnd].Open}
    }

:cleanupGive
    | v1.8.5: DONE signal fires here, from the single unified exit path.
    | Every exit from GiveToTarget — success, abort, or early-return — reaches
    | this block, so the collector never hangs 60s waiting on a bot that
    | bailed early. Safe even when ${charName}==${Me.Name}: no collector is
    | waiting on a self-targeted run.
    | Use e3bc broadcast (reliable) + e3bct (targeted) for redundancy.
    /squelch /e3bc /echo ${tgTag} \ar[DONE]\aw ${Me.Name}->${charName}
    /squelch /e3bct ${charName} /echo ${tgTag} \ar[SIGNAL_DONE]\aw ${Me.Name}

    /if (${Cursor.ID}) {
        /if (!${Window[InventoryWindow].Open}) /keypress i
        /delay 5 ${Window[InventoryWindow].Open}
        /if (${Window[InventoryWindow].Open}) {
            /notify InventoryWindow IW_CharacterView leftmouseup
            /delay 5 !${Cursor.ID}
        }
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
        }
    }
    | Close bag windows
    /call CloseBags
    | Restore follow — only restore self if not in batch mode (DeliverAll handles it)
    /if (!${isBatch}) {
        /if (${wasFollowing}) /squelch /afollow unpause
    }
    | Always restore target's combat bot and follow
    /call RemoteResumeBot "${charName}"
    /squelch /e3bct ${charName} /squelch /afollow unpause
/return

| =====================================================================
| LOAD PREFIXES FOR CHARACTER
| Reads _prefix1 through _prefix30 from [GiveList] and extracts
| patterns belonging to the specified character.
| Format: _prefix1=CharName:Spell:*   _prefix2=CharName:*Oleander
| Populates prefixList with encoded entries:
|   |P6:SPELL:||S8:OLEANDER||C10:DISTILLATE|
|   P = prefix (starts with), S = suffix (ends with), C = contains
| =====================================================================
Sub LoadPrefixesForChar(string charName)
    /declare idx int local
    /declare entry string local
    /declare colonPos int local 0
    /declare entryChar string local
    /declare entryPattern string local
    /declare patternText string local
    /declare patternLen int local
    /declare patternType string local
    /declare startsWithStar bool local FALSE
    /declare endsWithStar bool local FALSE

    /for idx 1 to 30
        /varset entry ${Ini[${iniFile},GiveList,_prefix${idx}]}
        /if (!${entry.Length} || ${entry.Equal[NULL]}) /continue

        | Format is CharName:Pattern — find the FIRST colon to split
        /varset colonPos ${entry.Find[:]}
        /if (!${colonPos}) /continue

        /varset entryChar ${entry.Left[${Math.Calc[${colonPos}-1]}]}
        /varset entryPattern ${entry.Mid[${Math.Calc[${colonPos}+1]},500]}

        | Check if this entry is for our target character (case-insensitive)
        /if (!${entryChar.Upper.Equal[${charName.Upper}]}) /continue

        /if (!${entryPattern.Length}) /continue

        | Detect pattern type based on * position
        /varset startsWithStar FALSE
        /varset endsWithStar FALSE
        /if (${entryPattern.Left[1].Equal[*]}) /varset startsWithStar TRUE
        /if (${entryPattern.Right[1].Equal[*]}) /varset endsWithStar TRUE

        /if (${startsWithStar} && ${endsWithStar}) {
            | *text* = contains match
            /varset patternType C
            /varset patternText ${entryPattern.Left[-1]}
            /varset patternText ${patternText.Right[-1]}
        } else /if (${startsWithStar}) {
            | *text = suffix match
            /varset patternType S
            /varset patternText ${entryPattern.Right[-1]}
        } else /if (${endsWithStar}) {
            | text* = prefix match
            /varset patternType P
            /varset patternText ${entryPattern.Left[-1]}
        } else {
            | No * at all — skip
            /continue
        }

        /if (!${patternText.Length}) /continue

        /varset patternLen ${patternText.Length}
        /varset prefixList ${prefixList}|${patternType}${patternLen}:${patternText.Upper}
        /if (${showDebug} || ${logToFile}) {
            /if (${patternType.Equal[P]}) {
                /call LogDebug "[turboGive] Pattern _prefix${idx} for ${charName}: STARTS WITH [${patternText}] (${patternLen} chars)"
            } else /if (${patternType.Equal[S]}) {
                /call LogDebug "[turboGive] Pattern _prefix${idx} for ${charName}: ENDS WITH [${patternText}] (${patternLen} chars)"
            } else {
                /call LogDebug "[turboGive] Pattern _prefix${idx} for ${charName}: CONTAINS [${patternText}] (${patternLen} chars)"
            }
        }
    /next idx

    /if (${prefixList.Length}) /varset prefixList ${prefixList}|
/return

| =====================================================================
| EXECUTE TRADE (click trade, tell target to click, wait for completion)
| =====================================================================
Sub ExecuteTrade(string tradeName)
    /if (!${Window[TradeWnd].Open}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Trade window not open - nothing to execute"
        /return
    }

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Clicking Trade button..."

    | We click Trade first
    /notify TradeWnd TRDW_Trade_Button leftmouseup
    /delay 1

    | Tell the target to click Trade (with small delay so their window is ready)
    /squelch /e3bct ${tradeName} /timed 2 /notify TradeWnd TRDW_Trade_Button leftmouseup

    | Wait for trade window to close (means both sides clicked)
    /declare tradeWait int local 0
    /while (${Window[TradeWnd].Open} && ${tradeWait} < 100) {
        /doevents
        /delay 1
        /varcalc tradeWait ${tradeWait}+1

        | Retry click every 2 seconds in case it didn't register
        /if (${Math.Calc[${tradeWait} % 20]} == 0) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Trade still pending, re-clicking..."
            /notify TradeWnd TRDW_Trade_Button leftmouseup
            /squelch /e3bct ${tradeName} /timed 2 /notify TradeWnd TRDW_Trade_Button leftmouseup
        }
    }

    /if (${Window[TradeWnd].Open}) {
        /echo ${tgTag} \arTrade timed out after 10 seconds. Cancelling.
        /if (${logToFile}) /call LogError "Trade timed out after 10 seconds"
        /notify TradeWnd TRDW_Cancel_Button leftmouseup
        /delay 10 !${Window[TradeWnd].Open}
        /if (${Cursor.ID}) /call ForceClearCursor
    } else {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Trade completed successfully"
    }

    | Unpause target's combat bot now that trade is done
    /call RemoteResumeBot "${tradeName}"

    | Brief pause to let game state settle before next batch
    /delay 1
/return

| =====================================================================
| COLLECT FROM GROUP
| =====================================================================
Sub CollectFromGroup(string scopeArg)
    /declare scope string local ${scopeArg.Upper.Replace[ ,]}
    /if (!${Defined[charDone]}) {
        /declare charDone bool outer FALSE
    } else {
        /varset charDone FALSE
    }
    /if (!${Defined[charDoneSender]}) {
        /declare charDoneSender string outer
    } else {
        /varset charDoneSender
    }
    /declare myName string local ${Me.Name}

    /echo ${tgTag} \awCollecting items from ${If[${scope.Equal[ALL]} || ${scope.Equal[RAID]},all e3 bots,group members]}...

    | Check feign death
    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned.
        /return
    }

    | Pause E3 logic and follow
    /declare wasFollowing bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowing TRUE
        /squelch /afollow pause
    }

    /declare memberName string local
    /declare memberIdx int local
    /declare membersAsked int local 0

    /if (!${scope.Length} || ${scope.Equal[NULL]} || ${scope.Equal[GROUP]}) {
        | ---- Group mode ----
        /for memberIdx 1 to ${Group.Members}
            /varset memberName ${Group.Member[${memberIdx}].Name}
            /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
            /if (${memberName.Equal[${myName}]}) {
                /continue
            }
            /if (!${Spawn[pc ${memberName}].ID}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Skipping ${memberName} - not in zone"
                /continue
            }

            /call AskForItems "${memberName}"
            /varcalc membersAsked ${membersAsked}+1
        /next memberIdx

    } else /if (${scope.Equal[ALL]} || ${scope.Equal[RAID]} || ${scope.Equal[E3BOTS]} || ${scope.Equal[BOTS]}) {
        | ---- E3 bots mode ----
        /declare clientList string local ${MQ2Mono.Query[e3,E3Bots.ConnectedClients]}
        /if (!${clientList.Length} || ${clientList.Equal[NULL]}) {
            /echo ${tgTag} \arNo connected E3 bots found.
            /if (${wasFollowing}) /squelch /afollow unpause
            /return
        }

        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Connected e3 bots: ${clientList}"

        | Parse comma-delimited client list
        /declare clientRemaining string local ${clientList}
        /declare commaPos int local 0
        /declare botName string local

:nextBot
        /if (!${clientRemaining.Length}) /goto :doneCollecting

        /varset commaPos ${clientRemaining.Find[,]}
        /if (${commaPos}) {
            /varset botName ${clientRemaining.Left[${Math.Calc[${commaPos}-1]}]}
            /varset clientRemaining ${clientRemaining.Mid[${Math.Calc[${commaPos}+1]},2048]}
        } else {
            /varset botName ${clientRemaining}
            /varset clientRemaining
        }

        /if (!${botName.Length}) /goto :nextBot
        /if (${botName.Equal[${myName}]}) /goto :nextBot
        /if (!${Spawn[pc ${botName}].ID}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Skipping ${botName} - not in zone"
            /goto :nextBot
        }

        /call AskForItems "${botName}"
        /varcalc membersAsked ${membersAsked}+1
        /goto :nextBot
    }

:doneCollecting
    /echo ${tgTag} \agCollection complete.\aw Asked \ag${membersAsked}\aw character(s).
    /if (${wasFollowing}) /squelch /afollow unpause
/return

| =====================================================================
| ASK FOR ITEMS (tell a character to run TurboGive to give us stuff)
| =====================================================================
Sub AskForItems(string senderName)
    /echo ${tgTag} \awAsking \ag${senderName}\aw to send items...

    /varset charDone FALSE
    /varset charDoneSender

    | Tell the sender to run TurboGive targeting us
    /squelch /e3bct ${senderName} /mac turbogive ${Me.Name}

    | Wait for the specific sender we just asked. A late DONE from the previous
    | sender must not release this wait early, or the next bot will try to trade
    | while the prior trade is still settling.
    /declare waitTicks int local 0
    /declare maxWait int local 600
    /declare settleTicks int local 0

    /while (( !${charDone} || ${charDoneSender.NotEqual[${senderName}]} ) && ${waitTicks} < ${maxWait}) {
        /doevents
        /delay 1
        /varcalc waitTicks ${waitTicks}+1

        | Heartbeat every 100 ticks (10s) so tester sees we're alive but waiting

        | If trade window opens, accept it
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Trade_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
    }

    /if (!${charDone} || ${charDoneSender.NotEqual[${senderName}]}) {
        /echo ${tgTag} \ayTimed out waiting for \ag${senderName}\ay (60s). Moving on.
    } else {
        | Give EQ a short settle window before asking the next sender. This
        | prevents "I'm busy right now" races when the prior trade just closed.
        /while (${Window[TradeWnd].Open} && ${settleTicks} < 50) {
            /doevents
            /delay 1
            /varcalc settleTicks ${settleTicks}+1
        }
        /delay 5
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] ${senderName} finished sending items"
    }
/return

| =====================================================================
| ADD ITEM TO GIVE LIST
| =====================================================================
Sub AddItemToGiveList(string targetName)
    /declare charName string local ${targetName}
    /declare cursorItem string local ${Cursor.Name}

    /if (!${Cursor.ID} || !${cursorItem.Length} || ${cursorItem.Equal[NULL]}) {
        /echo ${tgTag} \arNo item on cursor. Pick up an item first.
        /return
    }

    | Hard-block (1.8.9): refuse to add always-skip items to [GiveList]
    | so the user doesn't end up with a misleading INI entry that does
    | nothing (the give-time check would block it anyway). Returns the
    | item to inventory before bailing so the cursor isn't left holding.
    /call IsHardBlocked "${cursorItem}"
    /if (${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[ADD]\aw Refusing to add \ay${cursorItem}\aw - this item is on TurboGive's hardcoded always-skip list. It will never auto-give regardless of [GiveList] entries.\ax
        /autoinventory
        /delay 5 !${Cursor.ID}
        /return
    }

    | Check if this item already has a give-list entry
    /declare existing string local ${Ini[${iniFile},GiveList,${cursorItem}]}
    /if (${existing.Length} && !${existing.Equal[NULL]}) {
        /call GiveListIniValueMatchesChar "${existing}" "${charName}"
        /if (${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ay${cursorItem}\aw is already assigned to \ag${charName}\aw.
        } else {
            | Overwrite — item reassigned to new character
            /ini "${iniFile}" "GiveList" "${cursorItem}" "${charName}"
            /echo ${tgTag} \agUpdated\aw ${cursorItem}: \ay${existing}\aw -> \ag${charName}
        }
    } else {
        | New entry
        /ini "${iniFile}" "GiveList" "${cursorItem}" "${charName}"
        /echo ${tgTag} \agAdded\aw ${cursorItem} = \ag${charName}\aw to [GiveList].
    }

    | Return item to inventory
    /autoinventory
    /delay 5 !${Cursor.ID}
/return

| =====================================================================
| PRINT GIVE LIST
| Shows prefix rules, wildcard status, and exact-match items in bags
| for a character. Since we can't enumerate INI keys, exact items are
| shown by scanning inventory and checking each item via INI lookup.
| =====================================================================
Sub PrintGiveList(string targetName)
    /declare charName string local ${targetName}
    /declare itemNum int local 0

    /call Announce "${announceMethod}" "${tgTag} \ag${charName}\aw's give-list:"

    | Show prefix/pattern rules for this character from _prefix1 through _prefix30
    /declare pIdx int local
    /declare pVal string local
    /declare pColonPos int local 0
    /declare pChar string local
    /declare pPattern string local

    /for pIdx 1 to 30
        /varset pVal ${Ini[${iniFile},GiveList,_prefix${pIdx}]}
        /if (!${pVal.Length} || ${pVal.Equal[NULL]}) /continue

        /varset pColonPos ${pVal.Find[:]}
        /if (!${pColonPos}) /continue
        /varset pChar ${pVal.Left[${Math.Calc[${pColonPos}-1]}]}
        /varset pPattern ${pVal.Mid[${Math.Calc[${pColonPos}+1]},500]}

        /if (${pChar.Upper.Equal[${charName.Upper}]}) {
            /varcalc itemNum ${itemNum}+1
            | Detect pattern type for display
            /if (${pPattern.Left[1].Equal[*]} && ${pPattern.Right[1].Equal[*]}) {
                /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \ao[CONTAINS]\aw ${pPattern}"
            } else /if (${pPattern.Left[1].Equal[*]}) {
                /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \ao[ENDS WITH]\aw ${pPattern}"
            } else /if (${pPattern.Right[1].Equal[*]}) {
                /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \ao[STARTS WITH]\aw ${pPattern}"
            } else {
                /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \ao[PATTERN]\aw ${pPattern}"
            }
        }
    /next pIdx

    | Show wildcard status for this character
    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /declare wcSearch string local |${wildcardsRaw.Upper}|
        /if (${wcSearch.Find[|${charName.Upper}|]}) {
            /varcalc itemNum ${itemNum}+1
            /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \ag[WILDCARDS]\aw - all shared [Wildcards] rules (Spell:, Song:, Tome, etc.)"
        }
    }

    | Scan inventory for exact-match items assigned to this character
    /declare packNum int local
    /declare slotNum int local
    /declare maxSlots int local
    /declare itemName string local
    /declare iniLookup string local
    /declare shownItems string local |
    /declare invCount int local 0

    /for packNum 1 to 10
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} == 0) /continue
        /for slotNum 1 to ${maxSlots}
            /if (!${Me.Inventory[pack${packNum}].Item[${slotNum}].ID}) /continue
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue

            | Skip items we've already listed (dedup for stacks across slots)
            /if (${shownItems.Find[|${itemName}|]}) /continue

            | Direct INI lookup
            /varset iniLookup ${Ini[${iniFile},GiveList,${itemName}]}
            /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
                /varset iniLookup ${Ini[${iniFile},GiveList,${itemName.Upper}]}
            }
            /if (!${iniLookup.Length} || ${iniLookup.Equal[NULL]}) {
                /varset iniLookup ${Ini[${iniFile},GiveList,${itemName.Lower}]}
            }

            /if (${iniLookup.Length} && !${iniLookup.Equal[NULL]}) {
                /call GiveListIniValueMatchesChar "${iniLookup}" "${charName}"
                /if (${Macro.Return.Equal[TRUE]}) {
                    /varcalc itemNum ${itemNum}+1
                    /varset invCount ${FindItemCount[=${itemName}]}
                    /if (${giveListParsedQty} > 0) {
                        /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \at${itemName} \aw(${invCount} in bags, max \ag${giveListParsedQty}\aw per give)"
                    } else {
                        /call Announce "${announceMethod}" "${tgTag}   \aw${itemNum}. \at${itemName} \aw(${invCount} in my bags)"
                    }
                    /varset shownItems ${shownItems}${itemName}|
                }
            }
        /next slotNum
    /next packNum

    /if (${itemNum} == 0) {
        /call Announce "${announceMethod}" "${tgTag}   \aw(no matching items or rules found)"
    }
/return

| =====================================================================
| PRINT STATUS — show configuration, recipients, and item counts
| =====================================================================
Sub PrintStatus
    /echo ${tgTag} \au==== \agSTATUS \au====\ax

    | INI file
    /echo ${tgTag} \awINI: \ag${iniFile}\ax

    | Count exact items
    /declare keyIdx int local
    /declare keyName string local
    /declare keyVal string local
    /declare exactCount int local 0
    /declare recipients string local |

    /for keyIdx 1 to 200
        /varset keyName ${Ini[${iniFile},GiveList].Arg[${keyIdx},|]}
        /if (!${keyName.Length} || ${keyName.Equal[NULL]}) /break
        /if (${keyName.Left[1].Equal[_]}) /continue
        /varcalc exactCount ${exactCount}+1
        /varset keyVal ${Ini[${iniFile},GiveList,${keyName}]}
        /if (!${keyVal.Length} || ${keyVal.Equal[NULL]}) /continue
        /if (${keyVal.Find[*]} || ${keyVal.Find[:]}) /continue
        /call ParseGiveListIniValue "${keyVal}"
        /if (!${giveListParsedName.Length}) /continue
        /if (!${recipients.Find[|${giveListParsedName}|]}) {
            /varset recipients ${recipients}${giveListParsedName}|
        }
    /next keyIdx

    /echo ${tgTag} \awExact items: \ag${exactCount}\ax

    | Count prefix patterns
    /declare prefixCount int local 0
    /declare pIdx int local
    /declare pVal string local
    /declare pColonPos int local
    /declare pChar string local

    /for pIdx 1 to 30
        /varset pVal ${Ini[${iniFile},GiveList,_prefix${pIdx}]}
        /if (!${pVal.Length} || ${pVal.Equal[NULL]}) /continue
        /varcalc prefixCount ${prefixCount}+1
        /varset pColonPos ${pVal.Find[:]}
        /if (${pColonPos}) {
            /varset pChar ${pVal.Left[${Math.Calc[${pColonPos}-1]}]}
            /if (${pChar.Length} && !${recipients.Find[|${pChar}|]}) {
                /varset recipients ${recipients}${pChar}|
            }
        }
    /next pIdx

    /echo ${tgTag} \awPrefix patterns: \ag${prefixCount}\ax

    | Wildcards
    /declare wildcardsRaw string local ${Ini[${iniFile},GiveList,_wildcards]}
    /if (${wildcardsRaw.Length} && !${wildcardsRaw.Equal[NULL]}) {
        /echo ${tgTag} \awWildcard recipients: \ag${wildcardsRaw}\ax

        | Add wildcard chars to recipients
        /declare wRemaining string local ${wildcardsRaw}
        /declare wPipePos int local
        /declare wChar string local
        /while (${wRemaining.Length}) {
            /varset wPipePos ${wRemaining.Find[|]}
            /if (${wPipePos}) {
                /varset wChar ${wRemaining.Left[${Math.Calc[${wPipePos}-1]}]}
                /varset wRemaining ${wRemaining.Mid[${Math.Calc[${wPipePos}+1]},2048]}
            } else {
                /varset wChar ${wRemaining}
                /varset wRemaining
            }
            /if (${wChar.Length} && !${recipients.Find[|${wChar}|]}) {
                /varset recipients ${recipients}${wChar}|
            }
        }

        | Count active wildcards from [Wildcards] section
        /declare wcActive int local 0
        /declare wcVal string local
        /declare wcUpper string local
        /varset wcVal ${Ini[${iniFile},Wildcards,Spell:]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) { /varset wcUpper ${wcVal.Upper.Replace[ ,]}
            /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]}) /varcalc wcActive ${wcActive}+1
        }
        /varset wcVal ${Ini[${iniFile},Wildcards,Skill:]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) { /varset wcUpper ${wcVal.Upper.Replace[ ,]}
            /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]}) /varcalc wcActive ${wcActive}+1
        }
        /varset wcVal ${Ini[${iniFile},Wildcards,Song:]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) { /varset wcUpper ${wcVal.Upper.Replace[ ,]}
            /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]}) /varcalc wcActive ${wcActive}+1
        }
        /varset wcVal ${Ini[${iniFile},Wildcards,Tome ]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) { /varset wcUpper ${wcVal.Upper.Replace[ ,]}
            /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]}) /varcalc wcActive ${wcActive}+1
        }
        /varset wcVal ${Ini[${iniFile},Wildcards,Tome of ]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) { /varset wcUpper ${wcVal.Upper.Replace[ ,]}
            /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]}) /varcalc wcActive ${wcActive}+1
        }
        /echo ${tgTag} \awActive [Wildcards] rules: \ag${wcActive}\ax
    } else {
        /echo ${tgTag} \awWildcards: \ayNone\ax
    }

    /declare excludeRaw string local ${Ini[${iniFile},GiveExclude,_list]}
    /if (${excludeRaw.Length} && !${excludeRaw.Equal[NULL]}) {
        /echo ${tgTag} \aw[GiveExclude] _list: \ag${excludeRaw}\ax
    }

    | List all recipients and zone status
    /echo ${tgTag} \au---- \agRECIPIENTS \au----\ax
    /declare remaining string local ${recipients.Right[-1]}
    /if (${remaining.Left[1].Equal[|]}) /varset remaining ${remaining.Right[-1]}
    /declare pipePos int local
    /declare recipName string local
    /declare recipCount int local 0
    /declare inZoneCount int local 0
    /declare inGroupCount int local 0
    /declare gIdx int local
    /declare inZone bool local FALSE
    /declare inGroup bool local FALSE

    /while (${remaining.Length}) {
        /varset pipePos ${remaining.Find[|]}
        /if (${pipePos}) {
            /varset recipName ${remaining.Left[${Math.Calc[${pipePos}-1]}]}
            /varset remaining ${remaining.Mid[${Math.Calc[${pipePos}+1]},2048]}
        } else {
            /varset recipName ${remaining}
            /varset remaining
        }
        /if (!${recipName.Length}) /continue
        /varcalc recipCount ${recipCount}+1

        /varset inZone FALSE
        /varset inGroup FALSE
        /if (${SpawnCount[pc ${recipName}]} || ${Spawn[${recipName}].ID}) /varset inZone TRUE
        /if (${inZone}) /varcalc inZoneCount ${inZoneCount}+1
        /for gIdx 1 to ${Group.Members}
            /if (${Group.Member[${gIdx}].Name.Equal[${recipName}]}) {
                /varset inGroup TRUE
                /varcalc inGroupCount ${inGroupCount}+1
                /break
            }
        /next gIdx

        /if (${recipName.Equal[${Me.Name}]}) {
            /echo ${tgTag}   \ag${recipName}\aw (me)
        } else /if (${inGroup}) {
            /echo ${tgTag}   \ag${recipName}\aw (in group, in zone)
        } else /if (${inZone}) {
            /echo ${tgTag}   \ay${recipName}\aw (in zone, not in group)
        } else {
            /echo ${tgTag}   \ar${recipName}\aw (not in zone)
        }
    }

    /echo ${tgTag} \awTotal recipients: \ag${recipCount}\aw | In zone: \ag${inZoneCount}\aw | In group: \ag${inGroupCount}\ax
    /echo ${tgTag} \au========================\ax
/return

| =====================================================================
| PRINT HELP
| =====================================================================
Sub PrintHelp
    | Colors align with TurboLoot/Turbo.mac: \at section dividers, \ag commands, \au banners, \ao collect, \ap bank, \ay handin/setup
    /echo \au<<< \ar--------------- \atTurboGive Commands \ar--------------- \au>>>\ax
    /echo \awVersion: \ag1.9.5\aw  Purpose: item and currency sharing between characters\ax
    /echo \aw \ax
    /echo \at==== \aySUITE MAP \at====\ax
    /echo \aw  \agTurboGive.mac\ax — share/collect/hand items and coin between characters\ax
    /echo \aw  \agTurboLoot.mac\ax — loot/sell/bank/tribute/destroy by INI rules\ax
    /echo \aw  \ag/lua run Turbo\ax — auto-loot controller and looter picker\ax
    /echo \aw  \agTurboKey.mac\ax — tag cursor item into turboloot.ini\ax
    /echo \aw \ax
    /echo \at==== \ayGETTING STARTED \at====\ax
    /echo \aw  1) Add items: target a PC, pick up item, \ag/mac turbogive add\ax \aw(or \agadd target\ax)\ax
    /echo \aw  2) Distribute: \ag/mac turbogive\ax \aw(gives to group; each bot also gives theirs)\ax
    /echo \aw \ax
    /echo \at==== \ayDISTRIBUTE \at====\ax
    /echo \aw    \ag/mac turbogive\ax — default: you + each bot gives theirs\ax
    /echo \aw    \ag/mac turbogive solo\ax — only you give to group, no broadcast\ax
    /echo \aw    \ag/mac turbogive solo all\ax — only you give to all in zone, no broadcast\ax
    /echo \aw    \ag/mac turbogive all\ax — you + each e3 bot gives to all\ax
    /echo \aw    \ag/mac turbogive \atCHARNAME\ax — give my items to one character\ax
    /echo \aw    \ag/mac turbogive tell \atCHARNAME\ax — tell CHARNAME to give their items (single bot)\ax
    /echo \aw \ax
    /echo \at==== \ayHAND OUT \at====\ax
    /echo \aw    \ag/mac turbogive hand \atCOUNT\ax — pick up item, give COUNT to each\ax
    /echo \aw    \ag/mac turbogive hand \atCOUNT ItemName\ax — give COUNT of named item to each\ax
    /echo \aw    \ag/mac turbogive hand \atCOUNT ItemName\ax \ag all\ax — same, all e3 bots in zone\ax
    /echo \aw    \ag/mac turbogive hand tell \atCHARNAME COUNT ItemName\ax \aw[\agall\aw]\ax
    /echo \aw      tell CHARNAME to hand out from their inventory\ax
    /echo \aw \ax
    /echo \at==== \ayCOLLECT \at====\ax
    /echo \aw    \ao/mac turbogive collect\ax — group sends you your items\ax
    /echo \aw    \ao/mac turbogive collect all\ax \aw(or \aocollect raid\ax)\ax — all e3 bots send you your items\ax
    /echo \aw    \ao/mac turbogive collect tell \atCHARNAME\ax \aw[\agall\aw]\ax
    /echo \aw      tell CHARNAME to collect from their group (or all)\ax
    /echo \aw \ax
    /echo \at==== \ayBANK \at====\ax
    /echo \aw    \apbank\ax \aw or \apbank all\ax — tell others to pull (runner does not)\ax
    /echo \aw    \ap/mac turbogive bank solo\ax — I pull my own items from my bank\ax
    /echo \aw    \ap/mac turbogive bank pull\ax — I pull my bank for others (items assigned to them)\ax
    /echo \aw    \ap/mac turbogive bank \atCHARNAME\ax — I pull CHARNAME's items from my bank to my bags\ax
    /echo \aw    \ap/mac turbogive bank tell \atCHARNAME\ax — tell CHARNAME to pull their own items from their bank\ax
    /echo \aw \ax
    /echo \at==== \ayCASH / DC / CONVERT \at====\ax
    /echo \aw    \ao/mac turbogive collect cash\ax \aw[\atamount\aw] [\agall\aw]\ax
    /echo \aw      collect plat from group (omit or \at0\aw = \atall\aw plat + gp/sp/cp; aliases: \aoplat\ax, \aopp\ax)\ax
    /echo \aw    \ao/mac turbogive collect dc\ax \aw[\atamount\aw] [\agall\aw]\ax — collect Diamond Coin from group\ax
    /echo \aw    \ag/mac turbogive \atCHARNAME\ax \agcash\ax \aw[\atamount\aw]\ax
    /echo \aw      give plat to CHARNAME (omit or \at0\aw = \atall\aw plat + gp/sp/cp)\ax
    /echo \aw    \ag/mac turbogive \atCHARNAME\ax \agdc\ax \aw[\atamount\aw]\ax — give your DC to CHARNAME\ax
    /echo \aw    \am/mac turbogive convert aa\ax \aw[\atamount\aw]\ax — convert AA to DC at NPC (PoK/Marr)\ax
    /echo \aw    \am/mac turbogive convert dc\ax \aw[\atamount\aw]\ax — convert DC to AA at NPC\ax
    /echo \aw    \am/mac turbogive convert exchange\ax — alt-currency DC to inventory DC\ax
    /echo \aw    \am/mac turbogive convert all\ax — convert my AA -> DC + broadcast group\ax
    /echo \aw    \am/mac turbogive convert dc all\ax — convert my DC -> AA + broadcast group\ax
    /echo \aw \ax
    /echo \at==== \ayNPC HAND-IN \at====\ax
    /echo \aw    \ay/mac turbogive handin \at"Item Name"\ax \aw[\at#\aw] [\ardestroy\aw]\ax
    /echo \aw      hand item to targeted NPC (all or # qty)\ax
    /echo \aw    \ay/mac turbogive handin \atpp\ax|\atgp\ax|\atsp\ax|\atcp\ax \at#\ax — hand coin to targeted NPC\ax
    /echo \aw    \ay/mac turbogive handin tell \atCHARNAME \at"Item" \aw[\at#\aw] [\ardestroy\aw]\ax
    /echo \aw      tell bot to hand in to their target\ax
    /echo \aw \ax
    /echo \at==== \ayQUANTITY LIMITS \at====\ax
    /echo \aw    \ag/mac turbogive \atCHARNAME \at5\ax — give up to 5 total items\ax
    /echo \aw    \ao/mac turbogive collect \at5\ax — collect up to 5 total items\ax
    /echo \aw \ax
    /echo \at==== \aySETUP \at====\ax
    /echo \aw    \ayadd \atCHARNAME\ax \aw(or \ayadd target\ax) — add cursor item to character's list\ax
    /echo \aw    \aylist\ax \aw or \aylist \atCHARNAME\ax \aw or \aylist target\ax
    /echo \aw      show give-list (mine, named char, or target's)\ax
    /echo \aw    \aystatus\ax — config, recipients, zone\ax
    /echo \aw \ax
    /echo \at==== \ayINI FORMAT \at====\ax
    /echo \aw  \ag[GiveList]\ax \aw in turboloot.ini:\ax
    /echo \aw    \agItemName=\atCharName\ax \aw(exact, give all stacks / copies)\ax
    /echo \aw    \agItemName=\atCharName 5\ax \aw(exact, give up to 5 total units)\ax
    /echo \aw    \agItemName=\atCharName \atN\ax \aw(max \atN\aw pickups of that item this run; \atN\aw = positive int)\ax
    /echo \aw    \agItemName=\atBob \at10\ax\ag|\atJohn \at10\ax\ag|\atSally \at10\ax \aw(\au1.9.0\aw multi-recipient: give up to 10 each, every run)\ax
    /echo \aw      Pipes split recipients; each token is the same \atCharName N\aw form. Whitespace around \ag|\aw is OK.\ax
    /echo \aw      Always-give to each named recipient up to their cap, every \ag/turbogive\aw run. Existing per-run tally still applies.\ax
    /echo \aw      \au1.9.1:\aw Multi-recipient entries distribute from the \auoriginating character only\aw under \ag/turbogive\aw and \ag/turbogive all\aw.\ax
    /echo \aw      Bots receiving the broadcast skip multi-recipient rules to prevent trade collisions. Single-recipient rules still flow through bots normally.\ax
    /echo \aw    \ag_prefix1=\atCharName\ax\ag:Spell:*\ax \aw(starts with)\ax
    /echo \aw    \ag_prefix2=\atCharName\ax\ag:*Suffix\ax \aw(ends with)\ax
    /echo \aw    \ag_wildcards=\atCharName\ax\ag|\atOtherChar\ax \aw([Wildcards])\ax
    /echo \aw  \ag[GiveExclude]\ax \ag_list=\atName\ax\ag,\atName\ax \aw(exclude from prefix/wildcard only)\ax
    /echo \aw  \arHARD-BLOCK:\ax \awTome of Nife's Mercy is hardcoded as always-skip (auto-give, collect, bank-pull, and handin all refuse).\ax
    /echo \aw \ax
    /echo \aw  \aohttps://github.com/drel-git/TurboLoot\ax
/return

| =====================================================================
| EVENT HANDLERS
| =====================================================================
Sub Event_CharDone(string line, string charName)
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Received 'done' signal (e3bct) from ${charName}"
    /if (${Defined[_bankBroadcastMode]} && ${_bankBroadcastMode}) {
        | Bank broadcast mode: count unique senders, set charDone when all received
        /if (!${_bankReceivedFrom.Find[|${charName}|]}) {
            /varset _bankReceivedFrom ${_bankReceivedFrom}${charName}|
            /varcalc _bankReceivedCount ${_bankReceivedCount}+1
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Bank DONE from ${charName} (${_bankReceivedCount}/${_bankExpectedDone})"
            /if (${_bankReceivedCount} >= ${_bankExpectedDone}) /varset charDone TRUE
        }
    } else {
        /if (${Defined[charDoneSender]}) /varset charDoneSender ${charName}
        /if (${Defined[charDone]}) /varset charDone TRUE
    }
/return

Sub Event_CharDoneBC(string line, string senderName, string collectorName)
    | Bank broadcast mode: accept DONE from any sender (orchestrator may not be group leader)
    /if (${Defined[_bankBroadcastMode]} && ${_bankBroadcastMode}) {
        /if (!${_bankReceivedFrom.Find[|${senderName}|]}) {
            /varset _bankReceivedFrom ${_bankReceivedFrom}${senderName}|
            /varcalc _bankReceivedCount ${_bankReceivedCount}+1
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Bank DONE from ${senderName} (${_bankReceivedCount}/${_bankExpectedDone})"
            /if (${_bankReceivedCount} >= ${_bankExpectedDone}) /varset charDone TRUE
        }
        /return
    }
    | Normal mode: process when we are the collector, or when collector is ALL (broadcast to everyone)
    /if (${collectorName.Equal[${Me.Name}]} || ${collectorName.Equal[ALL]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Received 'done' broadcast (e3bc) from ${senderName}"
        /if (${Defined[charDoneSender]}) /varset charDoneSender ${senderName}
        /if (${Defined[charDone]}) /varset charDone TRUE
    } else {
    }
/return

Sub Event_CharDoneTell(string line, string charName)
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Received 'done' tell from ${charName}"
    /if (${Defined[charDoneSender]}) /varset charDoneSender ${charName}
    /if (${Defined[charDone]}) /varset charDone TRUE
/return

Sub Event_TradeCancelled
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Trade was cancelled"
/return

Sub Event_TradeComplete
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Trade completed"
/return

Sub Event_TooFar(string line, string npcName)
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Too far from ${npcName} to trade"
/return

| =====================================================================
| WILDCARD & PREFIX MATCHING
| =====================================================================

| Checks item name against give-list patterns (prefix, suffix, or contains)
| prefixList format: |P6:SPELL:||S8:OLEANDER||C10:DISTILLATE|
|   P = prefix (starts with), S = suffix (ends with), C = contains
Sub IsGivePrefix(string name)
    /if (!${prefixList.Length}) /return FALSE

    /declare u string local ${name.Upper}
    /declare searchPos int local 1
    /declare pipeEnd int local
    /declare gpEntry string local
    /declare gpType string local
    /declare colonPos int local
    /declare gpLen int local
    /declare gpText string local
    /declare gpChunk string local

:nextGivePrefix
    /varset searchPos ${Math.Calc[${searchPos}+1]}
    /if (${searchPos} >= ${prefixList.Length}) /return FALSE

    /varset gpChunk ${prefixList.Mid[${searchPos},500]}
    /if (!${gpChunk.Length}) /return FALSE

    /varset pipeEnd ${gpChunk.Find[|]}
    /if (!${pipeEnd} || ${pipeEnd} < 4) /return FALSE

    /varset gpEntry ${gpChunk.Left[${Math.Calc[${pipeEnd}-1]}]}
    /varset searchPos ${Math.Calc[${searchPos}+${pipeEnd}-1]}

    | First char is the type tag (P/S/C)
    /varset gpType ${gpEntry.Left[1]}
    /varset gpEntry ${gpEntry.Right[-1]}

    /varset colonPos ${gpEntry.Find[:]}
    /if (!${colonPos}) /goto :nextGivePrefix

    /varset gpLen ${Int[${gpEntry.Left[${Math.Calc[${colonPos}-1]}]}]}
    /if (${gpLen} < 1) /goto :nextGivePrefix

    /varset gpText ${gpEntry.Mid[${Math.Calc[${colonPos}+1]},${gpLen}]}

    | Branch on match type
    /if (${gpType.Equal[P]}) {
        | Prefix: starts with
        /if (${gpLen} > ${u.Length}) /goto :nextGivePrefix
        /if (${u.Left[${gpLen}].Equal[${gpText}]}) /return TRUE
    } else /if (${gpType.Equal[S]}) {
        | Suffix: ends with
        /if (${gpLen} > ${u.Length}) /goto :nextGivePrefix
        /if (${u.Right[${gpLen}].Equal[${gpText}]}) /return TRUE
    } else /if (${gpType.Equal[C]}) {
        | Contains: anywhere in name
        /if (${u.Find[${gpText}]}) /return TRUE
    }

    /goto :nextGivePrefix
/return FALSE

| Checks item name against shared [Wildcards] section prefixes
| wildcardPrefixes format: |6:SPELL:||5:SONG:||8:TOME OF |
| wildcardFirstChars format: |S|T| (unique first characters of all wildcards)
Sub IsWildcardItem(string name)
    /if (!${wildcardPrefixes.Length}) /return FALSE

    /declare u string local ${name.Upper}

    | Fast reject: if item's first char isn't in any wildcard's first char, skip entirely
    /if (${Defined[wildcardFirstChars]} && ${wildcardFirstChars.Length}) {
        /if (!${wildcardFirstChars.Find[|${u.Left[1]}|]}) /return FALSE
    }

    /declare searchPos int local 1
    /declare pipeEnd int local
    /declare wcEntry string local
    /declare colonPos int local
    /declare wcPrefixLen int local
    /declare wcPrefix string local
    /declare wcChunk string local

:nextWildcard
    /varset searchPos ${Math.Calc[${searchPos}+1]}
    /if (${searchPos} >= ${wildcardPrefixes.Length}) /return FALSE

    /varset wcChunk ${wildcardPrefixes.Mid[${searchPos},500]}
    /if (!${wcChunk.Length}) /return FALSE

    /varset pipeEnd ${wcChunk.Find[|]}
    /if (!${pipeEnd} || ${pipeEnd} < 3) /return FALSE

    /varset wcEntry ${wcChunk.Left[${Math.Calc[${pipeEnd}-1]}]}
    /varset searchPos ${Math.Calc[${searchPos}+${pipeEnd}-1]}

    /varset colonPos ${wcEntry.Find[:]}
    /if (!${colonPos}) /goto :nextWildcard

    /varset wcPrefixLen ${Int[${wcEntry.Left[${Math.Calc[${colonPos}-1]}]}]}
    /if (${wcPrefixLen} < 1 || ${wcPrefixLen} > ${u.Length}) /goto :nextWildcard

    /varset wcPrefix ${wcEntry.Mid[${Math.Calc[${colonPos}+1]},${wcPrefixLen}]}
    /if (${u.Left[${wcPrefixLen}].Equal[${wcPrefix}]}) /return TRUE

    /goto :nextWildcard
/return FALSE

| Optional [GiveExclude] _list=Name1,Name2 — blocks GiveList _prefix and [Wildcards] matches only (exact ItemName=Char still gives).
Sub LoadGiveExclude
    /if (!${Defined[giveExcludePipe]}) {
        /declare giveExcludePipe string outer
    }
    /varset giveExcludePipe |
    /declare raw string local ${Ini[${iniFile},GiveExclude,_list]}
    /if (!${raw.Length} || ${raw.Equal[NULL]}) /return

    /declare rem string local ${raw}
    /declare pipePos int local 0
    /declare piece string local
    /declare pUpper string local

:nextGiveExcludePiece
    /if (!${rem.Length}) /return
    /varset pipePos ${rem.Find[,]}
    /if (${pipePos}) {
        /varset piece ${rem.Left[${Math.Calc[${pipePos}-1]}]}
        /varset rem ${rem.Mid[${Math.Calc[${pipePos}+1]},2048]}
    } else {
        /varset piece ${rem}
        /varset rem
    }
    /if (${piece.Length}) {
        /varset pUpper ${piece.Upper}
        /if (!${giveExcludePipe.Find[|${pUpper}|]}) {
            /varset giveExcludePipe ${giveExcludePipe}${pUpper}|
        }
    }
    /goto :nextGiveExcludePiece

Sub IsGiveExcluded(string itemName)
    /if (!${Defined[giveExcludePipe]}) /return FALSE
    /if (${giveExcludePipe.Length} < 3) /return FALSE
    /declare u string local ${itemName.Upper}
    /if (${giveExcludePipe.Find[|${u}|]}) /return TRUE
/return FALSE

| =====================================================================
| HARD-BLOCK LIST (1.8.9) — items that ALWAYS refuse to trade/give/handin
| no matter what the [GiveList], [GiveExclude], or command-line says.
|
| Why this exists: some items cause repeated user pain when traded by
| accident (no-drop-on-trade quirks, quest items confused with vendor
| trash, etc.). The user-configurable [GiveExclude] _list= mechanism
| only blocks prefix/wildcard matches — it does NOT override an explicit
| ItemName=Char line. This sub is the absolute last word: always FALSE.
|
| Stored as a single uppercased pipe-delimited literal so additions are
| a one-line edit. To add another always-blocked item, append its
| UPPERCASE name to the string with a leading and trailing pipe.
|
| Apostrophes inside the literal are safe because we never expand it as
| a command — only walk it via .Find[].
|
| Coverage: called from the top of the give-loop in GiveToTarget, the
| bank-pull match check in CheckBankItemMatch, and HandinToNPC. The
| existing [GiveExclude] machinery is left untouched and still works
| for user-defined wildcards/prefix exclusions.
| =====================================================================
Sub IsHardBlocked(string itemName)
    /if (!${itemName.Length}) /return FALSE
    /declare hardBlockList string local |TOME OF NIFE'S MERCY|
    /declare u string local ${itemName.Upper}
    /if (${hardBlockList.Find[|${u}|]}) /return TRUE
/return FALSE

| Loads shared wildcard prefixes from [Wildcards] section in turboloot.ini
Sub LoadWildcards
    /if (!${Defined[wildcardPrefixes]}) {
        /declare wildcardPrefixes string outer
    }
    /varset wildcardPrefixes

    /declare wcVal string local
    /declare wcUpper string local
    /declare wcLen int local

    /varset wcVal ${Ini[${iniFile},Wildcards,Spell:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes ${wildcardPrefixes}|6:SPELL:
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [Spell:] (6 chars)"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Skill:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes ${wildcardPrefixes}|6:SKILL:
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [Skill:] (6 chars)"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Song:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes ${wildcardPrefixes}|5:SONG:
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [Song:] (5 chars)"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Tome ]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes ${wildcardPrefixes}|5:TOME 
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [Tome ] (5 chars)"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Tome of ]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes ${wildcardPrefixes}|8:TOME OF 
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [Tome of ] (8 chars)"
        }
    }

    | Custom wildcards: Wildcard1 through Wildcard20
    /declare i int local
    /declare rawPrefix string local
    /for i 1 to 20
        /varset wcVal ${Ini[${iniFile},Wildcards,Wildcard${i}]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]}) {
            /varset rawPrefix ${wcVal}
            /if (${rawPrefix.Length}) {
                /varset wcLen ${rawPrefix.Length}
                /varset wildcardPrefixes ${wildcardPrefixes}|${wcLen}:${rawPrefix.Upper}
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcard loaded: [${rawPrefix}] (${wcLen} chars)"
            }
        }
    /next i

    /if (${wildcardPrefixes.Length}) {
        /varset wildcardPrefixes ${wildcardPrefixes}|
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Shared wildcards active: ${wildcardPrefixes}"

        | Build fast first-character lookup string for quick rejection
        | Extract unique first characters from each wildcard prefix
        /if (!${Defined[wildcardFirstChars]}) {
            /declare wildcardFirstChars string outer |
        } else {
            /varset wildcardFirstChars |
        }
        /declare fcPos int local 1
        /declare fcChunk string local
        /declare fcPipe int local
        /declare fcEntry string local
        /declare fcColon int local
        /declare fcPrefixText string local
        /declare fcFirstChar string local

:nextFCWildcard
        /varset fcPos ${Math.Calc[${fcPos}+1]}
        /if (${fcPos} >= ${wildcardPrefixes.Length}) /goto :doneFCWildcard
        /varset fcChunk ${wildcardPrefixes.Mid[${fcPos},500]}
        /if (!${fcChunk.Length}) /goto :doneFCWildcard
        /varset fcPipe ${fcChunk.Find[|]}
        /if (!${fcPipe} || ${fcPipe} < 3) /goto :doneFCWildcard
        /varset fcEntry ${fcChunk.Left[${Math.Calc[${fcPipe}-1]}]}
        /varset fcPos ${Math.Calc[${fcPos}+${fcPipe}-1]}
        /varset fcColon ${fcEntry.Find[:]}
        /if (!${fcColon}) /goto :nextFCWildcard
        /varset fcPrefixText ${fcEntry.Mid[${Math.Calc[${fcColon}+1]},1]}
        /if (${fcPrefixText.Length} && !${wildcardFirstChars.Find[|${fcPrefixText}|]}) {
            /varset wildcardFirstChars ${wildcardFirstChars}${fcPrefixText}|
        }
        /goto :nextFCWildcard
:doneFCWildcard
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Wildcard first chars: ${wildcardFirstChars}"
    } else {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] No shared wildcards active"
    }
/return

| =====================================================================
| NAV TO ID WITH DOORS + NUDGES
| Reissues /nav if it stops early. If stuck (no movement progress),
| tries to open nearby doors and nudge with forward + strafe.
| Args: targetID, stopDist, maxTicks (10 ticks ~= 1 second)
| (Mirrors TurboLoot's NavToIDWithDoorsAndNudges)
| =====================================================================
Sub NavToIDWithDoorsAndNudges(int targetID, float stopDist, int maxTicks)
    /declare tid int local ${targetID}
    /declare distGoal float local ${stopDist}
    /declare limit int local ${maxTicks}

    /declare navTicks int local 0
    /declare lastDist float local 999999
    /declare stuckCount int local 0
    /declare lastX float local ${Me.X}
    /declare lastY float local ${Me.Y}
    /declare nudgeFlip bool local FALSE

    /squelch /nav stop
    /nav id ${tid} distance=${distGoal}

:NavIDLoop
    /doevents
    /delay 1
    /varcalc navTicks ${navTicks} + 1

    /if (!${Target.ID} || ${Target.ID} != ${tid}) {
        /squelch /nav stop
        /return
    }

    /if (${Target.Distance} <= ${distGoal}) {
        /squelch /nav stop
        /return
    }

    | Stuck detection: no distance or position change
    /if (${Math.Abs[${Target.Distance} - ${lastDist}]} < 0.5 && ${Math.Abs[${Me.X}-${lastX}]} < 0.5 && ${Math.Abs[${Me.Y}-${lastY}]} < 0.5) {
        /varcalc stuckCount ${stuckCount} + 1
    } else {
        /varset stuckCount 0
    }
    /varset lastDist ${Target.Distance}
    /varset lastX ${Me.X}
    /varset lastY ${Me.Y}

    | Reissue nav if it stopped early
    /if (!${Navigation.Active} && ${Target.Distance} > (${distGoal} + 2)) {
        /nav id ${tid} distance=${distGoal}
    }

    | Stuck — try opening doors and nudging
    /if (${stuckCount} >= 30) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Nav stuck (dist=${Target.Distance}) - trying door + nudge..."
        /squelch /nav stop
        /call TryOpenNearbyDoor 40
        /face fast
        /delay 1

        | Nudge: forward + alternating strafe
        /keypress forward hold
        /delay 2
        /keypress forward

        /if (!${nudgeFlip}) {
            /keypress strafe_left hold
            /delay 2
            /keypress strafe_left
            /varset nudgeFlip TRUE
        } else {
            /keypress strafe_right hold
            /delay 2
            /keypress strafe_right
            /varset nudgeFlip FALSE
        }

        /varset stuckCount 0
        /nav id ${tid} distance=${distGoal}
    }

    | Periodic door check
    /if (${Math.Calc[${navTicks}%20]} == 0) {
        /call TryOpenNearbyDoor 40
    }

    /if (${navTicks} >= ${limit}) {
        /squelch /nav stop
        /return
    }

    /goto :NavIDLoop
/return

| =====================================================================
| TRY OPEN NEARBY DOOR
| =====================================================================
Sub TryOpenNearbyDoor(int radius)
    /declare r int local ${radius}
    /if (${r} <= 0) /varset r 35

    /if (${SpawnCount[door radius ${r}]} == 0) /return FALSE

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Door nearby (within ${r}) - attempting to open..."
    /doortarget
    /delay 2

    /if (${DoorTarget.ID}) {
        /click left door
        /delay 10
        /return TRUE
    }
/return FALSE

| =====================================================================
| CURRENCY: COLLECT CASH (others send coin to you — pp+gp+sp+cp when draining all)
| v1.8.5: serialized — ask one bot, wait for its DONE, ask the next.
| Previously: fired /e3bct to every bot in parallel; bots raced at the
| trade window and only the first couple actually delivered. Now uses
| the same per-bot ask/wait pattern as CollectFromGroup / AskForItems.
| =====================================================================
Sub CollectCash(string scopeParam, int maxAmount)
    /declare scope string local ${scopeParam.Upper.Replace[ ,]}
    /declare groupOnly bool local TRUE
    /if (${scope.Equal[ALL]}) /varset groupOnly FALSE

    /echo ${tgTag} \ao[COLLECT CASH]\aw Collecting coin (pp/gp/sp/cp) from ${If[${groupOnly},group,all e3 bots]}${If[${maxAmount}>0, (limit: ${maxAmount}pp plat each; gp/sp/cp omitted),]}...

    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned.
        /return
    }

    | Ensure signaling vars exist. Disable bank-broadcast mode because we
    | wait per-bot now, not for an N-many aggregate.
    /if (!${Defined[charDone]}) {
        /declare charDone bool outer FALSE
    } else {
        /varset charDone FALSE
    }
    /if (!${Defined[charDoneSender]}) {
        /declare charDoneSender string outer
    } else {
        /varset charDoneSender
    }
    /if (!${Defined[_bankBroadcastMode]}) {
        /declare _bankBroadcastMode bool outer FALSE
    } else {
        /varset _bankBroadcastMode FALSE
    }

    | Pause E3 logic and follow
    /declare wasFollowingCC bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingCC TRUE
        /squelch /afollow pause
    }

    /declare memberIdx int local
    /declare memberName string local
    /declare sentCount int local 0
    /declare receivedCount int local 0
    /declare myName string local ${Me.Name}

    | Build + iterate the bot list. Group mode = group members. All/raid
    | mode = all connected e3 bots (parsed from E3Bots.ConnectedClients).
    /if (${groupOnly}) {
        /for memberIdx 1 to ${Group.Members}
            /varset memberName ${Group.Member[${memberIdx}].Name}
            /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
            /if (${memberName.Equal[${myName}]}) /continue
            /if (!${Spawn[pc ${memberName}].ID}) /continue

            /call AskOneForCash "${memberName}" ${maxAmount}
            /varcalc sentCount ${sentCount}+1
            /if (${Macro.Return.Equal[TRUE]}) /varcalc receivedCount ${receivedCount}+1
        /next memberIdx
    } else {
        /declare clientList string local ${MQ2Mono.Query[e3,E3Bots.ConnectedClients]}
        /if (!${clientList.Length} || ${clientList.Equal[NULL]}) {
            /echo ${tgTag} \arNo connected E3 bots found.
            /if (${wasFollowingCC}) /squelch /afollow unpause
            /return
        }
        /declare clientRemaining string local ${clientList}
        /declare commaPos int local 0
        /declare botName string local

:nextCashBot
        /if (!${clientRemaining.Length}) /goto :cashDone

        /varset commaPos ${clientRemaining.Find[,]}
        /if (${commaPos}) {
            /varset botName ${clientRemaining.Left[${Math.Calc[${commaPos}-1]}]}
            /varset clientRemaining ${clientRemaining.Mid[${Math.Calc[${commaPos}+1]},2048]}
        } else {
            /varset botName ${clientRemaining}
            /varset clientRemaining
        }

        /if (!${botName.Length}) /goto :nextCashBot
        /if (${botName.Equal[${myName}]}) /goto :nextCashBot
        /if (!${Spawn[pc ${botName}].ID}) /goto :nextCashBot

        /call AskOneForCash "${botName}" ${maxAmount}
        /varcalc sentCount ${sentCount}+1
        /if (${Macro.Return.Equal[TRUE]}) /varcalc receivedCount ${receivedCount}+1
        /goto :nextCashBot
    }

:cashDone
    /if (${sentCount} == 0) {
        /echo ${tgTag} \arNo group members found to collect cash from.
        /if (${wasFollowingCC}) /squelch /afollow unpause
        /return
    }
    /echo ${tgTag} \ao[COLLECT CASH]\aw Done. \ag${receivedCount}\aw/\ag${sentCount}\aw bot(s) delivered.
    /if (${wasFollowingCC}) /squelch /afollow unpause
/return

| =====================================================================
| ASK ONE FOR CASH — per-bot ask/wait (parallel to AskForItems).
| Returns TRUE if the bot signaled DONE within the timeout, FALSE otherwise.
| =====================================================================
Sub AskOneForCash(string senderName, int maxAmount)
    /echo ${tgTag} \ao[COLLECT CASH]\aw Asking \ag${senderName}\aw to send cash...

    /varset charDone FALSE
    /varset charDoneSender

    /if (${maxAmount} > 0) {
        /squelch /e3bct ${senderName} /mac turbogive _sendcash ${Me.Name} ${maxAmount}
    } else {
        /squelch /e3bct ${senderName} /mac turbogive _sendcash ${Me.Name}
    }

    | Wait for THIS sender's DONE. A late DONE from a previous bot must
    | not release this wait early, or the next bot races at the trade window.
    /declare waitTicks int local 0
    /declare maxWait int local 600
    /declare settleTicks int local 0

    /while (( !${charDone} || ${charDoneSender.NotEqual[${senderName}]} ) && ${waitTicks} < ${maxWait}) {
        /doevents
        /delay 1
        /varcalc waitTicks ${waitTicks}+1

        | If the trade window opens, accept it
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Trade_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
    }

    /if (!${charDone} || ${charDoneSender.NotEqual[${senderName}]}) {
        /echo ${tgTag} \ayTimed out waiting for \ag${senderName}\ay (60s). Moving on.
        /return FALSE
    }

    | Settle window before asking the next bot — prevents "I'm busy" races
    | when the prior trade just closed.
    /while (${Window[TradeWnd].Open} && ${settleTicks} < 50) {
        /doevents
        /delay 1
        /varcalc settleTicks ${settleTicks}+1
    }
    /delay 5
/return TRUE

| =====================================================================
| CURRENCY: COLLECT DC (others send Diamond Coins to you)
| v1.8.5: serialized — ask one bot, wait for its DONE, ask the next.
| See CollectCash comment for rationale.
| v1.9.4: collector reclaims received inventory DC after each trade/delivery.
| v1.9.5: per-bot/final summaries announce once; reclaim chatter is debug-only.
| v1.10.0: PullExactBankItemById(wantQty); BankSendMyStack + _banksendstack;
|          RequestTurboGearTradeSync note timing 8->2 (UI optimistic qty);
|          banker nav echoes cancel tip (/endmacro / Stop Nav).
| =====================================================================
Sub CollectDC(string scopeParam, int maxAmount)
    /declare scope string local ${scopeParam.Upper.Replace[ ,]}
    /declare groupOnly bool local TRUE
    /if (${scope.Equal[ALL]}) /varset groupOnly FALSE

    /echo ${tgTag} \ao[COLLECT DC]\aw Collecting Diamond Coin from ${If[${groupOnly},group,all e3 bots]}${If[${maxAmount}>0, (limit: ${maxAmount} each),]}...

    /if (${Me.Feigning}) {
        /echo ${tgTag} \arCannot trade while feigned.
        /return
    }

    /if (!${Defined[charDone]}) {
        /declare charDone bool outer FALSE
    } else {
        /varset charDone FALSE
    }
    /if (!${Defined[charDoneSender]}) {
        /declare charDoneSender string outer
    } else {
        /varset charDoneSender
    }
    /if (!${Defined[_bankBroadcastMode]}) {
        /declare _bankBroadcastMode bool outer FALSE
    } else {
        /varset _bankBroadcastMode FALSE
    }

    /declare wasFollowingCD bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingCD TRUE
        /squelch /afollow pause
    }

    /declare memberIdx int local
    /declare memberName string local
    /declare sentCount int local 0
    /declare receivedCount int local 0
    /declare totalReceivedDC int local 0
    /declare botReceivedDC int local 0
    /declare myName string local ${Me.Name}
    
    /declare dcChunk int local ${If[${maxAmount}>0 && ${maxAmount}<7000,${maxAmount},7000]}
    /declare passNum int local 0
    /declare maxPasses int local 200
    /declare passReceivedDC int local 0
    /declare activeThisPass int local 0
    /declare emptyPasses int local 0

    /if (!${Defined[_quietReclaim]}) {
        /declare _quietReclaim bool outer FALSE
    } else {
        /varset _quietReclaim FALSE
    }
    /if (!${Defined[_dcCollectLastSessions]}) {
        /declare _dcCollectLastSessions int outer 0
    } else {
        /varset _dcCollectLastSessions 0
    }

    /if (${FindItemCount[=Diamond Coin]} > 0) {
        /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Reclaiming existing inventory Diamond Coin before starting collection...
        /varset _quietReclaim TRUE
        /call ReclaimAltDC
        /varset _quietReclaim FALSE
    }

    :CollectDCPass
    /varcalc passNum ${passNum}+1
    /varset passReceivedDC 0
    /varset activeThisPass 0
    
    /if (${passNum} > ${maxPasses}) {
        /echo ${tgTag} \ay[COLLECT DC]\aw Safety stop after ${maxPasses} round-robin pass(es). Re-run if bots still have DC.
        /goto :CollectDCDone
    }
    
    /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Starting round-robin pass ${passNum}, chunk ${dcChunk} DC per bot...
    
    /for memberIdx 1 to ${Group.Members}
        /varset memberName ${Group.Member[${memberIdx}].Name}
        /if (!${memberName.Length} || ${memberName.Equal[NULL]}) /continue
        /if (${memberName.Equal[${myName}]}) /continue
        /if (!${Spawn[pc ${memberName}].ID}) /continue
    
        /varcalc activeThisPass ${activeThisPass}+1
    
        /call AskOneForDC "${memberName}" ${dcChunk}
        /varset botReceivedDC ${Macro.Return}
        /varcalc sentCount ${sentCount}+1
    
        /if (${botReceivedDC} >= 0) {
            /varcalc receivedCount ${receivedCount}+1
            /varcalc totalReceivedDC ${totalReceivedDC}+${botReceivedDC}
            /varcalc passReceivedDC ${passReceivedDC}+${botReceivedDC}
    
            /if (${FindItemCount[=Diamond Coin]} > 0) {
                /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Reclaiming received Diamond Coin before asking the next bot...
                /varset _quietReclaim TRUE
                /call ReclaimAltDC
                /varset _quietReclaim FALSE
            }
    
            /if (${botReceivedDC} > 0) {
                /call Announce "${announceMethod}" "${tgTag} \ao[COLLECT DC]\aw Pass ${passNum}: ${memberName} delivered \ag${botReceivedDC}\aw DC. Alt-currency DC now: \ag${Me.AltCurrency[20]}\aw."
            }
        }
    
        | Small settle gap between bots, similar spirit to the tester's /timed spacing.
        /delay 15
    /next memberIdx
    
    /if (${activeThisPass} == 0) {
        /echo ${tgTag} \arNo group members found to collect DC from.
        /goto :CollectDCDone
    }
    
    /if (${passReceivedDC} <= 0) {
        /varcalc emptyPasses ${emptyPasses}+1
    } else {
        /varset emptyPasses 0
    }
    
    | Require one completely empty pass to stop.
    /if (${emptyPasses} >= 1) /goto :CollectDCDone
    
    /goto :CollectDCPass
    
    :CollectDCDone

    /if (${sentCount} == 0) {
        /echo ${tgTag} \arNo group members found to collect DC from.
        /if (${wasFollowingCD}) /squelch /afollow unpause
        /return
    }
    /if (${FindItemCount[=Diamond Coin]} > 0) {
        /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Reclaiming remaining received Diamond Coin...
        /varset _quietReclaim TRUE
        /call ReclaimAltDC
        /varset _quietReclaim FALSE
    }
    /call Announce "${announceMethod}" "${tgTag} \ao[COLLECT DC]\aw Complete after \ag${passNum}\aw pass(es). \ag${receivedCount}\aw/\ag${sentCount}\aw request(s) returned. Total received/reclaimed: \ag${totalReceivedDC}\aw DC. Alt-currency DC now: \ag${Me.AltCurrency[20]}\aw."
    /if (${wasFollowingCD}) /squelch /afollow unpause
/return

| =====================================================================
| ASK ONE FOR DC — per-bot ask/wait (parallel to AskOneForCash).
| Returns received DC count, or -1 if the bot did not signal DONE.
| =====================================================================
Sub AskOneForDC(string senderName, int maxAmount)
    /echo ${tgTag} \ao[COLLECT DC]\aw Asking \ag${senderName}\aw to send DC...

    /varset charDone FALSE
    /varset charDoneSender
    /if (${Defined[_dcCollectLastSessions]}) /varset _dcCollectLastSessions 0

    /declare beforeAltDC int local ${Me.AltCurrency[20]}
    /declare beforeInvDC int local ${FindItemCount[=Diamond Coin]}
    /declare afterAltDC int local 0
    /declare afterInvDC int local 0
    /declare receivedDC int local 0
    /declare invDeltaDC int local 0

    /if (${maxAmount} > 0) {
        /squelch /e3bct ${senderName} /mac turbogive _senddc ${Me.Name} ${maxAmount}
    } else {
        /squelch /e3bct ${senderName} /mac turbogive _senddc ${Me.Name}
    }

    /declare waitTicks int local 0
    /declare maxWait int local 36000
    /declare settleTicks int local 0

    /while (( !${charDone} || ${charDoneSender.NotEqual[${senderName}]} ) && ${waitTicks} < ${maxWait}) {
        /doevents
        /delay 1
        /varcalc waitTicks ${waitTicks}+1

        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Trade_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
            /if (!${Window[TradeWnd].Open} && ${FindItemCount[=Diamond Coin]} > 0) {
                /if (${Defined[_dcCollectLastSessions]}) /varcalc _dcCollectLastSessions ${_dcCollectLastSessions}+1
                /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Reclaiming received Diamond Coin so ${senderName} can continue sending...
                /if (${Defined[_quietReclaim]}) /varset _quietReclaim TRUE
                /call ReclaimAltDC
                /if (${Defined[_quietReclaim]}) /varset _quietReclaim FALSE
            }
        }
    }

    /if (!${charDone} || ${charDoneSender.NotEqual[${senderName}]}) {
        /echo ${tgTag} \ayTimed out waiting for \ag${senderName}\ay (60m). Moving on.
        /return -1
    }

    /while (${Window[TradeWnd].Open} && ${settleTicks} < 50) {
        /doevents
        /delay 1
        /varcalc settleTicks ${settleTicks}+1
    }
    /delay 5
    /if (${FindItemCount[=Diamond Coin]} > 0) {
        /if (${showDebug}) /echo ${tgTag} \ao[COLLECT DC]\aw Reclaiming final received Diamond Coin from ${senderName}...
        /if (${Defined[_quietReclaim]}) /varset _quietReclaim TRUE
        /call ReclaimAltDC
        /if (${Defined[_quietReclaim]}) /varset _quietReclaim FALSE
    }
    /varset afterAltDC ${Me.AltCurrency[20]}
    /varset afterInvDC ${FindItemCount[=Diamond Coin]}
    /varset receivedDC ${Math.Calc[${afterAltDC}-${beforeAltDC}].Int}
    /varset invDeltaDC ${Math.Calc[${afterInvDC}-${beforeInvDC}].Int}
    /if (${invDeltaDC} > 0) /varcalc receivedDC ${receivedDC}+${invDeltaDC}
    /if (${receivedDC} < 0) /varset receivedDC 0
/return ${receivedDC}

| =====================================================================
| CURRENCY: secondary coin slots (DoConv-style — same trade as platinum)
| IW_Money0=plat IW_Money1=gold IW_Money2=silver IW_Money3=copper
| Only used when maxAmount==0 (full drain). If maxAmount>0, caller stays platinum-only for safety.
| =====================================================================
Sub TryOpenTradeWithMinorCoin(string wantName)
    | v1.7: now takes wantName for target verification before each click
    | When platinum is 0, open the trade window using gp/sp/cp (DoConv order: gold, then silver, then copper).
    /face fast
    /delay 2
    /if (${Me.Gold} > 0 && !${Window[TradeWnd].Open}) {
        /shift /notify InventoryWindow IW_Money1 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /call VerifyTradeTarget "${wantName}"
        /if (!${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ar[SAFETY]\aw Target drift before gp click — aborting minor-coin trade with ${wantName}.
            /return
        }
        /nomodkey /click left target
        /delay 15 ${Window[TradeWnd].Open}
    }
    /if (${Me.Silver} > 0 && !${Window[TradeWnd].Open}) {
        /shift /notify InventoryWindow IW_Money2 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /call VerifyTradeTarget "${wantName}"
        /if (!${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ar[SAFETY]\aw Target drift before sp click — aborting minor-coin trade with ${wantName}.
            /return
        }
        /nomodkey /click left target
        /delay 15 ${Window[TradeWnd].Open}
    }
    /if (${Me.Copper} > 0 && !${Window[TradeWnd].Open}) {
        /shift /notify InventoryWindow IW_Money3 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /call VerifyTradeTarget "${wantName}"
        /if (!${Macro.Return.Equal[TRUE]}) {
            /echo ${tgTag} \ar[SAFETY]\aw Target drift before cp click — aborting minor-coin trade with ${wantName}.
            /return
        }
        /nomodkey /click left target
        /delay 15 ${Window[TradeWnd].Open}
    }
/return

Sub OfferSecondaryCoinsToOpenTrade
    /if (!${Window[TradeWnd].Open}) /return
    | Gold
    /if (${Me.Gold} > 0) {
        /shift /notify InventoryWindow IW_Money1 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /nomodkey /click left target
        /delay 6
    }
    | Silver
    /if (${Me.Silver} > 0) {
        /shift /notify InventoryWindow IW_Money2 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /nomodkey /click left target
        /delay 6
    }
    | Copper
    /if (${Me.Copper} > 0) {
        /shift /notify InventoryWindow IW_Money3 leftmouseup
        /delay 5
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /nomodkey /click left target
        /delay 6
    }
/return

| =====================================================================
| CURRENCY: SEND MY CASH (internal — bot sends coin to collector)
| =====================================================================
| Open inventory using the real EQ bind name (not the letter I — remapped keys break /keypress i).
| Then force character view + General tab so IW_Money0 (coin row) is valid (bag/alt views can hide it).
Sub OpenInventoryWindowForTrade
    /declare invTry int local 0
    :OpenInvTradeLoop
    /if (!${Window[InventoryWindow].Open}) {
        /nomodkey /keypress inventory
        /delay 3
        /varcalc invTry ${invTry}+1
        /if (${invTry} < 12 && !${Window[InventoryWindow].Open}) /goto :OpenInvTradeLoop
    }
    /if (!${Window[InventoryWindow].Open}) {
        /nomodkey /keypress i
        /delay 6 ${Window[InventoryWindow].Open}
    }
    /if (!${Window[InventoryWindow].Open}) /return FALSE
    /notify InventoryWindow IW_CharacterView leftmouseup
    /delay 2
    /notify InventoryWindow IW_Subwindows tabselect 1
    /delay 3
/return TRUE

| Platinum on cursor often needs several /autoinventory; Cursor.ID may be false for coin.
Sub ClearCashCursorStuck
    /if (${Window[TradeWnd].Open}) {
        /notify TradeWnd TRDW_Cancel_Button leftmouseup
        /delay 6 !${Window[TradeWnd].Open}
    }
    /call ForceClearCursor
    /declare stashN int local 0
    /for stashN 1 to 8
        /autoinventory
        /delay 3
    /next stashN
/return

Sub SendMyCash(string collectorName, int maxAmount)
    /if (${collectorName.Equal[${Me.Name}]}) /return

    /declare myPlat int local ${Me.Platinum}
    /declare myGold int local ${Me.Gold}
    /declare mySilver int local ${Me.Silver}
    /declare myCopper int local ${Me.Copper}
    /if (${myPlat} <= 0 && ${myGold} <= 0 && ${mySilver} <= 0 && ${myCopper} <= 0) {
        /echo ${tgTag} \awNo coin to send.
        /return
    }

    /declare wasFollowingSC bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingSC TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${collectorName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[SEND CASH]\aw Cannot target ${collectorName} as a PC.
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }

    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 3

    /call OpenInventoryWindowForTrade
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[SEND CASH] Could not open inventory window. (Check keybind: Options -> Keys -> Inventory)
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }

    /if (${myPlat} <= 0) /goto :SendCashOpenMinor

    | Pickup retry counter — shared across both paths (LuaJIT footgun: declare once)
    /declare pickupTry int local 0

    | v1.7: maxAmount > 0 — use QuantityWnd path for exact amount
    | maxAmount = 0 — keep original shift-click "dump all" path (more reliable per author comment)
    /if (${maxAmount} > 0) {
        | Cap to what we actually have
        /if (${maxAmount} > ${myPlat}) /varset maxAmount ${myPlat}
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] SendMyCash: capped maxAmount to ${maxAmount}pp (have ${myPlat}pp)"

        :RetryPickupSCQty
        /if (${Cursor.ID}) /autoinventory
        /delay 2
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        | Unshift click on plat row opens QuantityWnd (amount picker)
        /nomodkey /notify InventoryWindow IW_Money0 leftmouseup
        /delay 15 ${Window[QuantityWnd].Open}

        /if (!${Window[QuantityWnd].Open}) {
            /varcalc pickupTry ${pickupTry}+1
            /if (${pickupTry} < 3) {
                /keypress esc
                /delay 2
                /goto :RetryPickupSCQty
            }
            /echo ${tgTag} \ar[SEND CASH]\aw QuantityWnd did not open after 3 attempts — cannot specify amount ${maxAmount}pp.
            /call ClearCashCursorStuck
            /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
            /if (${wasFollowingSC}) /squelch /afollow unpause
            /return
        }

        | Enter exact amount and accept
        /call SetQuantityWndValue ${maxAmount}
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 10 !${Window[QuantityWnd].Open}

        | Verify plat was actually picked up (plat often doesn't set Cursor.ID)
        /if (${Me.Platinum} >= ${myPlat} && !${Cursor.ID}) {
            /varcalc pickupTry ${pickupTry}+1
            /if (${pickupTry} < 3) {
                /keypress esc
                /delay 2
                /goto :RetryPickupSCQty
            }
            /echo ${tgTag} \ar[SEND CASH]\aw Failed to pick up ${maxAmount}pp after 3 attempts (plat still in coin row).
            /call ClearCashCursorStuck
            /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
            /if (${wasFollowingSC}) /squelch /afollow unpause
            /return
        }
        /goto :SendCashPickupDone
    }

    | Pick up plat — original shift-click "dump all" path (DoConv: plat often does NOT set Cursor.ID in MQ2)
    | Handin: unshift click opens QuantityWnd — accept if it appears
    :RetryPickupSC
    /if (${Cursor.ID}) /autoinventory
    /delay 2
    /if (${Window[QuantityWnd].Open}) {
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 3
    }
    /shift /notify InventoryWindow IW_Money0 leftmouseup
    /delay 4
    /if (${Window[QuantityWnd].Open}) {
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5
    }
    /if (${Me.Platinum} >= ${myPlat} && !${Cursor.ID}) {
        /varcalc pickupTry ${pickupTry}+1
        /if (${pickupTry} < 4) {
            /keypress esc
            /delay 2
            /goto :RetryPickupSC
        }
        /echo ${tgTag} \ar[SEND CASH] Failed to pick up platinum after 4 attempts (plat still in coin row).
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }

    :SendCashPickupDone
    | Initiate trade with retries (v1.7: hardened against wrong-target via OpenTradeWindow)
    /declare tradeTry int local 0
    :RetryTradeSC
    /call OpenTradeWindow "${collectorName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /varcalc tradeTry ${tradeTry}+1
        /if (${tradeTry} < 3) {
            /delay 3
            /goto :RetryTradeSC
        }
        /echo ${tgTag} \ar[SEND CASH] Trade window did not open after 3 attempts. Returning coin.
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }
    /goto :SendCashTradeReady

    :SendCashOpenMinor
    /call TryOpenTradeWithMinorCoin "${collectorName}"
    /if (!${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[SEND CASH] Could not open trade with gp/sp/cp (no platinum on character).
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }

    :SendCashTradeReady
    | DoConv: wait for cursor to clear into trade; add gp/sp/cp to same trade when draining all coin
    /delay 10
    /if (${Window[TradeWnd].Open} && ${Cursor.ID}) /delay 60 !${Cursor.ID}
    /if (${maxAmount} <= 0) /call OfferSecondaryCoinsToOpenTrade
    /if (${Window[TradeWnd].Open} && ${Cursor.ID}) /delay 60 !${Cursor.ID}
    /if (${Window[TradeWnd].Open} && !${Cursor.ID}) {
        /notify TradeWnd TRDW_Trade_Button leftmouseup
    } else /if (${Window[TradeWnd].Open} && ${Cursor.ID}) {
        /echo ${tgTag} \ay[SEND CASH] Coin still on cursor after trade open — canceling and stashing.
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /if (${wasFollowingSC}) /squelch /afollow unpause
        /return
    }

    | Tell collector to accept — retry up to 3 times
    /declare acceptTry int local 0
    :RetryAcceptSC
    /squelch /e3bct ${collectorName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
    /delay 20 !${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open}) {
        /varcalc acceptTry ${acceptTry}+1
        /if (${acceptTry} < 3) /goto :RetryAcceptSC
    }

    | Stuck trade / coin on cursor after accept attempts
    /if (${Window[TradeWnd].Open} || ${Cursor.ID}) {
        /echo ${tgTag} \ay[SEND CASH] Trade incomplete — canceling and returning coin to bags.
        /call ClearCashCursorStuck
    }
    /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory

    /declare afterPlat int local ${Me.Platinum}
    /declare afterGold int local ${Me.Gold}
    /declare afterSilver int local ${Me.Silver}
    /declare afterCopper int local ${Me.Copper}
    /declare sentAny bool local FALSE
    /if (${afterPlat} < ${myPlat}) /varset sentAny TRUE
    /if (${afterGold} < ${myGold}) /varset sentAny TRUE
    /if (${afterSilver} < ${mySilver}) /varset sentAny TRUE
    /if (${afterCopper} < ${myCopper}) /varset sentAny TRUE
    /if (${sentAny}) {
        /echo ${tgTag} \ao[SEND CASH]\aw Sent to ${collectorName}: ${Math.Calc[${myPlat}-${afterPlat}]}pp ${Math.Calc[${myGold}-${afterGold}]}gp ${Math.Calc[${mySilver}-${afterSilver}]}sp ${Math.Calc[${myCopper}-${afterCopper}]}cp.
    } else {
        /echo ${tgTag} \ar[SEND CASH] Trade may have failed - coin unchanged.
    }
    /if (${wasFollowingSC}) /squelch /afollow unpause
/return

| =====================================================================
| CURRENCY: SEND MY DC (internal — bot sends Diamond Coins to collector)
| =====================================================================
Sub SendMyDC(string collectorName, int maxAmount)
    /if (${collectorName.Equal[${Me.Name}]}) /return

    /declare dcCount int local ${FindItemCount[=Diamond Coin]}
    /if (${dcCount} <= 0 && ${Me.AltCurrency[20]} > 0) {
        /if (!${Me.FreeInventory}) {
            /echo ${tgTag} \ay[SEND DC]\aw No open inventory slots to create Diamond Coin. Free bag space and re-run.
            /return
        }
        /call ConvertAltDC2Currency ${If[${maxAmount}>0 && ${maxAmount}<7000,${maxAmount},7000]}
        /varset dcCount ${FindItemCount[=Diamond Coin]}
    }
    /if (${dcCount} <= 0) {
        /echo ${tgTag} \awNo Diamond Coin to send.
        /return
    }

    /declare wasFollowingSD bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingSD TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${collectorName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[SEND DC]\aw Cannot target ${collectorName} as a PC.
        /if (${wasFollowingSD}) /squelch /afollow unpause
        /return
    }

    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 3

    | v1.8.1: two-level loop. Outer = trade sessions (high safety cap).
    | Inner loop lives in FillAndFinalizeDCTrade (caps at 7 slots/session).
    /declare dcTraded int local 0
    /declare outerSess int local 0
    /declare outerCap int local 400
    /declare sessTraded int local 0
    /declare remainingCap int local 0

    :SendMoreDC
    /varcalc outerSess ${outerSess}+1
    /if (${outerSess} > ${outerCap}) {
        /echo ${tgTag} \ar[SEND DC]\ay [SAFETY]\aw Hard cap hit after ${outerCap} sessions - re-run for remaining DC.
        /goto :SendDCDone
    }
    /if (${maxAmount} > 0 && ${dcTraded} >= ${maxAmount}) /goto :SendDCDone
    /varset remainingCap ${If[${maxAmount}>0,${Math.Calc[${maxAmount}-${dcTraded}].Int},0]}
    /if (${FindItemCount[=Diamond Coin]} <= 0 && ${Me.AltCurrency[20]} > 0) {
        /if (!${Me.FreeInventory}) {
            /echo ${tgTag} \ay[SEND DC]\aw No open inventory slots to create more Diamond Coin. Stopping after ${dcTraded} sent.
            /goto :SendDCDone
        }
        /call ConvertAltDC2Currency ${If[${remainingCap}>0 && ${remainingCap}<7000,${remainingCap},7000]}
    }
    /if (${FindItemCount[=Diamond Coin]} <= 0) /goto :SendDCDone

    /varset remainingCap ${If[${maxAmount}>0,${Math.Calc[${maxAmount}-${dcTraded}].Int},0]}

    /call FillAndFinalizeDCTrade "${collectorName}" ${remainingCap}
    /varset sessTraded ${Macro.Return}
    /varcalc dcTraded ${dcTraded}+${sessTraded}

    /if (${_dcAbortReceiverFull}) {
        /echo ${tgTag} \ay[SEND DC]\aw ${collectorName}'s bags/trade slots are full - stopping. Free inventory space on ${collectorName}, then re-run for remaining DC.
        /goto :SendDCDone
    }
    /if (${_dcTradeAborted}) /goto :SendDCDone
    /if (${sessTraded} <= 0) /goto :SendDCDone

    /delay 5
    /goto :SendMoreDC

    :SendDCDone
    /echo ${tgTag} \ao[SEND DC]\aw Sent ${dcTraded} Diamond Coin to ${collectorName} in ${outerSess} session(s).
    /if (${wasFollowingSD}) /squelch /afollow unpause
/return

| =====================================================================
| ITEM: SEND ONE GEAR ITEM (source pushes a single item to a recipient)
| Invoked cross-box by TurboGear "Give now" via:
|   /mac turbogive _senditem <recipientName> <itemID>
| Reuses the hardened trade helpers (AcquireTradeTarget / VerifyTradeTarget /
| PickupExactBagItemById / NavToIDWithDoorsAndNudges / ForceClearCursor) and the
| same dual-side finalize the DC trade uses (sender clicks Trade, then the
| receiver is told to click Trade over /e3bct). On any failure the item is
| returned to bags. NO INI rule is written or read for this path.
|
| Guards: skips self, missing/no-drop items, occupied cursor, feign. The live
| item send scans bags by exact item ID so equipped/banked copies with the same
| ID cannot be selected. TurboGear also pre-filters those cases before offering
| the button (defense in depth).
| =====================================================================
Sub RequestTurboGearTradeSync(string recipientName)
    | Reconcile after trade. UI already optimistically patches local qty on
    | Give Now; short timed lite note lets bg save truth without a long wait.
    /squelch /timed 1 /lua run turbogear_autostart
    /squelch /timed 2 /tgearbg note
    /squelch /timed 2 /tgear note
    /if (${recipientName.Length} && !${recipientName.Equal[NULL]} && !${recipientName.Equal[${Me.Name}]}) {
        /squelch /e3bct ${recipientName} /squelch /lua run turbogear_autostart
        /squelch /e3bct ${recipientName} /squelch /timed 2 /tgearbg note
        /squelch /e3bct ${recipientName} /squelch /timed 2 /tgear note
    }
/return

| wantQty defaults to 1 when omitted / <= 0 (back-compat for BankSendMyItem).
| QuantityWnd: SetQuantityWndValue wantQty. Without QuantityWnd, whole-slot
| pickup is only accepted when wantQty is 1 or Cursor.Stack equals wantQty.
Sub PullExactBankItemById(int wantItemId, int wantQty)
    /if (${wantItemId} <= 0) {
        /echo ${tgTag} \ar[BANK ITEM]\aw Invalid item id.
        /return FALSE
    }
    /declare biWantQty int local ${wantQty}
    /if (${biWantQty} <= 0) /varset biWantQty 1
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ar[BANK ITEM]\aw Cursor is occupied (${Cursor.Name}) - aborting before bank pull.
        /return FALSE
    }
    /if (!${Me.FreeInventory}) {
        /echo ${tgTag} \ar[BANK ITEM]\aw No free inventory slot for bank pull.
        /return FALSE
    }

    /if (!${Window[BigBankWnd].Open}) {
        /call FindAndOpenBank
        /if (!${Window[BigBankWnd].Open}) {
            /echo ${tgTag} \ar[BANK ITEM]\aw Could not open bank window.
            /return FALSE
        }
    }

    /declare biBank int local
    /declare biSlot int local
    /declare biMaxSlots int local
    /declare biName string local
    /declare biStack int local
    /declare biCursorStack int local

    /for biBank 1 to 24
        /if (!${Me.Bank[${biBank}].ID}) /continue
        /varset biMaxSlots ${Me.Bank[${biBank}].Container}

        /if (${Me.Bank[${biBank}].ID} == ${wantItemId}) {
            /if (${biMaxSlots} > 0) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Refusing to pull bank container ${Me.Bank[${biBank}].Name}.
                /return FALSE
            }
            /if (${Me.Bank[${biBank}].NoDrop}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw ${Me.Bank[${biBank}].Name} is NO-DROP - cannot trade.
                /return FALSE
            }
            /varset biStack ${Me.Bank[${biBank}].Stack}
            /if (${biStack} <= 0) /varset biStack 1
            /if (${biWantQty} > ${biStack}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Bank stack only has ${biStack}, need ${biWantQty}.
                /return FALSE
            }
            /varset biName ${Me.Bank[${biBank}].Name}
            /nomodkey /itemnotify bank${biBank} leftmouseup
            /delay 15 ${Cursor.ID} || ${Window[QuantityWnd].Open}
            /if (${Window[QuantityWnd].Open}) {
                /call SetQuantityWndValue ${biWantQty}
                /notify QuantityWnd QTYW_Accept_Button leftmouseup
                /delay 5 !${Window[QuantityWnd].Open}
                /if (${Window[QuantityWnd].Open}) /keypress ENTER
                /delay 5 ${Cursor.ID}
            } else /if (${biWantQty} > 1) {
                /if (!${Cursor.ID}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw Quantity window did not open; cannot pull ${biWantQty} of ${biName}.
                    /return FALSE
                }
                /varset biCursorStack ${Cursor.Stack}
                /if (${biCursorStack} <= 0) /varset biCursorStack 1
                /if (${biCursorStack} != ${biWantQty}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw No QuantityWnd; whole-slot pickup is ${biCursorStack}, need ${biWantQty} - returning.
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) /call ForceClearCursor
                    /return FALSE
                }
            }
            /if (!${Cursor.ID}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Failed to pick up ${biName} from bank slot ${biBank}.
                /return FALSE
            }
            /if (${Cursor.ID} != ${wantItemId}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Cursor mismatch (have ${Cursor.Name}, expected id ${wantItemId}) - returning.
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
                /return FALSE
            }
            /if (${biWantQty} > 1) {
                /varset biCursorStack ${Cursor.Stack}
                /if (${biCursorStack} <= 0) /varset biCursorStack 1
                /if (${biCursorStack} < ${biWantQty}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw Cursor has ${biCursorStack}, need ${biWantQty} - returning.
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) /call ForceClearCursor
                    /return FALSE
                }
            }
            /autoinventory
            /delay 10 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
            /if (${Cursor.ID}) /return FALSE
            /echo ${tgTag} \ag[BANK ITEM]\aw Pulled ${biWantQty}x ${biName} from bank.
            /return TRUE
        }

        /if (${biMaxSlots} <= 0) /continue
        /for biSlot 1 to ${biMaxSlots}
            /if (!${Me.Bank[${biBank}].Item[${biSlot}].ID}) /continue
            /if (${Me.Bank[${biBank}].Item[${biSlot}].ID} != ${wantItemId}) /continue
            /if (${Me.Bank[${biBank}].Item[${biSlot}].NoDrop}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw ${Me.Bank[${biBank}].Item[${biSlot}].Name} is NO-DROP - cannot trade.
                /return FALSE
            }
            /varset biStack ${Me.Bank[${biBank}].Item[${biSlot}].Stack}
            /if (${biStack} <= 0) /varset biStack 1
            /if (${biWantQty} > ${biStack}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Bank stack only has ${biStack}, need ${biWantQty}.
                /return FALSE
            }
            /varset biName ${Me.Bank[${biBank}].Item[${biSlot}].Name}
            /nomodkey /itemnotify in bank${biBank} ${biSlot} leftmouseup
            /delay 15 ${Cursor.ID} || ${Window[QuantityWnd].Open}
            /if (${Window[QuantityWnd].Open}) {
                /call SetQuantityWndValue ${biWantQty}
                /notify QuantityWnd QTYW_Accept_Button leftmouseup
                /delay 5 !${Window[QuantityWnd].Open}
                /if (${Window[QuantityWnd].Open}) /keypress ENTER
                /delay 5 ${Cursor.ID}
            } else /if (${biWantQty} > 1) {
                /if (!${Cursor.ID}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw Quantity window did not open; cannot pull ${biWantQty} of ${biName}.
                    /return FALSE
                }
                /varset biCursorStack ${Cursor.Stack}
                /if (${biCursorStack} <= 0) /varset biCursorStack 1
                /if (${biCursorStack} != ${biWantQty}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw No QuantityWnd; whole-slot pickup is ${biCursorStack}, need ${biWantQty} - returning.
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) /call ForceClearCursor
                    /return FALSE
                }
            }
            /if (!${Cursor.ID}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Failed to pick up ${biName} from bank${biBank} slot ${biSlot}.
                /return FALSE
            }
            /if (${Cursor.ID} != ${wantItemId}) {
                /echo ${tgTag} \ar[BANK ITEM]\aw Cursor mismatch (have ${Cursor.Name}, expected id ${wantItemId}) - returning.
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
                /return FALSE
            }
            /if (${biWantQty} > 1) {
                /varset biCursorStack ${Cursor.Stack}
                /if (${biCursorStack} <= 0) /varset biCursorStack 1
                /if (${biCursorStack} < ${biWantQty}) {
                    /echo ${tgTag} \ar[BANK ITEM]\aw Cursor has ${biCursorStack}, need ${biWantQty} - returning.
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) /call ForceClearCursor
                    /return FALSE
                }
            }
            /autoinventory
            /delay 10 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
            /if (${Cursor.ID}) /return FALSE
            /echo ${tgTag} \ag[BANK ITEM]\aw Pulled ${biWantQty}x ${biName} from bank${biBank} slot ${biSlot}.
            /return TRUE
        /next biSlot
    /next biBank

    /echo ${tgTag} \ar[BANK ITEM]\aw Item id ${wantItemId} was not found in open bank.
/return FALSE

Sub BankSendMyItem(string recipientName, int wantItemId)
    /if (!${recipientName.Length} || ${recipientName.Equal[NULL]} || ${recipientName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Invalid recipient '${recipientName}'.
        /return
    }
    /if (${Me.Feigning}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Cannot bank/give while feigned.
        /return
    }

    /declare wasFollowingBS bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingBS TRUE
        /squelch /afollow pause
    }

    | Verify the recipient exists before touching the bank item.
    /call AcquireTradeTarget "${recipientName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Cannot target ${recipientName} as a PC (same zone / in range?).
        /if (${wasFollowingBS}) /squelch /afollow unpause
        /return
    }

    /call PullExactBankItemById ${wantItemId} 1
    /if (!${Macro.Return.Equal[TRUE]}) {
        /if (${Window[BigBankWnd].Open}) {
            /notify BigBankWnd DoneButton leftmouseup
            /delay 5 !${Window[BigBankWnd].Open}
        }
        /if (${wasFollowingBS}) /squelch /afollow unpause
        /return
    }

    /if (${Window[BigBankWnd].Open}) {
        /notify BigBankWnd DoneButton leftmouseup
        /delay 5 !${Window[BigBankWnd].Open}
    }
    /if (${wasFollowingBS}) /squelch /afollow unpause

    /call SendMyItem "${recipientName}" ${wantItemId}
/return

Sub BankSendMyStack(string recipientName, int wantItemId, int wantQty)
    /if (!${recipientName.Length} || ${recipientName.Equal[NULL]} || ${recipientName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Invalid recipient '${recipientName}'.
        /return
    }
    /if (${wantItemId} <= 0 || ${wantQty} <= 0) {
        /echo ${tgTag} \ar[BANK SEND]\aw Invalid item id/qty (${wantItemId}x${wantQty}).
        /return
    }
    /if (${Me.Feigning}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Cannot bank/give while feigned.
        /return
    }

    /declare wasFollowingBSS bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingBSS TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${recipientName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[BANK SEND]\aw Cannot target ${recipientName} as a PC (same zone / in range?).
        /if (${wasFollowingBSS}) /squelch /afollow unpause
        /return
    }

    /call PullExactBankItemById ${wantItemId} ${wantQty}
    /if (!${Macro.Return.Equal[TRUE]}) {
        /if (${Window[BigBankWnd].Open}) {
            /notify BigBankWnd DoneButton leftmouseup
            /delay 5 !${Window[BigBankWnd].Open}
        }
        /if (${wasFollowingBSS}) /squelch /afollow unpause
        /return
    }

    /if (${Window[BigBankWnd].Open}) {
        /notify BigBankWnd DoneButton leftmouseup
        /delay 5 !${Window[BigBankWnd].Open}
    }
    /if (${wasFollowingBSS}) /squelch /afollow unpause

    /call SendMyStack "${recipientName}" ${wantItemId} ${wantQty}
/return

Sub PickupExactBagItemById(int wantItemId)
    /if (${wantItemId} <= 0) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Invalid item id.
        /return FALSE
    }
    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${Cursor.ID}) /return FALSE
    }

    /declare pbiPack int local
    /declare pbiSlot int local
    /declare pbiMaxSlots int local
    /declare pbiStack int local
    /declare pbiTry int local 0

    /for pbiPack 1 to 10
        /varset pbiMaxSlots ${Me.Inventory[pack${pbiPack}].Container}
        /if (${pbiMaxSlots} == 0) /continue
        /for pbiSlot 1 to ${pbiMaxSlots}
            /if (!${Me.Inventory[pack${pbiPack}].Item[${pbiSlot}].ID}) /continue
            /if (${Me.Inventory[pack${pbiPack}].Item[${pbiSlot}].ID} != ${wantItemId}) /continue
            /if (${Me.Inventory[pack${pbiPack}].Item[${pbiSlot}].NoDrop}) {
                /echo ${tgTag} \ar[SEND ITEM]\aw ${Me.Inventory[pack${pbiPack}].Item[${pbiSlot}].Name} is NO-DROP/attuned in bags - cannot trade.
                /return FALSE
            }
            /varset pbiStack ${Me.Inventory[pack${pbiPack}].Item[${pbiSlot}].Stack}
            /if (${pbiStack} <= 0) /varset pbiStack 1

            /if (${pbiStack} > 1) {
                :pbiRetryQty
                /if (${Cursor.ID}) {
                    /autoinventory
                    /delay 5 !${Cursor.ID}
                    /if (${Cursor.ID}) /call ForceClearCursor
                    /if (${Cursor.ID}) /return FALSE
                }
                /nomodkey /itemnotify in pack${pbiPack} ${pbiSlot} leftmouseup
                /delay 15 ${Window[QuantityWnd].Open} || ${Cursor.ID}
                /if (!${Window[QuantityWnd].Open}) {
                    /if (${Cursor.ID}) {
                        /autoinventory
                        /delay 5 !${Cursor.ID}
                        /if (${Cursor.ID}) /call ForceClearCursor
                    }
                    /varcalc pbiTry ${pbiTry}+1
                    /if (${pbiTry} < 3) /goto :pbiRetryQty
                    /return FALSE
                }
                /call SetQuantityWndValue 1
                /notify QuantityWnd QTYW_Accept_Button leftmouseup
                /delay 5 !${Window[QuantityWnd].Open}
                /if (${Window[QuantityWnd].Open}) /keypress ENTER
                /delay 5 ${Cursor.ID}
            } else {
                /nomodkey /shift /itemnotify in pack${pbiPack} ${pbiSlot} leftmouseup
                /delay 10 ${Cursor.ID}
            }

            /if (!${Cursor.ID}) /return FALSE
            /if (${Cursor.ID} != ${wantItemId}) {
                /echo ${tgTag} \ar[SEND ITEM]\aw Cursor item mismatch (have ${Cursor.Name}, expected id ${wantItemId}) - returning.
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
                /return FALSE
            }
            /if (${Cursor.NoDrop}) {
                /echo ${tgTag} \ar[SEND ITEM]\aw ${Cursor.Name} is NO-DROP/attuned on cursor - returning.
                /autoinventory
                /delay 5 !${Cursor.ID}
                /if (${Cursor.ID}) /call ForceClearCursor
                /return FALSE
            }
            /return TRUE
        /next pbiSlot
    /next pbiPack

    /echo ${tgTag} \ar[SEND ITEM]\aw Item id ${wantItemId} was not found as a movable bag item on ${Me.Name}.
/return FALSE

Sub SendMyItem(string recipientName, int wantItemId)
    /if (!${recipientName.Length} || ${recipientName.Equal[NULL]} || ${recipientName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Invalid recipient '${recipientName}'.
        /return
    }

    | ---- Resolve item from movable bag slots only. Global FindItem can return
    | worn attuned copies with the same ID, which must never drive Give Now. ----
    /declare siName string local
    /declare siPack int local
    /declare siSlot int local
    /declare siMaxSlots int local
    /if (${wantItemId} <= 0) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Invalid item id ${wantItemId}.
        /return
    }

    /for siPack 1 to 10
        /varset siMaxSlots ${Me.Inventory[pack${siPack}].Container}
        /if (${siMaxSlots} == 0) /continue
        /for siSlot 1 to ${siMaxSlots}
            /if (!${Me.Inventory[pack${siPack}].Item[${siSlot}].ID}) /continue
            /if (${Me.Inventory[pack${siPack}].Item[${siSlot}].ID} != ${wantItemId}) /continue
            /if (${Me.Inventory[pack${siPack}].Item[${siSlot}].NoDrop}) {
                /echo ${tgTag} \ar[SEND ITEM]\aw ${Me.Inventory[pack${siPack}].Item[${siSlot}].Name} is NO-DROP/attuned in bags - cannot trade.
                /return
            }
            /varset siName ${Me.Inventory[pack${siPack}].Item[${siSlot}].Name}
            /goto :siHaveBagItem
        /next siSlot
    /next siPack
    /echo ${tgTag} \ar[SEND ITEM]\aw Item id ${wantItemId} not found as a movable bag item on ${Me.Name} (equipped, banked, attuned, or stale sync?).
    /return

:siHaveBagItem

    | ---- Eligibility guards ----
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Cursor is occupied (${Cursor.Name}) - aborting before touching anything.
        /return
    }
    /if (${Me.Feigning}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Cannot trade while feigned.
        /return
    }

    /declare wasFollowingSI bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingSI TRUE
        /squelch /afollow pause
    }

    | ---- Acquire + approach the recipient ----
    /call AcquireTradeTarget "${recipientName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Cannot target ${recipientName} as a PC (same zone / in range?).
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }
    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 3

    | ---- Pick up exactly one copy by ID from bags only. Equipped/bank copies won't match. ----
    /call PickupExactBagItemById ${wantItemId}
    /if (!${Macro.Return.Equal[TRUE]}) {
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }
    /if (!${Cursor.ID}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Could not pick up ${siName} (is it in bags, not equipped/bank?).
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }
    /if (${wantItemId} > 0 && ${Cursor.ID} != ${wantItemId}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Cursor item mismatch (have ${Cursor.Name}, expected id ${wantItemId}) - returning.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }

    | ---- Open trade + drop item (drift-guarded; classic /click left target) ----
    /call VerifyTradeTarget "${recipientName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[SEND ITEM]\ay [SAFETY]\aw Target drift before trade - returning ${siName}.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }
    /nomodkey /click left target
    /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}

    /if (!${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[SEND ITEM]\aw Trade window did not open - returning ${siName}.
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
        }
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }

    | Cursor must clear to confirm the item landed in the trade window.
    /delay 5 !${Cursor.ID}
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ay[SEND ITEM]\aw Could not place ${siName} into trade (recipient bags full?) - returning.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Cancel_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }

    | ---- Finalize: accept on both sides (sender, then broadcast receiver) ----
    | Receiver accept mirrors the DC finalize; it uses /e3bct directly. On
    | non-E3 setups the recipient simply accepts the trade manually.
    /delay 10 ${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open} && !${Cursor.ID}) /notify TradeWnd TRDW_Trade_Button leftmouseup
    /squelch /e3bct ${recipientName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
    /delay 30 !${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open}) {
        /squelch /e3bct ${recipientName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
        /delay 30 !${Window[TradeWnd].Open}
    }

    /if (${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[SEND ITEM]\ay [SAFETY]\aw Trade stuck open - cancelling, item stays with ${Me.Name}.
        /notify TradeWnd TRDW_Cancel_Button leftmouseup
        /delay 10 !${Window[TradeWnd].Open}
        /if (${Cursor.ID}) {
            /autoinventory
            /if (${Cursor.ID}) /call ForceClearCursor
        }
        /if (${wasFollowingSI}) /squelch /afollow unpause
        /return
    }

    /echo ${tgTag} \ag[SEND ITEM]\aw Gave ${siName} to ${recipientName}.
    /call Announce "${announceMethod}" "${tgTag} \ag[SEND ITEM]\aw Gave ${siName} to ${recipientName}."
    /call RequestTurboGearTradeSync "${recipientName}"
    /if (${wasFollowingSI}) /squelch /afollow unpause
/return

| =====================================================================
| SEND STACK — give exactly QTY of an item (by id or name) to one recipient.
| Uses PickupExactItemCount (QuantityWnd fail-closed) + the same trade finalize
| as SendMyItem / hand. Opens bag containers once up front so partial splits
| pop reliably. CLI:
|   /mac turbogive send CHAR QTY Item Name...
|   /mac turbogive send CHAR QTY id ITEMID
|   /mac turbogive _sendstack CHAR ITEMID QTY
|   /mac turbogive _banksendstack CHAR ITEMID QTY  (pull qty from bank, then SendMyStack)
| =====================================================================
| OPEN packs only (never toggle-close). rightmouseup on an already-open pack
| closes it — that was causing Stock Even Out Have=0 / pickup fails mid-queue.
Sub OpenMyBagsOnce
    /declare ombPack int local
    /for ombPack 1 to 10
        /if (${Me.Inventory[pack${ombPack}].ID} && ${Me.Inventory[pack${ombPack}].Container} > 0) {
            /if (!${Window[pack${ombPack}].Open}) {
                /nomodkey /itemnotify pack${ombPack} rightmouseup
                /delay 1 ${Window[pack${ombPack}].Open}
            }
        }
    /next ombPack
    /delay 2
/return

| Back-compat alias — same open-only behavior (do not toggle).
Sub ToggleMyBagsOnce
    /call OpenMyBagsOnce
/return

Sub SendMyStackByName(string recipientName, string itemName, int wantQty)
    /if (!${itemName.Length} || ${itemName.Equal[NULL]}) {
        /echo ${tgTag} \ar[SEND]\aw Missing item name.
        /return
    }
    /declare smsFindId int local ${FindItem[=${itemName}].ID}
    /if (${smsFindId} <= 0) {
        /echo ${tgTag} \ar[SEND]\aw ${itemName} not found on ${Me.Name}.
        /return
    }
    /call SendMyStack "${recipientName}" ${smsFindId} ${wantQty}
/return

Sub SendMyStack(string recipientName, int wantItemId, int wantQty)
    /if (!${recipientName.Length} || ${recipientName.Equal[NULL]} || ${recipientName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \ar[SEND]\aw Invalid recipient '${recipientName}'.
        /return
    }
    /if (${wantItemId} <= 0) {
        /echo ${tgTag} \ar[SEND]\aw Invalid item id.
        /return
    }
    /if (${wantQty} <= 0) {
        /echo ${tgTag} \ar[SEND]\aw Qty must be > 0.
        /return
    }
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ar[SEND]\aw Cursor is occupied (${Cursor.Name}) - aborting.
        /return
    }
    /if (${Me.Feigning}) {
        /echo ${tgTag} \ar[SEND]\aw Cannot trade while feigned.
        /return
    }

    | Open packs before resolve/pickup (open-only; never toggle-close).
    /call OpenMyBagsOnce

    | Resolve a movable bag copy. Prefer pack scan; fall back to FindItem by id
    | (same id path as `send ... id`) so Param-order mistakes are clearer and
    | top-level bag items still resolve.
    /declare smsName string local
    /declare smsPack int local
    /declare smsSlot int local
    /declare smsMax int local
    /for smsPack 1 to 10
        /varset smsMax ${Me.Inventory[pack${smsPack}].Container}
        /if (${smsMax} == 0) /continue
        /for smsSlot 1 to ${smsMax}
            /if (!${Me.Inventory[pack${smsPack}].Item[${smsSlot}].ID}) /continue
            /if (${Me.Inventory[pack${smsPack}].Item[${smsSlot}].ID} != ${wantItemId}) /continue
            /if (${Me.Inventory[pack${smsPack}].Item[${smsSlot}].NoDrop}) {
                /echo ${tgTag} \ar[SEND]\aw ${Me.Inventory[pack${smsPack}].Item[${smsSlot}].Name} is NO-DROP - cannot trade.
                /return
            }
            /varset smsName ${Me.Inventory[pack${smsPack}].Item[${smsSlot}].Name}
            /goto :smsHaveName
        /next smsSlot
    /next smsPack
    /if (${FindItem[${wantItemId}].ID}) {
        /if (${FindItem[${wantItemId}].NoDrop}) {
            /echo ${tgTag} \ar[SEND]\aw ${FindItem[${wantItemId}].Name} is NO-DROP - cannot trade.
            /return
        }
        /varset smsName ${FindItem[${wantItemId}].Name}
        /goto :smsHaveName
    }
    /if (${FindItemBank[${wantItemId}].ID} || ${FindItemBankCount[${wantItemId}]} > 0) {
        /echo ${tgTag} \ar[SEND]\aw Item id ${wantItemId} is in the BANK on ${Me.Name} - move to bags first (Stock counts bank; send does not).
        /return
    }
    /echo ${tgTag} \ar[SEND]\aw Item id ${wantItemId} not on ${Me.Name} (bags/inventory). Have=${FindItemCount[${wantItemId}]}
    /return

:smsHaveName

    /declare wasFollowingSMS bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingSMS TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${recipientName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[SEND]\aw Cannot target ${recipientName}.
        /if (${wasFollowingSMS}) /squelch /afollow unpause
        /return
    }
    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 2

    /call RemotePauseBot "${recipientName}"

    /call OpenMyBagsOnce
    /call PickupExactItemCount "${smsName}" ${wantQty}
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[SEND]\aw Could not pick up ${wantQty}x ${smsName}.
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
        }
        /call RemoteResumeBot "${recipientName}"
        /if (${wasFollowingSMS}) /squelch /afollow unpause
        /return
    }
    /if (${Cursor.ID} != ${wantItemId} || ${Cursor.Stack} != ${wantQty}) {
        /echo ${tgTag} \ar[SEND]\aw Cursor mismatch (have ${Cursor.Stack}x ${Cursor.Name}, wanted ${wantQty}x id ${wantItemId}).
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /call RemoteResumeBot "${recipientName}"
        /if (${wasFollowingSMS}) /squelch /afollow unpause
        /return
    }

    /call VerifyTradeTarget "${recipientName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ay[SEND]\aw Target drift - returning stack.
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
        /call RemoteResumeBot "${recipientName}"
        /if (${wasFollowingSMS}) /squelch /afollow unpause
        /return
    }

    /notify TargetWindow Target_HP leftmouseup
    /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
    /if (${Cursor.ID} && !${Window[TradeWnd].Open}) {
        /click left target
        /delay 10 !${Cursor.ID} || ${Window[TradeWnd].Open}
    }
    /if (!${Window[TradeWnd].Open} || ${Cursor.ID}) {
        /echo ${tgTag} \ar[SEND]\aw Trade did not accept the stack - returning.
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
            /if (${Cursor.ID}) /call ForceClearCursor
        }
        /if (${Window[TradeWnd].Open}) {
            /notify TradeWnd TRDW_Cancel_Button leftmouseup
            /delay 10 !${Window[TradeWnd].Open}
        }
        /call RemoteResumeBot "${recipientName}"
        /if (${wasFollowingSMS}) /squelch /afollow unpause
        /return
    }

    /delay 5
    /if (${Window[TradeWnd].Open} && !${Cursor.ID}) /notify TradeWnd TRDW_Trade_Button leftmouseup
    /squelch /e3bct ${recipientName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
    /delay 40 !${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open}) {
        /squelch /e3bct ${recipientName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
        /delay 30 !${Window[TradeWnd].Open}
    }
    /if (${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[SEND]\ay Trade stuck - cancelling.
        /notify TradeWnd TRDW_Cancel_Button leftmouseup
        /delay 10 !${Window[TradeWnd].Open}
    } else {
        /echo ${tgTag} \ag[SEND]\aw Gave ${wantQty}x ${smsName} to ${recipientName}.
        /call Announce "${announceMethod}" "${tgTag} \ag[SEND]\aw Gave ${wantQty}x ${smsName} to ${recipientName}."
        /call RequestTurboGearTradeSync "${recipientName}"
    }

    /call RemoteResumeBot "${recipientName}"
    /if (${wasFollowingSMS}) /squelch /afollow unpause
/return

| =====================================================================
| CURRENCY: GIVE CASH (you send coin to a specific character)
| =====================================================================
Sub GiveCash(string targetName, int maxAmount)
    /if (${targetName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \arCannot give cash to yourself.
        /return
    }

    /declare myPlat int local ${Me.Platinum}
    /declare myGold int local ${Me.Gold}
    /declare mySilver int local ${Me.Silver}
    /declare myCopper int local ${Me.Copper}
    /if (${myPlat} <= 0 && ${myGold} <= 0 && ${mySilver} <= 0 && ${myCopper} <= 0) {
        /echo ${tgTag} \arYou have no coin.
        /return
    }

    /declare wasFollowingGC bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingGC TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${targetName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[GIVE CASH]\aw Cannot target ${targetName} as a PC.
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }

    /squelch /e3bct ${targetName} /squelch /afollow pause

    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 3

    /call OpenInventoryWindowForTrade
    /if (!${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[GIVE CASH] Could not open inventory window. (Check keybind: Options -> Keys -> Inventory)
        /squelch /e3bct ${targetName} /squelch /afollow unpause
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }

    /if (${myPlat} <= 0) /goto :GiveCashOpenMinor

    | Pickup retry counter — shared across both paths (LuaJIT footgun: declare once)
    /declare pickupTryGC int local 0

    | v1.7: maxAmount > 0 — use QuantityWnd path for exact amount
    | maxAmount = 0 — keep original shift-click "dump all" path (more reliable per author comment)
    /if (${maxAmount} > 0) {
        | Cap to what we actually have
        /if (${maxAmount} > ${myPlat}) /varset maxAmount ${myPlat}
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] GiveCash: capped maxAmount to ${maxAmount}pp (have ${myPlat}pp)"

        :RetryPickupGCQty
        /if (${Cursor.ID}) /autoinventory
        /delay 2
        /if (${Window[QuantityWnd].Open}) {
            /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        | Unshift click on plat row opens QuantityWnd (amount picker)
        /nomodkey /notify InventoryWindow IW_Money0 leftmouseup
        /delay 15 ${Window[QuantityWnd].Open}

        /if (!${Window[QuantityWnd].Open}) {
            /varcalc pickupTryGC ${pickupTryGC}+1
            /if (${pickupTryGC} < 3) {
                /keypress esc
                /delay 2
                /goto :RetryPickupGCQty
            }
            /echo ${tgTag} \ar[GIVE CASH]\aw QuantityWnd did not open after 3 attempts — cannot specify amount ${maxAmount}pp.
            /call ClearCashCursorStuck
            /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
            /squelch /e3bct ${targetName} /squelch /afollow unpause
            /if (${wasFollowingGC}) /squelch /afollow unpause
            /return
        }

        | Enter exact amount and accept
        /call SetQuantityWndValue ${maxAmount}
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 10 !${Window[QuantityWnd].Open}

        | Verify plat was actually picked up (plat often doesn't set Cursor.ID)
        /if (${Me.Platinum} >= ${myPlat} && !${Cursor.ID}) {
            /varcalc pickupTryGC ${pickupTryGC}+1
            /if (${pickupTryGC} < 3) {
                /keypress esc
                /delay 2
                /goto :RetryPickupGCQty
            }
            /echo ${tgTag} \ar[GIVE CASH]\aw Failed to pick up ${maxAmount}pp after 3 attempts (plat still in coin row).
            /call ClearCashCursorStuck
            /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
            /squelch /e3bct ${targetName} /squelch /afollow unpause
            /if (${wasFollowingGC}) /squelch /afollow unpause
            /return
        }
        /goto :GiveCashPickupDone
    }

    | Pick up plat — original shift-click "dump all" path (DoConv + Handin QuantityWnd — do not require Cursor.ID for coin)
    :RetryPickupGC
    /if (${Cursor.ID}) /autoinventory
    /delay 2
    /if (${Window[QuantityWnd].Open}) {
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 3
    }
    /shift /notify InventoryWindow IW_Money0 leftmouseup
    /delay 4
    /if (${Window[QuantityWnd].Open}) {
        /nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5
    }
    /if (${Me.Platinum} >= ${myPlat} && !${Cursor.ID}) {
        /varcalc pickupTryGC ${pickupTryGC}+1
        /if (${pickupTryGC} < 4) {
            /keypress esc
            /delay 2
            /goto :RetryPickupGC
        }
        /echo ${tgTag} \ar[GIVE CASH] Failed to pick up platinum after 4 attempts (plat still in coin row).
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /squelch /e3bct ${targetName} /squelch /afollow unpause
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }

    :GiveCashPickupDone
    | Initiate trade with retries (v1.7: hardened against wrong-target via OpenTradeWindow)
    /declare tradeTryGC int local 0
    :RetryTradeGC
    /call OpenTradeWindow "${targetName}"
    /if (!${Macro.Return.Equal[TRUE]}) {
        /varcalc tradeTryGC ${tradeTryGC}+1
        /if (${tradeTryGC} < 3) {
            /delay 3
            /goto :RetryTradeGC
        }
        /echo ${tgTag} \ar[GIVE CASH] Trade window did not open after 3 attempts. Returning coin.
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /squelch /e3bct ${targetName} /squelch /afollow unpause
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }
    /goto :GiveCashTradeReady

    :GiveCashOpenMinor
    /call TryOpenTradeWithMinorCoin "${targetName}"
    /if (!${Window[TradeWnd].Open}) {
        /echo ${tgTag} \ar[GIVE CASH] Could not open trade with gp/sp/cp (no platinum on character).
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /squelch /e3bct ${targetName} /squelch /afollow unpause
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }

    :GiveCashTradeReady
    | DoConv: TRDW when cursor clear; add remaining gp/sp/cp when draining all
    /delay 10
    /if (${Window[TradeWnd].Open} && ${Cursor.ID}) /delay 60 !${Cursor.ID}
    /if (${maxAmount} <= 0) /call OfferSecondaryCoinsToOpenTrade
    /if (${Window[TradeWnd].Open} && ${Cursor.ID}) /delay 60 !${Cursor.ID}
    /if (${Window[TradeWnd].Open} && !${Cursor.ID}) {
        /notify TradeWnd TRDW_Trade_Button leftmouseup
    } else /if (${Window[TradeWnd].Open} && ${Cursor.ID}) {
        /echo ${tgTag} \ay[GIVE CASH] Coin still on cursor after trade open — canceling and stashing.
        /call ClearCashCursorStuck
        /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
        /squelch /e3bct ${targetName} /squelch /afollow unpause
        /if (${wasFollowingGC}) /squelch /afollow unpause
        /return
    }

    | Tell target to accept — retry up to 3 times
    /declare acceptTryGC int local 0
    :RetryAcceptGC
    /squelch /e3bct ${targetName} /notify TradeWnd TRDW_Trade_Button LeftMouseUp
    /delay 20 !${Window[TradeWnd].Open}
    /if (${Window[TradeWnd].Open}) {
        /varcalc acceptTryGC ${acceptTryGC}+1
        /if (${acceptTryGC} < 3) /goto :RetryAcceptGC
    }

    | Stuck trade / coin on cursor after accept attempts
    /if (${Window[TradeWnd].Open} || ${Cursor.ID}) {
        /echo ${tgTag} \ay[GIVE CASH] Trade incomplete — canceling and returning coin to bags.
        /call ClearCashCursorStuck
    }
    /if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory

    /declare afterPlat int local ${Me.Platinum}
    /declare afterGold int local ${Me.Gold}
    /declare afterSilver int local ${Me.Silver}
    /declare afterCopper int local ${Me.Copper}
    /declare gaveAny bool local FALSE
    /if (${afterPlat} < ${myPlat}) /varset gaveAny TRUE
    /if (${afterGold} < ${myGold}) /varset gaveAny TRUE
    /if (${afterSilver} < ${mySilver}) /varset gaveAny TRUE
    /if (${afterCopper} < ${myCopper}) /varset gaveAny TRUE
    /if (${gaveAny}) {
        /echo ${tgTag} \ag[GIVE CASH]\aw Gave ${targetName}: ${Math.Calc[${myPlat}-${afterPlat}]}pp ${Math.Calc[${myGold}-${afterGold}]}gp ${Math.Calc[${mySilver}-${afterSilver}]}sp ${Math.Calc[${myCopper}-${afterCopper}]}cp.
        /call Announce "${announceMethod}" "${tgTag} \ag[GIVE CASH]\aw Gave ${targetName}: ${Math.Calc[${myPlat}-${afterPlat}]}pp ${Math.Calc[${myGold}-${afterGold}]}gp ${Math.Calc[${mySilver}-${afterSilver}]}sp ${Math.Calc[${myCopper}-${afterCopper}]}cp."
    } else {
        /echo ${tgTag} \ar[GIVE CASH] Trade may have failed - coin unchanged.
    }
    /squelch /e3bct ${targetName} /squelch /afollow unpause
    /if (${wasFollowingGC}) /squelch /afollow unpause
/return

| =====================================================================
| CURRENCY: GIVE DC (you send Diamond Coins to a specific character)
| =====================================================================
Sub GiveDC(string targetName, int maxAmount)
    /if (${targetName.Equal[${Me.Name}]}) {
        /echo ${tgTag} \arCannot give DC to yourself.
        /return
    }

    /declare dcCount int local ${FindItemCount[=Diamond Coin]}
    /if (${dcCount} <= 0 && ${Me.AltCurrency[20]} > 0) {
        /if (!${Me.FreeInventory}) {
            /echo ${tgTag} \ay[GIVE DC]\aw No open inventory slots to create Diamond Coin. Free bag space and re-run.
            /return
        }
        /call ConvertAltDC2Currency ${If[${maxAmount}>0 && ${maxAmount}<7000,${maxAmount},7000]}
        /varset dcCount ${FindItemCount[=Diamond Coin]}
    }
    /if (${dcCount} <= 0) {
        /echo ${tgTag} \arYou have no Diamond Coin.
        /return
    }

    /declare wasFollowingGD bool local FALSE
    /if (${AdvPath.Following}) {
        /varset wasFollowingGD TRUE
        /squelch /afollow pause
    }

    /call AcquireTradeTarget "${targetName}"
    /if (!${_tradeTargetID}) {
        /echo ${tgTag} \ar[GIVE DC]\aw Cannot target ${targetName} as a PC.
        /if (${wasFollowingGD}) /squelch /afollow unpause
        /return
    }

    /squelch /e3bct ${targetName} /squelch /afollow pause

    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${_tradeTargetID} 10 300
    }
    /face fast
    /delay 3

    | v1.8.1: two-level loop. Outer = trade sessions (high safety cap).
    | Inner loop lives in FillAndFinalizeDCTrade (caps at 7 slots/session).
    /declare dcTraded int local 0
    /declare outerSess int local 0
    /declare outerCap int local 400
    /declare sessTraded int local 0
    /declare remainingCap int local 0

    :GiveMoreDC
    /varcalc outerSess ${outerSess}+1
    /if (${outerSess} > ${outerCap}) {
        /echo ${tgTag} \ar[GIVE DC]\ay [SAFETY]\aw Hard cap hit after ${outerCap} sessions - re-run for remaining DC.
        /goto :GiveDCDone
    }
    /if (${maxAmount} > 0 && ${dcTraded} >= ${maxAmount}) /goto :GiveDCDone
    /varset remainingCap ${If[${maxAmount}>0,${Math.Calc[${maxAmount}-${dcTraded}].Int},0]}
    /if (${FindItemCount[=Diamond Coin]} <= 0 && ${Me.AltCurrency[20]} > 0) {
        /if (!${Me.FreeInventory}) {
            /echo ${tgTag} \ay[GIVE DC]\aw No open inventory slots to create more Diamond Coin. Stopping after ${dcTraded} sent.
            /goto :GiveDCDone
        }
        /call ConvertAltDC2Currency ${If[${remainingCap}>0 && ${remainingCap}<7000,${remainingCap},7000]}
    }
    /if (${FindItemCount[=Diamond Coin]} <= 0) /goto :GiveDCDone

    /varset remainingCap ${If[${maxAmount}>0,${Math.Calc[${maxAmount}-${dcTraded}].Int},0]}

    /call FillAndFinalizeDCTrade "${targetName}" ${remainingCap}
    /varset sessTraded ${Macro.Return}
    /varcalc dcTraded ${dcTraded}+${sessTraded}

    /if (${_dcAbortReceiverFull}) {
        /echo ${tgTag} \ay[GIVE DC]\aw ${targetName}'s bags/trade slots are full - stopping. Free inventory space on ${targetName}, then re-run for remaining DC.
        /goto :GiveDCDone
    }
    /if (${_dcTradeAborted}) /goto :GiveDCDone
    /if (${sessTraded} <= 0) /goto :GiveDCDone

    /delay 5
    /goto :GiveMoreDC

    :GiveDCDone
    /echo ${tgTag} \ag[GIVE DC]\aw Gave ${dcTraded} Diamond Coin to ${targetName} in ${outerSess} session(s).
    /if (${dcTraded} > 0) /call Announce "${announceMethod}" "${tgTag} \ag[GIVE DC]\aw Gave ${dcTraded} Diamond Coin to ${targetName} in ${outerSess} session(s)."
    /squelch /e3bct ${targetName} /squelch /afollow unpause
    /if (${wasFollowingGD}) /squelch /afollow unpause
/return

| =====================================================================
| CURRENCY: CONVERT (AA <-> DC via NPC)
| =====================================================================
Sub ConvertCurrency(string convType, int amount)
    | Must be in PoK or Temple of Marr
    /declare convNPC string local
    /if (${Zone.ShortName.Equal[poknowledge]}) {
        /varset convNPC Amphrtxi
    } else /if (${Zone.ShortName.Equal[freeporttemple]}) {
        /varset convNPC Hoodah
    } else {
        /echo ${tgTag} \arYou must be in Plane of Knowledge or Temple of Marr to convert.
        /return
    }

    /declare convNPCID int local ${Spawn[=${convNPC}].ID}
    /if (!${convNPCID}) {
        /echo ${tgTag} \arCannot find conversion NPC ${convNPC}.
        /return
    }

    | Navigate to NPC
    /squelch /target id ${convNPCID}
    /delay 5 ${Target.ID} == ${convNPCID}
    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${convNPCID} 10 300
    }
    /face fast
    /delay 5

    /declare typeUp string local ${convType.Upper}
    /if (${typeUp.Equal[AA]}) {
        /declare currentAA int local ${Me.AAPoints}
        /declare convAmt int local ${If[${amount}>0,${amount},${currentAA}]}
        /if (${convAmt} <= 0 || ${currentAA} <= 0) {
            /echo ${tgTag} \arNo unspent AA to convert.
            /return
        }
        /if (${convAmt} > ${currentAA}) /varset convAmt ${currentAA}
        /declare dcResult int local ${Math.Calc[${convAmt}*3]}
        /echo ${tgTag} \am[CONVERT]\aw Converting ${convAmt} AA to ${dcResult} DC...
        /say convert AA ${convAmt}
        /delay 10
        /echo ${tgTag} \am[CONVERT]\aw Done. AA: ${Me.AAPoints}
    } else /if (${typeUp.Equal[DC]}) {
        | Reclaim inventory DC to alt-currency first
        /if (${FindItemCount[=Diamond Coin]} > 0) {
            /call ReclaimAltDC
        }
        /declare currentDC int local ${Me.AltCurrency[20]}
        /declare convAmtDC int local ${If[${amount}>0,${Math.Calc[${amount}*3]},${currentDC}]}
        /if (${convAmtDC} <= 0 || ${currentDC} <= 0) {
            /echo ${tgTag} \arNo Diamond Coin to convert.
            /return
        }
        /if (${convAmtDC} > ${currentDC}) /varset convAmtDC ${currentDC}
        /declare aaResult int local ${Math.Calc[${convAmtDC}/3]}
        /echo ${tgTag} \am[CONVERT]\aw Converting ${convAmtDC} DC to ${aaResult} AA...
        /say convert DC ${aaResult}
        /delay 10
        /echo ${tgTag} \am[CONVERT]\aw Done. AA: ${Me.AAPoints}
    }
/return

| =====================================================================
| CURRENCY: CONVERT ALT-CURRENCY DC TO INVENTORY DC
| =====================================================================
Sub SelectDiamondCoinAltCurrency(string contextTag)
    /declare dcListID int local 0
    /declare ctx string local ${contextTag}
    /if (!${ctx.Length} || ${ctx.Equal[NULL]}) /varset ctx EXCHANGE

    /if (!${Window[InventoryWindow].Open}) {
        /echo ${tgTag} \ar[${ctx}]\aw Inventory window is not open; cannot select Diamond Coins.
        /return 0
    }

    /notify InventoryWindow IW_Subwindows tabselect 5
    /delay 5

    | Do not assume Diamond Coin is always row 2; resolve the row by list text.
    /varset dcListID ${Window[InventoryWindow].Child[IW_AltCurr_PointList].List[=Diamond Coins,2]}
    /if (${dcListID} <= 0) /varset dcListID ${Window[InventoryWindow].Child[IW_AltCurr_PointList].List[=Diamond Coin,2]}
    /if (${dcListID} <= 0) {
        /echo ${tgTag} \ar[${ctx}]\aw Could not find Diamond Coins in the Alt Currency list. Open Inventory -> Alt Currency and confirm the row name.
        /return 0
    }

    /notify InventoryWindow IW_AltCurr_PointList listselect ${dcListID} leftmouseup
    /delay 3
/return ${dcListID}

Sub ConvertAltDC2Currency(int maxAmount)
    /declare altDC int local ${Me.AltCurrency[20]}
    /if (${altDC} <= 0) {
        /echo ${tgTag} \awNo alt-currency DC to convert.
        /return
    }
    | Lazarus Diamond Coin inventory stacks cap at 200 per Create click.
    /declare dcCreateStackMax int local 200
    /declare convertLimit int local ${maxAmount}
    /if (${convertLimit} <= 0 || ${convertLimit} > ${altDC}) /varset convertLimit ${altDC}
    /declare convertedDC int local 0
    /declare beforeAltDC int local 0
    /declare afterAltDC int local 0
    /declare madeDC int local 0
    /declare beforeInvDC int local 0
    /declare afterInvDC int local 0
    /declare madeInvDC int local 0
    /declare createThis int local 0

    /echo ${tgTag} \am[EXCHANGE]\aw Converting up to ${convertLimit} alt-currency DC to inventory...

    /call OpenInventoryWindowForTrade
    /if (!${Macro.Return}) {
        /echo ${tgTag} \ar[EXCHANGE]\aw Could not open inventory window. (Check keybind: Options -> Keys -> Inventory)
        /return
    }

    /call SelectDiamondCoinAltCurrency EXCHANGE
    /if (${Macro.Return} <= 0) /goto :DoneCreateDC

    :CreateMoreDC
    /if (${convertedDC} >= ${convertLimit}) /goto :DoneCreateDC
    /if (${Me.AltCurrency[20]} <= 0) /goto :DoneCreateDC
    /if (!${Me.FreeInventory} && ${FindItemCount[=Diamond Coin]} <= 0) {
        /echo ${tgTag} \ay[EXCHANGE]\aw No open inventory slots for Diamond Coin. Free bag space and re-run.
        /goto :DoneCreateDC
    }

    /varset beforeAltDC ${Me.AltCurrency[20]}
    /varset beforeInvDC ${FindItemCount[=Diamond Coin]}
    /varset createThis ${Math.Calc[${convertLimit}-${convertedDC}].Int}
    /if (${createThis} > ${beforeAltDC}) /varset createThis ${beforeAltDC}
    /if (${createThis} > ${dcCreateStackMax}) /varset createThis ${dcCreateStackMax}

    /nomodkey /notify InventoryWindow AltCurr_CreateItemButton LeftMouseUp
    /delay 5

    /if (${Window[QuantityWnd].Open}) {
        | Full stacks: QuantityWnd defaults to 200 — accept without slow digit typing.
        /if (${createThis} < ${dcCreateStackMax}) {
            /call SetQuantityWndValue ${createThis}
        }
        /nomodkey /notify QuantityWnd QTYW_Accept_Button LeftMouseUp
        /delay 5
    }

    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) {
            /autoi
            /delay 5 !${Cursor.ID}
        }
    }
    /if (${Cursor.ID}) {
        /echo ${tgTag} \ay[EXCHANGE]\aw Inventory is full; could not place ${Cursor.Name}. Stopping conversion.
        /call ForceClearCursor
        /goto :DoneCreateDC
    }

    /varset afterAltDC ${Me.AltCurrency[20]}
    /varset afterInvDC ${FindItemCount[=Diamond Coin]}
    /varset madeDC ${Math.Calc[${beforeAltDC}-${afterAltDC}].Int}
    /varset madeInvDC ${Math.Calc[${afterInvDC}-${beforeInvDC}].Int}
    /if (${madeDC} <= 0 && ${madeInvDC} > 0) /varset madeDC ${madeInvDC}
    /if (${madeDC} <= 0 && ${madeInvDC} <= 0) {
        /echo ${tgTag} \ay[EXCHANGE]\aw No DC was created this click. Stopping conversion.
        /goto :DoneCreateDC
    }
    /varcalc convertedDC ${convertedDC}+${madeDC}
    /goto :CreateMoreDC

    :DoneCreateDC
    /if (${Window[InventoryWindow].Open}) /nomodkey /notify InventoryWindow DoneButton leftmouseup
    /echo ${tgTag} \am[EXCHANGE]\aw Done. Inventory DC: ${FindItemCount[=Diamond Coin]}
/return

| =====================================================================
| CURRENCY: RECLAIM INVENTORY DC TO ALT-CURRENCY
| =====================================================================
Sub ReclaimAltDC
    /declare invDC int local ${FindItemCount[=Diamond Coin]}
    /if (${invDC} <= 0) /return
    /declare quietReclaim bool local FALSE
    /if (${Defined[_quietReclaim]} && ${_quietReclaim}) /varset quietReclaim TRUE

    /if (!${quietReclaim} || ${showDebug}) /echo ${tgTag} \am[RECLAIM]\aw Reclaiming ${invDC} inventory DC to alt-currency...

    /call OpenInventoryWindowForTrade
    /if (!${Macro.Return}) {
        /echo ${tgTag} \ar[RECLAIM]\aw Could not open inventory window. (Check keybind: Options -> Keys -> Inventory)
        /return
    }

    /call SelectDiamondCoinAltCurrency RECLAIM
    /if (${Macro.Return} <= 0) {
        /if (${Window[InventoryWindow].Open}) /nomodkey /notify InventoryWindow DoneButton leftmouseup
        /return
    }

    /nomodkey /notify InventoryWindow AltCurr_ReclaimButton LeftMouseUp
    /delay 5

    /if (${Window[InventoryWindow].Open}) /nomodkey /notify InventoryWindow DoneButton leftmouseup
    /if (!${quietReclaim} || ${showDebug}) /echo ${tgTag} \am[RECLAIM]\aw Done. Alt-currency DC: ${Me.AltCurrency[20]}
/return

| =====================================================================
| NPC HAND-IN (quest turn-ins, coin to NPCs)
| =====================================================================
Sub HandinToNPC(string itemArg, int amount, string destroyMode)
    /echo ${tgTag} \ay[HANDIN]\aw Handing in: ${itemArg}${If[${amount}>0, x${amount},]}${If[${destroyMode.Length}, (destroy rewards),]} to target NPC...

    | Validate target
    /if (!${Target.ID}) {
        /echo ${tgTag} \arNo target selected. Target an NPC first.\ax
        /return
    }
    /if (${Target.Type.Equal[PC]}) {
        /echo ${tgTag} \arTarget is a player, not an NPC. Use give/collect for players.\ax
        /return
    }

    | Hard-block (1.8.9): refuse manual handin of always-skip items even
    | when the user explicitly types `handin "Item"`. Coin shortcuts
    | (PP/GP/SP/CP/DC/AA) are not item names so IsHardBlocked returns
    | FALSE for them — coin handin paths are unaffected.
    /call IsHardBlocked "${itemArg}"
    /if (${Macro.Return.Equal[TRUE]}) {
        /echo ${tgTag} \ar[HANDIN]\aw Refusing to hand in \ay${itemArg}\aw - this item is on TurboGive's hardcoded always-skip list (see Sub IsHardBlocked).\ax
        /return
    }

    | Set up handin stop flag
    /if (!${Defined[_handinStop]}) {
        /declare _handinStop bool outer FALSE
    } else {
        /varset _handinStop FALSE
    }

    | Open inventory if needed
    /if (!${Window[InventoryWindow].Open}) {
        /keypress i
        /delay 10 ${Window[InventoryWindow].Open}
    }

    | Clear cursor
    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
    }

    /declare isCoin bool local FALSE
    /declare coinSlot string local
    /declare itemArgUp string local ${itemArg.Upper}
    /if (${itemArgUp.Equal[PP]}) {
        /varset isCoin TRUE
        /varset coinSlot IW_Money0
    } else /if (${itemArgUp.Equal[GP]}) {
        /varset isCoin TRUE
        /varset coinSlot IW_Money1
    } else /if (${itemArgUp.Equal[SP]}) {
        /varset isCoin TRUE
        /varset coinSlot IW_Money2
    } else /if (${itemArgUp.Equal[CP]}) {
        /varset isCoin TRUE
        /varset coinSlot IW_Money3
    }

    /declare handedIn int local 0
    /declare targetID int local ${Target.ID}
    /declare maxLoop int local ${If[${amount}>0,${amount},9999]}

:HandinLoop
    /doevents
    /if (${_handinStop}) {
        /echo ${tgTag} \ay[HANDIN]\aw NPC rejected or ran out. Handed in \ag${handedIn}\aw.
        /goto :HandinCleanup
    }
    /if (${handedIn} >= ${maxLoop}) /goto :HandinDone

    | Make sure target is still valid
    /if (!${Target.ID} || ${Target.ID} != ${targetID}) {
        /squelch /target id ${targetID}
        /delay 5 ${Target.ID} == ${targetID}
        /if (!${Target.ID}) {
            /echo ${tgTag} \arLost NPC target.\ax
            /goto :HandinCleanup
        }
    }

    | Nav if too far
    /if (${Target.Distance} > 15) {
        /call NavToIDWithDoorsAndNudges ${targetID} 10 300
    }
    /face fast

    | Pick up the item or coin
    /if (${isCoin}) {
        | Coin hand-in
        /declare coinHave int local 0
        /if (${itemArgUp.Equal[PP]}) /varset coinHave ${Me.Platinum}
        /if (${itemArgUp.Equal[GP]}) /varset coinHave ${Me.Gold}
        /if (${itemArgUp.Equal[SP]}) /varset coinHave ${Me.Silver}
        /if (${itemArgUp.Equal[CP]}) /varset coinHave ${Me.Copper}
        /if (${coinHave} <= 0) {
            /echo ${tgTag} \arOut of ${itemArg}.\ax
            /goto :HandinDone
        }
        /declare coinAmt int local ${If[${amount}>0,${amount},${coinHave}]}
        /if (${coinAmt} > ${coinHave}) /varset coinAmt ${coinHave}

        /notify InventoryWindow ${coinSlot} leftmouseup
        /delay 5 ${Window[QuantityWnd].Open}
        /if (${Window[QuantityWnd].Open}) {
            /call SetQuantityWndValue ${coinAmt}
            /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 3
        }
        /varcalc handedIn ${handedIn}+${coinAmt}
        | Coin is one-shot, set maxLoop to break after
        /varset maxLoop ${handedIn}
    } else {
        | Item hand-in
        /if (!${FindItem[=${itemArg}].ID}) {
            /echo ${tgTag} \awOut of \ag${itemArg}\aw after ${handedIn} hand-ins.\ax
            /goto :HandinDone
        }
        /if (${amount} == 1 || (${amount} == 0 && ${FindItemCount[=${itemArg}]} == 1)) {
            /ctrl /itemnotify "${FindItem[=${itemArg}].ItemSlot}" leftmouseup
        } else {
            /nomodkey /itemnotify "${FindItem[=${itemArg}].ItemSlot}" leftmouseup
            /delay 5 ${Window[QuantityWnd].Open} || ${Cursor.ID}
            /if (${Window[QuantityWnd].Open}) {
                /declare pickAmt int local ${If[${amount}>0,${Math.Calc[${amount}-${handedIn}]},9999]}
                /call SetQuantityWndValue ${pickAmt}
                /notify QuantityWnd QTYW_Accept_Button leftmouseup
                /delay 3
            }
        }
        /delay 5 ${Cursor.ID}
        /if (!${Cursor.ID}) {
            /echo ${tgTag} \arFailed to pick up ${itemArg}.\ax
            /goto :HandinCleanup
        }
    }

    | Click target to place item/coin
    /click left target
    /doevents
    /delay 5

    | Wait for GiveWnd (NPC give window) with timeout
    /declare giveWait int local 0
    /while (!${Window[GiveWnd].Open} && ${giveWait} < 50) {
        /delay 1
        /doevents
        /varcalc giveWait ${giveWait}+1
    }
    /if (!${Window[GiveWnd].Open}) {
        /echo ${tgTag} \arGive window did not open. Aborting.\ax
        /if (${Cursor.ID}) /autoinventory
        /goto :HandinCleanup
    }

    | Click Give
    /notify GiveWnd GVW_Give_Button leftmouseup
    /doevents
    /delay 5

    | Handle reward on cursor
    /if (${Cursor.ID}) {
        /call HandleHandinReward "${destroyMode}"
    }
    /delay 3
    | Handle any additional rewards
    /if (${Cursor.ID}) {
        /call HandleHandinReward "${destroyMode}"
    }

    /if (!${isCoin}) /varcalc handedIn ${handedIn}+1

    /goto :HandinLoop

:HandinDone
    /echo ${tgTag} \ay[HANDIN]\aw Complete. Handed in \ag${handedIn}\aw ${If[${isCoin},${itemArg},${itemArg}(s)]}.
    /if (${handedIn} > 0) /call Announce "${announceMethod}" "${tgTag} \ay[HANDIN]\aw Complete. Handed in \ag${handedIn}\aw ${If[${isCoin},${itemArg},${itemArg}(s)]}."

:HandinCleanup
    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
    }
    /if (${Window[GiveWnd].Open}) {
        /keypress esc
        /delay 5 !${Window[GiveWnd].Open}
    }
/return

| =====================================================================
| HANDLE HAND-IN REWARD (keep, destroy, or check INI)
| =====================================================================
Sub HandleHandinReward(string destroyMode)
    /if (!${Cursor.ID}) /return

    /declare rewardName string local ${Cursor.Name}
    /declare rewardRule string local

    | Check if destroy was explicitly requested
    /if (${destroyMode.Length} && ${destroyMode.Upper.Equal[DESTROY]}) {
        /destroy
        /delay 3
        /if (${Window[ConfirmationDialogBox].Open}) /notify ConfirmationDialogBox Yes_Button leftmouseup
        /delay 5 !${Cursor.ID}
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Handin reward destroyed: ${rewardName}"
        /return
    }

    | Check INI for this reward item
    /declare iniFile2 string local ../Config/turboloot.ini
    /declare rewardIniProfile string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /if (${rewardIniProfile.Length} && !${rewardIniProfile.Equal[NULL]} && !${rewardIniProfile.Equal[null]}) {
        /if (${Ini.File[../Config/${rewardIniProfile}].Exists}) {
            /varset iniFile2 ../Config/${rewardIniProfile}
        } else /if (${Ini.File[../Macros/${rewardIniProfile}].Exists}) {
            /varset iniFile2 ../Macros/${rewardIniProfile}
        }
    }
    /if (!${Ini.File[${iniFile2}].Exists}) /varset iniFile2 ../Config/turboloot.ini
    /if (!${Ini.File[${iniFile2}].Exists}) /varset iniFile2 ../Macros/turboloot.ini
    /if (${Ini.File[${iniFile2}].Exists}) {
        /varset rewardRule ${Ini[${iniFile2},ItemLimits,${rewardName}]}
        /if (!${rewardRule.Length} || ${rewardRule.Equal[NULL]}) {
            /varset rewardRule ${Ini[${iniFile2},ItemLimits,${rewardName.Upper}]}
        }
        /if (${rewardRule.Length} && !${rewardRule.Equal[NULL]}) {
            /declare ruleUp string local ${rewardRule.Upper}
            /if (${ruleUp.Equal[DESTROY]} || ${ruleUp.Equal[IGNORE]} || ${ruleUp.Equal[SKIP]}) {
                /destroy
                /delay 3
                /if (${Window[ConfirmationDialogBox].Open}) /notify ConfirmationDialogBox Yes_Button leftmouseup
                /delay 5 !${Cursor.ID}
                /echo ${tgTag} \ay[HANDIN]\aw Reward \ar${rewardName}\aw destroyed (INI: ${rewardRule}).
                /return
            }
        }
    }

    | Default: keep the reward
    /autoinventory
    /delay 5 !${Cursor.ID}
    /if (${Cursor.ID}) {
        /autoi
        /delay 5 !${Cursor.ID}
    }
    /echo ${tgTag} \ay[HANDIN]\aw Reward kept: \ag${rewardName}\ax
/return

| =====================================================================
| HAND-IN EVENT HANDLERS
| =====================================================================
Sub Event_HandinNotWanted
    /if (${Defined[_handinStop]}) /varset _handinStop TRUE
    /echo ${tgTag} \ay[HANDIN]\aw NPC doesn't want this item.
/return

Sub Event_HandinNoItems
    /if (${Defined[_handinStop]}) /varset _handinStop TRUE
/return

| =====================================================================
| UTILITY SUBS
| =====================================================================
Sub CloseBags
    /declare bag int local
    /for bag 1 to 10
        /if (${Window[pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
    /next bag
    /if (${Window[InventoryWindow].Open}) /nomodkey /notify InventoryWindow DoneButton leftmouseup
/return

| ForceClearCursor — retry /autoinventory up to 5 times (TurboLoot pattern for cursor-stuck resilience)
Sub ForceClearCursor
    /declare clearTries int local 0
    /while (${Cursor.ID} && ${clearTries} < 5) {
        /varcalc clearTries ${clearTries}+1
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboGive] Cursor has item: ${Cursor.Name} - clearing (attempt ${clearTries})"
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) {
            /autoi
            /delay 5 !${Cursor.ID}
        }
    }
/return

Sub LogDebug(string msg)
    /if (${showDebug}) /echo ${msg}
    /if (${logToFile} && ${logLevel} <= 0) {
        /call StripColorCodes "${msg}"
        /squelch /mqlog [${Time}] [turboGive] [DEBUG] ${Macro.Return}
    }
/return

| LogInfo: informational; echo when showDebug, file when logToFile and logLevel<=INFO
Sub LogInfo(string msg)
    /if (${showDebug}) /echo ${msg}
    /if (${logToFile} && ${logLevel} <= 1) {
        /call StripColorCodes "${msg}"
        /squelch /mqlog [${Time}] [turboGive] [INFO] ${Macro.Return}
    }
/return

| LogWarn: always echo (yellow); file when logToFile and logLevel<=WARN
Sub LogWarn(string msg)
    /echo ${tgTag} \ay${msg}
    /if (${logToFile} && ${logLevel} <= 2) {
        /call StripColorCodes "${msg}"
        /squelch /mqlog [${Time}] [turboGive] [WARN] ${Macro.Return}
    }
/return

| LogError: always echo (red); file when logToFile and logLevel<=ERROR
Sub LogError(string msg)
    /echo ${tgTag} \ar${msg}
    /if (${logToFile} && ${logLevel} <= 3) {
        /call StripColorCodes "${msg}"
        /squelch /mqlog [${Time}] [turboGive] [ERROR] ${Macro.Return}
    }
/return

Sub StripColorCodes(string msg)
    /declare result string local ${msg}
    /varset result ${result.Replace[\at,]}
    /varset result ${result.Replace[\ao,]}
    /varset result ${result.Replace[\ag,]}
    /varset result ${result.Replace[\ar,]}
    /varset result ${result.Replace[\am,]}
    /varset result ${result.Replace[\au,]}
    /varset result ${result.Replace[\aw,]}
    /varset result ${result.Replace[\ax,]}
    /varset result ${result.Replace[\ay,]}
    /varset result ${result.Replace[\ap,]}
/return ${result}

Sub Announce(string method, string msg)
    /if (!${method.Length}) /return
    /declare cleanMethod string local ${method}
:trimAnnounceSlash
    /if (${cleanMethod.Left[1].Equal[/]}) {
        /varset cleanMethod ${cleanMethod.Right[-1]}
        /goto :trimAnnounceSlash
    }
    /if (!${cleanMethod.Length}) /return
    /declare mUpper string local ${cleanMethod.Upper.Replace[ ,]}
    /if (${mUpper.Equal[OFF]} || ${mUpper.Equal[FALSE]} || ${mUpper.Equal[NO]} || ${mUpper.Equal[0]}) /return
    /if (${mUpper.Equal[GROUP]}) /varset cleanMethod g
    /if (${mUpper.Equal[RAID]}) /varset cleanMethod rsay
    /if (${mUpper.Equal[GUILD]}) /varset cleanMethod gu
    /if (${mUpper.Equal[S]}) /varset cleanMethod say
    /varset mUpper ${cleanMethod.Upper.Replace[ ,]}
    /if (${mUpper.Equal[ECHO]} || ${mUpper.Equal[E3BC]}) {
        /squelch /docommand /${cleanMethod} ${msg}
        /return
    }
    | Public chat channels should not receive MQ color codes.
    /call StripColorCodes "${msg}"
    /docommand /${cleanMethod} ${Macro.Return}
/return
