#turbo 100
#event Unlootable "You may not loot this corpse at this time."
#event TooFar "You are too far away to loot that corpse."
#event CursorOccupied "You may not loot an item while you have an item on your cursor."
|| Lazarus/RoF2 duplicate LORE denial (allow trailing punctuation/extra text)
#event LoreAlreadyPossess "You cannot pick up #1# because it is a lore item you already possess#*#"
|| Common alternate LORE denial (no item name in message)
#event LoreAlreadyPossessNoName "You already possess that item#*#"
|| P99-style duplicate LORE denial (no item name in message)
#event LoreAlreadyHaveOne "You cannot loot this Lore Item. You already have one#*#"
|| Exact-match variant (some clients/servers don't append extra characters)
#event LoreAlreadyHaveOneExact "You cannot loot this Lore Item. You already have one."
|| Generic catch-all for lore loot denial (covers punctuation/extra suffix text)
#event LoreDeniedGeneric "You cannot loot this Lore Item#*#"

Sub TurboLootVersion
    /return 3.9.76
/return

| ---------------------------------------------------------------------
| MAIN
| ---------------------------------------------------------------------
Sub Main
    /declare mode string local ${Param0.Upper}
    | Check for dry-run flag (supports: dryrun, dry, preview, --dryrun)
    /declare dryRunParam string local ${Param1.Upper}
    /declare isDryRun bool local FALSE
    /if (${dryRunParam.Length} && (${dryRunParam.Equal[DRYRUN]} || ${dryRunParam.Equal[DRY]} || ${dryRunParam.Equal[PREVIEW]} || ${dryRunParam.Equal[--DRYRUN]})) {
        /varset isDryRun TRUE
    }
    
    /if (${Defined[turboLootRunning]}) /deletevar turboLootRunning
    /declare turboLootRunning bool global TRUE
    /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
    /declare turboLootSafetyNet int global 1
    /if (!${Defined[turboLootCooldown]}) /declare turboLootCooldown int global 0

    | Help/commands (prints list and exits)
    /if (${mode.Equal[HELP]} || ${mode.Equal[COMMANDS]} || ${mode.Equal[CMDS]}) {
        /call PrintCommandsAndToggles
        /return
    }

    /if (${mode.Equal[DOCTOR]} || ${mode.Equal[DIAG]} || ${mode.Equal[CHECK]}) {
        /call TurboDoctor
        /return
    }
    
    | Detect if user accidentally ran "/mac turboloot dryrun" instead of "/mac turboloot sell dryrun"
    /if (${mode.Equal[DRYRUN]} || ${mode.Equal[DRY]} || ${mode.Equal[PREVIEW]}) {
        /echo \at[turboLoot] \arERROR: Invalid command syntax!
        /echo \at[turboLoot] \ayYou ran: \aw/mac turboloot ${mode}
        /echo \at[turboLoot] \ayCorrect usage:
        /echo \at[turboLoot]   \ag/mac turboloot sell dryrun\aw - Preview what would be sold
        /echo \at[turboLoot] \ayAlternative syntax: \awdry\ay, \awpreview\ay, or \aw--dryrun\aw also work
        /return
    }

    /call SetTurboLootActive ON

    /if (${mode.Equal[SELL]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal SELL
        /declare dryRun bool outer ${isDryRun}
        /if (!${isDryRun}) /call StopChaseForUtility
        /call PauseAFollow
        /if (${isDryRun}) {
            /call AutoSellDryRun FALSE
        } else {
            /call AutoSell
            /if (${returnToLeader}) /call NavBackToGroupLeader
        }
        /call UnpauseAFollow
        /call Cleanup
        /return
    }

    /if (${mode.Equal[REPORT]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal SELL
        /declare dryRun bool outer TRUE
        /call AutoSellDryRun FALSE
        /call Cleanup
        /return
    }
    
    /if (${mode.Equal[BANK]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal BANK
        /call StopChaseForUtility
        /call PauseAFollow
        /call AutoBank
        /if (${returnToLeader}) /call NavBackToGroupLeader
        /call UnpauseAFollow
        /call Cleanup
        /return
    }
    
    /if (${mode.Equal[TRIBUTE]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal TRIBUTE
        /call StopChaseForUtility
        /call PauseAFollow
        /call AutoTribute
        /if (${returnToLeader}) /call NavBackToGroupLeader
        /call UnpauseAFollow
        /call Cleanup
        /return
    }

    /if (${mode.Equal[DESTROY]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal DESTROY
        /call AutoDestroy
        /call Cleanup
        /return
    }

    | ---------------------------------------------------------------------
    | GO / GOLOOT — targeted single-item pickup for TurboGear Go buttons.
    | Usage: /mac TurboLoot go <corpseSpawnId> <Item Name With Spaces>
    | Example: /mac TurboLoot go 141 Wand of Ruptured Reality
    | ---------------------------------------------------------------------
    /if (${mode.Equal[GO]} || ${mode.Equal[GOLOOT]}) {
        | Capture Main /mac params HERE — /call Subs replace Param0.. with their
        | own args (empty → the string NULL), which broke BuildGoItemName.
        /declare goCorpseID int outer ${Int[${Param1}]}
        /declare goItemName string outer
        /if (${Param2.NotEqual[NULL]}) /varset goItemName ${Param2}
        /if (${Param3.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param3}
        /if (${Param4.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param4}
        /if (${Param5.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param5}
        /if (${Param6.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param6}
        /if (${Param7.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param7}
        /if (${Param8.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param8}
        /if (${Param9.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param9}
        /if (${Param10.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param10}
        /if (${Param11.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param11}
        /if (${Param12.NotEqual[NULL]}) /varset goItemName ${goItemName} ${Param12}
        /call InitState
        /call LoadSettings
        /if (${goCorpseID} <= 0 || !${goItemName.Length} || ${goItemName.Equal[NULL]}) {
            /echo ${tlTag} [GOLOOT] failed bad_args (ID: ${goCorpseID})
            /echo ${tlTag} Usage: /mac TurboLoot go <corpseId> <Item Name>
            /squelch /tgearbg golootdone failed bad_args ${goCorpseID} ${goItemName}
            /call Cleanup
            /return
        }
        /call PauseE3Logic
        /call StopChaseForUtility
        | GoLootOneItem reads outer goItemName (do not pass as Sub string arg).
        /call GoLootOneItem ${goCorpseID}
        /call Cleanup
        /return
    }

    /if (${mode.Equal[UNLOAD]}) {
        /call InitStateMinimal
        /call LoadSettingsMinimal TRIBUTE
        /declare unloadReturn bool local ${returnToLeader}
        /call StopChaseForUtility
        /call PauseAFollow
        /call AutoTribute
        /call LoadSettingsMinimal BANK
        /call AutoBank
        /call LoadSettingsMinimal SELL
        /call AutoSell
        /call AutoDestroy
        /call PrintUnloadSummary
        /if (${unloadReturn}) /call NavBackToGroupLeader
        /call UnpauseAFollow
        /call Cleanup
        /return
    }

    /call InitState
    /call LoadSettings

    | Check for aggressive mobs if StopLootWhenAttacked is enabled
    /if (${stopLootWhenAttacked}) {
        /if (${SpawnCount[npc radius ${lootDistance} los playerstate 4]}) {
            /echo ${tlTag} \arWARNING: STOPPING turboLoot - Aggressive mobs detected in loot area!
            /if (${Defined[logToFile]} && ${logToFile}) /call LogError "Stopping: aggressive mobs detected in loot area"
            /call Cleanup
            /return
        }
    }

    /call PreChecks
    /if (!${turboLootRunning}) /return

    /call PauseE3Logic

    /if (!${turboLootRunning}) /return

    /call BeginLooting

    /call AutoReclaimDiamondCoinsAfterLoot
    /call PrintSummary
    /call Cleanup
/return

| ---------------------------------------------------------------------
| INIT STATE
| ---------------------------------------------------------------------
Sub InitState
    /declare AlertIndex int outer 1
    /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}

    /declare Skip bool outer FALSE
    /declare LoreBlocked bool outer FALSE
    /declare LoreBlockedName string outer ""
    /declare LoreAttemptName string outer ""
    /declare LoreDeniedNames string outer ""
    /declare SkipGsayKeys string outer ""
    /declare IgnoreAnnouncedKeys string outer ""
    /declare SkippedAnnouncedKeys string outer ""
    /declare _skipCorpseID int outer 0
    /declare AllSkippedCorpseIds string outer ""
    /declare DidLoot bool outer FALSE
    /declare DidLootThisCorpse bool outer FALSE
    /declare tlTag string outer \at[turboLoot]
    /declare abortingMacro bool outer FALSE
    /declare safetyNoResume bool outer FALSE

    /declare showDebug bool outer
    /declare logToFile bool outer FALSE
    /declare lootPerfLog bool outer FALSE
    /declare lootPerfDetail bool outer FALSE
    /declare lootPerfLogged bool outer FALSE
    /declare perfMainLoops int outer 0
    /declare perfItemLoops int outer 0
    /declare perfCorpsefixCalls int outer 0
    /declare perfTargetRefreshes int outer 0
    /declare perfLootWindowWaits int outer 0
    /declare perfMoveLoops int outer 0
    /declare perfItemWaits int outer 0
    /declare perfEmptyCorpseWaits int outer 0
    /declare perfCursorClearWaits int outer 0
    /declare perfCloseLoops int outer 0
    /declare perfOpenFailures int outer 0
    /declare perfReopenAttempts int outer 0
    /declare perfTooFarRetries int outer 0
    /declare perfMoveFailures int outer 0
    /declare perfAbortChecks int outer 0
    /declare perfHuntingChecks int outer 0
    /declare perfIniLookups int outer 0
    /declare perfStuckEvents int outer 0
    /declare perfLongItemWaits int outer 0
    /declare perfMaxItemWaitTries int outer 0
    /declare perfMaxEmptyCorpseWaits int outer 0
    /declare perfMaxMoveTries int outer 0
    | logSkipListForIni: journals skips to TurboLoot_skips_log.txt via skip_log.lua; default ON
    /declare logSkipListForIni bool outer TRUE
    /declare SkipIniNamesLogged string outer ""
    /declare SkipBatch string outer ""
    /declare skipJournalIniDir string outer ""
    /declare skipQueueFile string outer ../Config/TurboLoot_skip_queue.ini
    /declare skipQueueNextId int outer 1
    /declare skipQueueWrites int outer 0
    /varset SkipBatch ""
    /if (${showDebug}) /echo [turboLoot] SkipReview: InitState SkipBatch declared len=${SkipBatch.Length}
    /declare SkipIniQueuedHintShown bool outer FALSE
    /declare enableHighValue int outer
    /declare minLootValue int outer
    /declare lootHighValueAll bool outer FALSE
    /declare minStackableValue int outer
    /declare lootStackable bool outer
    /declare announceSkipped int outer 1
    /declare announceLooted bool outer
    /declare announceMethod string outer
    /declare announceLore bool outer
    /declare announceLoreMethod string outer
    /declare announceSkippedMethod string outer
    /if (!${Defined[announceBankSell]}) /declare announceBankSell string outer
    /declare announceBankSellProgress int outer 0
    /declare announceBankSellPerItem int outer 1
    /declare announceDestroyed bool outer
    /declare announceSummary int outer
    /declare announceSummaryMethod string outer
    /declare announceDefaultTo string outer "echo"
    /declare announceDoneLootingTo string outer "e3bc"
    /declare huntingFile string outer ../Config/Turbo_hunting.ini
    /declare huntingTargetName string outer ""
    /declare huntingTargets string outer ""
    /declare huntingEnabled bool outer FALSE
    /declare huntingBeep bool outer TRUE
    /declare huntingAnnounceTo string outer ""
    /declare HuntingAnnouncedKeys string outer ""
    /declare restoreFollowMode string outer
    /declare restoreFollowDriver string outer
    /declare afollowWasPaused bool outer FALSE
    /declare stopLootWhenAttacked bool outer FALSE
    /declare autoRsayInRaid bool outer FALSE
    /if (${Defined[iniFile]}) /deletevar iniFile
    /declare iniFile string global
    /declare MaxLootRetries int outer 10
    /declare lootDistance int outer
    /declare finalSweepEnabled int outer 1
    /declare finalSweepRadiusFeet int outer 0
    /declare reclaimDiamondCoinsAfterLoot bool outer FALSE
    /declare useNavForCorpses int outer 0
    /declare RightClickLoot bool outer TRUE
    /declare allowLeftClickLoot bool outer FALSE
    /declare moveLoopDelay int outer 3
    /declare cursorClearDelay int outer 2
    /declare lootWindowDelay int outer 5
    /declare itemLootWaitDelay int outer 3
    /declare mainLoopIterations int outer 0
    /declare maxMainLoopIterations int outer 5000
    /declare corpseID int outer 0
    /declare midRunRefreshInterval int outer 5
    /declare lastMidRunRefresh int outer 0
    /declare corpseHideMode string outer "LOOTED"

    /declare loottotal int outer
    /declare lootslot int outer
    /declare lootName string outer
    /declare itemValue int outer
    /declare lootNoDropPrompt string outer
    /declare lootNoDropPromptReset string outer

    /declare moveTries int outer 0
    /declare _itemWait int outer 0
    /declare _reopenTry int outer 0
    /declare _lastCorpseItems int outer 0
    /declare _processPasses int outer 0
    /declare _attemptedLootThisPass bool outer FALSE
    /declare _transientSlotSkip bool outer FALSE
    /declare modeCheck string outer
    /declare itemLimit string outer
    /declare itemLimitUpper string outer
    | 3.8.57: ANNOUNCE rule — set TRUE inside the loot loop dispatcher when the
    | item's INI value normalizes to ANNOUNCE. Read by the IGNORE branch to
    | force a chat announcement (skip-class rule + loud broadcast). Cleared at
    | the top of every loot-loop iteration so it doesn't leak across items.
    /declare _isAnnounce bool outer FALSE
    /declare closeTries int outer 0
    /declare currentCount int outer 0

    /declare itemsSold int outer 0
    /declare platinumGain int outer 0
    /declare sellTotalCopper int outer 0
    /declare enableSellStackable bool outer
    /declare minSellStackableValue int outer
    /declare enableSellUnlistedValue bool outer
    /declare minSellUnlistedValue int outer
    /declare sellWildcards bool outer FALSE
    /declare bankWildcards bool outer FALSE
    /declare convertCoinOnBank bool outer TRUE
    /declare wildcardPrefixes string outer ""
    /declare wildcardFirstChars string outer ""
    /declare packNum int outer 0
    /declare slotNum int outer 0
    /declare maxSlots int outer 0
    /declare itemID int outer 0
    /declare itemName string outer
    /declare tributeItemsMoved int outer 0
    /declare tributePointsGained int outer 0
    
    /declare itemsBanked int outer 0

    /declare itemsLooted int outer 0
    /declare itemsDestroyed int outer 0
    /declare itemsSkipped int outer 0
    /declare itemsIgnored int outer 0
    /declare corpsesProcessed int outer 0
    /declare announceInventoryAlmostFull int outer 5
    /declare minFreeSlotsDuringLoot int outer 100
    /declare BankContainerWarnedKeys string outer ""
/return

|| ---------------------------------------------------------------------
|| INIT STATE MINIMAL (for BANK/SELL modes - faster startup)
|| ---------------------------------------------------------------------
Sub InitStateMinimal
    /declare showDebug bool outer
    /declare logToFile bool outer FALSE
    /declare lootPerfLog bool outer FALSE
    /declare lootPerfDetail bool outer FALSE
    /declare lootPerfLogged bool outer FALSE
    /declare perfMainLoops int outer 0
    /declare perfItemLoops int outer 0
    /declare perfCorpsefixCalls int outer 0
    /declare perfTargetRefreshes int outer 0
    /declare perfLootWindowWaits int outer 0
    /declare perfMoveLoops int outer 0
    /declare perfItemWaits int outer 0
    /declare perfEmptyCorpseWaits int outer 0
    /declare perfCursorClearWaits int outer 0
    /declare perfCloseLoops int outer 0
    /declare perfOpenFailures int outer 0
    /declare perfReopenAttempts int outer 0
    /declare perfTooFarRetries int outer 0
    /declare perfMoveFailures int outer 0
    /declare perfAbortChecks int outer 0
    /declare perfHuntingChecks int outer 0
    /declare perfIniLookups int outer 0
    /declare perfStuckEvents int outer 0
    /declare perfLongItemWaits int outer 0
    /declare perfMaxItemWaitTries int outer 0
    /declare perfMaxEmptyCorpseWaits int outer 0
    /declare perfMaxMoveTries int outer 0
    /declare logSkipListForIni bool outer TRUE
    /declare SkipIniNamesLogged string outer ""
    /if (!${Defined[SkipBatch]}) /declare SkipBatch string outer ""
    /varset SkipBatch ""
    /declare SkipIniQueuedHintShown bool outer FALSE
    /if (!${Defined[skipQueueWrites]}) /declare skipQueueWrites int outer 0
    | v3.8.6: missing declare caused "varset failed, variable 'skipJournalIniDir'
    | not found" at LoadSettingsMinimal lines 411 / 413 when entering BANK / SELL
    | / TRIBUTE / DESTROY paths. Var was only declared in full Sub InitState.
    | Defined-guard for re-entry safety (same pattern used for SkipBatch above).
    /if (!${Defined[skipJournalIniDir]}) /declare skipJournalIniDir string outer ""
    /declare announceLooted bool outer
    /if (${Defined[iniFile]}) /deletevar iniFile
    /declare iniFile string global
    /declare restoreFollowMode string outer
    /declare restoreFollowDriver string outer
    /declare afollowWasPaused bool outer FALSE
    /declare modeCheck string outer
    /declare itemsSold int outer 0
    /if (!${Defined[announceBankSell]}) /declare announceBankSell string outer
    /declare announceBankSellProgress int outer 0
    /declare announceBankSellPerItem int outer 1
    /declare platinumGain int outer 0
    /declare sellTotalCopper int outer 0
    /declare enableSellStackable bool outer
    /declare minSellStackableValue int outer
    /declare enableSellUnlistedValue bool outer
    /declare minSellUnlistedValue int outer
    /declare bankWildcards bool outer FALSE
    /declare sellWildcards bool outer FALSE
    /declare convertCoinOnBank bool outer TRUE
    /declare wildcardPrefixes string outer ""
    /declare wildcardFirstChars string outer ""
    /declare packNum int outer 0
    /declare slotNum int outer 0
    /declare tributeItemsMoved int outer 0
    /declare tributePointsGained int outer 0
    /declare maxSlots int outer 0
    /declare itemID int outer 0
    /declare itemName string outer
    /declare itemValue int outer
    /declare itemLimit string outer
    /declare itemLimitUpper string outer
    /declare itemsBanked int outer 0
    /declare itemsTributed int outer 0
    /declare itemsDestroyed int outer 0
    /declare tlTag string outer "\at[turboLoot]"
    /declare announceDefaultTo string outer "echo"
    /declare announceDoneLootingTo string outer "e3bc"
    /declare BankContainerWarnedKeys string outer ""
    /declare abortingMacro bool outer FALSE
    /declare safetyNoResume bool outer FALSE
    /declare lootNoDropPromptReset string outer "always"
    /declare dryRunSellCount int outer 0
    /declare dryRunSellTotalCopper int outer 0
    /declare returnToLeader bool outer TRUE
    /declare dropLevBeforeNav bool outer TRUE
/return

| ---------------------------------------------------------------------
| [Settings] logSkipListForIni — journals skips to TurboLoot_skips_log.txt (default ON; Skip Review GUI)
| ---------------------------------------------------------------------
Sub LoadSkipListIniSettings
    /declare logSkipSet string local ${IniGetStringOrEmpty[Settings,logSkipListForIni]}
    /if (${logSkipSet.Length}) {
        /declare logSkipUpper string local ${logSkipSet.Upper.Replace[ ,]}
        /if (${logSkipUpper.Equal[1]} || ${logSkipUpper.Equal[ON]} || ${logSkipUpper.Equal[TRUE]} || ${logSkipUpper.Equal[YES]}) {
            /varset logSkipListForIni TRUE
        } else {
            /varset logSkipListForIni FALSE
        }
    } else {
        | Key absent from INI — default ON so new users get Skip Review working out of the box
        /varset logSkipListForIni TRUE
    }
/return

|| ---------------------------------------------------------------------
|| LOAD SETTINGS MINIMAL (for BANK/SELL modes - faster startup)
|| ---------------------------------------------------------------------
Sub LoadSettingsMinimal(string modeParam)
    /declare altIniFile string local
    /declare modeUpper string local ${modeParam.Upper}
    /declare iniOverride string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /if (${iniOverride.Length} && !${iniOverride.Equal[NULL]} && !${iniOverride.Equal[turboloot.ini]}) {
        /if (${Ini.File[../Config/${iniOverride}].Exists}) {
            /varset iniFile "../Config/${iniOverride}"
        } else /if (${Ini.File[../Macros/${iniOverride}].Exists}) {
            /varset iniFile "../Macros/${iniOverride}"
        } else {
            /echo [turboLoot] WARNING: Profile ${iniOverride} not found, falling back to turboloot.ini
            /goto :defaultIniMinimal
        }
        /goto :iniFoundMinimal
    }
:defaultIniMinimal
    /varset iniFile "../Config/turboloot.ini"
    /varset altIniFile "../Macros/turboloot.ini"
    /if (${Ini.File[${iniFile}].Exists}) {
    } else /if (${Ini.File[${altIniFile}].Exists}) {
        /varset iniFile ${altIniFile}
    } else {
        /echo [turboLoot] ERROR: No turboloot.ini found in ../Config or ../Macros.
        /echo [turboLoot] Please create turboloot.ini with a [Settings] section and [ItemLimits] section.
        /call Cleanup
        /endmac
    }
:iniFoundMinimal
    /if (${iniFile.Find[../Macros/]}) {
        /varset skipJournalIniDir ../Macros
    } else {
        /varset skipJournalIniDir ../Config
    }
    /declare debugSetting string local ${IniGetStringOrEmpty[Settings,debug]}
    /if (${debugSetting.Length}) {
        /declare debugUpper string local ${debugSetting.Upper.Replace[ ,]}
        /if (${debugUpper.Equal[ON]} || ${debugUpper.Equal[TRUE]} || ${debugUpper.Equal[YES]}) {
            /varset showDebug 1
        } else /if (${debugUpper.Equal[OFF]} || ${debugUpper.Equal[FALSE]} || ${debugUpper.Equal[NO]}) {
            /varset showDebug 0
        } else {
            /declare tmpDbg int local ${Int[${debugUpper}]}
            /if (${tmpDbg} == 0 && !${debugUpper.Equal[0]}) {
                /varset showDebug -1
            } else {
                /varset showDebug ${tmpDbg}
            }
        }
    } else {
        /declare legacyDebugSetting string local ${IniGetStringOrEmpty[Settings,ShowDebug]}
        /declare legacyDebugUpper string local ${legacyDebugSetting.Upper.Replace[ ,]}
        /if (${legacyDebugUpper.Equal[ON]} || ${legacyDebugUpper.Equal[TRUE]} || ${legacyDebugUpper.Equal[YES]}) {
            /varset showDebug 1
        } else /if (${legacyDebugUpper.Equal[OFF]} || ${legacyDebugUpper.Equal[FALSE]} || ${legacyDebugUpper.Equal[NO]}) {
            /varset showDebug 0
        } else {
            /declare tmpLegacyDbg int local ${Int[${legacyDebugUpper}]}
            /if (${tmpLegacyDbg} == 0 && !${legacyDebugUpper.Equal[0]}) {
                /varset showDebug -1
            } else {
                /varset showDebug ${tmpLegacyDbg}
            }
        }
    }

    /declare announceLootSetting string local ${IniGetStringOrEmpty[Settings,announceLoot]}
    /if (${announceLootSetting.Length}) {
        /declare lootUpper string local ${announceLootSetting.Upper.Replace[ ,]}
        /if (${lootUpper.Equal[ON]} || ${lootUpper.Equal[TRUE]} || ${lootUpper.Equal[YES]}) {
            /varset announceLooted 1
        } else /if (${lootUpper.Equal[OFF]} || ${lootUpper.Equal[FALSE]} || ${lootUpper.Equal[NO]}) {
            /varset announceLooted 0
        } else {
            /declare tmpLoot int local ${Int[${lootUpper}]}
            /if (${tmpLoot} == 0 && !${lootUpper.Equal[0]}) {
                /varset announceLooted -1
            } else {
                /varset announceLooted ${tmpLoot}
            }
        }
    } else {
        /declare legacyAnnounceLooted string local ${IniGetStringOrEmpty[Settings,announceLooted]}
        /declare legacyLootUpper string local ${legacyAnnounceLooted.Upper.Replace[ ,]}
        /if (${legacyLootUpper.Equal[ON]} || ${legacyLootUpper.Equal[TRUE]} || ${legacyLootUpper.Equal[YES]}) {
            /varset announceLooted 1
        } else /if (${legacyLootUpper.Equal[OFF]} || ${legacyLootUpper.Equal[FALSE]} || ${legacyLootUpper.Equal[NO]}) {
            /varset announceLooted 0
        } else {
            /declare tmpLegacyLoot int local ${Int[${legacyLootUpper}]}
            /if (${tmpLegacyLoot} == 0 && !${legacyLootUpper.Equal[0]}) {
                /varset announceLooted -1
            } else {
                /varset announceLooted ${tmpLegacyLoot}
            }
        }
    }

    /if (${showDebug} != 0 && ${showDebug} != 1) /varset showDebug 0
    /if (${showDebug}) /call EchoLoadedIniProfile
    /if (${announceLooted} != 0 && ${announceLooted} != 1) /varset announceLooted 1

    /declare logToFileSetting string local ${IniGetStringOrEmpty[Settings,logToFile]}
    /if (${logToFileSetting.Length}) {
        /declare logToFileUpper string local ${logToFileSetting.Upper.Replace[ ,]}
        /if (${logToFileUpper.Equal[1]} || ${logToFileUpper.Equal[ON]} || ${logToFileUpper.Equal[TRUE]} || ${logToFileUpper.Equal[YES]}) {
            /varset logToFile TRUE
        } else {
            /varset logToFile FALSE
        }
    } else {
        /varset logToFile FALSE
    }
    /call LoadSkipListIniSettings
    /declare perfLogSetting string local ${IniGetStringOrEmpty[Settings,lootPerfLog]}
    /if (${perfLogSetting.Length}) {
        /declare perfLogUpper string local ${perfLogSetting.Upper.Replace[ ,]}
        /if (${perfLogUpper.Equal[1]} || ${perfLogUpper.Equal[ON]} || ${perfLogUpper.Equal[TRUE]} || ${perfLogUpper.Equal[YES]}) {
            /varset lootPerfLog TRUE
        } else {
            /varset lootPerfLog FALSE
        }
    } else {
        /varset lootPerfLog FALSE
    }
    /declare perfDetailSetting string local ${IniGetStringOrEmpty[Settings,lootPerfDetail]}
    /if (${perfDetailSetting.Length}) {
        /declare perfDetailUpper string local ${perfDetailSetting.Upper.Replace[ ,]}
        /if (${perfDetailUpper.Equal[1]} || ${perfDetailUpper.Equal[ON]} || ${perfDetailUpper.Equal[TRUE]} || ${perfDetailUpper.Equal[YES]}) {
            /varset lootPerfDetail TRUE
        } else {
            /varset lootPerfDetail FALSE
        }
    } else {
        /varset lootPerfDetail FALSE
    }
    | logLevel: DEBUG=0, INFO=1, WARN=2, ERROR=3. File logs only entries at or above this level. Default INFO.
    /if (!${Defined[logLevel]}) {
        /declare logLevel int outer 1
    } else {
        /varset logLevel 1
    }
    /declare logLevelSetting string local ${IniGetStringOrEmpty[Settings,logLevel]}
    /if (${logLevelSetting.Length}) {
        /declare logLevelUpper string local ${logLevelSetting.Upper.Replace[ ,]}
        /if (${logLevelUpper.Equal[DEBUG]}) /varset logLevel 0
        /if (${logLevelUpper.Equal[INFO]}) /varset logLevel 1
        /if (${logLevelUpper.Equal[WARN]}) /varset logLevel 2
        /if (${logLevelUpper.Equal[ERROR]}) /varset logLevel 3
    }
    
    /declare bankSellProgressSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellProgress]}
    /if (${bankSellProgressSetting.Length}) {
        /declare bankSellProgressUpper string local ${bankSellProgressSetting.Upper.Replace[ ,]}
        /if (${bankSellProgressUpper.Equal[0]} || ${bankSellProgressUpper.Equal[OFF]} || ${bankSellProgressUpper.Equal[FALSE]} || ${bankSellProgressUpper.Equal[NO]}) {
            /varset announceBankSellProgress 0
        } else /if (${bankSellProgressUpper.Equal[1]} || ${bankSellProgressUpper.Equal[ON]} || ${bankSellProgressUpper.Equal[TRUE]} || ${bankSellProgressUpper.Equal[YES]}) {
            /varset announceBankSellProgress 1
        } else {
            /declare tmpBankSellProgress int local ${Int[${bankSellProgressUpper}]}
            /if (${tmpBankSellProgress} > 0) /varset announceBankSellProgress 1
            /if (${tmpBankSellProgress} <= 0) /varset announceBankSellProgress 0
        }
    } else {
        /varset announceBankSellProgress 0
    }

    /declare bankSellPerItemSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellPerItem]}
    /if (${bankSellPerItemSetting.Length}) {
        /declare bankSellPerItemUpper string local ${bankSellPerItemSetting.Upper.Replace[ ,]}
        /if (${bankSellPerItemUpper.Equal[0]} || ${bankSellPerItemUpper.Equal[OFF]} || ${bankSellPerItemUpper.Equal[FALSE]} || ${bankSellPerItemUpper.Equal[NO]}) {
            /varset announceBankSellPerItem 1
        } else /if (${bankSellPerItemUpper.Equal[1]} || ${bankSellPerItemUpper.Equal[ON]} || ${bankSellPerItemUpper.Equal[TRUE]} || ${bankSellPerItemUpper.Equal[YES]}) {
            /varset announceBankSellPerItem 1
        } else {
            /declare tmpBankSellPerItem int local ${Int[${bankSellPerItemUpper}]}
            /if (${tmpBankSellPerItem} > 0) /varset announceBankSellPerItem 1
            /if (${tmpBankSellPerItem} <= 0) /varset announceBankSellPerItem 0
        }
    } else {
        /varset announceBankSellPerItem 1
    }

    /declare bankWildcardsSetting string local ${IniGetStringOrEmpty[Settings,bankWildcards]}
    /if (${bankWildcardsSetting.Length}) {
        /declare bankWildcardsUpper string local ${bankWildcardsSetting.Upper.Replace[ ,]}
        /if (${bankWildcardsUpper.Equal[1]} || ${bankWildcardsUpper.Equal[ON]} || ${bankWildcardsUpper.Equal[TRUE]} || ${bankWildcardsUpper.Equal[YES]}) {
            /varset bankWildcards TRUE
        } else {
            /varset bankWildcards FALSE
        }
    } else {
        /varset bankWildcards FALSE
    }

    /declare convertCoinSetting string local ${IniGetStringOrEmpty[Settings,convertCoinOnBank]}
    /if (${convertCoinSetting.Length}) {
        /declare convertCoinUpper string local ${convertCoinSetting.Upper.Replace[ ,]}
        /if (${convertCoinUpper.Equal[0]} || ${convertCoinUpper.Equal[OFF]} || ${convertCoinUpper.Equal[FALSE]} || ${convertCoinUpper.Equal[NO]}) {
            /varset convertCoinOnBank FALSE
        } else {
            /varset convertCoinOnBank TRUE
        }
    } else {
        /varset convertCoinOnBank TRUE
    }

    /declare announceDefaultToSetting string local ${IniGetStringOrEmpty[Settings,announceDefaultTo]}
    /varset announceDefaultTo ${announceDefaultToSetting}
    /call NormalizeAnnounceMethod "${announceDefaultTo}"
    /varset announceDefaultTo ${Macro.Return}
    /declare announceDefaultUpper string local ${announceDefaultTo.Upper.Replace[ ,]}
    /if (!${announceDefaultTo.Length} || ${announceDefaultTo.Equal[NULL]} || ${announceDefaultTo.Equal[null]} || ${announceDefaultUpper.Equal[0]} || ${announceDefaultUpper.Equal[OFF]}) /varset announceDefaultTo "echo"
    | /call avoids ${IniGetStringOrEmpty[Settings,announceDoneLootingTo]} substituting outer announceDoneLootingTo as the key
    /declare announceDoneLootingSetting string local
    /call IniGetStringOrEmpty Settings announceDoneLootingTo
    /varset announceDoneLootingSetting ${Macro.Return}
    /if (${announceDoneLootingSetting.Length}) {
        /call NormalizeAnnounceMethod "${announceDoneLootingSetting}"
        /varset announceDoneLootingTo ${Macro.Return}
    }
    /if (!${announceDoneLootingTo.Length} || ${announceDoneLootingTo.Equal[NULL]}) /varset announceDoneLootingTo ${announceDefaultTo}
    /declare announceBankSellToSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellTributeTo]}
    /declare bankSellAnnounceSetting string local ${IniGetStringOrEmpty[Settings,bankSellTributeAnnounceMethod]}
    /declare legacyAnnounceBankSellSetting string local ${IniGetStringOrEmpty[Settings,announceBankSell]}
    /declare bankSellToUpper string local
    /declare bankSellToMethod string local ""
    /declare bankSellToDisable bool local FALSE
    /if (${announceBankSellToSetting.Length}) {
        /varset bankSellToUpper ${announceBankSellToSetting.Upper.Replace[ ,]}
        /if (${bankSellToUpper.Equal[0]} || ${bankSellToUpper.Equal[OFF]}) {
            /varset bankSellToDisable TRUE
        } else /if (${bankSellToUpper.Equal[1]} || ${bankSellToUpper.Equal[ON]}) {
            /if (${announceDefaultToSetting.Length}) /varset bankSellToMethod ${announceDefaultToSetting}
        } else {
            /varset bankSellToMethod ${announceBankSellToSetting}
        }
    }
    /declare bankSellResolved string local ""
    /if (${bankSellAnnounceSetting.Length}) {
        /call NormalizeAnnounceMethod "${bankSellAnnounceSetting}"
        /varset bankSellResolved ${Macro.Return}
    }
    /if (!${bankSellResolved.Length} && ${bankSellToDisable}) {
        /varset bankSellResolved "OFF"
    }
    /if (!${bankSellResolved.Length} && ${bankSellToMethod.Length}) {
        /call NormalizeAnnounceMethod "${bankSellToMethod}"
        /varset bankSellResolved ${Macro.Return}
    }
    /if (!${bankSellResolved.Length} && ${legacyAnnounceBankSellSetting.Length}) {
        /call NormalizeAnnounceMethod "${legacyAnnounceBankSellSetting}"
        /varset bankSellResolved ${Macro.Return}
    }
    /if (!${bankSellResolved.Length} && ${announceDefaultToSetting.Length}) {
        /call NormalizeAnnounceMethod "${announceDefaultToSetting}"
        /varset bankSellResolved ${Macro.Return}
    }
    /if (!${bankSellResolved.Length} || ${bankSellResolved.Equal[Null]}) {
        /varset bankSellResolved "echo"
    }
    /varset announceBankSell ${bankSellResolved}
    /declare followModeSetting string local ${IniGetStringOrEmpty[Settings,followRestoreMode]}
    /if (!${followModeSetting.Length}) /varset followModeSetting ${IniGetStringOrEmpty[Settings,RestoreFollowMode]}
    /varset restoreFollowMode ${followModeSetting}
    /if (!${restoreFollowMode.Length} || ${restoreFollowMode.Equal[Null]}) /varset restoreFollowMode "NONE"
    /varset modeCheck ${restoreFollowMode.Upper.Replace[ ,]}
    /declare followDriverSetting string local ${IniGetStringOrEmpty[Settings,followRestoreDriver]}
    /if (${followDriverSetting.Length}) {
        /varset restoreFollowDriver ${followDriverSetting}
    } else {
        /varset restoreFollowDriver ${IniGetStringOrEmpty[Settings,RestoreFollowDriver]}
    }
    /if (!${restoreFollowDriver.Length} || ${restoreFollowDriver.Equal[Null]}) /varset restoreFollowDriver "AUTO"

    /declare noDropExitSetting string local ${IniGetStringOrEmpty[Settings,noDropPolicyOnExit]}
    /if (${noDropExitSetting.Length}) {
        /varset lootNoDropPromptReset ${noDropExitSetting}
    } else {
        /varset lootNoDropPromptReset ${IniGetStringOrEmpty[Settings,lootNoDropPromptReset]}
    }
    /if (!${lootNoDropPromptReset.Length}) /varset lootNoDropPromptReset "always"

    /if (${showDebug} || ${logToFile}) {
        /call LogDebug "DBG(min) announceDefaultTo=[${announceDefaultTo}] announceLoot=${announceLooted} bankSell=[${announceBankSell}] | bankSellTributeAnn=[${bankSellAnnounceSetting}] announceBankSellTributeTo=[${announceBankSellToSetting}] legacyBankSell=[${legacyAnnounceBankSellSetting}] bankSellResolved=[${announceBankSell}]"
    }

    /if (${modeUpper.Equal[SELL]}) {
        | New key: SellUnlistedStackable - sell unlisted stackable items
        | OFF/0: disabled (default)
        | ON/1: sell any unlisted stackable item with vendor value
        /declare sellStackableSetting string local ${IniGetStringOrEmpty[Settings,SellUnlistedStackable]}
        /if (${sellStackableSetting.Length}) {
            /declare sellCheck string local ${sellStackableSetting.Upper.Replace[ ,]}
            /if (${sellCheck.Equal[ON]} || ${sellCheck.Equal[TRUE]} || ${sellCheck.Equal[YES]} || ${sellCheck.Equal[1]}) {
                /varset enableSellStackable 1
                /varset minSellStackableValue 0
            } else /if (${sellCheck.Equal[OFF]} || ${sellCheck.Equal[FALSE]} || ${sellCheck.Equal[NO]} || ${sellCheck.Equal[0]}) {
                /varset enableSellStackable 0
                /varset minSellStackableValue 0
            } else {
                /varset enableSellStackable 0
                /varset minSellStackableValue 0
            }
        } else {
            /varset enableSellStackable ${Int[${IniGetStringOrEmpty[Settings,EnableSellStackable]}]}
            /if (${enableSellStackable} != 0 && ${enableSellStackable} != 1) /varset enableSellStackable 0
            /varset minSellStackableValue 0
        }

        | New key: sellUnlistedItems - sell ANY unlisted item (not just stackables)
        | OFF/0: disabled (default)
        | ON/1: sell any unlisted item with vendor value
        /declare sellUnlistedSetting string local ${IniGetStringOrEmpty[Settings,sellUnlistedItems]}
        /if (${sellUnlistedSetting.Length}) {
            /declare sellUnlistedCheck string local ${sellUnlistedSetting.Upper.Replace[ ,]}
            /if (${sellUnlistedCheck.Equal[ON]} || ${sellUnlistedCheck.Equal[TRUE]} || ${sellUnlistedCheck.Equal[YES]} || ${sellUnlistedCheck.Equal[1]}) {
                /varset enableSellUnlistedValue 1
                /varset minSellUnlistedValue 0
            } else /if (${sellUnlistedCheck.Equal[OFF]} || ${sellUnlistedCheck.Equal[FALSE]} || ${sellUnlistedCheck.Equal[NO]} || ${sellUnlistedCheck.Equal[0]}) {
                /varset enableSellUnlistedValue 0
                /varset minSellUnlistedValue 0
            } else {
                /varset enableSellUnlistedValue 0
                /varset minSellUnlistedValue 0
            }
        } else {
            /varset enableSellUnlistedValue 0
            /varset minSellUnlistedValue 0
        }

        | New key: sellWildcards
        | OFF/0: protect wildcards from auto-sell (but explicit Item=SELL still sells)
        | ON/1: auto-sell wildcards unless explicitly KEEP/IGNORE/BANK/TRIBUTE
        /declare sellWildcardsSetting string local ${IniGetStringOrEmpty[Settings,sellWildcards]}
        /if (${sellWildcardsSetting.Length}) {
            /declare sellWildcardsUpper string local ${sellWildcardsSetting.Upper.Replace[ ,]}
            /if (${sellWildcardsUpper.Equal[ON]} || ${sellWildcardsUpper.Equal[TRUE]} || ${sellWildcardsUpper.Equal[YES]}) {
                /varset sellWildcards 1
            } else /if (${sellWildcardsUpper.Equal[OFF]} || ${sellWildcardsUpper.Equal[FALSE]} || ${sellWildcardsUpper.Equal[NO]}) {
                /varset sellWildcards 0
            } else {
                /declare tmpSellWild int local ${Int[${sellWildcardsUpper}]}
                /if (${tmpSellWild} == 0 && !${sellWildcardsUpper.Equal[0]}) {
                    /varset sellWildcards 0
                } else {
                    /varset sellWildcards ${tmpSellWild}
                }
            }
        } else {
            /varset sellWildcards 0
        }
    }
    /declare rtlSetting string local ${IniGetStringOrEmpty[Settings,returnToLeader]}
    /if (${rtlSetting.Length}) {
        /declare rtlUpper string local ${rtlSetting.Upper.Replace[ ,]}
        /if (${rtlUpper.Equal[ON]} || ${rtlUpper.Equal[TRUE]} || ${rtlUpper.Equal[YES]} || ${rtlUpper.Equal[1]}) {
            /varset returnToLeader TRUE
        } else {
            /varset returnToLeader FALSE
        }
    }

    /declare dropLevSetting string local ${IniGetStringOrEmpty[Settings,dropLevBeforeNav]}
    /if (${dropLevSetting.Length}) {
        /declare dropLevUpper string local ${dropLevSetting.Upper.Replace[ ,]}
        /if (${dropLevUpper.Equal[ON]} || ${dropLevUpper.Equal[TRUE]} || ${dropLevUpper.Equal[YES]} || ${dropLevUpper.Equal[1]}) {
            /varset dropLevBeforeNav TRUE
        } else {
            /varset dropLevBeforeNav FALSE
        }
    } else {
        /varset dropLevBeforeNav TRUE
    }

    /call LoadWildcards
/return

| ---------------------------------------------------------------------
| LOAD SETTINGS
| ---------------------------------------------------------------------
Sub LoadSettings
    /declare altIniFile string local

    /declare iniOverride string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /if (${iniOverride.Length} && !${iniOverride.Equal[NULL]} && !${iniOverride.Equal[turboloot.ini]}) {
        /if (${Ini.File[../Config/${iniOverride}].Exists}) {
            /varset iniFile "../Config/${iniOverride}"
        } else /if (${Ini.File[../Macros/${iniOverride}].Exists}) {
            /varset iniFile "../Macros/${iniOverride}"
        } else {
            /echo [turboLoot] WARNING: Profile ${iniOverride} not found, falling back to turboloot.ini
            /goto :defaultIni
        }
        /goto :iniFound
    }
:defaultIni
    /varset iniFile "../Config/turboloot.ini"
    /varset altIniFile "../Macros/turboloot.ini"

    /if (${Ini.File[${iniFile}].Exists}) {
    } else /if (${Ini.File[${altIniFile}].Exists}) {
        /varset iniFile ${altIniFile}
    } else {
        /echo [turboLoot] ERROR: No turboloot.ini found in ../Config or ../Macros.
        /echo [turboLoot] Please create turboloot.ini with a [Settings] section and [ItemLimits] section.
        /echo [turboLoot] See documentation for required settings and item limit examples.
        /call Cleanup
        /endmac
    }
:iniFound
    /if (${iniFile.Find[../Macros/]}) {
        /varset skipJournalIniDir ../Macros
    } else {
        /varset skipJournalIniDir ../Config
    }

    /declare followModeSetting string local ${IniGetStringOrEmpty[Settings,followRestoreMode]}
    /if (!${followModeSetting.Length}) /varset followModeSetting ${IniGetStringOrEmpty[Settings,RestoreFollowMode]}
    /varset restoreFollowMode ${followModeSetting}
    /if (!${restoreFollowMode.Length} || ${restoreFollowMode.Equal[Null]}) /varset restoreFollowMode "NONE"
    /varset modeCheck ${restoreFollowMode.Upper.Replace[ ,]}
    
    /if (${modeCheck.NotEqual[NONE]} && ${modeCheck.Length} && ${modeCheck.NotEqual[NULL]} && ${modeCheck.NotEqual[0]}) {
        /call StopFollowAndMovement
    }

    /declare debugSetting string local ${IniGetStringOrEmpty[Settings,debug]}
    /if (${debugSetting.Length}) {
        /declare debugUpper string local ${debugSetting.Upper.Replace[ ,]}
        /if (${debugUpper.Equal[ON]} || ${debugUpper.Equal[TRUE]} || ${debugUpper.Equal[YES]}) {
            /varset showDebug 1
        } else /if (${debugUpper.Equal[OFF]} || ${debugUpper.Equal[FALSE]} || ${debugUpper.Equal[NO]}) {
            /varset showDebug 0
        } else {
            /declare tmpDbg int local ${Int[${debugUpper}]}
            /if (${tmpDbg} == 0 && !${debugUpper.Equal[0]}) {
                /varset showDebug -1
            } else {
                /varset showDebug ${tmpDbg}
            }
        }
    } else {
        /declare legacyDebugSetting string local ${IniGetStringOrEmpty[Settings,ShowDebug]}
        /declare legacyDebugUpper string local ${legacyDebugSetting.Upper.Replace[ ,]}
        /if (${legacyDebugUpper.Equal[ON]} || ${legacyDebugUpper.Equal[TRUE]} || ${legacyDebugUpper.Equal[YES]}) {
            /varset showDebug 1
        } else /if (${legacyDebugUpper.Equal[OFF]} || ${legacyDebugUpper.Equal[FALSE]} || ${legacyDebugUpper.Equal[NO]}) {
            /varset showDebug 0
        } else {
            /declare tmpLegacyDbg int local ${Int[${legacyDebugUpper}]}
            /if (${tmpLegacyDbg} == 0 && !${legacyDebugUpper.Equal[0]}) {
                /varset showDebug -1
            } else {
                /varset showDebug ${tmpLegacyDbg}
            }
        }
    }

    /declare logToFileSetting string local ${IniGetStringOrEmpty[Settings,logToFile]}
    /if (${logToFileSetting.Length}) {
        /declare logToFileUpper string local ${logToFileSetting.Upper.Replace[ ,]}
        /if (${logToFileUpper.Equal[1]} || ${logToFileUpper.Equal[ON]} || ${logToFileUpper.Equal[TRUE]} || ${logToFileUpper.Equal[YES]}) {
            /varset logToFile TRUE
        } else {
            /varset logToFile FALSE
        }
    } else {
        /varset logToFile FALSE
    }
    /call LoadSkipListIniSettings
    /declare perfLogSetting string local ${IniGetStringOrEmpty[Settings,lootPerfLog]}
    /if (${perfLogSetting.Length}) {
        /declare perfLogUpper string local ${perfLogSetting.Upper.Replace[ ,]}
        /if (${perfLogUpper.Equal[1]} || ${perfLogUpper.Equal[ON]} || ${perfLogUpper.Equal[TRUE]} || ${perfLogUpper.Equal[YES]}) {
            /varset lootPerfLog TRUE
        } else {
            /varset lootPerfLog FALSE
        }
    } else {
        /varset lootPerfLog FALSE
    }
    /declare perfDetailSetting string local ${IniGetStringOrEmpty[Settings,lootPerfDetail]}
    /if (${perfDetailSetting.Length}) {
        /declare perfDetailUpper string local ${perfDetailSetting.Upper.Replace[ ,]}
        /if (${perfDetailUpper.Equal[1]} || ${perfDetailUpper.Equal[ON]} || ${perfDetailUpper.Equal[TRUE]} || ${perfDetailUpper.Equal[YES]}) {
            /varset lootPerfDetail TRUE
        } else {
            /varset lootPerfDetail FALSE
        }
    } else {
        /varset lootPerfDetail FALSE
    }
    | logLevel: DEBUG=0, INFO=1, WARN=2, ERROR=3. File logs only entries at or above this level.
    /if (!${Defined[logLevel]}) {
        /declare logLevel int outer 1
    } else {
        /varset logLevel 1
    }
    /declare logLevelSetting string local ${IniGetStringOrEmpty[Settings,logLevel]}
    /if (${logLevelSetting.Length}) {
        /declare logLevelUpper string local ${logLevelSetting.Upper.Replace[ ,]}
        /if (${logLevelUpper.Equal[DEBUG]}) /varset logLevel 0
        /if (${logLevelUpper.Equal[INFO]}) /varset logLevel 1
        /if (${logLevelUpper.Equal[WARN]}) /varset logLevel 2
        /if (${logLevelUpper.Equal[ERROR]}) /varset logLevel 3
    }

    | StopLootWhenAttacked: stop looting if aggressive mobs are in loot area (default: OFF)
    /declare stopLootSetting string local ${IniGetStringOrEmpty[Settings,StopLootWhenAttacked]}
    /if (${stopLootSetting.Length}) {
        /declare stopLootUpper string local ${stopLootSetting.Upper.Replace[ ,]}
        /if (${stopLootUpper.Equal[ON]} || ${stopLootUpper.Equal[TRUE]} || ${stopLootUpper.Equal[YES]} || ${stopLootUpper.Equal[1]}) {
            /varset stopLootWhenAttacked TRUE
        } else {
            /varset stopLootWhenAttacked FALSE
        }
    } else {
        /varset stopLootWhenAttacked FALSE
    }

    | AutoRsayInRaid: auto-switch announce method to rsay when in a raid (default: OFF)
    /declare autoRsaySetting string local ${IniGetStringOrEmpty[Settings,AutoRsayInRaid]}
    /if (${autoRsaySetting.Length}) {
        /declare autoRsayUpper string local ${autoRsaySetting.Upper.Replace[ ,]}
        /if (${autoRsayUpper.Equal[ON]} || ${autoRsayUpper.Equal[TRUE]} || ${autoRsayUpper.Equal[YES]} || ${autoRsayUpper.Equal[1]}) {
            /varset autoRsayInRaid TRUE
        } else {
            /varset autoRsayInRaid FALSE
        }
    } else {
        /varset autoRsayInRaid FALSE
    }

    /varset lootHighValueAll FALSE
    /declare highValueMinSetting string local ${IniGetStringOrEmpty[Settings,lootHighValueMinPP]}
    /if (${highValueMinSetting.Length}) {
        /declare hvCheck string local ${highValueMinSetting.Upper.Replace[ ,]}
        /declare hvVal int local 0
        /if (${hvCheck.Equal[ON]} || ${hvCheck.Equal[TRUE]} || ${hvCheck.Equal[YES]}) {
            /varset hvVal 1
        } else /if (${hvCheck.Equal[OFF]} || ${hvCheck.Equal[FALSE]} || ${hvCheck.Equal[NO]}) {
            /varset hvVal 0
        } else {
            /varset hvVal ${Int[${hvCheck}]}
        }
        /if (${hvVal} <= 0) {
            /varset enableHighValue 0
            /varset minLootValue 0
        } else /if (${hvVal} == 1) {
            /varset enableHighValue 1
            /varset minLootValue 0
            /varset lootHighValueAll TRUE
        } else {
            /varset enableHighValue 1
            /varset minLootValue ${hvVal}
        }
    } else {
        | New key: lootHighValue (legacy: EnableHighValue)
        /declare highValueSetting string local ${IniGetStringOrEmpty[Settings,lootHighValue]}
        /if (${highValueSetting.Length}) {
            /varset enableHighValue ${Int[${highValueSetting.Replace[ ,]}]}
        } else {
            /varset enableHighValue ${Int[${IniGetStringOrEmpty[Settings,EnableHighValue]}]}
        }
        /varset minLootValue ${Int[${IniGetStringOrEmpty[Settings,MinLootValue]}]}
        /if (!${minLootValue} || ${minLootValue} < 0) /varset minLootValue 0
    }

    /declare stackableSetting string local ${IniGetStringOrEmpty[Settings,lootStackableMinPP]}
    /if (${stackableSetting.Length}) {
        /declare stackableCheck string local ${stackableSetting.Upper.Replace[ ,]}
        /declare stackableVal int local 0
        /if (${stackableCheck.Equal[ON]} || ${stackableCheck.Equal[TRUE]} || ${stackableCheck.Equal[YES]}) {
            /varset stackableVal 1
        } else /if (${stackableCheck.Equal[OFF]} || ${stackableCheck.Equal[FALSE]} || ${stackableCheck.Equal[NO]}) {
            /varset stackableVal 0
        } else {
            /varset stackableVal ${Int[${stackableCheck}]}
        }
        /if (${stackableVal} <= 0) {
            /varset lootStackable 0
            /varset minStackableValue 0
        } else /if (${stackableVal} == 1) {
            /varset lootStackable 1
            /varset minStackableValue 0
        } else {
            /varset lootStackable 1
            /varset minStackableValue ${stackableVal}
        }
    } else {
        /varset lootStackable ${Int[${IniGetStringOrEmpty[Settings,LootStackable]}]}
        /varset minStackableValue ${Int[${IniGetStringOrEmpty[Settings,MinStackableValue]}]}
        /if (!${minStackableValue} || ${minStackableValue} < 0) /varset minStackableValue 0
    }


    /declare announceDefaultToSetting string local ${IniGetStringOrEmpty[Settings,announceDefaultTo]}
    /varset announceDefaultTo ${announceDefaultToSetting}
    /call TrimSpaces "${announceDefaultTo}"
    /varset announceDefaultTo ${Macro.Return}
    /declare announceDefaultUpper string local ${announceDefaultTo.Upper.Replace[ ,]}
    /if (!${announceDefaultTo.Length} || ${announceDefaultTo.Equal[NULL]} || ${announceDefaultTo.Equal[null]} || ${announceDefaultUpper.Equal[0]} || ${announceDefaultUpper.Equal[OFF]}) /varset announceDefaultTo "echo"
    | Main loot used InitState default only- LoadSettingsMinimal had INI read but full LoadSettings did not
    /declare announceDoneLootingSetting string local
    /call IniGetStringOrEmpty Settings announceDoneLootingTo
    /varset announceDoneLootingSetting ${Macro.Return}
    /if (${announceDoneLootingSetting.Length}) {
        /call NormalizeAnnounceMethod "${announceDoneLootingSetting}"
        /varset announceDoneLootingTo ${Macro.Return}
    }
    /if (!${announceDoneLootingTo.Length} || ${announceDoneLootingTo.Equal[NULL]}) /varset announceDoneLootingTo ${announceDefaultTo}
    /declare announceLootToSetting string local ${IniGetStringOrEmpty[Settings,announceLootTo]}
    /declare announceDestroyToSetting string local ${IniGetStringOrEmpty[Settings,announceDestroyTo]}
    /declare announceBankSellToSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellTributeTo]}
    /declare announceLoreToSetting string local ${IniGetStringOrEmpty[Settings,announceLoreTo]}
    /declare announceSkipToSetting string local ${IniGetStringOrEmpty[Settings,announceSkipTo]}

    /declare lootAnnounceSetting string local ${IniGetStringOrEmpty[Settings,lootAnnounceMethod]}
    /declare legacyAnnounceMethodSetting string local ${IniGetStringOrEmpty[Settings,announceMethod]}
    /declare lootToUpper string local
    /declare destroyToUpper string local
    /declare lootToMethod string local ""
    /declare destroyToMethod string local ""
    /if (${announceLootToSetting.Length}) {
        /varset lootToUpper ${announceLootToSetting.Upper.Replace[ ,]}
        /if (${lootToUpper.Equal[1]} || ${lootToUpper.Equal[ON]}) {
            | Explicit 1/ON: use announceDefaultTo if available
            /if (${announceDefaultToSetting.Length}) /varset lootToMethod ${announceDefaultToSetting}
        } else /if (!${lootToUpper.Equal[0]} && !${lootToUpper.Equal[OFF]}) {
            /varset lootToMethod ${announceLootToSetting}
        }
    }
    /if (${announceDestroyToSetting.Length}) {
        /varset destroyToUpper ${announceDestroyToSetting.Upper.Replace[ ,]}
        /if (${destroyToUpper.Equal[1]} || ${destroyToUpper.Equal[ON]}) {
            | Explicit 1/ON: use announceDefaultTo if available
            /if (${announceDefaultToSetting.Length}) /varset destroyToMethod ${announceDefaultToSetting}
        } else /if (!${destroyToUpper.Equal[0]} && !${destroyToUpper.Equal[OFF]}) {
            /varset destroyToMethod ${announceDestroyToSetting}
        }
    }
    /if (${lootToMethod.Length} && ${destroyToMethod.Length} && ${lootToMethod.NotEqual[${destroyToMethod}]}) {
        /echo [turboLoot] WARNING: announceLootTo and announceDestroyTo differ, but this macro uses one loot announce method. Using announceLootTo (${announceLootToSetting}).
    }
    /if (${lootAnnounceSetting.Length}) {
        /varset announceMethod ${lootAnnounceSetting}
    } else /if (${legacyAnnounceMethodSetting.Length}) {
        /varset announceMethod ${legacyAnnounceMethodSetting}
    } else /if (${lootToMethod.Length}) {
        /varset announceMethod ${lootToMethod}
    } else /if (${destroyToMethod.Length}) {
        /varset announceMethod ${destroyToMethod}
    } else /if (${announceDefaultToSetting.Length}) {
        /varset announceMethod ${announceDefaultToSetting}
    } else {
        /varset announceMethod ""
    }

    /declare bankSellAnnounceSetting string local ${IniGetStringOrEmpty[Settings,bankSellTributeAnnounceMethod]}
    /declare legacyAnnounceBankSellSetting string local ${IniGetStringOrEmpty[Settings,announceBankSell]}
    /declare bankSellToUpper string local
    /declare bankSellToMethod string local ""
    /declare bankSellToDisable bool local FALSE
    /if (${announceBankSellToSetting.Length}) {
        /varset bankSellToUpper ${announceBankSellToSetting.Upper.Replace[ ,]}
        /if (${bankSellToUpper.Equal[0]} || ${bankSellToUpper.Equal[OFF]}) {
            /varset bankSellToDisable TRUE
        } else /if (${bankSellToUpper.Equal[1]} || ${bankSellToUpper.Equal[ON]}) {
            /if (${announceDefaultToSetting.Length}) /varset bankSellToMethod ${announceDefaultToSetting}
        } else {
            /varset bankSellToMethod ${announceBankSellToSetting}
        }
    }
    /if (${bankSellAnnounceSetting.Length}) {
        /varset announceBankSell ${bankSellAnnounceSetting}
    } else /if (${bankSellToDisable}) {
        /varset announceBankSell "OFF"
    } else /if (${bankSellToMethod.Length}) {
        /varset announceBankSell ${bankSellToMethod}
    } else /if (${legacyAnnounceBankSellSetting.Length}) {
        /varset announceBankSell ${legacyAnnounceBankSellSetting}
    } else /if (${announceDefaultToSetting.Length}) {
        /varset announceBankSell ${announceDefaultToSetting}
    } else {
        /varset announceBankSell ""
    }

    /declare bankSellProgressSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellProgress]}
    /if (${bankSellProgressSetting.Length}) {
        /declare bankSellProgressUpper string local ${bankSellProgressSetting.Upper.Replace[ ,]}
        /if (${bankSellProgressUpper.Equal[0]} || ${bankSellProgressUpper.Equal[OFF]} || ${bankSellProgressUpper.Equal[FALSE]} || ${bankSellProgressUpper.Equal[NO]}) {
            /varset announceBankSellProgress 0
        } else /if (${bankSellProgressUpper.Equal[1]} || ${bankSellProgressUpper.Equal[ON]} || ${bankSellProgressUpper.Equal[TRUE]} || ${bankSellProgressUpper.Equal[YES]}) {
            /varset announceBankSellProgress 1
        } else {
            /declare tmpBankSellProgress int local ${Int[${bankSellProgressUpper}]}
            /if (${tmpBankSellProgress} > 0) /varset announceBankSellProgress 1
            /if (${tmpBankSellProgress} <= 0) /varset announceBankSellProgress 0
        }
    } else {
        /varset announceBankSellProgress 1
    }

    /declare bankSellPerItemSetting string local ${IniGetStringOrEmpty[Settings,announceBankSellPerItem]}
    /if (${bankSellPerItemSetting.Length}) {
        /declare bankSellPerItemUpper string local ${bankSellPerItemSetting.Upper.Replace[ ,]}
        /if (${bankSellPerItemUpper.Equal[0]} || ${bankSellPerItemUpper.Equal[OFF]} || ${bankSellPerItemUpper.Equal[FALSE]} || ${bankSellPerItemUpper.Equal[NO]}) {
            /varset announceBankSellPerItem 0
        } else /if (${bankSellPerItemUpper.Equal[1]} || ${bankSellPerItemUpper.Equal[ON]} || ${bankSellPerItemUpper.Equal[TRUE]} || ${bankSellPerItemUpper.Equal[YES]}) {
            /varset announceBankSellPerItem 1
        } else {
            /declare tmpBankSellPerItem int local ${Int[${bankSellPerItemUpper}]}
            /if (${tmpBankSellPerItem} > 0) /varset announceBankSellPerItem 1
            /if (${tmpBankSellPerItem} <= 0) /varset announceBankSellPerItem 0
        }
    } else {
        /varset announceBankSellPerItem 1
    }

    /declare summarySetting string local ${IniGetStringOrEmpty[Settings,announceRunSummary]}
    /declare summaryUpper string local
    /if (${summarySetting.Length}) {
        /varset summaryUpper ${summarySetting.Upper.Replace[ ,]}
        /if (${summaryUpper.Equal[0]} || ${summaryUpper.Equal[OFF]} || ${summaryUpper.Equal[FALSE]} || ${summaryUpper.Equal[NO]}) {
            /varset announceSummary 0
        } else /if (${summaryUpper.Equal[1]} || ${summaryUpper.Equal[ON]} || ${summaryUpper.Equal[TRUE]} || ${summaryUpper.Equal[YES]}) {
            /varset announceSummary 1
            /if (${announceDefaultToSetting.Length}) /varset announceSummaryMethod ${announceDefaultToSetting}
            /if (!${announceSummaryMethod.Length}) /varset announceSummaryMethod ${announceMethod}
        } else {
            /varset announceSummary 1
            /varset announceSummaryMethod ${summarySetting}
        }
    } else {
        | Default OFF when announceRunSummary / announceSummary are unset (quiet loot runs).
        /declare legacySummarySetting string local ${IniGetStringOrEmpty[Settings,announceSummary]}
        /if (${legacySummarySetting.Length}) {
            /varset announceSummary ${Int[${legacySummarySetting}]}
            /if (${announceSummary} == 1) /varset announceSummaryMethod ${announceMethod}
        } else {
            /varset announceSummary 0
        }
    }

    /declare announceLootSetting string local ${IniGetStringOrEmpty[Settings,announceLoot]}
    /declare legacyAnnounceLooted string local ${IniGetStringOrEmpty[Settings,announceLooted]}
    /if (${announceLootSetting.Length}) {
        /declare lootUpper string local ${announceLootSetting.Upper.Replace[ ,]}
        /if (${lootUpper.Equal[ON]} || ${lootUpper.Equal[TRUE]} || ${lootUpper.Equal[YES]}) {
            /varset announceLooted 1
        } else /if (${lootUpper.Equal[OFF]} || ${lootUpper.Equal[FALSE]} || ${lootUpper.Equal[NO]}) {
            /varset announceLooted 0
        } else {
            /declare tmpLoot int local ${Int[${lootUpper}]}
            /if (${tmpLoot} == 0 && !${lootUpper.Equal[0]}) {
                /varset announceLooted -1
            } else {
                /varset announceLooted ${tmpLoot}
            }
        }
    } else {
        /declare legacyLootUpper string local ${legacyAnnounceLooted.Upper.Replace[ ,]}
        /if (${legacyLootUpper.Equal[ON]} || ${legacyLootUpper.Equal[TRUE]} || ${legacyLootUpper.Equal[YES]}) {
            /varset announceLooted 1
        } else /if (${legacyLootUpper.Equal[OFF]} || ${legacyLootUpper.Equal[FALSE]} || ${legacyLootUpper.Equal[NO]}) {
            /varset announceLooted 0
        } else {
            /declare tmpLegacyLoot int local ${Int[${legacyLootUpper}]}
            /if (${tmpLegacyLoot} == 0 && !${legacyLootUpper.Equal[0]}) {
                /varset announceLooted -1
            } else {
                /varset announceLooted ${tmpLegacyLoot}
            }
        }
    }
    /if (${announceLootToSetting.Length} && !${announceLootSetting.Length} && !${legacyAnnounceLooted.Length}) {
        /varset lootToUpper ${announceLootToSetting.Upper.Replace[ ,]}
        /if (${lootToUpper.Equal[0]} || ${lootToUpper.Equal[OFF]}) {
            /varset announceLooted 0
        } else {
            /varset announceLooted 1
        }
    }

    /declare announceDestroySetting string local ${IniGetStringOrEmpty[Settings,announceDestroy]}
    /declare legacyAnnounceDestroyed string local ${IniGetStringOrEmpty[Settings,announceDestroyed]}
    /if (${announceDestroySetting.Length}) {
        /declare destroyUpper string local ${announceDestroySetting.Upper.Replace[ ,]}
        /if (${destroyUpper.Equal[ON]} || ${destroyUpper.Equal[TRUE]} || ${destroyUpper.Equal[YES]}) {
            /varset announceDestroyed 1
        } else /if (${destroyUpper.Equal[OFF]} || ${destroyUpper.Equal[FALSE]} || ${destroyUpper.Equal[NO]}) {
            /varset announceDestroyed 0
        } else {
            /declare tmpDestroy int local ${Int[${destroyUpper}]}
            /if (${tmpDestroy} == 0 && !${destroyUpper.Equal[0]}) {
                /varset announceDestroyed -1
            } else {
                /varset announceDestroyed ${tmpDestroy}
            }
        }
    } else {
        /declare legacyDestroyUpper string local ${legacyAnnounceDestroyed.Upper.Replace[ ,]}
        /if (${legacyDestroyUpper.Equal[ON]} || ${legacyDestroyUpper.Equal[TRUE]} || ${legacyDestroyUpper.Equal[YES]}) {
            /varset announceDestroyed 1
        } else /if (${legacyDestroyUpper.Equal[OFF]} || ${legacyDestroyUpper.Equal[FALSE]} || ${legacyDestroyUpper.Equal[NO]}) {
            /varset announceDestroyed 0
        } else {
            /declare tmpLegacyDestroy int local ${Int[${legacyDestroyUpper}]}
            /if (${tmpLegacyDestroy} == 0 && !${legacyDestroyUpper.Equal[0]}) {
                /varset announceDestroyed -1
            } else {
                /varset announceDestroyed ${tmpLegacyDestroy}
            }
        }
    }
    /if (${announceDestroyToSetting.Length} && !${announceDestroySetting.Length} && !${legacyAnnounceDestroyed.Length}) {
        /varset destroyToUpper ${announceDestroyToSetting.Upper.Replace[ ,]}
        /if (${destroyToUpper.Equal[0]} || ${destroyToUpper.Equal[OFF]}) {
            /varset announceDestroyed 0
        } else {
            /varset announceDestroyed 1
        }
    }

    /declare loreAnnounceSetting string local ${IniGetStringOrEmpty[Settings,loreAnnounceMethod]}
    /if (${loreAnnounceSetting.Length}) {
        /declare loreCheck string local ${loreAnnounceSetting.Replace[ ,]}
        /if (${loreCheck.Equal[0]}) {
            /varset announceLore 0
            /varset announceLoreMethod "echo"
        } else /if (${loreCheck.Equal[1]}) {
            /varset announceLore 1
            /varset announceLoreMethod ${announceMethod}
        } else {
            /varset announceLore 1
            /varset announceLoreMethod ${loreAnnounceSetting}
        }
    } else {
        /if (${announceLoreToSetting.Length}) {
            /declare loreToCheck string local ${announceLoreToSetting.Upper.Replace[ ,]}
            /if (${loreToCheck.Equal[0]} || ${loreToCheck.Equal[OFF]}) {
                /varset announceLore 0
                /varset announceLoreMethod "echo"
            } else /if (${loreToCheck.Equal[1]} || ${loreToCheck.Equal[ON]}) {
                /varset announceLore 1
                /if (${announceDefaultToSetting.Length}) /varset announceLoreMethod ${announceDefaultToSetting}
                /if (!${announceLoreMethod.Length}) /varset announceLoreMethod ${announceMethod}
            } else {
                /varset announceLore 1
                /varset announceLoreMethod ${announceLoreToSetting}
            }
        } else {
            /varset announceLore ${Int[${IniGetStringOrEmpty[Settings,announceLore]}]}
            /varset announceLoreMethod ${IniGetStringOrEmpty[Settings,announceLoreMethod]}
        }
    }

    /declare skipAnnounceSetting string local ${IniGetStringOrEmpty[Settings,skipAnnounceMethod]}
    /declare explicitSkipTo string local ""
    /if (${announceSkipToSetting.Length}) {
        /declare skipToUpper2 string local ${announceSkipToSetting.Upper.Replace[ ,]}
        /if (!${skipToUpper2.Equal[0]} && !${skipToUpper2.Equal[OFF]} && !${skipToUpper2.Equal[1]} && !${skipToUpper2.Equal[ON]}) {
            /varset explicitSkipTo ${announceSkipToSetting}
        }
    }
    /if (${skipAnnounceSetting.Length}) {
        /declare skipCheck string local ${skipAnnounceSetting.Replace[ ,]}
        /if (${skipCheck.Equal[0]}) {
            /varset announceSkipped 0
            /varset announceSkippedMethod ${announceMethod}
        } else /if (${skipCheck.Equal[1]}) {
            /varset announceSkipped 1
            /if (${explicitSkipTo.Length}) {
                /varset announceSkippedMethod ${explicitSkipTo}
            } else {
                /varset announceSkippedMethod ${announceMethod}
            }
        } else {
            /varset announceSkipped 1
            /varset announceSkippedMethod ${skipAnnounceSetting}
        }
    } else {
        /if (${announceSkipToSetting.Length}) {
            /declare skipToCheck string local ${announceSkipToSetting.Upper.Replace[ ,]}
            /if (${skipToCheck.Equal[0]} || ${skipToCheck.Equal[OFF]}) {
                /varset announceSkipped 0
                /varset announceSkippedMethod ${announceMethod}
            } else /if (${skipToCheck.Equal[1]} || ${skipToCheck.Equal[ON]}) {
                /varset announceSkipped 1
                /if (${announceDefaultToSetting.Length}) /varset announceSkippedMethod ${announceDefaultToSetting}
                /if (!${announceSkippedMethod.Length}) /varset announceSkippedMethod ${announceMethod}
            } else {
                /varset announceSkipped 1
                /varset announceSkippedMethod ${announceSkipToSetting}
            }
        } else {
            /declare legacyAnnounceSkipped string local ${IniGetStringOrEmpty[Settings,announceSkipped]}
            /varset announceSkipped ${Int[${legacyAnnounceSkipped}]}
            /varset announceSkippedMethod ${IniGetStringOrEmpty[Settings,announceSkippedMethod]}
            | Default: announce skips when legacy key not set (user hasn't explicitly disabled)
            /if (!${legacyAnnounceSkipped.Length}) /varset announceSkipped 1
        }
    }

    | lootDistance = canonical (Lua GUI writes this). lootRadiusFeet = legacy Example INI key only.
    /declare lootDistSetting string local ${IniGetStringOrEmpty[Settings,lootDistance]}
    /if (${lootDistSetting.Length}) {
        /varset lootDistance ${Int[${lootDistSetting.Replace[ ,]}]}
    } else {
        /declare lootRadiusSetting string local ${IniGetStringOrEmpty[Settings,lootRadiusFeet]}
        /if (${lootRadiusSetting.Length}) {
            /varset lootDistance ${Int[${lootRadiusSetting.Replace[ ,]}]}
        }
    }
    /if (!${lootDistance} || ${lootDistance} < 1) /varset lootDistance 50

    | New key: finalSweep (default ON)
    | Runs one extra retry pass at end when all corpses are alerted (helps with lag/pathing misses)
    /declare finalSweepSetting string local ${IniGetStringOrEmpty[Settings,finalSweep]}
    /if (${finalSweepSetting.Length}) {
        /declare finalSweepUpper string local ${finalSweepSetting.Upper.Replace[ ,]}
        /if (${finalSweepUpper.Equal[ON]} || ${finalSweepUpper.Equal[TRUE]} || ${finalSweepUpper.Equal[YES]} || ${finalSweepUpper.Equal[1]}) {
            /varset finalSweepEnabled 1
        } else /if (${finalSweepUpper.Equal[OFF]} || ${finalSweepUpper.Equal[FALSE]} || ${finalSweepUpper.Equal[NO]} || ${finalSweepUpper.Equal[0]}) {
            /varset finalSweepEnabled 0
        } else {
            /declare tmpFinalSweep int local ${Int[${finalSweepUpper}]}
            /if (${tmpFinalSweep} != 0 && ${tmpFinalSweep} != 1) {
                /echo [turboLoot] WARNING: finalSweep must be ON/OFF/1/0. Defaulting to ON.
                /varset finalSweepEnabled 1
            } else {
                /varset finalSweepEnabled ${tmpFinalSweep}
            }
        }
    } else {
        /varset finalSweepEnabled 1
    }

    | New key: finalSweepRadiusFeet (0 = use lootDistance)
    /declare finalSweepRadiusSetting string local ${IniGetStringOrEmpty[Settings,finalSweepRadiusFeet]}
    /if (${finalSweepRadiusSetting.Length}) {
        /varset finalSweepRadiusFeet ${Int[${finalSweepRadiusSetting.Replace[ ,]}]}
        /if (${finalSweepRadiusFeet} < 0) /varset finalSweepRadiusFeet 0
    } else {
        /varset finalSweepRadiusFeet 0
    }

    | Optional post-run Diamond Coin reclaim. Read once, used only after normal /mac turboloot looting finishes.
    /declare reclaimDcSetting string local ${IniGetStringOrEmpty[Settings,reclaimDiamondCoinsAfterLoot]}
    /if (${reclaimDcSetting.Length}) {
        /declare reclaimDcUpper string local ${reclaimDcSetting.Upper.Replace[ ,]}
        /if (${reclaimDcUpper.Equal[ON]} || ${reclaimDcUpper.Equal[TRUE]} || ${reclaimDcUpper.Equal[YES]} || ${reclaimDcUpper.Equal[1]}) {
            /varset reclaimDiamondCoinsAfterLoot TRUE
        } else {
            /varset reclaimDiamondCoinsAfterLoot FALSE
        }
    } else {
        /varset reclaimDiamondCoinsAfterLoot FALSE
    }

    | Mid-run spawn refresh: refresh MQ spawn list every X corpses (0=disabled)
    /declare midRunRefreshSetting string local ${IniGetStringOrEmpty[Settings,midRunRefreshCorpses]}
    /if (${midRunRefreshSetting.Length}) {
        /varset midRunRefreshInterval ${Int[${midRunRefreshSetting.Replace[ ,]}]}
        /if (${midRunRefreshInterval} < 0) /varset midRunRefreshInterval 0
    } else {
        /varset midRunRefreshInterval 5
    }

    | Corpse hide mode: ALL=hide from everyone, GROUP=hide from group only (looter still sees), SELF=hide from looter only, OFF=no hiding
    | IMPORTANT: This setting must be on the LOOTER's TurboLoot.ini (the character running TurboLoot)
    /declare corpseHideModeSetting string local ${IniGetStringOrEmpty[Settings,corpseHideMode]}
    /if (${corpseHideModeSetting.Length}) {
        /declare corpseHideModeCheck string local ${corpseHideModeSetting.Upper.Replace[ ,]}
        /if (${corpseHideModeCheck.Equal[ALL]} || ${corpseHideModeCheck.Equal[1]} || ${corpseHideModeCheck.Equal[ON]}) {
            /varset corpseHideMode ALL
        } else /if (${corpseHideModeCheck.Equal[GROUP]}) {
            /varset corpseHideMode GROUP
        } else /if (${corpseHideModeCheck.Equal[SELF]}) {
            /varset corpseHideMode SELF
        } else /if (${corpseHideModeCheck.Equal[LOOTED]}) {
            /varset corpseHideMode LOOTED
        } else /if (${corpseHideModeCheck.Equal[OFF]} || ${corpseHideModeCheck.Equal[0]}) {
            /varset corpseHideMode OFF
        } else {
            /echo [turboLoot] WARNING: corpseHideMode "${corpseHideModeSetting}" is invalid. Valid values: ALL, GROUP, SELF, LOOTED, OFF. Defaulting to LOOTED.
            /varset corpseHideMode LOOTED
        }
    } else {
        | No corpseHideMode set - check if user has legacy keys and warn
        /declare legacyHide string local ${IniGetStringOrEmpty[Settings,hideLootedCorpses]}
        /declare legacyGroup string local ${IniGetStringOrEmpty[Settings,groupHideCorpseAll]}
        /if (${legacyHide.Length} || ${legacyGroup.Length}) {
            /echo [turboLoot] WARNING: hideLootedCorpses and groupHideCorpseAll are no longer supported. Please update your INI to use corpseHideMode=ALL/GROUP/SELF/LOOTED/OFF. Defaulting to LOOTED.
            /squelch /docommand /e3bc [turboLoot] WARNING: hideLootedCorpses and groupHideCorpseAll are no longer supported. Update INI to use corpseHideMode=ALL/GROUP/SELF/LOOTED/OFF
        }
        /varset corpseHideMode LOOTED
    }

    /declare useNavSetting string local ${IniGetStringOrEmpty[Settings,UseNavForCorpses]}
    /if (${useNavSetting.Length}) {
        /declare useNavUpper string local ${useNavSetting.Upper.Replace[ ,]}
        /if (${useNavUpper.Equal[1]} || ${useNavUpper.Equal[ON]} || ${useNavUpper.Equal[TRUE]} || ${useNavUpper.Equal[YES]}) {
            /varset useNavForCorpses 1
        } else {
            /varset useNavForCorpses 0
        }
    } else {
        /varset useNavForCorpses 0
    }

    /call LoadRightClickLootSetting

    /declare invWarnSetting string local ${IniGetStringOrEmpty[Settings,inventoryWarnSlots]}
    /if (${invWarnSetting.Length}) {
        /varset announceInventoryAlmostFull ${Int[${invWarnSetting.Replace[ ,]}]}
    } else {
        /declare invWarnLegacy string local ${IniGetStringOrEmpty[Settings,announceInventoryAlmostFull]}
        /if (!${invWarnLegacy.Length}) /varset invWarnLegacy ${IniGetStringOrEmpty[Settings,MinFreeInventory]}
        /if (${invWarnLegacy.Length}) {
            /varset announceInventoryAlmostFull ${Int[${invWarnLegacy.Replace[ ,]}]}
        } else {
            /varset announceInventoryAlmostFull 5
        }
    }

    /declare followDriverSetting string local ${IniGetStringOrEmpty[Settings,followRestoreDriver]}
    /if (${followDriverSetting.Length}) {
        /varset restoreFollowDriver ${followDriverSetting}
    } else {
        /varset restoreFollowDriver ${IniGetStringOrEmpty[Settings,RestoreFollowDriver]}
    }
    /if (!${restoreFollowDriver.Length} || ${restoreFollowDriver.Equal[Null]}) /varset restoreFollowDriver "AUTO"
    
    /declare sellStackableSetting string local ${IniGetStringOrEmpty[Settings,SellUnlistedStackable]}
    /if (${sellStackableSetting.Length}) {
        /declare sellCheck string local ${sellStackableSetting.Upper.Replace[ ,]}
        /if (${sellCheck.Equal[ON]} || ${sellCheck.Equal[TRUE]} || ${sellCheck.Equal[YES]} || ${sellCheck.Equal[1]}) {
            /varset enableSellStackable 1
            /varset minSellStackableValue 0
        } else /if (${sellCheck.Equal[OFF]} || ${sellCheck.Equal[FALSE]} || ${sellCheck.Equal[NO]} || ${sellCheck.Equal[0]}) {
            /varset enableSellStackable 0
            /varset minSellStackableValue 0
        } else {
            /varset enableSellStackable 0
            /varset minSellStackableValue 0
        }
    } else {
        /varset enableSellStackable ${Int[${IniGetStringOrEmpty[Settings,EnableSellStackable]}]}
        /if (${enableSellStackable} != 0 && ${enableSellStackable} != 1) /varset enableSellStackable 0
        /varset minSellStackableValue 0
    }
    
    /if (!${announceMethod.Length} || ${announceMethod.Equal[Null]}) /varset announceMethod ${announceDefaultTo}
    /if (!${announceLoreMethod.Length} || ${announceLoreMethod.Equal[Null]}) /varset announceLoreMethod ${announceDefaultTo}
    /if (!${announceSkippedMethod.Length} || ${announceSkippedMethod.Equal[Null]}) /varset announceSkippedMethod ${announceDefaultTo}
    /if (!${announceBankSell.Length} || ${announceBankSell.Equal[Null]}) /varset announceBankSell ${announceDefaultTo}
    /if (!${announceSummaryMethod.Length} || ${announceSummaryMethod.Equal[Null]}) /varset announceSummaryMethod ${announceDefaultTo}
    /call NormalizeAnnounceMethod "${announceMethod}"
    /varset announceMethod ${Macro.Return}
    /call NormalizeAnnounceMethod "${announceLoreMethod}"
    /varset announceLoreMethod ${Macro.Return}
    /call NormalizeAnnounceMethod "${announceSkippedMethod}"
    /varset announceSkippedMethod ${Macro.Return}
    /call NormalizeAnnounceMethod "${announceBankSell}"
    /varset announceBankSell ${Macro.Return}
    /call NormalizeAnnounceMethod "${announceSummaryMethod}"
    /varset announceSummaryMethod ${Macro.Return}
    /if (!${announceMethod.Length}) /varset announceMethod ${announceDefaultTo}
    /if (!${announceLoreMethod.Length}) /varset announceLoreMethod ${announceDefaultTo}
    /if (!${announceSkippedMethod.Length}) /varset announceSkippedMethod ${announceDefaultTo}
    /if (!${announceBankSell.Length}) /varset announceBankSell ${announceDefaultTo}
    /if (!${announceSummaryMethod.Length}) /varset announceSummaryMethod ${announceDefaultTo}
    
    /if (${announceSkipToSetting.Length}) {
        /declare skipToFinalUpper string local ${announceSkipToSetting.Upper.Replace[ ,]}
        /if (${skipToFinalUpper.Equal[0]} || ${skipToFinalUpper.Equal[OFF]}) {
            /varset announceSkipped 0
        } else /if (!${skipToFinalUpper.Equal[1]} && !${skipToFinalUpper.Equal[ON]}) {
            /varset announceSkipped 1
            /call NormalizeAnnounceMethod "${announceSkipToSetting}"
            /varset announceSkippedMethod ${Macro.Return}
        }
    }

    /if (${autoRsayInRaid} && ${Raid.Members} > 0) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] AutoRsayInRaid: In raid with ${Raid.Members} members, switching announce methods to rsay"
        /varset announceMethod rsay
        /varset announceLoreMethod rsay
        /varset announceSkippedMethod rsay
        /varset announceSummaryMethod rsay
    }
  	
    /declare noDropSetting string local ${IniGetStringOrEmpty[Settings,noDropPolicy]}
    /if (${noDropSetting.Length}) {
        /varset lootNoDropPrompt ${noDropSetting}
    } else {
        /varset lootNoDropPrompt ${IniGetStringOrEmpty[Settings,lootNoDropPrompt]}
    }
    /declare noDropExitSetting string local ${IniGetStringOrEmpty[Settings,noDropPolicyOnExit]}
    /if (${noDropExitSetting.Length}) {
        /varset lootNoDropPromptReset ${noDropExitSetting}
    } else {
        /varset lootNoDropPromptReset ${IniGetStringOrEmpty[Settings,lootNoDropPromptReset]}
    }
    /docommand /lootnodrop ${lootNoDropPrompt}

    /if (${logToFile} && ${logLevel} <= 0) {
        /call LogDebugFileOnly "DBG announce: defaultTo=[${announceDefaultTo}] doneLootingTo=[${announceDoneLootingTo}] method=[${announceMethod}] loot=${announceLooted} destroy=${announceDestroyed} lore=${announceLore} skipped=${announceSkipped} summary=${announceSummary} | loreMethod=[${announceLoreMethod}] skipMethod=[${announceSkippedMethod}] bankSell=[${announceBankSell}] | skipToIni=[${announceSkipToSetting}] skipAnnounce=[${skipAnnounceSetting}]"
    }

    | ---------------------------------------------------------------------
    | ---------------------------------------------------------------------
    /if (${showDebug} != 0 && ${showDebug} != 1) {
        /echo [turboLoot] WARNING: ShowDebug must be 0 or 1, defaulting to 0
        /varset showDebug 0
    }
    /if (${showDebug}) /call EchoLoadedIniProfile
    /if (${enableHighValue} != 0 && ${enableHighValue} != 1) {
        /echo [turboLoot] WARNING: EnableHighValue must be 0 or 1, defaulting to 0
        /varset enableHighValue 0
    }
    /if (${lootStackable} != 0 && ${lootStackable} != 1) {
        /echo [turboLoot] WARNING: LootStackable must be 0 or 1, defaulting to 0
        /varset lootStackable 0
    }
    /if (${announceSkipped} != 0 && ${announceSkipped} != 1) {
        /echo [turboLoot] WARNING: announceSkipped must be 0 or 1, defaulting to 1
        /varset announceSkipped 1
    }
    /if (${announceLooted} != 0 && ${announceLooted} != 1) {
        /echo [turboLoot] WARNING: announceLooted must be 0 or 1, defaulting to 1
        /varset announceLooted 1
    }
    /if (${announceLore} != 0 && ${announceLore} != 1) {
        /echo [turboLoot] WARNING: announceLore must be 0 or 1, defaulting to 1
        /varset announceLore 1
    }
    /if (${announceDestroyed} != 0 && ${announceDestroyed} != 1) {
        /echo [turboLoot] WARNING: announceDestroyed must be 0 or 1, defaulting to 1
        /varset announceDestroyed 1
    }
    /if (${announceSummary} < 0 || ${announceSummary} > 1) {
        /varset announceSummary 0
    }
    /if (!${announceSummaryMethod.Length} || ${announceSummaryMethod.Equal[Null]} || ${announceSummaryMethod.Equal[NULL]} || ${announceSummaryMethod.Equal[null]}) {
        /varset announceSummaryMethod ${announceMethod}
    }
    /declare summaryMethodUpper string local ${announceSummaryMethod.Upper}
    /if (${announceSummary} == 1 && !${summaryMethodUpper.Left[4].Equal[ECHO]} && !${summaryMethodUpper.Left[4].Equal[E3BC]} && !${summaryMethodUpper.Left[4].Equal[GSAY]} && !${summaryMethodUpper.Left[4].Equal[RSAY]} && !${summaryMethodUpper.Left[3].Equal[SAY]} && !${summaryMethodUpper.Left[1].Equal[G]} && !${summaryMethodUpper.Left[2].Equal[RS]} && !${summaryMethodUpper.Left[2].Equal[T ]} && !${summaryMethodUpper.Left[5].Equal[TELL ]}) {
        /echo [turboLoot] WARNING: announceRunSummary must be OFF/0, ON/1, echo/e3bc/gsay/rsay/say, or t Name. Defaulting to ${announceMethod}.
        /varset announceSummaryMethod ${announceMethod}
    }

    /if (${minLootValue} < 0) {
        /echo [turboLoot] WARNING: MinLootValue (${minLootValue}) is negative, defaulting to 0
        /varset minLootValue 0
    }
    /if (${minStackableValue} < 0) {
        /echo [turboLoot] WARNING: MinStackableValue (${minStackableValue}) is negative, defaulting to 0
        /varset minStackableValue 0
    }
    /if (!${lootDistance} || ${lootDistance} < 1) {
        /echo [turboLoot] WARNING: lootDistance (${lootDistance}) is invalid, defaulting to 50
        /varset lootDistance 50
    }
    /if (${lootDistance} > 100) {
        /echo [turboLoot] WARNING: lootDistance (${lootDistance}) seems high, ensure it's in feet.
    }
    | Sync E3 LootRadius to INI so Tloot events (${MQ2Mono.Query[e3,LootRadius]}) match TurboLoot scan range
    /squelch /e3varset LootRadius ${lootDistance}
    /if (${announceInventoryAlmostFull} < 0) {
        /echo [turboLoot] WARNING: announceInventoryAlmostFull (${announceInventoryAlmostFull}) is negative, defaulting to 5
        /varset announceInventoryAlmostFull 5
    }

    /if (!${lootNoDropPrompt.Length}) {
        /echo [turboLoot] WARNING: lootNoDropPrompt not set in INI, defaulting to "always"
        /varset lootNoDropPrompt "always"
    }
    /if (!${lootNoDropPromptReset.Length}) {
        /echo [turboLoot] WARNING: lootNoDropPromptReset not set in INI, defaulting to "always"
        /varset lootNoDropPromptReset "always"
    }
    /if (!${announceMethod.Length} || ${announceMethod.Equal[null]}) {
        /echo [turboLoot] WARNING: announceMethod not set, defaulting to "echo"
        /varset announceMethod "echo"
    }
    /if (!${announceLoreMethod.Length} || ${announceLoreMethod.Equal[null]}) {
        /echo [turboLoot] WARNING: announceLoreMethod not set, defaulting to "echo"
        /varset announceLoreMethod "echo"
    }
    /if (!${announceSkippedMethod.Length} || ${announceSkippedMethod.Equal[null]}) {
        /echo [turboLoot] WARNING: announceSkippedMethod not set, defaulting to announceMethod
        /varset announceSkippedMethod ${announceMethod}
    }
    /if (!${announceBankSell.Length} || ${announceBankSell.Equal[null]}) {
        /echo [turboLoot] WARNING: announceBankSell not set, defaulting to "echo"
        /varset announceBankSell "echo"
    }

    /if (${logToFile} && ${logLevel} <= 0) /call LogDebugFileOnly "[INI] ${iniFile}"
    /if (${enableHighValue} && ${lootHighValueAll}) {
        /if (${logToFile} && ${logLevel} <= 0) /call LogDebugFileOnly "[turboLoot] High-value looting ENABLED: Looting ALL non-stackable items (no value threshold)"
    } else /if (${enableHighValue} && ${minLootValue} > 0) {
        /if (${logToFile} && ${logLevel} <= 0) /call LogDebugFileOnly "[turboLoot] High-value looting ENABLED: Looting non-stackable items worth ${minLootValue} platinum or more"
    } else /if (${enableHighValue} && ${minLootValue} <= 0) {
        /echo [turboLoot] WARNING: EnableHighValue is ON but MinLootValue is ${minLootValue}. High-value looting is DISABLED.
        /echo [turboLoot] Set MinLootValue to a positive number (e.g., 100) or use lootHighValueMinPP=1 to loot all non-stackable.
    }
    /if (${lootStackable} && ${minStackableValue} > 0) {
        /if (${logToFile} && ${logLevel} <= 0) /call LogDebugFileOnly "[turboLoot] Stackable value threshold ENABLED: Looting stackable items worth ${minStackableValue} platinum or more"
    } else     /if (${lootStackable} && ${minStackableValue} <= 0) {
        /if (${logToFile} && ${logLevel} <= 0) /call LogDebugFileOnly "[turboLoot] Stackable looting ENABLED: Looting all stackable items (no value threshold)"
    }
    | INI tips + wildcard summary: /mac turboloot doctor (chat); mqlog DEBUG lines above when logToFile=ON & logLevel=DEBUG

    /call LoadWildcards
/return

| ---------------------------------------------------------------------
| Cooldown global: keep variable defined (0=idle, 1=active) so other macros
| that read ${turboLootCooldown} do not error after /timed clears it.
| ---------------------------------------------------------------------
Sub SetTurboLootCooldown
    /if (!${Defined[turboLootCooldown]}) /declare turboLootCooldown int global 0
    /varset turboLootCooldown 1
    /timed 50 /varset turboLootCooldown 0
/return

| ---------------------------------------------------------------------
| PRECHECKS
| ---------------------------------------------------------------------
Sub PreChecks
    /call CheckLootAbortState

    /if (${Defined[turboLootCooldown]} && ${turboLootCooldown}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cooldown active. Skipping to prevent event spam."
        /call Cleanup
        /return
    }

    /declare corpseCheckRetries int local 0
    /declare maxCorpseCheckRetries int local 2
    /declare corpseCount int local 0
:checkCorpses
    /varset corpseCount ${SpawnCount[npccorpse radius ${lootDistance}]}
    /if (!${corpseCount}) {
        /varcalc corpseCheckRetries ${corpseCheckRetries}+1
        /if (${corpseCheckRetries} <= ${maxCorpseCheckRetries}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] No corpses found within ${lootDistance}. Refreshing corpse data without changing hidecorpse (retry ${corpseCheckRetries}/${maxCorpseCheckRetries})..."
            | Refresh corpse data without clearing hidecorpse; clearing it can reveal old camp corpses and re-trigger loot spam.
            /if (${lootPerfLog}) /varcalc perfTargetRefreshes ${perfTargetRefreshes}+1
            /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
            /squelch /docommand #corpsefix
            /delay 1
            /goto :checkCorpses
        }
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] No corpses found within ${lootDistance} after ${maxCorpseCheckRetries} retries. Exiting."
        /deletevar turboLootRunning
        /call SetTurboLootCooldown
        /call Cleanup
        /return
    }
/return

| ---------------------------------------------------------------------
| PAUSE E3 LOGIC
| ---------------------------------------------------------------------
Sub PauseE3Logic
    /e3p on
    /delay 1

    /timed 6000 /if (${Macro.Name.Equal[turboLoot]}) /echo [turboLoot] SAFETY NET: Macro still running after 10 minutes - resuming E3Next (/e3p off).
    /timed 6000 /if (${Macro.Name.Equal[turboLoot]}) /e3p off
    
    /call PauseAFollow
    
    /stopcast
    /delay 1
/return

| ---------------------------------------------------------------------
| BEGIN LOOTING
| ---------------------------------------------------------------------
Sub BeginLooting
    /if (${corpseHideMode.Equal[ALL]} || ${corpseHideMode.Equal[SELF]} || ${corpseHideMode.Equal[LOOTED]}) /squelch /hidecorpse looted
    /varset LoreDeniedNames ""
    /echo ${tlTag} \ag[${Time}] Started Looting \at(range: ${lootDistance} ft)
    /if (${logToFile}) /call LogInfo "Started looting (range: ${lootDistance} ft)"
    /if (${logSkipListForIni}) /varset SkipIniQueuedHintShown FALSE
    /if (${logSkipListForIni}) /varset SkipIniNamesLogged ""
    /if (${logSkipListForIni}) /varset skipQueueWrites 0
    /if (${logSkipListForIni}) {
        /if (!${Defined[SkipBatch]}) /declare SkipBatch string outer ""
        /varset SkipBatch ""
        /declare _qsec string local Queue_${Me.Name}
        /declare _next string local ${Ini[${skipQueueFile},${_qsec},NextID]}
        /if (!${_next.Length} || ${_next.Equal[NULL]} || ${_next.Equal[null]}) {
            /varset skipQueueNextId 1
        } else {
            /varset skipQueueNextId ${_next}
        }
        /if (${showDebug}) /echo [turboLoot] SkipReview: BeginLooting batch reset len=${SkipBatch.Length}
    }
    /if (${logSkipListForIni}) /call SkipIniLogSessionStart
    /varset minFreeSlotsDuringLoot ${Me.FreeInventory}
    /call LoadHuntingSettings

    /declare corpseCount int local 0
    /declare lookupName string local
    /declare endConfirm int local 0
    /declare lastMoveDistance float local 0
    /declare stuckCount int local 0
    /declare finalSweepDone bool local FALSE
    /declare finalSweepNeeded bool local FALSE
    /declare sweepLootDistance int local ${lootDistance}
    /if (${finalSweepRadiusFeet} > 0 && ${finalSweepRadiusFeet} < ${sweepLootDistance}) /varset sweepLootDistance ${finalSweepRadiusFeet}
    /declare _lootFailCorpseID int local 0
    /declare _failedCorpseID int local 0
    /declare _reopenCorpseID int local 0
    | Captured right after /call ShouldAnnounceDoneLooting (LogDebug must not sit between call and capture)
    /declare _doneLootGate int local 0

:mainlootloop
    /if (${lootPerfLog}) /varcalc perfMainLoops ${perfMainLoops}+1
    /squelch /afollow pause
    /call CheckLootAbortState

    /if (${Defined[midRunRefreshInterval]} && ${Defined[lastMidRunRefresh]} && ${midRunRefreshInterval} > 0 && ${corpsesProcessed} > 0 && ${corpsesProcessed} > ${lastMidRunRefresh}) {
        /if (${Math.Calc[${corpsesProcessed}%${midRunRefreshInterval}]} == 0 && !${Window[LootWnd].Open}) {
            /varset lastMidRunRefresh ${corpsesProcessed}
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Mid-run corpse refresh: using #corpsefix without changing hidecorpse."
            /if (${lootPerfLog}) /varcalc perfTargetRefreshes ${perfTargetRefreshes}+1
            /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
            /squelch /docommand #corpsefix
            /delay 3
        }
    }

    /if (${stopLootWhenAttacked}) {
        /if (${SpawnCount[npc radius ${lootDistance} los playerstate 4]}) {
            /echo ${tlTag} \arWARNING: STOPPING turboLoot - Aggressive mobs detected in loot area!
            /if (${logToFile}) /call LogError "Stopping: aggressive mobs detected in loot area"
            /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
            /call CloseBags
            /deletevar turboLootRunning
            /varset mainLoopIterations 0
            /call Cleanup
            /return
        }
    }

    /varset corpseCount ${SpawnCount[npccorpse radius ${lootDistance}]}
    /if (!${corpseCount}) {
        | If we've looted something, we're probably done. Otherwise, try refreshing spawn list once
        /if (!${DidLoot}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] No corpses found within ${lootDistance}. Refreshing corpse data without changing hidecorpse..."
            /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
            /squelch /docommand #corpsefix
            /delay 1
            | Re-check after refresh (npccorpse only)
            /varset corpseCount ${SpawnCount[npccorpse radius ${lootDistance}]}
            /if (${corpseCount}) {
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Spawn list refresh successful - found corpses"
                /goto :mainlootloop
            }
        }
        | Reopen failed with items left (INI-listed) - corpse may be out of range or spawn list stale; retry before exiting
        /if (${_reopenCorpseID} && ${Spawn[${_reopenCorpseID}].ID} && ${Me.FreeInventory}) {
            /if (${Spawn[${_reopenCorpseID}].Distance} <= ${lootDistance}) {
                | Corpse in range but spawn list didn't show it - target and go straight to loot
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${_reopenCorpseID} in range (spawn list stale) - retargeting to finish INI items"
                /target id ${_reopenCorpseID}
                /varset corpseID ${_reopenCorpseID}
                /call CheckLootAbortState
                /if (${Target.ID} == ${_reopenCorpseID}) /goto :doneMoving
            } else /if (${Spawn[${_reopenCorpseID}].Distance} < 200) {
                | Corpse out of range - move to it
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${_reopenCorpseID} at ${Spawn[${_reopenCorpseID}].Distance} ft (reopen failed) - moving to retry INI items"
                /target id ${_reopenCorpseID}
                /delay 1 ${Target.ID} == ${_reopenCorpseID}
                /if (${Target.ID} == ${_reopenCorpseID}) {
                    /if (${useNavForCorpses} && ${Navigation.PathExists[id ${_reopenCorpseID}]}) {
                        /nav id ${_reopenCorpseID} distance=10
                        /delay 100 !${Navigation.Active} || ${Spawn[${_reopenCorpseID}].Distance} <= 15
                        /call CheckLootAbortState
                        /if (${Navigation.Active}) /squelch /nav stop
                    } else {
                        /moveto id ${_reopenCorpseID} dist 10
                        /delay 50 ${Spawn[${_reopenCorpseID}].Distance} <= 15
                        /call CheckLootAbortState
                    }
                    /delay 1
                    /varset corpseID ${_reopenCorpseID}
                    /call CheckLootAbortState
                    /if (${Target.ID} == ${_reopenCorpseID} && ${Spawn[${_reopenCorpseID}].Distance} <= 15) /goto :doneMoving
                }
            }
        }
        /goto :EndConfirmLoop
    }
    
    /varset corpseCount ${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]}
    /if (!${corpseCount}) {
        /if (${finalSweepEnabled} && ${finalSweepNeeded} && !${finalSweepDone}) {
            /varset finalSweepDone TRUE
            /if (${lootDistance} != ${sweepLootDistance}) /varset lootDistance ${sweepLootDistance}
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Final sweep: retrying corpses within ${lootDistance} ft (1 extra pass)"
            /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
            | Re-add "all skipped" corpses to alert so we don't retarget them (prevents Lionhide Backpack loop)
            /if (${Defined[AllSkippedCorpseIds]} && ${AllSkippedCorpseIds.Length}) {
                /declare _rest string local ${AllSkippedCorpseIds}
                /declare _id string local
                /declare _p int local 0
                /while (${_rest.Length} > 1) {
                    /varset _rest ${_rest.Mid[2,500]}
                    /varset _p ${_rest.Find[|]}
                    /if (!${_p}) /break
                    /varset _id ${_rest.Left[${Math.Calc[${_p}-1]}]}
                    /if (${_id.Length} && ${Int[${_id}]}) /squelch /alert add ${AlertIndex} id ${_id}
                    /varset _rest ${_rest.Mid[${_p},500]}
                }
            }
            /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
            /squelch /docommand #corpsefix
            /delay 3
            /goto :mainlootloop
        }
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] All corpses in range are marked as alerted."
        /if (${DidLoot}) {
            /varset corpseCount ${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]}
            /if (!${corpseCount}) /goto :EndConfirmLoop
        } else {
            /goto :EndConfirmLoop
        }
    }

    /varcalc mainLoopIterations ${mainLoopIterations}+1
    /if (${mainLoopIterations} > ${maxMainLoopIterations}) {
        /echo [turboLoot] WARNING: Main loop exceeded ${maxMainLoopIterations} iterations. Exiting to prevent infinite loop.
    /if (${logToFile}) /call LogError "Main loop exceeded ${maxMainLoopIterations} iterations - exiting"
        /e3p off
        /deletevar turboLootRunning
        /varset mainLoopIterations 0
        /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
        /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
        /call SetTurboLootCooldown
        /docommand /lootnodrop ${lootNoDropPromptReset}
        /call UnpauseAFollow
        /endmac
    }

    /if (${Me.FreeInventory}) {
        /varset corpseCount ${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]}
        /if (${corpseCount} > 0) {
            | Prioritize corpse we failed to reopen (had items left - e.g. Superb Animal Pelt, Shabby Runic Vellum)
            /if (${_reopenCorpseID} && ${Spawn[${_reopenCorpseID}].ID} && ${Spawn[${_reopenCorpseID}].Distance} <= ${lootDistance} && ${Spawn[${_reopenCorpseID}].Type.Equal[Corpse]} && ${Spawn[${_reopenCorpseID}].Type.NotEqual[PC]}) {
                /target id ${_reopenCorpseID}
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Retargeting corpse ${_reopenCorpseID} (reopen failed - retrying to finish looting)"
            }
            /if (!${Target.ID} || !${Target.Type.Equal[Corpse]}) {
                /target npccorpse noalert ${AlertIndex} radius ${lootDistance}
            }
            | If targeting failed but SpawnCount says corpses exist, try refreshing spawn list once per loop iteration
            /if (!${Target.ID} || !${Target.Type.Equal[Corpse]}) {
                /declare targetingRefreshDone bool local FALSE
                /if (!${targetingRefreshDone}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Targeting failed but SpawnCount shows corpses exist - refreshing corpse data without changing hidecorpse..."
                    /if (${lootPerfLog}) /varcalc perfTargetRefreshes ${perfTargetRefreshes}+1
                    /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
                    /squelch /docommand #corpsefix
                    /delay 1
                    /varset targetingRefreshDone TRUE
                    | Retry targeting (npccorpse only)
                    /if (${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]} > 0) {
                        /target npccorpse noalert ${AlertIndex} radius ${lootDistance}
                    }
                }
            }

            /if ((${Target.ID}) && (${Target.Type.Equal[Corpse]}) && (${Target.Type.NotEqual[PC]})) {
                /if (${Target.Distance} > ${lootDistance}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${Target.ID} is too far (${Target.Distance} > ${lootDistance}), skipping this attempt"
                    /target clear
                    /goto :mainlootloop
                }
                
                /call CheckLootAbortState
                
                /varset moveTries 0
                /face fast
                
                | Store corpse ID for validation during movement
                /varset corpseID ${Target.ID}
                | Stuck detection: reset per corpse
                /varset lastMoveDistance ${Target.Distance}
                /varset stuckCount 0
                
                /if (${useNavForCorpses} && ${Target.Distance} > 10) {
                    /if (${Navigation.PathExists[id ${Target.ID}]}) {
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Using /nav to reach corpse ${Target.ID} (distance: ${Target.Distance})"
                        /nav id ${Target.ID} distance=10
                        /delay 100 !${Navigation.Active} || ${Target.Distance} <= 10
                        /call CheckLootAbortState
                        /if (${Navigation.Active}) {
                            /squelch /nav stop
                        }
                    } else {
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] No nav path, using /moveto for corpse ${Target.ID}"
                        /goto :moveToCorpseLoop
                    }
                }
                
                /if (${Target.Distance} <= 10) /goto :doneMoving
                
                | Fallback moveto loop for fine positioning or when nav unavailable
:moveToCorpseLoop
                /call CheckLootAbortState
                /if (${Target.Distance} <= 10) /goto :doneMoving
                
                | Verify target is still our corpse
                /if (!${Target.ID} || ${Target.ID} != ${corpseID}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Lost corpse target during movement"
                    /target clear
                    /goto :mainlootloop
                }
                
                /if (${Target.Distance} >= ${lootDistance}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${Target.ID} became too far during movement (${Target.Distance} >= ${lootDistance}), skipping this attempt"
                    /target clear
                    /goto :mainlootloop
                }
                
                /varcalc moveTries ${moveTries}+1
                /if (${lootPerfLog} && ${moveTries} > ${perfMaxMoveTries}) /varset perfMaxMoveTries ${moveTries}
                /if (${moveTries} > 30) {
                    /if (${lootPerfDetail}) /call PerfLogLine "detail movement_failed corpse=${Target.ID} dist=${Target.Distance} moveTries=${moveTries}"
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cannot reach corpse ${Target.ID} after ${moveTries} attempts"
                    /if (${lootPerfLog}) /varcalc perfMoveFailures ${perfMoveFailures}+1
                    /echo [turboLoot] WARNING: Movement failed for corpse ${Target.ID} - ensure MQ2Nav or MQ2MoveUtils is loaded
                    /if (${Target.Distance} > 15) {
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${Target.ID} still too far (${Target.Distance} > 15), marking to skip"
                        /varset finalSweepNeeded TRUE
                        /squelch /alert add ${AlertIndex} id ${Target.ID}
                    } else {
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${Target.ID} is close (${Target.Distance}) but pathing failed, will retry later"
                    }
                    /target clear
                    /goto :mainlootloop
                }
                
                | Stuck detection: distance not decreasing = running into wall
                /if (${Target.Distance} >= ${lastMoveDistance} || ${Math.Calc[${lastMoveDistance}-${Target.Distance}]} < 0.1) {
                    /varcalc stuckCount ${stuckCount}+1
                    /if (${stuckCount} >= 12) {
                        /if (${lootPerfLog}) /varcalc perfStuckEvents ${perfStuckEvents}+1
                        /if (${lootPerfDetail}) /call PerfLogLine "detail movement_stuck corpse=${Target.ID} dist=${Target.Distance} stuckCount=${stuckCount} moveTries=${moveTries}"
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Stuck (no progress for ${stuckCount} moves) - corpse ${Target.ID} at ${Target.Distance} ft, attempting loot anyway"
                        /squelch /moveto off
                        | Try looting from current position before giving up - EQ loot range may be sufficient
                        /call CheckLootAbortState
                        /loot
                        /if (${lootPerfLog}) /varcalc perfLootWindowWaits ${perfLootWindowWaits}+1
                        /delay ${lootWindowDelay} ${Window[LootWnd].Open}
                        /doevents
                        /if (${Window[LootWnd].Open}) {
                            | Skips :doneMoving /loot- must set so done-looting announce fires
                            /varset DidLoot TRUE
                            /goto :processItems
                        }
                        | Still failed - truly stuck, skip and sweep will retry
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Stuck and loot failed - corpse ${Target.ID} at ${Target.Distance} ft, skipping"
                        /echo [turboLoot] WARNING: Stuck running toward corpse ${Target.ID} - likely blocked by wall/obstacle
                        /if (${announceSkipped}) /call Announce "${announceSkippedMethod}" "${tlTag} \ar[STUCK]\aw Stuck running toward corpse ${Target.ID} - likely blocked by wall/obstacle, skipping"
                        /varset finalSweepNeeded TRUE
                        /squelch /alert add ${AlertIndex} id ${Target.ID}
                        /target clear
                        /goto :mainlootloop
                    }
                } else {
                    /varset stuckCount 0
                }
                /varset lastMoveDistance ${Target.Distance}
                
                /face fast
                /moveto id ${Target.ID} dist 10
                /if (${lootPerfLog}) /varcalc perfMoveLoops ${perfMoveLoops}+1
                /delay ${moveLoopDelay} ${Target.Distance} <= 10
                /goto :moveToCorpseLoop
                
:doneMoving
                /if (!${Target.ID} || !${Target.Type.Equal[Corpse]}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse no longer valid after movement"
                    /target clear
                    /goto :mainlootloop
                }

                /if (${Cursor.ID}) {
                    /autoinventory
                    /if (${lootPerfLog}) /varcalc perfCursorClearWaits ${perfCursorClearWaits}+1
                    /delay ${cursorClearDelay} !${Cursor.ID}
                    /if (${Cursor.ID}) {
                        /autoi
                        /if (${lootPerfLog}) /varcalc perfCursorClearWaits ${perfCursorClearWaits}+1
                        /delay ${cursorClearDelay} !${Cursor.ID}
                        /if (${Cursor.ID}) {
                            /autoinventory
                            /if (${lootPerfLog}) /varcalc perfCursorClearWaits ${perfCursorClearWaits}+1
                            /delay ${cursorClearDelay} !${Cursor.ID}
                            /if (${Cursor.ID}) {
                                /echo [turboLoot] ERROR: Item stuck on cursor after /autoinventory: ${Cursor.Name}. Clear cursor and rerun.
                                /if (${logToFile}) /call LogError "Item stuck on cursor after autoinventory: ${Cursor.Name}"
                                /e3p off
                                /deletevar turboLootRunning
                                /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
                                /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
                                /call SetTurboLootCooldown
                                /docommand /lootnodrop ${lootNoDropPromptReset}
                                /call UnpauseAFollow
                                /endmac
                            }
                        }
                    }
                }
                
                /varset modeCheck ${restoreFollowMode.Upper.Replace[ ,]}
                /if (${modeCheck.NotEqual[NONE]} && ${modeCheck.Length} && ${modeCheck.NotEqual[NULL]} && ${modeCheck.NotEqual[0]}) {
                    /call StopFollowAndMovement
                }
                /if (${Defined[tooFarHit]}) /varset tooFarHit FALSE
                /if (!${Target.ID} || !${Target.Type.Equal[Corpse]}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Lost corpse target before /loot (Target.ID=${Target.ID}), skipping"
                    /target clear
                    /goto :mainlootloop
                }
                /call CheckLootAbortState
                /loot
                /doevents
                /varset DidLoot TRUE
                /varset DidLootThisCorpse FALSE

                /if (${lootPerfLog}) /varcalc perfLootWindowWaits ${perfLootWindowWaits}+1
                /delay ${lootWindowDelay} ${Window[LootWnd].Open}
                /doevents
                /if (${Window[LootWnd].Open}) {
                    /varcalc corpsesProcessed ${corpsesProcessed}+1
                }
                /if (!${Window[LootWnd].Open}) {
                    | Capture corpse ID now - Target may be cleared by TooFar/doevents during retries
                    /varset _lootFailCorpseID ${Target.ID}
                    /if (!${_lootFailCorpseID}) /varset _lootFailCorpseID ${corpseID}
                    | Retarget by ID before retry (Target can be cleared by game/doevents)
                    /target id ${_lootFailCorpseID}
                    /delay 1 ${Target.ID} == ${_lootFailCorpseID}
                    /if (${Target.ID} != ${_lootFailCorpseID}) {
                        /target id ${_lootFailCorpseID}
                        /delay 1 ${Target.ID} == ${_lootFailCorpseID}
                    }
                    | Try a small position adjustment and retry
                    /if (${lootPerfLog}) /varcalc perfOpenFailures ${perfOpenFailures}+1
                    /if (${lootPerfDetail}) /call PerfLogLine "detail loot_open_failed corpse=${_lootFailCorpseID} dist=${Target.Distance}"
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Loot window failed to open for corpse ${_lootFailCorpseID}, trying position adjustment..."
                    /keypress forward hold
                    /delay 2
                    /keypress forward
                    /delay 1
                    /call CheckLootAbortState
                    /loot
                    /if (${lootPerfLog}) /varcalc perfLootWindowWaits ${perfLootWindowWaits}+1
                    /delay ${lootWindowDelay} ${Window[LootWnd].Open}
                    /doevents
                }
                /if (!${Window[LootWnd].Open}) {
                    | If TooFar happened, do a couple quick re-tries before giving up
                    /if (${Defined[tooFarHit]} && ${tooFarHit}) {
                        /if (${tooFarStrikes} < ${tooFarStrikeThreshold}) {
                            | Retarget by ID before retry (Target often cleared when TooFar fires)
                            /target id ${_lootFailCorpseID}
                            /delay 1 ${Target.ID} == ${_lootFailCorpseID}
                            /if (${Target.ID} != ${_lootFailCorpseID}) {
                                /target id ${_lootFailCorpseID}
                                /delay 1 ${Target.ID} == ${_lootFailCorpseID}
                            }
                            /if (${lootPerfLog}) /varcalc perfTooFarRetries ${perfTooFarRetries}+1
                            /if (${lootPerfDetail}) /call PerfLogLine "detail too_far_retry corpse=${_lootFailCorpseID} dist=${Target.Distance}"
                            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] TooFar retry: micro-step + re-loot corpse ${_lootFailCorpseID}"
                            /keypress forward hold
                            /delay 1
                            /keypress forward
                            /delay 1
                            /call CheckLootAbortState
                            /loot
                            /if (${lootPerfLog}) /varcalc perfLootWindowWaits ${perfLootWindowWaits}+1
                            /delay ${lootWindowDelay} ${Window[LootWnd].Open}
                            /doevents
                            /if (${Window[LootWnd].Open}) {
                                | Skips :doneMoving /loot- must set so done-looting announce fires
                                /varset DidLoot TRUE
                                /goto :processItems
                            }
                        }
                        | Now it's exceeded threshold, treat like true failure
                        /if (${Target.ID}) /squelch /alert add ${AlertIndex} id ${Target.ID}
                    }
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Loot window still failed to open for corpse ${_lootFailCorpseID} after retry, will retry on sweep"
                    /varset finalSweepNeeded TRUE
                    | Add to alert to avoid tight retarget loop, sweep will clear and retry
                    /varset _failedCorpseID ${If[${Target.ID},${Target.ID},${_lootFailCorpseID}]}
                    /if (!${_failedCorpseID}) /varset _failedCorpseID ${corpseID}
                    /if (${_failedCorpseID}) /squelch /alert add ${AlertIndex} id ${_failedCorpseID}
                    /target clear
                    /goto :mainlootloop
                }

                /varset loottotal ${Corpse.Items}
                /varset _itemWait 0
                /if (${loottotal}<=0 && ${Window[LootWnd].Open}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse.Items=0, waiting for window to populate..."
                }
                | Uniform polling — 5 ticks at /delay 1 each
                | If items haven't appeared after this, corpse is empty or coin-only
                /while (${loottotal}<=0 && ${_itemWait} < 5 && ${Window[LootWnd].Open}) {
                    /if (${lootPerfLog}) /varcalc perfEmptyCorpseWaits ${perfEmptyCorpseWaits}+1
                    /delay 1
                    /doevents
                    /varset loottotal ${Corpse.Items}
                    /varcalc _itemWait ${_itemWait}+1
                }
                /if (${lootPerfLog} && ${_itemWait} > ${perfMaxEmptyCorpseWaits}) /varset perfMaxEmptyCorpseWaits ${_itemWait}
                | Final confirmation before declaring the corpse empty. The poll above
                | can give up one frame before a slow item list arrives; this waits up
                | to 2 more ticks but EXITS the instant items appear, so a genuinely
                | empty corpse pays almost nothing while a late-populating one is
                | recovered (and logged) instead of silently closed.
                /if (${loottotal}<=0 && ${Window[LootWnd].Open}) {
                    /delay 2 ${Corpse.Items} > 0
                    /doevents
                    /varset loottotal ${Corpse.Items}
                    /if (${loottotal} > 0) {
                        /if (${lootPerfDetail}) /call PerfLogLine "detail late_populate_recovered corpse=${Target.ID} items=${loottotal} afterWaits=${_itemWait}"
                        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse ${Target.ID} populated late (items=${loottotal}) after ${_itemWait} waits - recovered, processing"
                    }
                }
                /if (${loottotal}<=0) {
                    /if (${lootPerfDetail}) /call PerfLogLine "detail empty_corpse_wait corpse=${Target.ID} waits=${_itemWait}"
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse.Items=0 after ${_itemWait} waits - closing (coin-only or empty) corpse=${Target.ID} name=[${Target.CleanName}] distance=${Target.Distance} windowOpen=${Window[LootWnd].Open}"
                    /if (${Target.ID}) /squelch /alert add ${AlertIndex} id ${Target.ID}
                    /notify LootWnd DoneButton leftmouseup
                    /delay 1
                    /goto :mainlootloop
                }
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Corpse.Items=${loottotal} after ${_itemWait} waits"

                /docommand /lootnodrop ${lootNoDropPrompt}
                
                /varset _processPasses 0
                | Keep skip announce dedupe run-scoped. Reopened loot windows can see
                | the same corpse/items again, and clearing here allows duplicate chat.
                /goto :processItems
            }
        }
    } else {
        /call FormatMessage "\ar [turboLoot] My Inventory is full!!" "${announceMethod}"
        /declare msg string local ${Macro.Return}
        /docommand /${announceMethod} ${msg}
        /e3p off
        /deletevar turboLootRunning
        /varset mainLoopIterations 0
        /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
        /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
        /call SetTurboLootCooldown
        /docommand /lootnodrop ${lootNoDropPromptReset}
        /call UnpauseAFollow
        /endmac
    }
    /goto :mainlootloop

| ---------------------------------------------------------------------
| ITEM PROCESSING LOOP
| ---------------------------------------------------------------------
:processItems
    /varset _reopenCorpseID 0
    /varset loottotal ${Corpse.Items}
    /varset _lastCorpseItems ${loottotal}
    /varset _attemptedLootThisPass FALSE
    /varset _transientSlotSkip FALSE
    /if (${loottotal} < 8) /varset loottotal 8
    | Prefer the loot-loop corpse id over Target.ID: target can drift to a
    | different corpse mid-pass and would stamp the wrong (ID: n) onto [ANNOUNCE]
    | / [SKIP] lines (and onto TurboGear Go-loot buttons).
    /varset _skipCorpseID 0
    /if (${corpseID}) /varset _skipCorpseID ${corpseID}
    /if (!${_skipCorpseID} && ${Target.ID} && ${Target.Type.Equal[Corpse]}) /varset _skipCorpseID ${Target.ID}

    /for lootslot ${loottotal} downto 1
        /call CheckLootAbortState
        /doevents
        /if (${Cursor.ID}) /call ForceClearCursor
        /if (${LoreBlocked}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Lore block detected at start of loop for slot ${lootslot}"
            /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
            /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) {
                /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Added [${LoreAttemptName}] to LoreDeniedNames cache"
            }
            /varset LoreBlocked FALSE
            /varset LoreBlockedName ""
        }
        
        /if (!${Window[LootWnd].Open}) {
            | Capture corpse ID - Target may be cleared by TooFar/doevents during reopen attempts
            /varset _reopenCorpseID ${Target.ID}
            /if (!${_reopenCorpseID}) /varset _reopenCorpseID ${corpseID}
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Loot window closed unexpectedly during item processing, attempting to reopen corpse ${_reopenCorpseID}"
            /varset _reopenTry 0
            /while (${_reopenCorpseID} && !${Window[LootWnd].Open} && ${_reopenTry} < 4) {
                /if (${lootPerfLog}) /varcalc perfReopenAttempts ${perfReopenAttempts}+1
                /if (${lootPerfDetail}) /call PerfLogLine "detail reopen_attempt corpse=${_reopenCorpseID} try=${Math.Calc[${_reopenTry}+1]}"
                /call CheckLootAbortState
                /target id ${_reopenCorpseID}
                /delay 1 ${Target.ID} == ${_reopenCorpseID}
                /if (${Target.ID} != ${_reopenCorpseID}) {
                    /target id ${_reopenCorpseID}
                    /delay 1 ${Target.ID} == ${_reopenCorpseID}
                }
                | Small position nudge on retries (may help if TooFar closed the window)
                /if (${_reopenTry} > 0) {
                    /keypress forward hold
                    /delay 1
                    /keypress forward
                    /delay 1
                }
                /if (!${Target.ID} || !${Target.Type.Equal[Corpse]}) /break
                /call CheckLootAbortState
                /loot
                /delay 5 ${Window[LootWnd].Open}
                /doevents
                /if (${Window[LootWnd].Open}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Reopened loot window for corpse ${_reopenCorpseID}, continuing"
                    /varset _processPasses 0
                    /goto :processItems
                }
                /varcalc _reopenTry ${_reopenTry}+1
                /if (${_reopenTry} < 4) /delay 3 ${Window[LootWnd].Open}
            }
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Could not reopen loot window, returning to main loop to retarget corpse ${_reopenCorpseID}"
            /goto :mainlootloop
        }
        
        /if (!${Corpse.Item[${lootslot}].ID}) {
            | Slot index beyond the live item count is just padding from the min-8
            | scan window — genuinely empty, skip silently as before (no delay, so
            | the healthy path is exactly as fast as today).
            /if (${lootslot} > ${Corpse.Items}) /continue
            | Slot is WITHIN the live item count but read empty: almost always a
            | one-frame populate race (the cause of the rare silent misses since the
            | delay optimization). Settle one tick and re-read before giving up.
            /delay 1
            /doevents
            /if (!${Corpse.Item[${lootslot}].ID}) {
                /varset _transientSlotSkip TRUE
                /if (${lootPerfDetail}) /call PerfLogLine "detail transient_slot_empty corpse=${Target.ID} slot=${lootslot} items=${Corpse.Items}"
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Transient empty ID at slot ${lootslot} (items=${Corpse.Items}) - flagged for reprocess"
                /continue
            }
            /if (${lootPerfDetail}) /call PerfLogLine "detail transient_slot_recovered corpse=${Target.ID} slot=${lootslot}"
        }
        /if (${lootPerfLog}) /varcalc perfItemLoops ${perfItemLoops}+1

        /varset lootName ${Corpse.Item[${lootslot}].Name}
        /if (!${lootName.Length} || ${lootName.Equal[NULL]} || ${lootName.Equal[null]}) {
            | Valid ID but empty name is the same populate race one level deeper.
            | Settle and re-read once before treating the slot as unreadable.
            /delay 1
            /doevents
            /varset lootName ${Corpse.Item[${lootslot}].Name}
            /if (!${lootName.Length} || ${lootName.Equal[NULL]} || ${lootName.Equal[null]}) {
                /varset _transientSlotSkip TRUE
                /if (${lootPerfDetail}) /call PerfLogLine "detail transient_slot_noname corpse=${Target.ID} slot=${lootslot} id=${Corpse.Item[${lootslot}].ID}"
                /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] ERROR: Cannot get item name for slot ${lootslot} (ID: ${Corpse.Item[${lootslot}].ID}) - flagged for reprocess"
                /continue
            }
        }
        /varset itemValue ${Math.Calc[${Corpse.Item[${lootslot}].Value} / 1000]}
        /call TrimSpaces "${lootName}"
        /varset lookupName ${Macro.Return}
        /if (${huntingEnabled}) {
            /if (${lootPerfLog}) /varcalc perfHuntingChecks ${perfHuntingChecks}+1
            /call CheckHuntingItem ${lootslot} "${lookupName}"
        }
        /if (${lootPerfLog}) /varcalc perfIniLookups ${perfIniLookups}+1
        /varset itemLimit ${Ini[${iniFile},ItemLimits,${lookupName}]}
        | 3.8.57: clear ANNOUNCE flag at top of every iteration so it never
        | carries from a previous item to a current one.
        /varset _isAnnounce FALSE
        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            | 3.8.57: ANNOUNCE → IGNORE-class normalization. Item stays on the
            | corpse (no loot), but the IGNORE branch below sees _isAnnounce
            | and forces a chat announcement so another character can grab it.
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) {
                /varset _isAnnounce TRUE
                /varset itemLimitUpper IGNORE
            }
        } else {
            /varset itemLimit ""
            /varset itemLimitUpper ""
        }
        /if (!${itemLimitUpper.Length} || ${itemLimitUpper.Equal[NULL]} || ${itemLimitUpper.Equal[0]} || ${itemLimitUpper.Equal[NOTFOUND]}) {
            /varset itemLimit ""
            /varset itemLimitUpper ""
        }
        /if (${showDebug}) /call LogDebug "Item ${lootName} | INI:[${itemLimit}] upper:[${itemLimitUpper}]"
        /if (${showDebug} && ${itemLimitUpper.Equal[SELL]}) /call LogDebug "Found SELL item: ${lootName} limit=[${itemLimit}] upper=[${itemLimitUpper}]"

        | IGNORE
        /if (${itemLimitUpper.Equal[IGNORE]}) {
            /varcalc itemsIgnored ${itemsIgnored}+1
            /if (${showDebug}) /call LogDebug "[IGNORE] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} (ID: ${_skipCorpseID})"
            /if (${IgnoreAnnouncedKeys.Length} > 2000) /varset IgnoreAnnouncedKeys ""
            | ANNOUNCE-class IGNORE leaves the item on the corpse and emits one
            | player-facing message through the same channel pipeline as skipped
            | messages. It does not journal to Skip Review.
            /if (${_isAnnounce}) {
                /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \at[ANNOUNCE] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})"
                /continue
            }
            /if (${showDebug} && ${announceSkipped} && !${IgnoreAnnouncedKeys.Find[|${lootName}|]}) {
                /varset IgnoreAnnouncedKeys "${IgnoreAnnouncedKeys}|${lootName}|"
                /call Announce "${announceSkippedMethod}" "${tlTag} \aw[IGNORE] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})"
            }
            /continue
        }

        | DESTROY
    /if (${itemLimitUpper.Equal[DESTROY]}) {
            /if (${Corpse.Item[${lootslot}].Lore}) {
                /varset currentCount ${Math.Calc[${FindItemCount[=${lootName}]}+${FindItemBankCount[=${lootName}]}]}
                /if (${currentCount} >= 1) {
    /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - LORE item already in inventory/bank (can't loot to destroy)"
                    /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_have_copy_cannot_destroy"
                    /continue
                }
            }
            /if (${showDebug} || ${announceDestroyed}) /call Announce "${announceMethod}" "${tlTag} \ar[DESTROY] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})"
            /call LootAndDestroyCorpseItem ${lootslot} "${lootName}"
            /varset DidLootThisCorpse TRUE
            /varset _attemptedLootThisPass TRUE
            /continue
        }

        | LORE-DENIED CACHE
        /if (${Corpse.Item[${lootslot}].Lore} && ${LoreDeniedNames.Find[|${lootName}|]}) {
            /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have"
            /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_denied_cache"
            /continue
        }

        | WILDCARD ITEMS
        /if (${IsWildcardItem[${lootName}]}) {
            /if (${showDebug}) /call LogDebug "Wildcard item: ${lootName} INI=[${itemLimit}] upper=[${itemLimitUpper}]"
        
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) /call LogDebug "[IGNORE] Wildcard ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} (ID: ${_skipCorpseID})"
                /varcalc itemsIgnored ${itemsIgnored}+1
                /continue
            }
        
            | If item has an explicit INI rule (SELL, BANK, TRIBUTE, KEEP, DESTROY, ALL, or numeric),
            | respect it - let it fall through to the normal INI-driven processing below.
            | Only force-to-ALL for truly unlisted wildcard items.
            /if (${itemLimitUpper.Length} && (${itemLimitUpper.Equal[SELL]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || ${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[DESTROY]} || ${Int[${itemLimit}]} > 0)) {
                /if (${showDebug}) /call LogDebug "Wildcard has explicit INI rule (${itemLimitUpper})"
                | Fall through to normal processing below (HIGH-VALUE -> STACKABLE -> NORMAL INI blocks)
            } else {
                | Unlisted wildcard item - force to ALL
                /varset itemLimit ALL
                /varset itemLimitUpper WILD
                /if (${showDebug}) /call LogDebug "Wildcard (unlisted) forcing ALL"
        
                /call ProcessLootItem ${lootslot} "${itemLimit}"
                /varset _attemptedLootThisPass TRUE
                /if (!${Corpse.Item[${lootslot}].ID}) /varset DidLootThisCorpse TRUE
                /continue
            }
        }
        
        | HIGH-VALUE
        /if (!${Corpse.Item[${lootslot}].Stackable} && (${enableHighValue} && (${lootHighValueAll} || (${minLootValue} > 0 && ${itemValue} >= ${minLootValue})))) {
            /if (${Corpse.Item[${lootslot}].Lore} && ${LoreDeniedNames.Find[|${lootName}|]}) {
                /if (${showDebug}) /call LogDebug "[VALUE] Skipping ${lootName} - LoreDeniedNames cache"
                /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have (cached)"
                /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_denied_cache"
                /continue
            }
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) /call Announce "${announceMethod}" "${tlTag} \aw[IGNORE] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - High value but IGNORE"
                /varcalc itemsIgnored ${itemsIgnored}+1
                /continue
            }
            /if (${itemLimitUpper.Equal[SELL]} || ${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]}) {
                /if (${showDebug}) /call LogDebug "[VALUE] ${lootName} marked ${itemLimitUpper} - ProcessLootItem path"
                /call ProcessLootItem ${lootslot} "${itemLimit}"
                /varset _attemptedLootThisPass TRUE
                /if (!${Corpse.Item[${lootslot}].ID}) /varset DidLootThisCorpse TRUE
                /continue
            }
            /if (${Corpse.Item[${lootslot}].Lore}) {
                /varset currentCount ${Math.Calc[${FindItemCount[=${lootName}]}+${FindItemBankCount[=${lootName}]}]}
                /if (${currentCount}>=1) {
                    /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have"
                    /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_already_have"
                    /continue
                }
            }
            /if (${showDebug}) /call LogDebug "[VALUE] Looting ${lootName} (${itemValue}pp)"
            /call LootHighValueItem ${lootslot}
            /varset _attemptedLootThisPass TRUE
            /if (!${Corpse.Item[${lootslot}].ID}) /varset DidLootThisCorpse TRUE
            /continue
        }

        | STACKABLE
        /if (${Corpse.Item[${lootslot}].Stackable} && ${lootStackable}) {
            /if (${Corpse.Item[${lootslot}].Lore} && ${LoreDeniedNames.Find[|${lootName}|]}) {
                /if (${showDebug}) /call LogDebug "[STACK] Skipping ${lootName} - LoreDeniedNames"
                /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have (cached)"
                /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_denied_cache"
                /continue
            }
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) /call Announce "${announceMethod}" "${tlTag} \aw[IGNORE] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Stackable but IGNORE"
                /varcalc itemsIgnored ${itemsIgnored}+1
                /continue
            }
            /if (${itemLimit.Length} && (${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[SELL]} || ${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0))) {
                /if (${showDebug}) /call LogDebug "[STACK] Listed stackable ${lootName} limit [${itemLimit}] | ProcessLootItem"
                /call ProcessLootItem ${lootslot} "${itemLimit}"
                /varset _attemptedLootThisPass TRUE
            } else {
                /if (!${lootStackable} || (${minStackableValue} > 0 && ${itemValue} < ${minStackableValue})) {
                    /if (${showDebug}) /call LogDebug "[STACK] Unlisted stackable ${lootName} ${itemValue}pp below threshold"
                    /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Below ${minStackableValue}pp threshold"
                    /call LogSkipForCorpseItem ${lootslot} "${lootName}" "stackable_below_pp_threshold"
                    /continue
                }
                /if (${showDebug}) /call LogDebug "[STACK] Unlisted stackable ${lootName} ${itemValue}pp - looting (LootStackable)"
                /call CheckInventorySpace "${lootName}" ${lootslot}
                /call LootTheItem ${lootslot} "${lootName}" 999999 "${If[${itemLimit.Length},${itemLimit},STACK]}"
                /varset _attemptedLootThisPass TRUE
            }
            /if (!${Corpse.Item[${lootslot}].ID}) /varset DidLootThisCorpse TRUE
            /continue
        }

        | NORMAL (INI-driven)
        /if (${Corpse.Item[${lootslot}].Lore}) {
            /varset currentCount ${Math.Calc[${FindItemCount[=${lootName}]}+${FindItemBankCount[=${lootName}]}]}
            /if (${showDebug}) /call LogDebug "LORE precheck: ${lootName} inv=${FindItemCount[=${lootName}]} bank=${FindItemBankCount[=${lootName}]} total=${currentCount}"
            /if (${currentCount}>=1) {
                /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have"
                /call LogSkipForCorpseItem ${lootslot} "${lootName}" "lore_already_have"
                /continue
            }
        }

        | Process ALL, numeric limits, SELL, KEEP, BANK, and TRIBUTE items
        /if (${showDebug} && ${itemLimitUpper.Equal[SELL]}) /call LogDebug "Checking SELL ${lootName}"
        /if (${itemLimit.Length} && (${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[SELL]} || ${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0))) {
            /if (${showDebug} && ${itemLimitUpper.Equal[SELL]}) /call LogDebug "SELL ${lootName} -> ProcessLootItem"
            /call ProcessLootItem ${lootslot} "${itemLimit}"
            /varset _attemptedLootThisPass TRUE
            /if (!${Corpse.Item[${lootslot}].ID}) /varset DidLootThisCorpse TRUE
        } else {
            | Item is unlisted - skip
            /if (${showDebug}) /call LogDebug "Unlisted (skip): ${lootName}"
            /call AnnounceSkipped "${_skipCorpseID}:${lootName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootslot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})"
            /call LogSkipForCorpseItem ${lootslot} "${lootName}" "unlisted"
        }

    /next lootslot

    /if (${Window[LootWnd].Open} && ${Corpse.Items} > 0) {
        /if (${Corpse.Items} != ${_lastCorpseItems}) {
            /varset _processPasses 0
            /if (${showDebug} || ${logToFile}) /call LogDebug "Corpse has ${Corpse.Items} item(s) left (count changed), re-processing"
            /goto :processItems
        }
        | No net count change, but a slot read empty mid-scan (one-frame populate
        | race). Give the corpse a small, bounded number of extra passes so a
        | transiently-skipped item still gets looted. The count-change branch above
        | already handles normal progress; this only fires on the rare race and is
        | capped by _processPasses so it can never spin.
        /if (${_transientSlotSkip} && ${_processPasses} < 3) {
            /varcalc _processPasses ${_processPasses}+1
            /if (${showDebug} || ${logToFile}) /call LogDebug "Corpse ${Target.ID}: transient empty slot read, reprocessing (pass ${_processPasses})"
            /if (${lootPerfDetail}) /call PerfLogLine "detail transient_reprocess corpse=${Target.ID} pass=${_processPasses} items=${Corpse.Items}"
            /delay 1
            /goto :processItems
        }
    }

:DoneLooting
    /if (${Target.ID}) /squelch /alert add ${AlertIndex} id ${Target.ID}
    /if (!${DidLootThisCorpse} && !${Skip}) {
        /if (${Corpse.Items} > 0) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "Corpse ${Target.ID}: nothing looted, items remain (skipped/limits) - done"
            /if (${AllSkippedCorpseIds.Length} > 500) /varset AllSkippedCorpseIds ""
            /if (!${AllSkippedCorpseIds.Find[|${Target.ID}|]}) /varset AllSkippedCorpseIds "${AllSkippedCorpseIds}|${Target.ID}|"
        }
    }
    /varset Skip FALSE
    /varset LoreBlocked FALSE
    /varset LoreBlockedName ""
    /varset closeTries 0
:CloseLootWindow
    /if (${lootPerfLog}) /varcalc perfCloseLoops ${perfCloseLoops}+1
    /varcalc closeTries ${closeTries}+1
    /if (${closeTries} > 10) {
        /if (${lootPerfDetail}) /call PerfLogLine "detail close_loot_window_stuck loops=${closeTries}"
        /if (${showDebug} || ${logToFile}) /call LogDebug "Loot window stuck after ${closeTries} tries, forcing close"
        /call TryCloseLootWindow
        /delay 1
        /if (${Window[LootWnd].Open}) {
            /echo [turboLoot] ERROR: Loot window still open. Aborting to prevent hang.
            /call Cleanup
            /endmac
        }
        /goto :mainlootloop
    }
    /call TryCloseLootWindow
    /delay 1

    /doevents
    /if (${Window[LootWnd].Open}) /goto :CloseLootWindow


    /if (!${Me.FreeInventory}) {
        /call ShouldAnnounceDoneLooting
        /varset _doneLootGate ${Int[${Macro.Return}]}
        /if (${showDebug}) /call LogDebug "doneLootingGate ret=${_doneLootGate} DidLoot=${DidLoot} grouped=${Me.Grouped} doneLootDest=[${announceDoneLootingTo}] corpses=${corpsesProcessed}"
        /if (${_doneLootGate}) /call Announce "${announceDoneLootingTo}" "${tlTag} [DONE LOOTING ${corpsesProcessed} CORPSES]"
        /if (${showDebug} || ${logToFile}) /call LogDebug "No more lootable corpses. Exiting."
        | Don't hide on inventory-full exit - we may have left unprocessed corpses
        /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
        /call CloseBags
        /deletevar turboLootRunning
        /varset mainLoopIterations 0
        /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
        /call SetTurboLootCooldown
        /call Cleanup
        /return
    }
    /goto :mainlootloop

:EndConfirmLoop
    /varcalc endConfirm ${endConfirm}+1
    /if (${lootPerfLog}) /varcalc perfCorpsefixCalls ${perfCorpsefixCalls}+1
    /squelch /docommand #corpsefix
    /delay 1

    /if (${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "EndConfirm: unalerted corpses after refresh - continuing"
        /varset endConfirm 0
        /goto :mainlootloop
    }
    /if (${endConfirm} < 2) /goto :EndConfirmLoop

    /if (${showDebug} || ${logToFile}) /call LogDebug "No corpses within ${lootDistance}. Exiting."
    /call ShouldAnnounceDoneLooting
    /varset _doneLootGate ${Int[${Macro.Return}]}
    /if (${showDebug}) /call LogDebug "doneLootingGate ret=${_doneLootGate} DidLoot=${DidLoot} grouped=${Me.Grouped} doneLootDest=[${announceDoneLootingTo}] corpses=${corpsesProcessed}"
    /if (${_doneLootGate}) /call Announce "${announceDoneLootingTo}" "${tlTag} [DONE LOOTING ${corpsesProcessed} CORPSES]"
    | Safeguard: wait 2s, check for new unprocessed corpses before hiding (avoids hiding during combat)
    /if (!${corpseHideMode.Equal[OFF]} && !${corpseHideMode.Equal[LOOTED]} && ${DidLoot}) {
        /delay 2
        /if (${SpawnCount[npccorpse noalert ${AlertIndex} radius ${lootDistance}]}) {
            /varset endConfirm 0
            /goto :mainlootloop
        }
        /if (${corpseHideMode.Equal[ALL]}) /squelch /hidecorpse all
        /if (${corpseHideMode.Equal[SELF]}) /squelch /hidecorpse npc
        | E3Next: /e3bcg sends to group EXCLUDING self - non-looters hide corpses
        /if ((${corpseHideMode.Equal[ALL]} || ${corpseHideMode.Equal[GROUP]}) && ${Me.Grouped}) /squelch /docommand /e3bcg /squelch /hidecorpse all
    }
    /if (${AlertIndex}) /squelch /alert clear ${AlertIndex}
    /call CloseBags
    /deletevar turboLootRunning
    /varset mainLoopIterations 0
    /call SetTurboLootCooldown
    /call Cleanup
/return

|| ---------------------------------------------------------------------
|| AUTO SELL
|| ---------------------------------------------------------------------
Sub AutoSell
    
    /varset itemsSold 0
    /varset platinumGain 0
    /varset sellTotalCopper 0
    
    /declare totalItemsChecked int local 0
    /declare itemsWithIniEntry int local 0
    /declare itemLink string local
    /declare iniColor string local
    
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoStarting turboSell process..."

    /if (${dropLevBeforeNav} && ${Me.Levitating}) {
        /call AnnounceBankSellProgress "${tlTag} \ayDetected levitation - removing before navigating..."
        /removelev
        /delay 10 !${Me.Levitating}
        /if (${Me.Levitating}) /call AnnounceBankSell "${tlTag} \aoWARNING: Could not remove levitation. This may cause navigation issues."
    }

    /target clear
    /delay 1
    
    /if (!${Window[MerchantWnd].Open}) {
        /call AnnounceBankSellProgress "${tlTag} \ayMerchant window not open - attempting to find and open merchant..."
        
        | Check if merchant is already targeted first (fast path - only try opening if close enough)
        | Exclude players (PC) and self to prevent issues
        /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Merchant]} || ${Target.Type.Equal[NPC]})) {
            | Merchant is targeted - only try opening window if close enough (avoid delay when far away)
            /if (${Target.Distance} <= 10) {
                /invoke ${Merchant.OpenWindow}
                /delay 100 ${Window[MerchantWnd].Open}
                /doevents
            }
        }
        
        | If still not open, try targeting nearest merchant first
        /if (!${Window[MerchantWnd].Open}) {
            | Try multiple methods to find merchant
            | Method 1: Check if merchant is already targeted (accept NPC type too, as manual targeting might not show "Merchant" type)
            | Retarget if: no target, target is self, target is PC, or target is not Merchant/NPC
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Merchant]} && ${Target.Type.NotEqual[NPC]})) {
                | Method 2: Target nearest NPC merchant using spawn search
                /target npc merchant
                /delay 1
            }
            
            | If still no merchant, try broader search
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Merchant]} && ${Target.Type.NotEqual[NPC]})) {
                | Method 3: Use SpawnCount to find merchants
                /if (${SpawnCount[npc merchant radius 200]} > 0) {
                    /target npc merchant radius 200
                    /delay 1
                }
            }
            
            | Accept target if it's a merchant OR an NPC (manual targeting might show NPC type)
            | Exclude players (PC) and self to prevent issues
            /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Merchant]} || ${Target.Type.Equal[NPC]})) {
                /call AnnounceBankSellProgress "${tlTag} \ayFound merchant: \aw${Target.CleanName} \ay(distance: \aw${Target.Distance}\ay; type: \aw${Target.Type}\ay)"
                
                | Navigate to merchant if too far away
                /if (${Target.Distance} > 10) {
                    /call AnnounceBankSellProgress "${tlTag} \ayNavigating to merchant (distance: \aw${Target.Distance} \ayunits)..."
                    /face fast
                    
                    | Try nav first (proper pathfinding), fall back to moveto if unavailable
                    /declare navTries int local 0
                    /declare merchantID int local ${Target.ID}
                    /declare usedNav bool local FALSE
                    
                    /if (${Navigation.PathExists[id ${Target.ID}]}) {
                        /if (${showDebug} || ${logToFile}) /call LogDebug "Using /nav to reach merchant"
                        /nav id ${Target.ID} distance=10
                        | Wait for nav to complete (up to 15 seconds)
                        /delay 150 !${Navigation.Active} || ${Target.Distance} <= 10
                        /if (${Navigation.Active}) {
                            /squelch /nav stop
                        }
                        /varset usedNav TRUE
                    }
                    
                    | If nav got us close enough, skip the moveto loop
                    /if (${Target.Distance} <= 10) /goto :reachedMerchant
                    
                    | Fallback moveto loop
                    :moveToMerchant
                    /if (${Target.Distance} <= 10) /goto :reachedMerchant
                    
                    | Check if target is still valid
                    /if (!${Target.ID} || ${Target.ID} != ${merchantID}) {
                        /call AnnounceBankSell "${tlTag} \arERROR: Lost merchant target during navigation"
                        /return
                    }
                    
                    /varcalc navTries ${navTries} + 1
                    /if (${navTries} > 50) {
                        /call AnnounceBankSell "${tlTag} \aoWARNING: Could not reach merchant after \aw${navTries} \aoattempts (distance: \aw${Target.Distance}\ao)"
                        /call AnnounceBankSellProgress "${tlTag} \ayAttempting to open window anyway..."
                        /goto :reachedMerchant
                    }
                    
                    /face fast
                    /moveto id ${Target.ID} dist 10
                    /delay 5
                    /doevents
                    /goto :moveToMerchant
                    
                    :reachedMerchant
                    /if (${Target.Distance} <= 10) {
                        /call AnnounceBankSellProgress "${tlTag} \agReached merchant (distance: \aw${Target.Distance}\ag)"
                    } else {
                        /call AnnounceBankSell "${tlTag} \aoWARNING: Could not fully reach merchant (distance: \aw${Target.Distance}\ao) - attempting to open window anyway"
                    }
                }
                
                | Face merchant and open window
                /face fast
                /delay 1
                
                | Try opening merchant window now that we have a target (and are close)
                /invoke ${Merchant.OpenWindow}
                
                | Wait for window to open (conditional delay - exits early when window opens, like banking)
                /delay 100 ${Window[MerchantWnd].Open}
                /doevents
                
                /if (${Window[MerchantWnd].Open}) {
                    /call AnnounceBankSellProgress "${tlTag} \agMerchant window opened: \aw${Target.CleanName}"
                } else {
                    /call AnnounceBankSell "${tlTag} \arERROR: Failed to open merchant window"
                    /call AnnounceBankSell "${tlTag} \awPlease manually target a merchant and open their window - then try again"
                    /return
                }
            } else {
                /call AnnounceBankSell "${tlTag} \arERROR: No merchant found nearby"
                /call AnnounceBankSell "${tlTag} \awPlease manually target a merchant and open their window - then try again"
                /return
            }
        } else {
            /call AnnounceBankSellProgress "${tlTag} \agMerchant window opened successfully"
        }
    }
    
    /call AnnounceBankSellProgress "${tlTag} \ayScanning inventory for items marked SELL..."
    
    /call AnnounceBankSellProgress "${tlTag} \ayScanning main inventory slots (23-32)..."
    /for slotNum 23 to 32
        | Process events to keep macro responsive
        /doevents
        
        | Check if merchant window is still open (periodic check)
        /if (!${Window[MerchantWnd].Open}) {
            /call AnnounceBankSell "${tlTag} \arERROR: Merchant window closed during scan!"
            /return
        }
        
        | Check if slot has an item (check ID first, then name)
        /if (!${Me.Inventory[${slotNum}].ID}) /continue
        
        | Get item name directly (main inventory slots use direct slot access)
        | Use .Name explicitly to ensure we get the full item name
        /varset itemName ${Me.Inventory[${slotNum}].Name}
        | Set itemLink and iniColor for this loop iteration (variables already declared at start of subroutine)
        /varset itemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
        /varset iniColor \aw
        
        | Debug output for main inventory items (only if showDebug is enabled)
        /if (${showDebug} && ${itemName.Length} && !${itemName.Equal[NULL]}) {
            /call AnnounceBankSell "${tlTag} \ayMain inventory slot ${slotNum}: ${itemLink} (ID: ${Me.Inventory[${slotNum}].ID})"
        } else /if (${showDebug} && (!${itemName.Length} || ${itemName.Equal[NULL]})) {
            /call AnnounceBankSell "${tlTag} \arWARNING: Slot ${slotNum} has item ID ${Me.Inventory[${slotNum}].ID} but name retrieval failed!"
        }

        /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
        
        | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback)
        /varcalc totalItemsChecked ${totalItemsChecked} + 1
        /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
        }
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
        }
        /varset itemLimitUpper ${itemLimit.Upper}
        /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
        /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
        /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
        | Determine color for INI value based on type (reuse iniColor already declared)
        /varset iniColor \aw
        /if (${itemLimitUpper.Equal[KEEP]}) /varset iniColor \ag
        /if (${itemLimitUpper.Equal[ALL]}) /varset iniColor \at
        /if (${itemLimitUpper.Equal[DESTROY]}) /varset iniColor \ar
        /if (${itemLimitUpper.Equal[IGNORE]}) /varset iniColor \ao
        /if (${itemLimitUpper.Equal[SELL]}) /varset iniColor \ag
        /if (${itemLimitUpper.Equal[BANK]}) /varset iniColor \ag
        | Check if it's a number (value limit) - only check numeric if not already set to a keyword
        /if (${iniColor.Equal[\aw]} && ${itemLimit.Length} && ${itemLimit.NotEqual[NULL]} && ${itemLimit.NotEqual[0]}) {
            | Try to convert to int - if it succeeds and is in valid range, it's a number
            /if (${Int[${itemLimit}]} > 0 && ${Int[${itemLimit}]} < 10000) /varset iniColor \ay
        }
        | Debug output for INI lookup (only if showDebug is enabled)
        /if (${showDebug}) {
            /call AnnounceBankSell "${tlTag} \aySlot ${slotNum} (${itemLink}) - INI lookup: \"${iniColor}${itemLimit}\ay\" (upper: \"${iniColor}${itemLimitUpper}\ay\")"
        }
        
        | Track items with INI entries for debugging
        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
            /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
        }
        
            | Priority 1: SELL - always sell
        /if (${itemLimitUpper.Equal[SELL]}) {
            | Use bagNum=0 to indicate main inventory, pass actual slot number (23-32)
            | Note: SellItem will skip main inventory items (MQ2 limitation) and show a helpful message
            /call SellItem 0 ${slotNum} "${itemName}"
            /continue
        }
        
        | Check for BANK items in main inventory (show notice even though we can't bank them)
        /if (${itemLimitUpper.Equal[BANK]}) {
            /call AnnounceBankSell "${tlTag} \aoNOTICE: Item ${itemLink} \aoin main inventory slot ${slotNum} is marked \agBANK\ao."
            /call AnnounceBankSell "${tlTag} \arACTION REQUIRED: Move ${itemLink} \arto a bag (pack1-pack10); then run \ag/mac turboloot bank\ar to bank it. This is a limitation of MQ."
            /continue
        }
        
        | Priority 2: KEEP, legacy ALL, or numeric - never sell (keep in inventory unless explicitly SELL/BANK/TRIBUTE)
        /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
            /if (${showDebug}) {
                /echo \ag[AutoSell]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
            }
            /continue
        }
        
        | Priority 3: IGNORE - never sell (same as KEEP for selling)
        /if (${itemLimitUpper.Equal[IGNORE]}) {
            /if (${showDebug}) {
                /echo \ag[AutoSell]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
            }
            /continue
        }

        | Priority 4: Wildcard auto-sell (optional)
        | - ON: auto-sell wildcards unless explicitly protected via KEEP/#/IGNORE/BANK/TRIBUTE
        | - OFF: never auto-sell wildcards (but explicit Item=SELL still sells)
        /if (${sellWildcards} && ${IsWildcardItem[${itemName}]}) {
            /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[IGNORE]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0)) {
                /continue
            }
            /call SellItem 0 ${slotNum} "${itemName}"
            /continue
        }
        
        | Priority 5: Sell unlisted stackables (optional)
        | Behavior: sell any unlisted stackable item with vendor value (if SellUnlistedStackable=ON)
        /if (${enableSellStackable} && ${Me.Inventory[${slotNum}].Stackable} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
            | Check if item is truly unlisted (no INI entry or empty/NULL)
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                | Item is unlisted - check if it has vendor value
                /if (${Me.Inventory[${slotNum}].Value} > 0) {
                    | Double-check it's not marked as KEEP/legacy ALL/numeric
                    /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                        /varset itemValue ${Int[${Math.Calc[${Me.Inventory[${slotNum}].Value} / 1000]}]}
                        /call AnnounceBankSell "${tlTag} \ag*** Turboselling unlisted stackable ${itemLink} \ag(value: \aw${itemValue}pp\ag) ***"
                        | Use bagNum=0 to indicate main inventory, pass actual slot number (23-32)
                        /call SellItem 0 ${slotNum} "${itemName}"
                        /continue
                    }
                }
            }
        }

        | Priority 6: Sell ANY unlisted item (not just stackables)
        | Behavior: sell any unlisted item that has vendor value (if sellUnlistedItems=ON)
        /if (${enableSellUnlistedValue} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
            | Check if item is truly unlisted (no INI entry or empty/NULL)
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                | Item is unlisted - check if it has vendor value
                /if (${Me.Inventory[${slotNum}].Value} > 0) {
                    | Double-check it's not marked as KEEP/legacy ALL/numeric
                    /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                        /varset itemValue ${Int[${Math.Calc[${Me.Inventory[${slotNum}].Value} / 1000]}]}
                        /call AnnounceBankSell "${tlTag} \ag*** turboSelling unlisted item ${itemLink} \ag(value: \aw${itemValue}pp\ag) ***"
                        | Use bagNum=0 to indicate main inventory, pass actual slot number (23-32)
                        /call SellItem 0 ${slotNum} "${itemName}"
                        /continue
                    }
                }
            }
        }
    /next slotNum
    
    /if (${showDebug} || ${logToFile}) /call LogDebug "Progress: finished main inventory slots, scanning bags..."
    
    /for packNum 1 to 10
        | Check if merchant window is still open (periodic check)
        /if (!${Window[MerchantWnd].Open}) {
            /call AnnounceBankSell "${tlTag} \arERROR: Merchant window closed during scan!"
            /return
        }
        
        | Check if pack exists first - check Container property (0 means pack doesn't exist or isn't a container)
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} == 0) /continue
        
        /for slotNum 1 to ${maxSlots}
            | Process events to keep macro responsive
            /doevents
            
            | Get item name directly
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            
            | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback)
            /varcalc totalItemsChecked ${totalItemsChecked} + 1
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
            }
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
            }
            | Safety check: ensure itemLimit is initialized before string operations
            /if (!${itemLimit.Length}) /varset itemLimit ""
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
            | Set itemLink and iniColor for this bag slot iteration (variables already declared at start of subroutine)
            /varset itemLink ${Me.Inventory[pack${packNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
            /varset iniColor \aw
            
            | Track items with INI entries for debugging
            /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
                /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
            }
            
            | Priority 1: SELL - always sell
            /if (${itemLimitUpper.Equal[SELL]}) {
                /call SellItem ${packNum} ${slotNum} "${itemName}"
                /continue
            }
            
            | Priority 2: KEEP, legacy ALL, or numeric - never sell (keep in inventory unless explicitly SELL/BANK/TRIBUTE)
            /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
                /if (${showDebug}) {
                    /echo \ag[AutoSell]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
                }
                /continue
            }
            
            | Priority 3: IGNORE - never sell (same as KEEP for selling)
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) {
                    /echo \ag[AutoSell]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
                }
                /continue
            }

            | Priority 4: Wildcard auto-sell (optional)
            | - ON: auto-sell wildcards unless explicitly protected via KEEP/#/IGNORE/BANK/TRIBUTE
            | - OFF: never auto-sell wildcards (but explicit Item=SELL still sells)
            /if (${sellWildcards} && ${IsWildcardItem[${itemName}]}) {
                /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[IGNORE]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0)) {
                    /continue
                }
                /call SellItem ${packNum} ${slotNum} "${itemName}"
                /continue
            }
            
            | Priority 5: Sell unlisted stackables (optional)
            | Behavior: sell any unlisted stackable item with vendor value (if SellUnlistedStackable=ON)
            /if (${enableSellStackable} && ${Me.Inventory[pack${packNum}].Item[${slotNum}].Stackable} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
                | Check if item is truly unlisted (no INI entry or empty/NULL)
                /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                    | Item is unlisted - check if it has vendor value
                    /if (${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} > 0) {
                        | Double-check it's not marked as KEEP/legacy ALL/numeric (shouldn't happen if unlisted, but safety check)
                        /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                            /varset itemValue ${Int[${Math.Calc[${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} / 1000]}]}
                            /call AnnounceBankSell "${tlTag} \ag*** turboSelling unlisted stackable ${itemLink} \ag(value: \aw${itemValue}pp\ag) ***"
                            /call SellItem ${packNum} ${slotNum} "${itemName}"
                            /continue
                        }
                    }
                }
            }

            | Priority 6: Sell ANY unlisted item (not just stackables)
            | Behavior: sell any unlisted item that has vendor value (if sellUnlistedItems=ON)
            /if (${enableSellUnlistedValue} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
                | Check if item is truly unlisted (no INI entry or empty/NULL)
                /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                    | Item is unlisted - check if it has vendor value
                    /if (${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} > 0) {
                        | Double-check it's not marked as KEEP/legacy ALL/numeric
                        /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                            /varset itemValue ${Int[${Math.Calc[${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} / 1000]}]}
                            /call AnnounceBankSell "${tlTag} \ag*** turboSelling unlisted item ${itemLink} \ag(value: \aw${itemValue}pp\ag) ***"
                            /call SellItem ${packNum} ${slotNum} "${itemName}"
                            /continue
                        }
                    }
                }
            }
            
        /next slotNum
    /next packNum
    
    | Build a nice currency breakdown from sellTotalCopper
    /declare soldPP int local ${Int[${Math.Calc[${sellTotalCopper}/1000]}]}
    /declare soldGP int local ${Int[${Math.Calc[(${sellTotalCopper}%1000)/100]}]}
    /declare soldSP int local ${Int[${Math.Calc[(${sellTotalCopper}%100)/10]}]}
    /declare soldCP int local ${Int[${Math.Calc[${sellTotalCopper}%10]}]}

    /if (${itemsSold} > 0) {
        /call AnnounceBankSell "${tlTag} \agturboSell complete. \awItems sold: \ag${itemsSold}\aw - Total value: \ag${soldPP}pp ${soldGP}gp ${soldSP}sp ${soldCP}cp"
        /if (${sellTotalCopper} > 0 && ${Lua.Script[Turbo/gains].Status.Lower.Find[running]}) /squelch /turbogains sold ${sellTotalCopper} ${itemsSold}
    } else {
        /call AnnounceBankSell "${tlTag} \aoNo items were sold."
        /call AnnounceBankSell "${tlTag} \awCheck your \ayturboLoot.ini \aw[ItemLimits] section."
        /call AnnounceBankSell "${tlTag} \awItems must be marked \agSELL \aw(e.g. \ayItemName=SELL\aw) to be sold."
    }

    /call AnnounceBankSellProgress "${tlTag} \ayClosing merchant window when the windows and bags are closed..."
    /call CloseBags

    /if (${Window[MerchantWnd].Open}) {
        /notify MerchantWnd MW_Done_Button leftmouseup
        /delay 10 !${Window[MerchantWnd].Open}
    }
    /call AnnounceBankSellProgress "${tlTag} \ayClosed merchant window."
/return

||| ---------------------------------------------------------------------
||| AUTO SELL DRY RUN (preview what would be sold)
||| ---------------------------------------------------------------------
Sub AutoSellDryRun(bool skipSummary)
    /varset dryRunSellCount 0
    /varset dryRunSellTotalCopper 0
    
    /declare totalItemsChecked int local 0
    /declare itemsWithIniEntry int local 0
    /declare itemLink string local
    /declare iniColor string local
    
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoDRY RUN MODE - No items will be sold"
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \ao=== ITEMS THAT WOULD BE SOLD ==="
    
    /for slotNum 23 to 32
        | Process events to keep macro responsive
        /doevents
        
        | Note: No merchant window check needed for dry-run (we're not actually selling)
        
        | Check if slot has an item (check ID first, then name) - same as AutoSell
        /if (!${Me.Inventory[${slotNum}].ID}) /continue
        
        | Get item name directly (main inventory slots use direct slot access) - same as AutoSell
        | Use .Name explicitly to ensure we get the full item name
        /varset itemName ${Me.Inventory[${slotNum}].Name}
        | Set itemLink and iniColor for this loop iteration (variables already declared at start of subroutine)
        /varset itemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
        /varset iniColor \aw
        
        /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
        
        | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback) - same as AutoSell
        /varcalc totalItemsChecked ${totalItemsChecked} + 1
        /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
        }
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
        }
        /varset itemLimitUpper ${itemLimit.Upper}
        /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
        /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
        /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
        
        | Track items with INI entries for debugging
        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
            /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
        }
        
        | Priority 1: SELL - always sell - same as AutoSell line 2280
        /if (${itemLimitUpper.Equal[SELL]}) {
            | Display immediately (mirrors SellItem call at line 2283)
            /call DisplayDryRunSellItem 0 ${slotNum} "${itemName}" "\ag[SELL]\aw"
            /continue
        }
        
        | Check for BANK items in main inventory (show notice even though we can't bank them) - same as AutoSell
        /if (${itemLimitUpper.Equal[BANK]}) {
            /call AnnounceBankSell "${tlTag} \aoNOTICE: Item ${itemLink} \aoin main inventory slot ${slotNum} is marked \agBANK\ao."
            /call AnnounceBankSell "${tlTag} \arACTION REQUIRED: Move ${itemLink} \arto a bag (pack1-pack10); then run \ag/mac turboloot bank\ar to bank it. This is a limitation of MQ."
            /continue
        }
        
        | Priority 2: KEEP, legacy ALL, or numeric - never sell (same as AutoSell)
        /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
            /if (${showDebug}) {
                /echo \ag[AutoSell]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
            }
            /continue
        }
        
        | Priority 3: IGNORE - never sell (same as KEEP for selling) - same as AutoSell
        /if (${itemLimitUpper.Equal[IGNORE]}) {
            /if (${showDebug}) {
                /echo \ag[AutoSell]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
            }
            /continue
        }

        | Priority 4: Wildcard auto-sell (optional) - same as AutoSell line 2313
        | - ON: auto-sell wildcards unless explicitly protected via KEEP/IGNORE/BANK/TRIBUTE
        | - OFF: never auto-sell wildcards (but explicit Item=SELL still sells)
        /if (${sellWildcards} && ${IsWildcardItem[${itemName}]}) {
            /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[IGNORE]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0)) {
                /continue
            }
            | Display immediately (mirrors SellItem call)
            /call DisplayDryRunSellItem 0 ${slotNum} "${itemName}" "\ay[Wildcard]\aw"
            /continue
        }
        
        | Priority 5: Sell unlisted stackables (optional) - same as AutoSell line 2302
        | Behavior: sell any unlisted stackable item with vendor value (if SellUnlistedStackable=ON)
        /if (${enableSellStackable} && ${Me.Inventory[${slotNum}].Stackable} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
            | Check if item is truly unlisted (no INI entry or empty/NULL)
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                | Item is unlisted - check if it has vendor value
                /if (${Me.Inventory[${slotNum}].Value} > 0) {
                    | Double-check it's not marked as KEEP/legacy ALL/numeric
                    /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                        | Display immediately (mirrors SellItem call)
                        /call DisplayDryRunSellItem 0 ${slotNum} "${itemName}" "\ao(Unlisted stackable)\aw"
                        /continue
                    }
                }
            }
        }

        | Priority 6: Sell ANY unlisted item (not just stackables) - same as AutoSell line 2350
        | Behavior: sell any unlisted item that has vendor value (if sellUnlistedItems=ON)
        /if (${enableSellUnlistedValue} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
            | Check if item is truly unlisted (no INI entry or empty/NULL)
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                | Item is unlisted - check if it has vendor value
                /if (${Me.Inventory[${slotNum}].Value} > 0) {
                    | Double-check it's not marked as KEEP/legacy ALL/numeric
                    /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                        | Display immediately (mirrors SellItem call)
                        /call DisplayDryRunSellItem 0 ${slotNum} "${itemName}" "\ao(Unlisted item)\aw"
                        /continue
                    }
                }
            }
        }
    /next slotNum
    
    /if (${showDebug} || ${logToFile}) /call LogDebug "Progress: finished main inventory slots, scanning bags..."
    
    /for packNum 1 to 10
        | Note: No merchant window check needed for dry-run (we're not actually selling)
        
        | Check if pack exists first - check Container property (0 means pack doesn't exist or isn't a container)
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} == 0) /continue
        
        /for slotNum 1 to ${maxSlots}
            | Process events to keep macro responsive
            /doevents
            
            | Get item name directly - same as AutoSell line 2391
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            
            | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback) - same as AutoSell line 2395
            /varcalc totalItemsChecked ${totalItemsChecked} + 1
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
            }
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
            }
            | Safety check: ensure itemLimit is initialized before string operations
            /if (!${itemLimit.Length}) /varset itemLimit ""
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
            | Set itemLink and iniColor for this bag slot iteration (variables already declared at start of subroutine)
            /varset itemLink ${Me.Inventory[pack${packNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
            /varset iniColor \aw
            
            | Track items with INI entries for debugging
            /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
                /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
            }
            
            | Priority 1: SELL - always sell - same as AutoSell line 2418
            /if (${itemLimitUpper.Equal[SELL]}) {
                | Display immediately (mirrors SellItem call at line 2419)
                /call DisplayDryRunSellItem ${packNum} ${slotNum} "${itemName}" "\ag[SELL]\aw"
                /continue
            }
            
            | Priority 2: KEEP, legacy ALL, or numeric - never sell (same as AutoSell)
            /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
                /if (${showDebug}) {
                    /echo \ag[AutoSell]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
                }
                /continue
            }
            
            | Priority 3: IGNORE - never sell (same as KEEP for selling) - same as AutoSell
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) {
                    /echo \ag[AutoSell]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
                }
                /continue
            }

            | Priority 4: Wildcard auto-sell (optional) - same as AutoSell
            | - ON: auto-sell wildcards unless explicitly protected via KEEP/#/IGNORE/BANK/TRIBUTE
            | - OFF: never auto-sell wildcards (but explicit Item=SELL still sells)
            /if (${sellWildcards} && ${IsWildcardItem[${itemName}]}) {
                /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || ${itemLimitUpper.Equal[IGNORE]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]} || (${Int[${itemLimit}]} > 0)) {
                    /continue
                }
                | Display immediately (mirrors SellItem call at line 2446)
                /call DisplayDryRunSellItem ${packNum} ${slotNum} "${itemName}" "\ay[Wildcard]\aw"
                /continue
            }
            
            | Priority 5: Sell unlisted stackables (optional) - same as AutoSell line 2454
            | Behavior: sell any unlisted stackable item with vendor value (if SellUnlistedStackable=ON)
            /if (${enableSellStackable} && ${Me.Inventory[pack${packNum}].Item[${slotNum}].Stackable} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
                | Check if item is truly unlisted (no INI entry or empty/NULL)
                /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                    | Item is unlisted - check if it has vendor value
                    /if (${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} > 0) {
                        | Double-check it's not marked as KEEP/legacy ALL/numeric (shouldn't happen if unlisted, but safety check)
                        /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                            | Display immediately (mirrors SellItem call at line 2467)
                            /call DisplayDryRunSellItem ${packNum} ${slotNum} "${itemName}" "\ao(Unlisted stackable)\aw"
                            /continue
                        }
                    }
                }
            }
            
            | Priority 6: Sell ANY unlisted item (not just stackables) - same as AutoSell line 2470
            | Behavior: sell any unlisted item that has vendor value (if sellUnlistedItems=ON)
            /if (${enableSellUnlistedValue} && (!${IsWildcardItem[${itemName}]} || ${sellWildcards})) {
                | Check if item is truly unlisted (no INI entry or empty/NULL)
                /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                    | Item is unlisted - check if it has vendor value
                    /if (${Me.Inventory[pack${packNum}].Item[${slotNum}].Value} > 0) {
                        | Double-check it's not marked as KEEP/legacy ALL/numeric
                        /if (${itemLimitUpper.NotEqual[KEEP]} && ${itemLimitUpper.NotEqual[ALL]} && ${Int[${itemLimit}]} <= 0) {
                            | Display immediately (mirrors SellItem call)
                            /call DisplayDryRunSellItem ${packNum} ${slotNum} "${itemName}" "\ao(Unlisted item)\aw"
                            /continue
                        }
                    }
                }
            }
        /next slotNum
    /next packNum
    
    /if (!${skipSummary}) {
        /call PrintDryRunSellSummary
    }
/return


|| ---------------------------------------------------------------------
|| AUTO BANK
|| ---------------------------------------------------------------------
Sub AutoBank
    
    /varset itemsBanked 0
    
    /declare totalItemsChecked int local 0
    /declare itemsWithIniEntry int local 0
    /declare itemLink string local
    /declare iniColor string local
    
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoStarting turboBank process..."

    /if (${dropLevBeforeNav} && ${Me.Levitating}) {
        /call AnnounceBankSellProgress "${tlTag} \ayDetected levitation - removing before navigating..."
        /removelev
        /delay 10 !${Me.Levitating}
        /if (${Me.Levitating}) /call AnnounceBankSell "${tlTag} \aoWARNING: Could not remove levitation. This may cause navigation issues."
    }

    /target clear
    /delay 1
    
    /if (!${Window[BigBankWnd].Open}) {
        /call AnnounceBankSellProgress "${tlTag} \ayBank window not open - attempting to find and open banker..."
        
        | Check if banker is already targeted first (fast path - only try opening if close enough)
        | Exclude players (PC) and self to prevent issues
        /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Banker]} || ${Target.Type.Equal[NPC]})) {
            | Banker is targeted - only try opening window if close enough (avoid delay when far away)
            /if (${Target.Distance} <= 10) {
                /click right target
                /delay 100 ${Window[BigBankWnd].Open}
                /doevents
            }
        }
        
        | If still not open, try targeting nearest banker first
        /if (!${Window[BigBankWnd].Open}) {
            | Try multiple methods to find banker
            | Method 1: Check if banker is already targeted (exclude PC and self explicitly)
            | Retarget if: no target, target is self, target is PC, or target is not Banker/NPC
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Banker]} && ${Target.Type.NotEqual[NPC]})) {
                | Method 2: Target nearest NPC banker using spawn search
                /target npc banker
                /delay 1
            }
            
            | If still no banker, try broader search
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || (${Target.Type.NotEqual[Banker]} && ${Target.Type.NotEqual[NPC]})) {
                | Method 3: Use SpawnCount to find bankers
                /if (${SpawnCount[npc banker radius 200]} > 0) {
                    /target npc banker radius 200
                    /delay 1
                }
            }
        }
        
        | Accept target if it's a banker OR an NPC (manual targeting might show NPC type)
        | Exclude players (PC) and self to prevent issues
        /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Banker]} || ${Target.Type.Equal[NPC]})) {
            /call AnnounceBankSellProgress "${tlTag} \ayFound banker: \aw${Target.CleanName} \ay(distance: \aw${Target.Distance}\ay; type: \aw${Target.Type}\ay)"
            
            | Navigate to banker if too far away
            /if (${Target.Distance} > 10) {
                /call AnnounceBankSellProgress "${tlTag} \ayNavigating to banker (distance: \aw${Target.Distance} \ayunits)..."
                /face fast
                
                | Try nav first (proper pathfinding), fall back to moveto if unavailable
                /declare navTries int local 0
                /declare bankerID int local ${Target.ID}
                /declare usedNav bool local FALSE
                
                /if (${Navigation.PathExists[id ${Target.ID}]}) {
                    /if (${showDebug} || ${logToFile}) /call LogDebug "Using /nav to reach banker"
                    /nav id ${Target.ID} distance=10
                    | Wait for nav to complete (up to 15 seconds)
                    /delay 150 !${Navigation.Active} || ${Target.Distance} <= 10
                    /if (${Navigation.Active}) {
                        /squelch /nav stop
                    }
                    /varset usedNav TRUE
                }
                
                | If nav got us close enough, skip the moveto loop
                /if (${Target.Distance} <= 10) /goto :reachedBanker
                
                | Fallback moveto loop
                :moveToBanker
                /if (${Target.Distance} <= 10) /goto :reachedBanker
                
                | Check if target is still valid
                /if (!${Target.ID} || ${Target.ID} != ${bankerID}) {
                    /call AnnounceBankSell "${tlTag} \arERROR: Lost banker target during navigation"
                    /return
                }
                
                /varcalc navTries ${navTries} + 1
                /if (${navTries} > 50) {
                    /call AnnounceBankSell "${tlTag} \aoWARNING: Could not reach banker after \aw${navTries} \aoattempts (distance: \aw${Target.Distance}\ao)"
                    /call AnnounceBankSellProgress "${tlTag} \ayAttempting to open window anyway..."
                    /goto :reachedBanker
                }
                
                /face fast
                /moveto id ${Target.ID} dist 10
                /delay 5
                /doevents
                /goto :moveToBanker
                
                :reachedBanker
                /if (${Target.Distance} <= 10) {
                    /call AnnounceBankSellProgress "${tlTag} \agReached banker (distance: \aw${Target.Distance}\ag)"
                } else {
                    /call AnnounceBankSell "${tlTag} \aoWARNING: Could not fully reach banker (distance: \aw${Target.Distance}\ao) - attempting to open window anyway"
                }
            }
            
            | Face banker and open window
            /face fast
            /delay 1
            
            | Right-click banker to open bank window
            /click right target
            
            | Wait for window to open (conditional delay - exits early when window opens)
            /delay 100 ${Window[BigBankWnd].Open}
            /doevents
            
            /if (${Window[BigBankWnd].Open}) {
                /call AnnounceBankSellProgress "${tlTag} \agBank window opened: \aw${Target.CleanName}"
            } else {
                /call AnnounceBankSell "${tlTag} \arERROR: Failed to open bank window"
                /call AnnounceBankSell "${tlTag} \awPlease manually target a banker and open their window - then try again"
                /return
            }
        } else {
            /call AnnounceBankSell "${tlTag} \arERROR: No banker found nearby"
            /call AnnounceBankSell "${tlTag} \awPlease manually target a banker and open their window - then try again"
            /return
        }
    } else {
        /call AnnounceBankSellProgress "${tlTag} \agBank window already open"
    }
    
    /if (${convertCoinOnBank}) {
        /call ConvertCoins
    } else {
        /call AnnounceBankSellProgress "${tlTag} \ayCoin conversion skipped by convertCoinOnBank=OFF."
    }

    /call AnnounceBankSellProgress "${tlTag} \agScanning inventory for items marked BANK..."
    
    /call AnnounceBankSellProgress "${tlTag} \ayScanning main inventory slots (23-32)..."
    /for slotNum 23 to 32
        | Process events to keep macro responsive
        /doevents
        
        | Check if bank window is still open (periodic check)
        /if (!${Window[BigBankWnd].Open}) {
            /call AnnounceBankSell "${tlTag} \arERROR: Bank window closed during scan!"
            /return
        }
        
        | Get item name directly (main inventory slots use direct slot access)
        | Use .Name explicitly to ensure we get the full item name
        /varset itemName ${Me.Inventory[${slotNum}].Name}
        | Set itemLink for this main inventory slot iteration (variable already declared at start of subroutine)
        /varset itemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
        /if (${showDebug} && ${itemName.Length} && !${itemName.Equal[NULL]}) {
            /call AnnounceBankSell "${tlTag} \ayMain inventory slot ${slotNum}: ${itemLink}"
        }
        /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
        
        | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback)
        /varcalc totalItemsChecked ${totalItemsChecked} + 1
        /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
        }
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
        }
        /varset itemLimitUpper ${itemLimit.Upper}
        /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
        /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
        /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
        | Determine color for INI value based on type (reuse iniColor already declared)
        /varset iniColor \aw
        /if (${itemLimitUpper.Equal[KEEP]}) /varset iniColor \ag
        /if (${itemLimitUpper.Equal[ALL]}) /varset iniColor \at
        /if (${itemLimitUpper.Equal[DESTROY]}) /varset iniColor \ar
        /if (${itemLimitUpper.Equal[IGNORE]}) /varset iniColor \ao
        /if (${itemLimitUpper.Equal[SELL]}) /varset iniColor \ag
        /if (${itemLimitUpper.Equal[BANK]}) /varset iniColor \ap
        | Check if it's a number (value limit) - only check numeric if not already set to a keyword
        /if (${iniColor.Equal[\aw]} && ${itemLimit.Length} && ${itemLimit.NotEqual[NULL]} && ${itemLimit.NotEqual[0]}) {
            | Try to convert to int - if it succeeds and is in valid range, it's a number
            /if (${Int[${itemLimit}]} > 0 && ${Int[${itemLimit}]} < 10000) /varset iniColor \ay
        }
        
        | Track items with INI entries for debugging
        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
            /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
        }
        
        | Priority 1: BANK - always bank (includes wildcard matches if enabled)
        | Check for wildcard match if bankWildcards is enabled and item isn't already marked BANK
        /if (${bankWildcards} && !${itemLimitUpper.Equal[BANK]} && !${itemLimitUpper.Equal[KEEP]} && !${itemLimitUpper.Equal[ALL]} && !${itemLimitUpper.Equal[IGNORE]} && !${itemLimitUpper.Equal[SELL]} && ${Int[${itemLimit}]} <= 0) {
            /if (${IsWildcardItem[${itemName}]}) {
                /varset itemLimitUpper BANK
                /if (${showDebug} || ${logToFile}) /call LogDebug "[AutoBank] Wildcard ${itemName} -> BANK"
            }
        }
        /if (${itemLimitUpper.Equal[BANK]}) {
            | Use bagNum=0 to indicate main inventory, pass actual slot number (23-32)
            /call BankItem 0 ${slotNum} "${itemName}"
            /continue
        }
        
        | Check for SELL items in main inventory (show notice even though we're in bank mode)
        /if (${itemLimitUpper.Equal[SELL]}) {
            /call AnnounceBankSell "${tlTag} \aoNOTICE/ACTION REQUIRED:\aw ${itemLink} \aoin main inventory slot ${slotNum} is marked \agSELL\ao. \arMove it to a bag, then run \ag/mac turboloot sell\ar. \ay(MQ limitation)\ax"
            /continue
        }
        
        | Priority 2: KEEP, legacy ALL, or numeric - never bank (keep in inventory unless explicitly BANK/SELL/TRIBUTE)
        /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
            /if (${showDebug}) {
                /echo \ag[AutoBank]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
            }
            /continue
        }
        
        | Priority 3: IGNORE - never bank (same as KEEP for banking)
        /if (${itemLimitUpper.Equal[IGNORE]}) {
            /if (${showDebug}) {
                /echo \ag[AutoBank]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
            }
            /continue
        }
    /next slotNum
    
    /if (${showDebug} || ${logToFile}) /call LogDebug "Progress: finished main inventory slots, scanning bags..."
    
    /for packNum 1 to 10
        | Check if bank window is still open (periodic check)
        /if (!${Window[BigBankWnd].Open}) {
            /call AnnounceBankSell "${tlTag} \arERROR: Bank window closed during scan!"
            /return
        }
        
        | Check if pack exists first - check Container property (0 means pack doesn't exist or isn't a container)
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} == 0) /continue
        
        /for slotNum 1 to ${maxSlots}
            | Process events to keep macro responsive
            /doevents
            
            | Get item name directly
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            
            | Check [ItemLimits] for this item (direct INI lookup with case-insensitive fallback)
            /varcalc totalItemsChecked ${totalItemsChecked} + 1
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
            }
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) {
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
            }
            | Safety check: ensure itemLimit is initialized before string operations
            /if (!${itemLimit.Length}) /varset itemLimit ""
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
            | Set itemLink and iniColor for this bag slot iteration (variables already declared at start of subroutine)
            /varset itemLink ${Me.Inventory[pack${packNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
            /varset iniColor \aw
            
            | Track items with INI entries for debugging
            /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
                /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
            }
            
            | Priority 1: BANK - always bank (includes wildcard matches if enabled)
            | Check for wildcard match if bankWildcards is enabled and item isn't already marked BANK
            /if (${bankWildcards} && !${itemLimitUpper.Equal[BANK]} && !${itemLimitUpper.Equal[KEEP]} && !${itemLimitUpper.Equal[ALL]} && !${itemLimitUpper.Equal[IGNORE]} && !${itemLimitUpper.Equal[SELL]} && ${Int[${itemLimit}]} <= 0) {
                /if (${IsWildcardItem[${itemName}]}) {
                    /varset itemLimitUpper BANK
                    /if (${showDebug} || ${logToFile}) /call LogDebug "[AutoBank] Wildcard ${itemName} -> BANK"
                }
            }
            /if (${itemLimitUpper.Equal[BANK]}) {
                /call BankItem ${packNum} ${slotNum} "${itemName}"
                /continue
            }
            
            | Priority 2: KEEP, legacy ALL, or numeric - never bank (keep in inventory unless explicitly BANK/SELL/TRIBUTE)
            /if (${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[ALL]} || (${Int[${itemLimit}]} > 0)) {
                /if (${showDebug}) {
                    /echo \ag[AutoBank]\ag Skipping ${itemLink}\ag - marked as \agKEEP\aw/\ay#\aw
                }
                /continue
            }
            
            | Priority 3: IGNORE - never bank (same as KEEP for banking)
            /if (${itemLimitUpper.Equal[IGNORE]}) {
                /if (${showDebug}) {
                    /echo \ag[AutoBank]\ao Skipping ${itemLink}\ao - marked as \aoIGNORE
                }
                /continue
            }
            
        /next slotNum
    /next packNum
    
    /call AnnounceBankSell "${tlTag} \agturboBank complete. \awItems checked: \ay${totalItemsChecked}\aw; Items with INI entries: \ay${itemsWithIniEntry}\aw; Items banked: \ag${itemsBanked}"
    /if (${itemsBanked} == 0 && ${totalItemsChecked} > 0) {
        /call AnnounceBankSell "${tlTag} \aoWARNING: No items were banked. Check your turboloot.ini [ItemLimits] section."
        /call AnnounceBankSell "${tlTag} \awItems must be marked as \apBANK (e.g. ItemName=BANK) to be banked."
    }
    
    /if (${Window[BigBankWnd].Open}) {
        /notify BigBankWnd DoneButton leftmouseup
        /delay 5 !${Window[BigBankWnd].Open}
        /if (${Window[BigBankWnd].Open}) {
            /call AnnounceBankSellProgress "${tlTag} \ayClosing bank window..."
            /windowstate BigBankWnd close
        }
    }
/return

||| ---------------------------------------------------------------------
||| CONVERT COINS
||| ---------------------------------------------------------------------
Sub ConvertCoins
    /declare coinSlot int local

    /if (!${Window[BigBankWnd].Open}) {
        /call AnnounceBankSellProgress "${tlTag} \ayBank window is not open; skipping coin conversion."
        /return
    }

    /if (${Cursor.ID}) {
        /autoinventory
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) {
            /call AnnounceBankSell "${tlTag} \arWARNING: Cursor occupied by \aw${Cursor.Name}\ar. Skipping coin conversion."
            /return
        }
    }

    /if (!${Window[InventoryWindow]}) /invoke ${Window[InventoryWindow].DoOpen}
    /delay 5 ${Window[InventoryWindow].Open}

    /if (!${Window[InventoryWindow].Open}) {
        /keypress i
        /delay 10 ${Window[InventoryWindow].Open}
    }

    /if (!${Window[InventoryWindow].Open}) {
        /call AnnounceBankSell "${tlTag} \arWARNING: Inventory window did not open. Skipping coin conversion."
        /return
    }

    /delay 2

    /call AnnounceBankSellProgress "${tlTag} \ayConverting coin stacks..."

    /for coinSlot 3 downto 1
        /nomodkey /shiftkey /notify InventoryWindow IW_Money${coinSlot} leftmouseup
        /delay 1
        /nomodkey /shiftkey /notify InventoryWindow IW_Money${Math.Calc[${coinSlot}-1].Int} leftmouseup
        /delay 1
        /nomodkey /shiftkey /notify InventoryWindow IW_Money${coinSlot} leftmouseup
        /delay 1
    /next coinSlot

    /call AnnounceBankSellProgress "${tlTag} \agCoin conversion complete."
/return

||| ---------------------------------------------------------------------
||| AUTO TRIBUTE (main tribute subroutine)
||| ---------------------------------------------------------------------
Sub AutoTribute

    /varset itemsTributed 0
    /varset tributeItemsMoved 0
    /varset tributePointsGained 0

    /declare totalItemsChecked int local 0
    /declare itemsWithIniEntry int local 0
    /declare itemLink string local
    /declare iniColor string local
    /declare itemTributeValue int local 0
    
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoStarting turboTribute process..."

    /if (${dropLevBeforeNav} && ${Me.Levitating}) {
        /call AnnounceBankSellProgress "${tlTag} \ayDetected levitation - removing before navigating..."
        /removelev
        /delay 10 !${Me.Levitating}
        /if (${Me.Levitating}) /call AnnounceBankSell "${tlTag} \aoWARNING: Could not remove levitation. This may cause navigation issues."
    }

    /target clear
    /delay 1
    
    /if (!${Window[TributeMasterWnd].Open}) {
        /call AnnounceBankSellProgress "${tlTag} \ayTribute window not open - attempting to find and open tribute master..."
        
        | Check if tribute master is already targeted first (fast path - only try opening if close enough)
        | Exclude players (PC) and self to prevent issues
        /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && ${Target.Type.Equal[NPC]}) {
            | Tribute master is targeted - only try opening window if close enough (avoid delay when far away)
            /if (${Target.Distance} <= 10) {
                /click right target
                /delay 100 ${Window[TributeMasterWnd].Open}
                /doevents
            }
        }
        
        | If still not open, try targeting nearest tribute master first
        /if (!${Window[TributeMasterWnd].Open}) {
            | Try multiple methods to find tribute master
            | Method 1: Check if tribute master is already targeted (exclude PC and self explicitly)
            | Retarget if: no target, target is self, target is PC, or target is not NPC
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || ${Target.Type.NotEqual[NPC]}) {
                | Method 2: Target nearest NPC tribute master using spawn search
                /target npc tribute
                /delay 1
            }
            
            | If still no tribute master, try broader search
            /if (!${Target.ID} || ${Target.ID} == ${Me.ID} || ${Target.Type.Equal[PC]} || ${Target.Type.NotEqual[NPC]}) {
                | Method 3: Use SpawnCount to find tribute masters
                /if (${SpawnCount[npc tribute radius 200]} > 0) {
                    /target npc tribute radius 200
                    /delay 1
                }
            }
            
            | Accept target if it's an NPC (exclude players and self)
            /if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && ${Target.Type.Equal[NPC]}) {
                /call AnnounceBankSellProgress "${tlTag} \ayFound Tribute Master: \aw${Target.CleanName} \ay(distance: \aw${Target.Distance}\ay)"
                
                | Navigate to tribute master if needed
                /if (${Target.Distance} > 15) {
                    /call AnnounceBankSellProgress "${tlTag} \ayNavigating to tribute master..."
/declare tributeID int local ${Target.ID}

| Nav-only approach (no MQ2MoveUtils). Includes door-open + nudge if stuck.
/call NavToIDWithDoorsAndNudges ${tributeID} 10 900

| Verify target still valid
/if (!${Target.ID} || ${Target.ID} != ${tributeID}) {
    /call AnnounceBankSell "${tlTag} \arERROR: Lost tribute master target during navigation"
    /return
}

:reachedTribute
/face fast
/delay 1
                }
                
                | Open tribute window
                /click right target
                /delay 100 ${Window[TributeMasterWnd].Open}
                /doevents
            }
        }
    }
    
    /if (!${Window[TributeMasterWnd].Open}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Could not open Tribute Master window. Please target a Tribute Master NPC and try again."
        /return
    }
    
    /call AnnounceBankSellProgress "${tlTag} \agTribute Master window open. Scanning inventory for items marked TRIBUTE..."

    /for packNum 1 to 10
        /if (!${Me.Inventory[pack${packNum}].ID}) /continue
        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        
        | Process slots in reverse order to avoid skipping items when inventory shifts after tributing
        /for slotNum ${maxSlots} downto 1
            /varcalc totalItemsChecked ${totalItemsChecked} + 1
            /if (!${Me.Inventory[pack${packNum}].Item[${slotNum}].ID}) /continue
            
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            
            | Look up INI entry (case-insensitive like main looting loop)
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]}) {
                | Try uppercase
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
            }
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]}) {
                | Try lowercase
                /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
            }
            /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
                /varset itemLimitUpper ${itemLimit.Upper}
                /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
                /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
                /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
                /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
            } else {
                /varset itemLimitUpper ""
            }
            
            | Check if item is marked TRIBUTE in INI
            /varset itemTributeValue ${Me.Inventory[pack${packNum}].Item[${slotNum}].Tribute}
            /if (${itemLimitUpper.Equal[TRIBUTE]} || (!${itemLimitUpper.Length} && ${itemTributeValue} > 0)) {
                | Verify item still exists and has tribute value > 0 (inventory may have shifted)
                /if (!${Me.Inventory[pack${packNum}].Item[${slotNum}].ID} || !${Me.Inventory[pack${packNum}].Item[${slotNum}].Name.Equal[${itemName}]}) /continue
                /if (${itemTributeValue} > 0) {
                    /if (${showDebug}) /call AnnounceBankSell "${tlTag} \ay[DEBUG] Processing TRIBUTE item: ${itemName} in pack${packNum} slot${slotNum} (tribute value: ${itemTributeValue})"
                    /call TributeItem ${packNum} ${slotNum} "${itemName}"
                    | Small delay after tribute to allow inventory to update before checking next item
                    /delay 1
                } else {
                    | Item marked TRIBUTE but has 0 tribute value - notify user
                    /call AnnounceBankSell "${tlTag} \aoWARNING: Item ${Me.Inventory[pack${packNum}].Item[${slotNum}].ItemLink[CLICKABLE]} \aois marked \ayTRIBUTE\ao but has tribute value \ar0\ao (cannot be tributed)"
                }
            }
        /next slotNum
    /next packNum
    
    /for slotNum 23 to 32
        /varcalc totalItemsChecked ${totalItemsChecked} + 1
        /if (!${Me.Inventory[${slotNum}].ID}) /continue
        
        /varset itemName ${Me.Inventory[${slotNum}].Name}
        /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
        
        | Look up INI entry (case-insensitive like main looting loop)
        /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]}) {
            | Try uppercase
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
        }
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]}) {
            | Try lowercase
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}
        }
        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]}) {
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE
            /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
        } else {
            /varset itemLimitUpper ""
        }
        
        | Check if item is marked TRIBUTE - notify user they need to move to bag
        /if (${itemLimitUpper.Equal[TRIBUTE]}) {
            /varset itemTributeValue ${Me.Inventory[${slotNum}].Tribute}
            /if (${itemTributeValue} > 0) {
                /declare mainInvItemLink string local ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
                /call AnnounceBankSell "${tlTag} \aoNOTICE: Item ${mainInvItemLink} \aoin main inventory slot ${slotNum} is marked \ayTRIBUTE\ao."
                /call AnnounceBankSell "${tlTag} \arACTION REQUIRED: Move ${mainInvItemLink} \arto a bag (pack1-pack10); then run \ag/mac turboloot tribute\ar again to tribute it. This is a limitation of MQ."
            }
        }
    /next slotNum

    /call AnnounceBankSell "${tlTag} \agturboTribute complete. \awItems checked: \ay${totalItemsChecked}\aw; Items with INI entries: \ay${itemsWithIniEntry}\aw; Units tributed: \ay${tributeItemsMoved}\aw; Tribute gained: \ay${tributePointsGained}"
    /if (${tributeItemsMoved} == 0 && ${totalItemsChecked} > 0) {
        /call AnnounceBankSell "${tlTag} \aoWARNING: No items were tributed. Check your turboloot.ini [ItemLimits] section."
        /call AnnounceBankSell "${tlTag} \awItems must be marked as \ayTRIBUTE (e.g. ItemName=TRIBUTE) to be tributed."
    }

    /if (${Window[TributeMasterWnd].Open}) {
        /squelch /notify TributeMasterWnd DoneButton leftmouseup
        /squelch /notify TributeMasterWnd TMW_DoneButton leftmouseup
        /delay 2 !${Window[TributeMasterWnd].Open}
        /if (${Window[TributeMasterWnd].Open}) /windowstate TributeMasterWnd close
        /delay 5 !${Window[TributeMasterWnd].Open}
    }
/return

||| ---------------------------------------------------------------------
||| AUTO DESTROY (destroys items in inventory marked DESTROY)
||| ---------------------------------------------------------------------
Sub AutoDestroy
    /varset itemsDestroyed 0
    /declare totalItemsChecked int local 0
    /declare itemsWithIniEntry int local 0
    /declare itemLink string local

    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoStarting turboDestroy process...\aw (will destroy inventory items marked \arDESTROY\aw in your INI)"

    /for packNum 1 to 10
        /if (!${Me.Inventory[pack${packNum}].ID}) /continue

        /varset maxSlots ${Me.Inventory[pack${packNum}].Container}
        /if (${maxSlots} <= 0) /continue

        | Ensure bag window is open so /itemnotify works reliably
        /if (!${Window[pack${packNum}].Open}) {
            /nomodkey /itemnotify pack${packNum} rightmouseup
            /delay 2 ${Window[pack${packNum}].Open}
        }

        | Process slots in reverse order (inventory can shift when destroying)
        /for slotNum ${maxSlots} downto 1
            /doevents
            /if (!${Me.Inventory[pack${packNum}].Item[${slotNum}].ID}) /continue

            /varcalc totalItemsChecked ${totalItemsChecked} + 1
            /varset itemName ${Me.Inventory[pack${packNum}].Item[${slotNum}].Name}
            /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
            /varset itemLink ${Me.Inventory[pack${packNum}].Item[${slotNum}].ItemLink[CLICKABLE]}

            | INI lookup (case-insensitive fallback)
            /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
            /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}

            /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]} && !${itemLimit.Equal[0]}) {
                /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
                /varset itemLimitUpper ${itemLimit.Upper}
                /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
                /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
                /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE

                /if (${itemLimitUpper.Equal[DESTROY]}) {
                    /call DestroyItem ${packNum} ${slotNum} "${itemName}"
                }
            }
        /next slotNum
    /next packNum

    /for slotNum 23 to 32
        /if (!${Me.Inventory[${slotNum}].ID}) /continue
        /varcalc totalItemsChecked ${totalItemsChecked} + 1
        
        | Safety check: get item name and validate
        /varset itemName ${Me.Inventory[${slotNum}].Name}
        /if (!${itemName.Length} || ${itemName.Equal[NULL]}) /continue
        
        | Safety check: get item link - ItemLink[CLICKABLE] can crash on some items
        | Use item name as fallback if ItemLink fails (safer than crashing)
        /varset itemLink ${itemName}
        | Try to get ItemLink, but don't crash if it fails - just use item name instead
        /if (${Me.Inventory[${slotNum}].ID}) {
            /varset itemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
            | If ItemLink failed or is invalid, fall back to item name
            /if (!${itemLink.Length} || ${itemLink.Equal[NULL]}) {
                /varset itemLink ${itemName}
            }
        }

        /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Upper}]}
        /if (!${itemLimit.Length} || ${itemLimit.Equal[NULL]} || ${itemLimit.Equal[0]}) /varset itemLimit ${Ini[${iniFile},ItemLimits,${itemName.Lower}]}

        /if (${itemLimit.Length} && !${itemLimit.Equal[NULL]} && !${itemLimit.Equal[0]}) {
            /varcalc itemsWithIniEntry ${itemsWithIniEntry} + 1
            /varset itemLimitUpper ${itemLimit.Upper}
            /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
            /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
            /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE

            /if (${itemLimitUpper.Equal[DESTROY]}) {
                /call AnnounceBankSell "${tlTag} \aoNOTICE/ACTION REQUIRED:\aw ${itemLink} \aoin main inventory slot ${slotNum} is marked \arDESTROY\ao. \arMove it to a bag (pack1-pack10), then run \ag/mac turboloot destroy\ar. \ay(MQ limitation)\ax"
            }
        }
    /next slotNum

    /if (${itemsDestroyed} > 0) {
        /call AnnounceBankSell "${tlTag} \agturboDestroy complete.\aw Items destroyed: \ag${itemsDestroyed}\aw."
    } else {
        /call AnnounceBankSell "${tlTag} \aoturboDestroy complete.\aw No items were destroyed."
        /call AnnounceBankSell "${tlTag} \awItems must be marked as \arDESTROY\aw (e.g. \ayItemName=DESTROY\aw) to be destroyed."
    }

    /if (${showDebug} || ${logToFile}) /call LogDebug "DBG(destroy) checked=${totalItemsChecked} ini=${itemsWithIniEntry} destroyed=${itemsDestroyed}"
    /call CloseBags
/return

|| ---------------------------------------------------------------------
|| BANK ITEM (helper subroutine)
|| ---------------------------------------------------------------------
Sub BankItem(int bagNum, int slotNum, string itemName)
    
    /declare currentItemName string local
    /declare itemnotifySlot int local
    /declare bankItemLink string local
    
    /if (${bagNum} == 0) {
        | Main inventory slot (23-32) - use .Name explicitly
        /varset currentItemName ${Me.Inventory[${slotNum}].Name}
        /varset itemValue ${Int[${Math.Calc[${Me.Inventory[${slotNum}].Value} / 1000]}]}
        /varset bankItemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
    } else {
        | Bag slot
        /varset currentItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
        /varset itemValue ${Int[${Math.Calc[${Me.Inventory[pack${bagNum}].Item[${slotNum}].Value} / 1000]}]}
        /varset bankItemLink ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
    }
    /if (!${currentItemName.Length} || ${currentItemName.Equal[NULL]}) /return
    
    /if (${currentItemName.NotEqual[${itemName}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Item changed: expected ${itemName}, found ${currentItemName}"
        /return
    }
    
    /if (!${Window[BigBankWnd].Open}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Bank window closed during bank!"
        /return
    }
    
    /if (${showDebug}) {
        /if (${bagNum} == 0) {
            /echo [BankItem] Attempting to bank ${itemName} (main inventory slot ${slotNum})
        } else {
            /echo [BankItem] Attempting to bank ${itemName} (pack${bagNum}, slot${slotNum})
        }
    }
    
    /if (${Cursor.ID}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Cursor occupied (${Cursor.Name}), clearing"
        | Try IW_CharacterView first (most reliable)
        /if (!${Window[InventoryWindow].Open}) /keypress i
        /delay 5 ${Window[InventoryWindow].Open}
        /if (${Window[InventoryWindow].Open}) {
            /notify InventoryWindow IW_CharacterView leftmouseup
            /delay 5 !${Cursor.ID}
        }
        | Fallback to /autoinventory
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
        }
        | If still occupied, warn and skip this item
        /if (${Cursor.ID}) {
            /call AnnounceBankSell "${tlTag} \arWARNING: Could not clear cursor (has: ${Cursor.Name}). Skipping ${itemName}."
            /return
        }
    }
    
    /if (${bagNum} == 0) {
        | bankItemLink already set at top of subroutine
        /call AnnounceBankSell "${tlTag} \aoNOTICE: Item ${bankItemLink} \aoin main inventory slot ${slotNum} is marked \ayBANK\ao."
        /call AnnounceBankSell "${tlTag} \arACTION REQUIRED: Move ${bankItemLink} \arto a bag (pack1-pack10); then run \ag/mac turboloot bank\ar again to bank it. This is a limitation of MQ."
        /return
    } else {
        | Fast path: non-stackable containers cannot be auto-banked into bank bags. Skip without touching cursor.
        /declare slotContainerSlots int local ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Container}
        /declare slotIsStackable bool local ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}
        /if (${slotContainerSlots} > 0 && !${slotIsStackable}) {
            /declare warnKey string local ${currentItemName.Upper.Replace[ ,]}
            /if (!${warnKey.Length}) /varset warnKey "UNKNOWNCONTAINER"
            /if (${BankContainerWarnedKeys.Length} > 2000) /varset BankContainerWarnedKeys ""
            /if (!${BankContainerWarnedKeys.Length} || !${BankContainerWarnedKeys.Find[|${warnKey}|]}) {
                /varset BankContainerWarnedKeys "${BankContainerWarnedKeys}|${warnKey}|"
                /call Announce "${announceDefaultTo}" "${tlTag} \ar[ERROR]\aw Cannot auto-bank containers unless there is an open top-level bank slot (outside of bank bags)."
                /call Announce "${announceDefaultTo}" "${tlTag} \ayConsider removing this container from your INI BANK settings: \aw${bankItemLink}"
            }
            /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Skip container before cursor: ${currentItemName} slots=${slotContainerSlots} stack=${slotIsStackable}"
            /return
        }
        /nomodkey /shift /itemnotify in pack${bagNum} ${slotNum} leftmouseup
    }
    
    /delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
    
    /if (${Window[QuantityWnd].Open}) {
        /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5 !${Window[QuantityWnd].Open}
    }
    
    /if (!${Cursor.ID}) {
        /nomodkey /shift /itemnotify in pack${bagNum} ${slotNum} leftmouseup
        /delay 10 ${Cursor.ID}
    }
    
    /if (!${Cursor.ID}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] No move to cursor: ${itemName}"
        /return
    }
    
    /declare isContainer bool local FALSE
    /declare cursorInfo string local "Name: ${Cursor.Name} | Container: ${Cursor.Container} | Stackable: ${Cursor.Stackable} | Lore: ${Cursor.Lore} | NoDrop: ${Cursor.NoDrop}"
    /if (${Cursor.Container} > 0) /varset isContainer TRUE
    /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Cursor: ${cursorInfo} container=${isContainer}"
    
    /notify BigBankWnd BIGB_AutoButton leftmouseup
    
    /if (${isContainer}) {
        /delay 10 !${Cursor.ID} || ${Cursor.Name.Length}
    } else {
        /delay 20 !${Cursor.ID} || ${Cursor.Name.Length}
    }
    
    /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] After autobank cursor ID=${Cursor.ID} name=${Cursor.Name}"
    
    /if (!${Cursor.ID}) {
        /varcalc itemsBanked ${itemsBanked} + 1
        /call AnnounceBankSell "${tlTag} \ap[BANK]\aw ${bankItemLink}"
        /return
    }

    /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Bank fail, cursor still full container=${isContainer}"

    /if (${isContainer} && ${Cursor.Stackable}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Stackable container retry: ${cursorInfo}"
        /notify BigBankWnd BIGB_AutoButton leftmouseup
        /delay 10 !${Cursor.ID} || ${Cursor.Name.Length}
        /if (!${Cursor.ID}) {
            /varcalc itemsBanked ${itemsBanked} + 1
            /call AnnounceBankSellPerItem "${tlTag} \ap[BANK]\aw ${bankItemLink}"
            /return
        }
    }

    /if (${isContainer}) {
        /declare warnKey string local ${Cursor.Name.Upper.Replace[ ,]}
        /if (!${warnKey.Length}) /varset warnKey "UNKNOWNCONTAINER"
        /if (${BankContainerWarnedKeys.Length} > 2000) /varset BankContainerWarnedKeys ""
        /if (!${BankContainerWarnedKeys.Length} || !${BankContainerWarnedKeys.Find[|${warnKey}|]}) {
            /varset BankContainerWarnedKeys "${BankContainerWarnedKeys}|${warnKey}|"
            /call Announce "${announceDefaultTo}" "${tlTag} \ar[ERROR]\aw Cannot auto-bank containers unless there is an open top-level bank slot (outside of bank bags)."
            /call Announce "${announceDefaultTo}" "${tlTag} \ayConsider removing this container from your INI BANK settings: \aw${bankItemLink}"
        }
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Container autobank failed: ${cursorInfo}"
        | Try multiple methods to return item to inventory
        | Method 1: Click the character model/class icon area in inventory window (most reliable)
        /if (!${Window[InventoryWindow].Open}) /keypress i
        /delay 5 ${Window[InventoryWindow].Open}
        /if (${Window[InventoryWindow].Open}) {
            /notify InventoryWindow IW_CharacterView leftmouseup
            /delay 5 !${Cursor.ID}
        }
        | Method 2: /autoinventory as fallback
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
        }
        | Method 3: Click back on the original bag slot
        /if (${Cursor.ID} && ${bagNum} > 0) {
            /nomodkey /itemnotify in pack${bagNum} ${slotNum} leftmouseup
            /delay 5 !${Cursor.ID}
        }
        /if (${Cursor.ID}) {
            /call AnnounceBankSell "${tlTag} \arWARNING: Item still on cursor: \aw${Cursor.Name}\ar. Please clear manually."
        }
        /return
    }
    
    /if (${Cursor.ID} && ${Cursor.Name.Equal[${itemName}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[BankItem] Item still on cursor, attempting auto-deposit again..."
        /notify BigBankWnd BIGB_AutoButton leftmouseup
        
        | Wait again (short) for cursor to settle
        /delay 20 !${Cursor.ID} || ${Cursor.Name.Length}
        
        | Check if cursor is now empty (success)
        /if (!${Cursor.ID}) {
            /varcalc itemsBanked ${itemsBanked} + 1
            /call AnnounceBankSellPerItem "${tlTag} \ap[BANK]\aw ${bankItemLink}"
            /return
        }
    }
    
    /if (${Cursor.ID}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Banking failed for \aw${itemName}\ar. There may be no bank space left. Returning to inventory."
        | Try multiple methods to return item to inventory
        | Method 1: Click the character model/class icon area in inventory window
        /if (!${Window[InventoryWindow].Open}) /keypress i
        /delay 5 ${Window[InventoryWindow].Open}
        /if (${Window[InventoryWindow].Open}) {
            /notify InventoryWindow IW_CharacterView leftmouseup
            /delay 5 !${Cursor.ID}
        }
        | Method 2: /autoinventory as fallback
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 5 !${Cursor.ID}
        }
        | Method 3: Click back on the original bag slot
        /if (${Cursor.ID} && ${bagNum} > 0) {
            /nomodkey /itemnotify in pack${bagNum} ${slotNum} leftmouseup
            /delay 5 !${Cursor.ID}
        }
        /if (${Cursor.ID}) {
            /call AnnounceBankSell "${tlTag} \arWARNING: Item still on cursor: \aw${Cursor.Name}\ar. Please clear manually."
        }
        /return
    }
/return
|| ---------------------------------------------------------------------
|| SELL ITEM (helper subroutine)
|| ---------------------------------------------------------------------
Sub SellItem(int bagNum, int slotNum, string itemName)
    /declare sellingItemText string local
    /declare currentItemName string local
    /declare sellItemLink string local

    /declare stackCount int local 1
    /declare perItemCopper int local 0
    /declare totalStackCopper int local 0
    /declare totalStackPP int local 0

    | --- Read item, stack count, and value ---
    /if (${bagNum} == 0) {
        | Main inventory slot (23-32)
        /varset currentItemName ${Me.Inventory[${slotNum}].Name}
        /varset sellItemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}

        /if (${Me.Inventory[${slotNum}].Stackable}) /varset stackCount ${Me.Inventory[${slotNum}].Stack}
        /varset perItemCopper ${Me.Inventory[${slotNum}].Value}
    } else {
        | Bag slot
        /varset currentItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
        /varset sellItemLink ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ItemLink[CLICKABLE]}

        /if (${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}) /varset stackCount ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack}
        /varset perItemCopper ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Value}
    }
    | --- DEBUG: raw MQ2 values ---
    /if (${showDebug}) {
        /if (${bagNum} == 0) {
            /echo [SellDBG] bag=${bagNum} slot=${slotNum} want=${itemName}
            /echo [SellDBG] have=${Me.Inventory[${slotNum}].Name}
            /echo [SellDBG] value=${Me.Inventory[${slotNum}].Value}
            /echo [SellDBG] stack=${Me.Inventory[${slotNum}].Stack} stackable=${Me.Inventory[${slotNum}].Stackable}
        } else {
            /echo [SellDBG] bag=${bagNum} slot=${slotNum} want=${itemName}
            /echo [SellDBG] have=${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
            /echo [SellDBG] value=${Me.Inventory[pack${bagNum}].Item[${slotNum}].Value}
            /echo [SellDBG] stack=${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack} stackable=${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}
        }
    }


    /if (!${currentItemName.Length} || ${currentItemName.Equal[NULL]}) /return

    /if (${currentItemName.NotEqual[${itemName}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellItem] Item changed: expected ${itemName}, found ${currentItemName}"
        /return
    }

    /varset totalStackCopper ${Math.Calc[${perItemCopper}*${stackCount}]}
    /varset totalStackPP ${Int[${Math.Calc[${totalStackCopper}/1000]}]}

    /varset itemValue ${totalStackPP}

    /if (${perItemCopper} <= 0) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellItem] Skipping ${itemName} - value is 0 (items with 0 value cannot be sold)"
        /return
    }

    /if (!${Window[MerchantWnd].Open}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Merchant window closed during sell!"
        /return
    }

    /if (${bagNum} == 0) {
        /call AnnounceBankSell "${tlTag} \aoNOTICE/ACTION REQUIRED:\aw ${sellItemLink} \aoin main inventory slot ${slotNum} is marked \agSELL\ao. \arMove it to a bag, then run \ag/mac turboloot sell\ar again. \ay(MQ limitation)\ax"
        /return
    }

    /if (${Cursor.ID}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellItem] Cursor occupied, attempting to clear..."
        /autoinventory
        /delay 10 !${Cursor.ID}
    }

    /nomodkey /itemnotify in pack${bagNum} ${slotNum} leftmouseup

    /if (${Window[QuantityWnd].Open}) {
        /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5 !${Window[QuantityWnd].Open}
    }
    
    
    /delay 5 ${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text.Equal[${itemName}]}
    /varset sellingItemText ${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text}
    /if (${sellingItemText.NotEqual[${itemName}]}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Cannot get merchant to select item: \aw${itemName}"
        /return
    }

    /if (!${Window[MerchantWnd].Child[MW_Sell_Button].Enabled}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellItem] Sell button not enabled for ${itemName} - skipping"
        /return
    }
    
    /declare beforeCopper int local ${Math.Calc[${Me.Platinum}*1000+${Me.Gold}*100+${Me.Silver}*10+${Me.Copper}]}
    
    /nomodkey /shift /notify MerchantWnd MW_Sell_Button leftmouseup

    /declare waitSold int local 0
    /declare slotItemName string local
    /while (${waitSold} < 100) {
        /varset slotItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
        /if (${slotItemName.Equal[NULL]} || !${slotItemName.Length} || ${slotItemName.NotEqual[${itemName}]}) /break
        /varcalc waitSold ${waitSold} + 1
        /delay 1
    }

    /if (!${Window[MerchantWnd].Open}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Merchant window closed during sell!"
        /return
    }

    /varset currentItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
    /if (${currentItemName.Equal[NULL]} || !${currentItemName.Length} || ${currentItemName.NotEqual[${itemName}]}) {
        /delay 1
        | Snapshot coins AFTER selling (copper units) and compute delta
        /declare afterCopper int local ${Math.Calc[${Me.Platinum}*1000+${Me.Gold}*100+${Me.Silver}*10+${Me.Copper}]}
        /declare gainedCopper int local ${Math.Calc[${afterCopper}-${beforeCopper}]}
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellDBG] gainedCopper=${gainedCopper}"
        /if (${showDebug} || ${logToFile}) /call LogDebug "[SellDBG] estCopper=${totalStackCopper} gainedCopper=${gainedCopper}"
    
        | Increment totals:
        | - itemsSold counts each unit in stack as 1
        | - sellTotalCopper counts full stack value (per-item copper * stack)
        /varcalc itemsSold ${itemsSold} + ${stackCount}
        /varcalc sellTotalCopper ${sellTotalCopper} + ${gainedCopper}
        
        | Keep platinumGain as whole platinum (based on actual gained copper)
        /varcalc platinumGain ${platinumGain} + ${Int[${Math.Calc[${gainedCopper}/1000]}]}

        | Build per-sell currency text (pp gp sp cp)
        /declare p int local ${Int[${Math.Calc[${gainedCopper}/1000]}]}
        /declare g int local ${Int[${Math.Calc[(${gainedCopper}%1000)/100]}]}
        /declare s int local ${Int[${Math.Calc[(${gainedCopper}%100)/10]}]}
        /declare c int local ${Int[${Math.Calc[${gainedCopper}%10]}]}

        /if (${showDebug} || ${announceLooted}) {
            /call AnnounceBankSell "${tlTag} \ag[SELL] ${sellItemLink} \aw(x${stackCount}) \awfor \ag${p}pp ${g}gp ${s}sp ${c}cp\ag \au"
        }
        /return
    }

    /call AnnounceBankSell "${tlTag} \arERROR: Selling item failed. Item:\aw${itemName} \arStill in inventory. pack:\aw${bagNum} \arslot:\aw${slotNum}"
    /if (${showDebug}) {
        /call AnnounceBankSell "${tlTag} \arDEBUG: Sell button enabled: ${Window[MerchantWnd].Child[MW_Sell_Button].Enabled}"
        /call AnnounceBankSell "${tlTag} \arDEBUG: Merchant selected item: ${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text}"
        /call AnnounceBankSell "${tlTag} \arDEBUG: Current item in slot: ${currentItemName}"
    }
/return

||| ---------------------------------------------------------------------
||| TRIBUTE ITEM (helper subroutine)
||| ---------------------------------------------------------------------
Sub TributeItem(int bagNum, int slotNum, string itemName)
    | ---------- Locals (declare once = bulletproof) ----------
    /declare currentItemName string local
    /declare tributeItemLink string local
    /declare tributeValue int local 0
    /declare tributeItemID int local 0
    /declare originalStackSize int local 0
    /declare beforeStack int local 0
    /declare afterStack int local 0
    /declare afterSlotID int local 0

    /declare beforeInv int local 0
    /declare afterInv int local 0
    /declare tributedUnits int local 0

    /declare beforeTP int local 0
    /declare afterTP int local 0
    /declare gainedTP int local 0

    /declare announceTP int local 0
    /declare pointsToAdd int local 0

    | ---------- Read item info ----------
    /if (${bagNum} == 0) {
        | Main inventory slot (23-32)
        /varset currentItemName ${Me.Inventory[${slotNum}].Name}
        /varset tributeItemID ${Me.Inventory[${slotNum}].ID}
        /varset tributeValue ${Me.Inventory[${slotNum}].Tribute}
        /varset tributeItemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
    } else {
        | Bag slot
        /varset currentItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
        /varset tributeItemID ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID}
        /varset tributeValue ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Tribute}
        /varset tributeItemLink ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
    
        | Reset stack tracking (prevents leakage from previous items)
        /varset originalStackSize 0
        /varset beforeStack 0
        /varset afterStack 0
    
        | Capture BEFORE stack size (for stack delta)
        /if (${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} && ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}) {
            /varset originalStackSize ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack}
            /varset beforeStack ${originalStackSize}
        }
    }

    /if (!${currentItemName.Length} || ${currentItemName.Equal[NULL]}) /return

    /if (${currentItemName.NotEqual[${itemName}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[TributeItem] Item changed: expected ${itemName}, found ${currentItemName}"
        /return
    }

    /if (!${Window[TributeMasterWnd].Open}) {
        /call AnnounceBankSell "${tlTag} \arERROR: Tribute window closed during tribute!"
        /return
    }

    /if (${tributeValue} <= 0) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[TributeItem] Skipping ${itemName} - tribute value is ${tributeValue}"
        /return
    }

    /if (${bagNum} == 0) {
        /call AnnounceBankSell "${tlTag} \aoNOTICE: Item ${tributeItemLink} \aoin main inventory slot ${slotNum} is marked \ayTRIBUTE\ao."
        /call AnnounceBankSell "${tlTag} \arACTION REQUIRED: Move ${tributeItemLink} \arto a bag (pack1-pack10); then run \ag/mac turboloot tribute\ar again to tribute it. This is a limitation of MQ."
        /return
    }

    /if (${showDebug} || ${logToFile}) /call LogDebug "[TributeItem] Attempting to tribute ${itemName} (pack${bagNum}, slot${slotNum})"

    | ---------- Delta snapshots BEFORE donating ----------
    /varset beforeInv ${FindItemCount[=${itemName}]}
    /varset beforeTP ${Me.CurrentFavor}

    /declare tries int local 0
    /declare waitDonate int local 0
    /declare clickedDonate bool local FALSE
    /while ((${tries} < 4) && (!${clickedDonate})) {
        | Safety: slot content can change as items move; never risk donating the wrong item
        /if (!${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} || ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} != ${tributeItemID}) {
            /call AnnounceBankSell "${tlTag} \aoWARNING: Tribute slot changed before donating. Expected id=${tributeItemID} but found id=${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} in pack${bagNum} slot${slotNum}. Skipping to avoid donating the wrong item."
            /return
        }

        | Tribute selection can be flaky unless the bag window is open (UI/client dependent)
        /if (!${Window[pack${bagNum}].Open}) {
            /nomodkey /itemnotify pack${bagNum} rightmouseup
            /delay 2 ${Window[pack${bagNum}].Open}
        }

        | Ensure cursor is clear before interacting with the tribute UI
        /if (${Cursor.ID}) /call ClearCursor

        | Click item to load into tribute window
        /nomodkey /itemnotify in pack${bagNum} ${slotNum} leftmouseup
        /delay 2 ${Window[QuantityWnd].Open}

        | Quantity window can appear on select for some stackables
        /if (${Window[QuantityWnd].Open}) {
            /notify QuantityWnd QTYW_Accept_Button leftmouseup
            /delay 5 !${Window[QuantityWnd].Open}
        }

        | Wait briefly for Donate to become enabled, then click it
        /varset waitDonate 0
        /while ((${waitDonate} < 10) && (!${clickedDonate})) {
            /call IsTributeDonateEnabled
            /if (${Macro.Return}) {
                | Safety: re-check slot hasn't changed right before clicking Donate
                /if (!${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} || ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} != ${tributeItemID}) {
                    /call AnnounceBankSell "${tlTag} \aoWARNING: Tribute slot changed while waiting to donate. Expected id=${tributeItemID} but found id=${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID} in pack${bagNum} slot${slotNum}. Skipping to avoid donating the wrong item."
                    /return
                }
                /call TryClickTributeDonateButton
                /if (${Macro.Return}) /varset clickedDonate TRUE
            } else {
                /delay 1
            }
            /varcalc waitDonate ${waitDonate} + 1
        }

        /varcalc tries ${tries} + 1
        /delay 1
    }

    /if (!${clickedDonate}) {
        /call AnnounceBankSell "${tlTag} \aoWARNING: Cannot tribute ${tributeItemLink} \ao(Donate never enabled). pack${bagNum} slot${slotNum} id=${tributeItemID} tributeValue=${tributeValue}. Skipping this item."
        /return
    }

    /if (${Window[QuantityWnd].Open}) {
        /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /delay 5 !${Window[QuantityWnd].Open}
    }

    /delay 1

   | Wait (briefly) for favor to update (exits early if it changes)
   /declare waitTP int local 0
   /while ((${waitTP} < 20) && (${Me.CurrentFavor} == ${beforeTP})) {
       /delay 1
       /varcalc waitTP ${waitTP} + 1
   }
   
    | ---------- Delta snapshots AFTER donating ----------
    /if (${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}) {
        /varset afterStack ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack}
    }

    /varset afterSlotID ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID}
    
    /if (${beforeStack} > 0 && ${afterStack} > 0 && ${afterStack} < ${beforeStack}) {
        /varset tributedUnits ${Math.Calc[${beforeStack}-${afterStack}]}
    }
    
    /varset afterInv ${FindItemCount[=${itemName}]}
    /varset afterTP ${Me.CurrentFavor}
    
    /if (${tributedUnits} <= 0) /varset tributedUnits ${Math.Calc[${beforeInv}-${afterInv}]}
    /if (${tributedUnits} < 0) /varset tributedUnits 0
    
    /if (${tributedUnits} < 0) /varset tributedUnits 0

    /varset gainedTP ${Math.Calc[${afterTP}-${beforeTP}]}
    /if (${gainedTP} < 0) /varset gainedTP 0

    /if (${showDebug} || ${logToFile}) /call LogDebug "[TribDBG] item=${itemName} beforeInv=${beforeInv} afterInv=${afterInv} beforeTP=${beforeTP} afterTP=${afterTP} units=${tributedUnits} gainedTP=${gainedTP}"

    | ---------- Decide success ----------
    /if (${tributedUnits} > 0 || ${gainedTP} > 0) {

        | If the slot item changed/cleared but our unit delta missed it, assume 1 unit for non-stackables
        /if (${tributedUnits} <= 0 && ${afterSlotID} != ${tributeItemID} && ${tributeItemID} > 0) /varset tributedUnits 1

        | Prefer actual gainedTP; otherwise estimate from tributeValue * units
        /varset pointsToAdd ${gainedTP}
        /if (${pointsToAdd} <= 0) {
            /if (${tributedUnits} > 0) {
                /varset pointsToAdd ${Math.Calc[${tributeValue}*${tributedUnits}]}
            } else {
                /varset pointsToAdd ${tributeValue}
            }
        }

        | Update run totals (outer vars)
        /varcalc tributeItemsMoved ${tributeItemsMoved} + ${tributedUnits}
        /varcalc tributePointsGained ${tributePointsGained} + ${pointsToAdd}

        | Keep your existing counter (per action, not per unit)
        /varcalc itemsTributed ${itemsTributed} + 1

        /varset announceTP ${pointsToAdd}

        /call AnnounceBankSell "${tlTag} \ay[TRIBUTE]\aw ${tributeItemLink} \at(+${announceTP} TP)"
        /return
    }

    | ---------- If we get here, delta says nothing changed ----------
    /call AnnounceBankSell "${tlTag} \aoWARNING: Tribute for ${tributeItemLink} did not show an immediate delta (inv/favor unchanged). If this item should tribute - try again or increase delay."
/return

|| ---------------------------------------------------------------------
|| DESTROY ITEM (helper subroutine)
|| ---------------------------------------------------------------------
Sub DestroyItem(int bagNum, int slotNum, string itemName)
    /declare currentItemName string local
    /declare destroyItemLink string local
    /declare destroyItemID int local 0
    /declare destroyUnits int local 1
    /declare pickupTries int local 0
    /declare waitPick int local 0

    /if (${bagNum} == 0) {
        /declare mainLink string local ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
        /call AnnounceBankSell "${tlTag} \aoNOTICE/ACTION REQUIRED:\aw ${mainLink} \aoin main inventory slot ${slotNum} is marked \arDESTROY\ao. \arMove it to a bag (pack1-pack10), then run \ag/mac turboloot destroy\ar. \ay(MQ limitation)\ax"
        /return
    }

    /varset currentItemName ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Name}
    /varset destroyItemID ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ID}
    /varset destroyItemLink ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
    /varset destroyUnits 1
    /if (${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}) /varset destroyUnits ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack}
    /if (${destroyUnits} <= 0) /varset destroyUnits 1
    /if (!${currentItemName.Length} || ${currentItemName.Equal[NULL]} || !${destroyItemID}) /return

    /if (${currentItemName.NotEqual[${itemName}]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[DestroyItem] Item changed: expected ${itemName}, found ${currentItemName}"
        /return
    }

    /if (!${Window[pack${bagNum}].Open}) {
        /nomodkey /itemnotify pack${bagNum} rightmouseup
        /delay 2 ${Window[pack${bagNum}].Open}
    }

    /varset pickupTries 0
    :tryPickupForDestroy
    /varcalc pickupTries ${pickupTries} + 1

    /if (${Cursor.ID}) /call ClearCursor
    /delay 5 !${Cursor.ID}
    /if (${Cursor.ID}) {
        /call AnnounceBankSell "${tlTag} \arWARNING: Could not clear cursor (has: \aw${Cursor.Name}\ar). Skipping destroy of \aw${destroyItemLink}\ar."
        /return
    }

    /nomodkey /shift /itemnotify in pack${bagNum} ${slotNum} leftmouseup

    /varset waitPick 0
    /while (${waitPick} < 20 && !${Cursor.ID}) {
        /doevents
        /if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow
        /if (${Cursor.ID}) /break
        /delay 1
        /varcalc waitPick ${waitPick} + 1
    }

    /if (!${Cursor.ID}) {
        | One more (or two) pickup attempts before giving up
        /if (${pickupTries} < 3) /goto :tryPickupForDestroy
        /call AnnounceBankSell "${tlTag} \arWARNING: Could not pick up \aw${destroyItemLink}\ar to cursor (UI lag). Skipping this item for now."
        /return
    }

    /if (${Cursor.ID} != ${destroyItemID}) {
        /call AnnounceBankSell "${tlTag} \aoWARNING: Cursor item changed unexpectedly while destroying. Expected id=${destroyItemID} but got id=${Cursor.ID}. Clearing cursor to avoid destroying the wrong item."
        /call ClearCursor
        /return
    }
    /if (${Cursor.Stackable}) /varset destroyUnits ${Cursor.Stack}
    /if (${destroyUnits} <= 0) /varset destroyUnits 1

    /call AnnounceBankSellPerItem "${tlTag} \ar[DESTROY]\aw ${destroyItemLink} \aw(x${destroyUnits})"

    /destroy
    /delay 10 !${Cursor.ID}
    /if (${Cursor.ID}) {
        | One more attempt
        /destroy
        /delay 10 !${Cursor.ID}
    }

    /if (${Cursor.ID}) {
        /call AnnounceBankSell "${tlTag} \arWARNING: Destroy failed; item still on cursor: \aw${Cursor.Name}\ar. Please clear manually."
        /return
    }

    /varcalc itemsDestroyed ${itemsDestroyed} + ${destroyUnits}
    /call AnnounceBankSellPerItem "${tlTag} \ar[DESTROY]\aw ${destroyItemLink} \aw(x${destroyUnits})"
/return

| ---------------------------------------------------------------------
| TRY CLICK TRIBUTE DONATE (UI-safe helpers)
| ---------------------------------------------------------------------
Sub IsTributeDonateEnabled
    | Returns 1 if any known Donate button is enabled, else 0
    /if (${Window[TributeMasterWnd].Child[TMW_DonateButton]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateButton].Enabled}) /return 1
    }
    /if (${Window[TributeMasterWnd].Child[DonateButton]}) {
        /if (${Window[TributeMasterWnd].Child[DonateButton].Enabled}) /return 1
    }
    /if (${Window[TributeMasterWnd].Child[TMW_Donate_Button]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_Donate_Button].Enabled}) /return 1
    }
    /if (${Window[TributeMasterWnd].Child[TMW_DonateItem_Button]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateItem_Button].Enabled}) /return 1
    }
    /if (${Window[TributeMasterWnd].Child[TMW_DonateItemButton]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateItemButton].Enabled}) /return 1
    }
    /return 0

Sub TryClickTributeDonateButton
    | Returns 1 if a known Donate button was clicked, else 0
    /if (${Window[TributeMasterWnd].Child[TMW_DonateButton]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateButton].Enabled}) {
            /notify TributeMasterWnd TMW_DonateButton leftmouseup
            /return 1
        }
    }
    /if (${Window[TributeMasterWnd].Child[DonateButton]}) {
        /if (${Window[TributeMasterWnd].Child[DonateButton].Enabled}) {
            /notify TributeMasterWnd DonateButton leftmouseup
            /return 1
        }
    }
    /if (${Window[TributeMasterWnd].Child[TMW_Donate_Button]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_Donate_Button].Enabled}) {
            /notify TributeMasterWnd TMW_Donate_Button leftmouseup
            /return 1
        }
    }
    /if (${Window[TributeMasterWnd].Child[TMW_DonateItem_Button]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateItem_Button].Enabled}) {
            /notify TributeMasterWnd TMW_DonateItem_Button leftmouseup
            /return 1
        }
    }
    /if (${Window[TributeMasterWnd].Child[TMW_DonateItemButton]}) {
        /if (${Window[TributeMasterWnd].Child[TMW_DonateItemButton].Enabled}) {
            /notify TributeMasterWnd TMW_DonateItemButton leftmouseup
            /return 1
        }
    }
    /return 0

| ---------------------------------------------------------------------
| PROCESS LOOT ITEM (normal INI-driven looting)
| ---------------------------------------------------------------------
Sub ProcessLootItem(int lootSlot, string limitParam)
    /declare thisName string local
    
    /varset thisName ${Corpse.Item[${lootSlot}].Name}
    /if (!${thisName.Length} || ${thisName.Equal[NULL]} || ${thisName.Equal[null]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] ERROR: Cannot get item name for slot ${lootSlot} in ProcessLootItem"
        /return
    }
    /varset itemLimitUpper ${limitParam.Upper}
    /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
    /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
    /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE

    /if (!${itemLimitUpper.Length} || ${itemLimitUpper.Equal[0]} || ${itemLimitUpper.Equal[NOTFOUND]} || ${itemLimitUpper.Equal[NULL]}) {
        /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) \at(unlisted)"
        /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "unlisted"
        /return
    }

    /if (${showDebug}) /call LogDebug "ProcessLootItem: ${thisName} limit=[${limitParam}] Lore=${Corpse.Item[${lootSlot}].Lore}"
    /if (${showDebug} && ${itemLimitUpper.Equal[SELL]}) /call LogDebug "ProcessLootItem SELL: ${thisName} limit=[${limitParam}]"

    /if (${itemLimitUpper.Equal[IGNORE]}) {
        /if (${showDebug}) {
            /if (${announceMethod.Upper.Equal[ECHO]} || ${announceMethod.Upper.Equal[E3BC]}) {
                /docommand /${announceMethod} ${tlTag} \aw[IGNORE] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})
            } else {
                /declare msg string local ${tlTag} \aw[IGNORE] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID})
                /varset msg ${msg.Replace[NULL,${thisName}]}
                /varset msg ${msg.Replace[null,${thisName}]}
                /call FormatMessage "${msg}" "${announceMethod}"
                /declare formattedMsg string local ${Macro.Return}
                /docommand /${announceMethod} ${formattedMsg}
            }
        }
        /varcalc itemsIgnored ${itemsIgnored}+1
        /return
    }

    /if (${itemLimitUpper.Equal[DESTROY]}) {
        /call LootAndDestroyCorpseItem ${lootSlot} "${thisName}"
        /return
    }

    /if (${Corpse.Item[${lootSlot}].Lore}) {
        /varset currentCount ${Math.Calc[${FindItemCount[=${thisName}]}+${FindItemBankCount[=${thisName}]}]}
        /if (${showDebug}) /call LogDebug "ProcessLootItem LORE check count=${currentCount}"
        /if (${currentCount} >= 1) {
            /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) - Already have"
            /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "lore_already_have"
            /if (${showDebug} && (${thisName.Find[Spell]} || ${thisName.Find[Skill]})) /call LogDebug "Wildcard skipped LORE already have ${currentCount}"
            /return
        }
    }

    /if (${itemLimitUpper.Equal[SELL]} || ${itemLimitUpper.Equal[KEEP]} || ${itemLimitUpper.Equal[BANK]} || ${itemLimitUpper.Equal[TRIBUTE]}) {
        /if (${showDebug}) /call LogDebug "ProcessLootItem ${itemLimitUpper} -> ALL path"
        /call CheckInventorySpace "${thisName}" ${lootSlot}
        /call LootTheItem ${lootSlot} "${thisName}" 999999 "${limitParam}"
        /return
    }

    /if (${itemLimitUpper.Equal[ALL]}) {
        /if (${showDebug}) /call LogDebug "ProcessLootItem ALL -> LootTheItem"
        /call CheckInventorySpace "${thisName}" ${lootSlot}
        /call LootTheItem ${lootSlot} "${thisName}" 999999 "${limitParam}"
        /return
    }

    /if (!${itemLimitUpper.Equal[ALL]} && !${itemLimitUpper.Equal[IGNORE]} && !${itemLimitUpper.Equal[DESTROY]} && ${Int[${limitParam}]} > 0) {
        /varset currentCount ${Math.Calc[${FindItemCount[=${thisName}]}+${FindItemBankCount[=${thisName}]}]}
        /if (${showDebug}) /call LogDebug "ProcessLootItem limit check count=${currentCount} max=${Int[${limitParam}]}"
        /if (${currentCount} >= ${Int[${limitParam}]}) {
            /if (${showDebug}) /call LogDebug "ProcessLootItem SKIP at limit (${currentCount} >= ${Int[${limitParam}]})"
            /if (${showDebug} && (${thisName.Find[Spell]} || ${thisName.Find[Skill]})) /call LogDebug "WARN wildcard ${thisName} skipped at limit"
            /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ar*** LIMIT REACHED ***\aw You have reached your limit of ${Int[${limitParam}]} for ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} - skipping"
            /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "numeric_limit_reached"
            /return
        }
        
        /call CheckInventorySpace "${thisName}" ${lootSlot}
        /call LootTheItem ${lootSlot} "${thisName}" ${Int[${limitParam}]} "${limitParam}"
    }
/return

| ---------------------------------------------------------------------
| LOOT HIGH VALUE ITEM
| ---------------------------------------------------------------------
Sub LootHighValueItem(int lootSlot)
    /call CheckLootAbortState

    /declare tries int local 0
    /declare waitTries int local 0
    /declare thisName string local
    
    /if (!${Corpse.Item[${lootSlot}].ID}) /return
    /varset thisName ${Corpse.Item[${lootSlot}].Name}
    /if (!${thisName.Length} || ${thisName.Equal[NULL]} || ${thisName.Equal[null]}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] ERROR: Cannot get item name for slot ${lootSlot} in LootHighValueItem"
        /return
    }
    /varset LoreAttemptName "${thisName}"
    
    | Cache item link and value BEFORE any loot attempt - the slot can empty during loot
    /declare cachedItemLink string local ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]}
    /if (!${cachedItemLink.Length} || ${cachedItemLink.Equal[NULL]}) /varset cachedItemLink ${thisName}
    /declare cachedValuePP int local ${Math.Calc[${Corpse.Item[${lootSlot}].Value} / 1000]}

    /if (${showDebug} || ${announceLooted}) /call Announce "${announceMethod}" "${tlTag} \ag[VALUE] ${cachedItemLink} \at(worth ${cachedValuePP}pp)"

:retryHigh
    /varcalc tries ${tries}+1

    /if (${Cursor.ID}) /call ForceClearCursor

    /call CheckLootAbortState
    /if (${RightClickLoot}) {
        /ctrl /itemnotify loot${lootSlot} rightmouseup
    } else {
        /shiftkey /itemnotify loot${lootSlot} leftmouseup
    }
    /doevents
    /if (!${Corpse.Item[${lootSlot}].ID}) {
        /varcalc itemsLooted ${itemsLooted}+1
        /if (${Cursor.ID}) /call ForceClearCursor
        /return
    }
    /if (${lootPerfLog}) /varcalc perfItemWaits ${perfItemWaits}+1
    /delay ${itemLootWaitDelay} ${Cursor.ID} || !${Corpse.Item[${lootSlot}].ID} || ${LoreBlocked}
    /doevents
    /varset waitTries 0
    /while (${Corpse.Item[${lootSlot}].ID} && !${Cursor.ID} && !${LoreBlocked} && ${waitTries} < 15) {
        /call CheckLootAbortState
        /if (${lootPerfLog}) /varcalc perfItemWaits ${perfItemWaits}+1
        /delay 1
        /doevents
        /varcalc waitTries ${waitTries}+1
    }
    /if (${lootPerfLog} && ${waitTries} > ${perfMaxItemWaitTries}) /varset perfMaxItemWaitTries ${waitTries}
    /if (${lootPerfLog} && ${waitTries} >= 5) /varcalc perfLongItemWaits ${perfLongItemWaits}+1
    /if (${lootPerfDetail} && ${waitTries} >= 5) /call PerfLogLine "detail item_wait_high slot=${lootSlot} item=${thisName} waits=${waitTries} tries=${tries} cursor=${Cursor.ID} lore=${LoreBlocked}"

    /if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow
    /if (${Window[ConfirmationDialogBox].Open}) /call HandleNoDropConfirmation

    /if (${LoreBlocked}) {
        /if (${LoreBlockedName.Length} && ${LoreBlockedName.NotEqual[""]} && ${LoreBlockedName.NotEqual[NULL]} && !${thisName.Equal[${LoreBlockedName}]}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked message was for "${LoreBlockedName}", not "${thisName}" - ignoring
            /varset LoreBlocked FALSE
            /varset LoreBlockedName ""
        } else {
            /call HandleLoreBlocked ${lootSlot} "${thisName}"
            /return
        }
    }

    /if (!${Corpse.Item[${lootSlot}].ID} || ${Cursor.ID}) {
        /varcalc itemsLooted ${itemsLooted}+1

        /doevents
        /if (${Cursor.ID}) /call ForceClearCursor

        /return
    }

    /if (${tries} < ${MaxLootRetries}) /goto :retryHigh

    /call HandleGiveUpLoot ${lootSlot} "${thisName}" ${tries}
/return

| ---------------------------------------------------------------------
| LOOT THE ITEM (normal looting)
| ---------------------------------------------------------------------
Sub LootTheItem(int lootSlot, string thisName, int maxCount, string limitParam)
    /call CheckLootAbortState

    /declare tries int local 0
    /declare waitTries int local 0
    /varset itemLimitUpper ${limitParam.Upper}
    /varset itemLimitUpper ${itemLimitUpper.Replace[ ,]}
    /if (${itemLimitUpper.Equal[SKIP]}) /varset itemLimitUpper IGNORE
    /if (${itemLimitUpper.Equal[ANNOUNCE]}) /varset itemLimitUpper IGNORE

    /varset currentCount ${Math.Calc[${FindItemCount[=${thisName}]}+${FindItemBankCount[=${thisName}]}]}

    | Cache item link BEFORE any loot attempt - the slot can empty during loot
    /declare cachedItemLink string local
    /if (${Corpse.Item[${lootSlot}].ID}) {
        /varset cachedItemLink ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]}
    }
    /if (!${cachedItemLink.Length} || ${cachedItemLink.Equal[NULL]}) /varset cachedItemLink ${thisName}

    /if (${currentCount} >= ${maxCount}) {
        /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ar*** LIMIT REACHED ***\aw You have reached your limit of ${maxCount} for ${cachedItemLink} - skipping"
        /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "numeric_limit_reached"
        /return
    }

    /varset LoreAttemptName "${thisName}"
    
    /if (${showDebug} || ${announceLooted}) {
        /if (${itemLimitUpper.Equal[SELL]}) {
            /call Announce "${announceMethod}" "${tlTag} \ag[SELL] ${cachedItemLink} \at(ID: ${_skipCorpseID})"
        } else /if (${itemLimitUpper.Equal[BANK]}) {
            /call Announce "${announceMethod}" "${tlTag} \ap[BANK] ${cachedItemLink} \at(ID: ${_skipCorpseID})"
        } else /if (${itemLimitUpper.Equal[TRIBUTE]}) {
            /call Announce "${announceMethod}" "${tlTag} \ay[TRIBUTE] ${cachedItemLink} \at(ID: ${_skipCorpseID})"
        } else /if (${itemLimitUpper.Equal[KEEP]}) {
            /call Announce "${announceMethod}" "${tlTag} \ag[KEEP] ${cachedItemLink} \at(ID: ${_skipCorpseID})"
        } else /if (${itemLimitUpper.Equal[WILD]}) {
            /call Announce "${announceMethod}" "${tlTag} \at[WILD] ${cachedItemLink} \at(ID: ${_skipCorpseID})"
        } else {
            /call Announce "${announceMethod}" "${tlTag} \ag[LOOT] ${cachedItemLink}"
        }
    }

:retryLoot
    /varcalc tries ${tries}+1

    /if (${Cursor.ID}) /call ForceClearCursor

    /call CheckLootAbortState
    /if (${RightClickLoot}) {
        /ctrl /itemnotify loot${lootSlot} rightmouseup
    } else {
        /shiftkey /itemnotify loot${lootSlot} leftmouseup
    }
    /doevents
    /if (!${Corpse.Item[${lootSlot}].ID}) {
        /varcalc itemsLooted ${itemsLooted}+1
        /if (${Cursor.ID}) /call ForceClearCursor
        /return
    }
    /if (${lootPerfLog}) /varcalc perfItemWaits ${perfItemWaits}+1
    /delay ${itemLootWaitDelay} ${Cursor.ID} || !${Corpse.Item[${lootSlot}].ID} || ${LoreBlocked}
    /doevents
    /varset waitTries 0
    /while (${Corpse.Item[${lootSlot}].ID} && !${Cursor.ID} && !${LoreBlocked} && ${waitTries} < 15) {
        /call CheckLootAbortState
        /if (${lootPerfLog}) /varcalc perfItemWaits ${perfItemWaits}+1
        /delay 1
        /doevents
        /varcalc waitTries ${waitTries}+1
    }
    /if (${lootPerfLog} && ${waitTries} > ${perfMaxItemWaitTries}) /varset perfMaxItemWaitTries ${waitTries}
    /if (${lootPerfLog} && ${waitTries} >= 5) /varcalc perfLongItemWaits ${perfLongItemWaits}+1
    /if (${lootPerfDetail} && ${waitTries} >= 5) /call PerfLogLine "detail item_wait_high slot=${lootSlot} item=${thisName} waits=${waitTries} tries=${tries} cursor=${Cursor.ID} lore=${LoreBlocked}"

    /if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow

    /if (${Window[ConfirmationDialogBox].Open}) /call HandleNoDropConfirmation

    /if (${LoreBlocked}) {
        /if (${LoreBlockedName.Length} && ${LoreBlockedName.NotEqual[""]} && ${LoreBlockedName.NotEqual[NULL]} && !${thisName.Equal[${LoreBlockedName}]}) {
            /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked message was for "${LoreBlockedName}", not "${thisName}" - ignoring
            /varset LoreBlocked FALSE
            /varset LoreBlockedName ""
        } else {
            /call HandleLoreBlocked ${lootSlot} "${thisName}"
            /return
        }
    }

    /if (!${Corpse.Item[${lootSlot}].ID} || ${Cursor.ID}) {
        /varcalc itemsLooted ${itemsLooted}+1

        | Inventory the looted item (only clear cursor if needed)
        /doevents
        /if (${Cursor.ID}) /call ForceClearCursor

        /if ((${maxCount} < 999999) && (${maxCount} > 0)) {
            /varset currentCount ${Math.Calc[${FindItemCount[=${thisName}]}+${FindItemBankCount[=${thisName}]}]}
            /if (${currentCount} >= ${maxCount}) {
                /call Announce "${announceSkippedMethod}" "${tlTag} \ar*** LIMIT REACHED ***\aw You now have ${currentCount}/${maxCount} ${thisName}"
            }
        }

        /return
    }

    /if (${tries} < ${MaxLootRetries}) /goto :retryLoot

    /call HandleGiveUpLoot ${lootSlot} "${thisName}" ${tries}
/return

| ---------------------------------------------------------------------
| LOOT AND DESTROY CORPSE ITEM
| ---------------------------------------------------------------------
Sub LootAndDestroyCorpseItem(int lootSlot, string destroyName)
    /declare tries int local 0

:LootDestroyLoop
    /call CheckLootAbortState
    /if (!${Corpse.Item[${lootSlot}].ID}) /return

    /varcalc tries ${tries}+1
        /if (${tries} >= ${MaxLootRetries}) {
        /if (${showDebug} || ${announceSkipped}) {
            /declare destroyFailMsg string local "${tlTag} \ar[DESTROY] ${destroyName} \at(ID: ${_skipCorpseID}) - failed ${tries}x"
            /call FormatMessage "${destroyFailMsg}" "${announceMethod}"
            /docommand /${announceMethod} ${Macro.Return}
        }
        | Don't mark entire corpse as skip - just this item failed
        | /squelch /alert add ${AlertIndex} id ${Target.ID}
        | /varset Skip TRUE
        /return
    }

    /call CheckLootAbortState
    /shiftkey /itemnotify loot${lootSlot} leftmouseup
    /delay 1 ${Cursor.ID}

    /if (${Window[ConfirmationDialogBox].Open}) /call HandleNoDropConfirmation

    /if (${Cursor.ID}) {
        /destroy
        | Conditional delay - exits early when cursor is empty
        /delay 10 !${Cursor.ID}
        /varcalc itemsDestroyed ${itemsDestroyed}+1
        /return
    }

    /if (!${Corpse.Item[${lootSlot}].ID}) /return

    /if (${tries} < ${MaxLootRetries}) /goto :LootDestroyLoop

    /call HandleGiveUpLoot ${lootSlot} "${destroyName}" ${tries}
/return

| ---------------------------------------------------------------------
| HELPER FUNCTIONS
| ---------------------------------------------------------------------
| WILDCARD DETECTION (checks against prefixes loaded from [Wildcards] INI section)
| ---------------------------------------------------------------------
Sub IsWildcardItem(string name)
    | Checks item name against all prefixes loaded from [Wildcards] INI section.
    | wildcardPrefixes format: |6:SPELL:||5:SONG:||8:TOME OF |
    | Fast reject: first chars of each prefix in wildcardFirstChars (|S|T|...)
    /if (!${wildcardPrefixes.Length}) /return FALSE

    /declare u string local ${name.Upper}
    /if (!${u.Length}) /return FALSE

    /if (${Defined[wildcardFirstChars]} && ${wildcardFirstChars.Length}) {
        /if (!${wildcardFirstChars.Find[|${u.Left[1]}|]}) /return FALSE
    }
    /declare searchPos int local 1
    /declare pipeEnd int local
    /declare entry string local
    /declare colonPos int local
    /declare prefixLen int local
    /declare prefix string local
    /declare chunk string local

    :nextWildcard
    /varset searchPos ${Math.Calc[${searchPos}+1]}
    /if (${searchPos} >= ${wildcardPrefixes.Length}) /return FALSE

    /varset chunk ${wildcardPrefixes.Mid[${searchPos},500]}
    /if (!${chunk.Length}) /return FALSE

    /varset pipeEnd ${chunk.Find[|]}
    /if (!${pipeEnd} || ${pipeEnd} < 3) /return FALSE

    /varset entry ${chunk.Left[${Math.Calc[${pipeEnd}-1]}]}
    /varset searchPos ${Math.Calc[${searchPos}+${pipeEnd}-1]}

    /varset colonPos ${entry.Find[:]}
    /if (!${colonPos}) /goto :nextWildcard

    /varset prefixLen ${Int[${entry.Left[${Math.Calc[${colonPos}-1]}]}]}
    /if (${prefixLen} < 1 || ${prefixLen} > ${u.Length}) /goto :nextWildcard

    /varset prefix ${entry.Mid[${Math.Calc[${colonPos}+1]},${prefixLen}]}
    /if (${u.Left[${prefixLen}].Equal[${prefix}]}) /return TRUE

    /goto :nextWildcard
/return FALSE

| ---------------------------------------------------------------------
| HANDLE QUANTITY WINDOW
| ---------------------------------------------------------------------
Sub HandleQuantityWindow
    /if (!${Window[QuantityWnd].Open}) /return

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] QuantityWnd detected - attempting to accept"

    /squelch /notify QuantityWnd AcceptButton leftmouseup
    /squelch /notify QuantityWnd QTYW_Accept_Button leftmouseup
    /keypress ENTER
    /delay 3 !${Window[QuantityWnd].Open}
    /delay 1
    /if (${Cursor.ID}) {
        /delay 5 !${Cursor.ID}
        /if (${Cursor.ID}) /call ForceClearCursor
    }

    /if (${Window[QuantityWnd].Open}) {
        /echo [turboLoot] ERROR: Quantity window stuck open. Aborting macro.
        /if (${Me.Grouped}) /docommand /${announceMethod} [turboLoot] ERROR: Quantity window stuck open. Aborting looting.
        /varset abortingMacro TRUE
        /call Cleanup
        /endmac
    }
/return

| ---------------------------------------------------------------------
| HANDLE NO-DROP CONFIRMATION
| ---------------------------------------------------------------------
Sub HandleNoDropConfirmation
    /if (!${Window[ConfirmationDialogBox].Open}) /return
    
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] No-drop confirmation dialog detected"
    
    /notify ConfirmationDialogBox Yes_Button leftmouseup
    /delay 5 !${Window[ConfirmationDialogBox].Open}
    
    /if (${Window[ConfirmationDialogBox].Open}) {
        /notify ConfirmationDialogBox CD_Yes_Button leftmouseup
        /delay 5 !${Window[ConfirmationDialogBox].Open}
    }
    
    /if (${Window[ConfirmationDialogBox].Open}) {
        /keypress ENTER
        /delay 3 !${Window[ConfirmationDialogBox].Open}
    }
/return

| ---------------------------------------------------------------------
| CHECK INVENTORY SPACE
| ---------------------------------------------------------------------
Sub CheckInventorySpace(string itemName, int lootSlot)
    /declare quantity int local ${Corpse.Item[${lootSlot}].Stack}
    /declare stackSize int local ${Corpse.Item[${lootSlot}].StackSize}
    /varset currentCount ${FindItemCount[=${itemName}]}

    /declare currentStacks int local 0
    /if (${FindItem[=${itemName}].ID}) {
        /varset currentStacks ${FindItem[=${itemName}].Stacks}
    }
    /declare totalInFullStacks int local ${Math.Calc[${currentStacks} * ${stackSize}]}

    /declare spaceInCurrentStacks int local ${Math.Calc[${totalInFullStacks} - ${currentCount}]}
    /if (${spaceInCurrentStacks} < 0) /varset spaceInCurrentStacks 0

    /if (${quantity} <= ${spaceInCurrentStacks}) /return

    /declare extraNeeded int local ${Math.Calc[${quantity} - ${spaceInCurrentStacks}]}
    /if (${stackSize} <= 1) {
        /declare newStacksNeeded int local ${extraNeeded}
    } else {
        /declare newStacksNeeded int local ${Math.Calc[(${extraNeeded} + ${stackSize} - 1) / ${stackSize}]}
    }

    /if (${newStacksNeeded} <= 0) /return

    /declare free int local ${Me.FreeInventory}
    /if (${free} < ${minFreeSlotsDuringLoot}) /varset minFreeSlotsDuringLoot ${free}
/return

| ---------------------------------------------------------------------
| HANDLE LORE BLOCKED
| ---------------------------------------------------------------------
Sub HandleLoreBlocked(int lootSlot, string thisName)
    /declare itemDisplay string local ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]}
    /if (!${itemDisplay.Length} || ${itemDisplay.Equal[NULL]}) {
        /varset itemDisplay ${thisName}
    }
    
    /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "\ao[SKIP] ${itemDisplay} \at(ID: ${_skipCorpseID}) \at(already owned)"
    /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "lore_already_owned"

    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) {
        /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
    }
    | Always add thisName directly as fallback - covers servers where item stays in slot and LoreAttemptName may already be cleared
    /if (${thisName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${thisName}|]})) {
        /varset LoreDeniedNames "${LoreDeniedNames}|${thisName}|"
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (generic) - added [${thisName}] to LoreDeniedNames cache"
    }

    /varset LoreBlocked FALSE
    /varset LoreBlockedName ""
/return

| ---------------------------------------------------------------------
| HANDLE GIVE UP (max retries)
| ---------------------------------------------------------------------
Sub HandleGiveUpLoot(int lootSlot, string thisName, int tries)
    /if (${Corpse.Item[${lootSlot}].Lore}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE item failed after ${tries} attempts - treating as lore-blocked"
        | Add to lore denied cache so we don't retry on other corpses
        /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
        /if (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${thisName}|]}) /varset LoreDeniedNames "${LoreDeniedNames}|${thisName}|"
        | Announce as skip
        /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ao[SKIP] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(ID: ${_skipCorpseID}) \at(lore - already owned)"
        /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "lore_already_owned"
        /return
    }

    /call AnnounceSkipped "${_skipCorpseID}:${thisName}" "${tlTag} \ar[GIVING UP] ${Corpse.Item[${lootSlot}].ItemLink[CLICKABLE]} \at(failed ${tries}x)"
    /call LogSkipForCorpseItem ${lootSlot} "${thisName}" "loot_failed_gave_up"

/return

| ---------------------------------------------------------------------
| UTILITY FUNCTIONS
| ---------------------------------------------------------------------
Sub CloseBags
    /declare bag int local

    /if (${Window[InventoryWindow].Open}) /nomodkey /notify InventoryWindow DoneButton leftmouseup
    /for bag 1 to 10
        /if (${Window[pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
    /next bag
/return

Sub Event_Unlootable
    /varset Skip TRUE
    /squelch /alert add ${AlertIndex} id ${Target.ID}
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] CANNOT LOOT ID: ${Target.ID} (marking corpse to skip)"
/return


Sub Event_TooFar
    /if (!${Defined[tooFarHit]}) /declare tooFarHit bool outer FALSE
    /if (!${Defined[tooFarStrikes]}) /declare tooFarStrikes int outer 0
    /if (!${Defined[tooFarCorpseID]}) /declare tooFarCorpseID int outer 0
    /if (!${Defined[tooFarStrikeThreshold]}) /declare tooFarStrikeThreshold int outer 3

    /varset tooFarHit TRUE

    /if (${Target.ID}!=${tooFarCorpseID}) {
        /varset tooFarCorpseID ${Target.ID}
        /varset tooFarStrikes 0
    }
    /varcalc tooFarStrikes ${tooFarStrikes}+1

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] TooFar on ${Target.ID} (strike ${tooFarStrikes}/${tooFarStrikeThreshold})"
/return

Sub Event_CursorOccupied
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cursor occupied - clearing cursor"
    /call ForceClearCursor
    /delay 2 !${Cursor.ID}
    /if (${Cursor.ID}) /call ForceClearCursor
/return


Sub Event_LoreAlreadyPossess(string itemName)
    /varset LoreBlocked TRUE
    /varset LoreBlockedName "${itemName}"
    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${itemName}|]}) /varset LoreDeniedNames "${LoreDeniedNames}|${itemName}|"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (already possess): "${itemName}" - ID: ${Target.ID}
/return


Sub Event_LoreAlreadyHaveOne
    /varset LoreBlocked TRUE
    /varset LoreBlockedName ""
    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (already have one) - ID: ${Target.ID}"
/return


Sub Event_LoreAlreadyHaveOneExact
    /varset LoreBlocked TRUE
    /varset LoreBlockedName ""
    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (already have one) [exact] - ID: ${Target.ID}"
/return


Sub Event_LoreDeniedGeneric
    /varset LoreBlocked TRUE
    /varset LoreBlockedName ""
    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (generic) - ID: ${Target.ID}"
/return


Sub Event_LoreAlreadyPossessNoName
    /varset LoreBlocked TRUE
    /varset LoreBlockedName ""
    /if (${LoreDeniedNames.Length} > 2000) /varset LoreDeniedNames ""
    /if (${LoreAttemptName.Length} && (!${LoreDeniedNames.Length} || !${LoreDeniedNames.Find[|${LoreAttemptName}|]})) /varset LoreDeniedNames "${LoreDeniedNames}|${LoreAttemptName}|"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] LORE blocked (already possess) - ID: ${Target.ID}"
/return


Sub CheckLootAbortState
    /if (${lootPerfLog}) /varcalc perfAbortChecks ${perfAbortChecks}+1
    /if (${Me.Feigning}) {
        /if (${Me.Grouped}) {
            /docommand /${announceMethod} [FEIGNED] Currently FD and not looting
        } else {
            /echo [turboLoot] Feigned - stopping loot macro
        }
        /varset abortingMacro TRUE
        /varset safetyNoResume TRUE
        /e3p on
        /deletevar turboLootRunning
        /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
        /call StopFollowAndMovement
        /call Cleanup
        /endmac
    }
    /if (${Me.Invis}) {
        /if (${Me.Grouped}) {
            /docommand /${announceMethod} [INVIS] Currently invisible and not looting
        } else {
            /echo [turboLoot] Invisible - stopping loot macro
        }
        /if (${logToFile}) /call LogError "Stopping: invisible and not looting"
        /varset abortingMacro TRUE
        /varset safetyNoResume TRUE
        /e3p on
        /deletevar turboLootRunning
        /if (${Defined[turboLootSafetyNet]}) /deletevar turboLootSafetyNet
        /call StopFollowAndMovement
        /call Cleanup
        /endmac
    }
/return


Sub AutoReclaimDiamondCoinsAfterLoot
    /if (!${Defined[reclaimDiamondCoinsAfterLoot]} || !${reclaimDiamondCoinsAfterLoot}) /return 0
    /if (${Defined[turboLootRunning]} && !${turboLootRunning}) /return 0
    /declare beforeInvDC int local ${FindItemCount[=Diamond Coin]}
    /if (${beforeInvDC} <= 0) /return 0
    /declare beforeAltDC int local ${Me.AltCurrency[20]}
    /declare listId int local 0
    /declare invWasOpen bool local ${Window[InventoryWindow].Open}

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Auto reclaim Diamond Coins after loot: found ${beforeInvDC} inventory DC."
    /if (!${Window[InventoryWindow].Open}) /invoke ${Window[InventoryWindow].DoOpen}
    /delay 5 ${Window[InventoryWindow].Open}
    /if (!${Window[InventoryWindow].Open}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Auto reclaim skipped: InventoryWindow did not open."
        /return 0
    }

    /notify InventoryWindow IW_Subwindows tabselect 5
    /delay 3
    /varset listId ${Window[InventoryWindow].Child[IW_AltCurr_PointList].List[=Diamond Coins,2]}
    /if (${listId} <= 0) /varset listId ${Window[InventoryWindow].Child[IW_AltCurr_PointList].List[=Diamond Coin,2]}
    /if (${listId} <= 0) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Auto reclaim skipped: Diamond Coins row not found in Alt Currency list."
        /if (!${invWasOpen} && ${Window[InventoryWindow].Open}) /windowstate InventoryWindow close
        /return 0
    }

    /notify InventoryWindow IW_AltCurr_PointList listselect ${listId} leftmouseup
    /delay 2
    /nomodkey /notify InventoryWindow AltCurr_ReclaimButton leftmouseup
    /delay 8 ${FindItemCount[=Diamond Coin]} < ${beforeInvDC} || ${Me.AltCurrency[20]} > ${beforeAltDC}
    /if (${FindItemCount[=Diamond Coin]} >= ${beforeInvDC}) {
        /nomodkey /notify InventoryWindow IW_AltCurr_Reclaimbutton leftmouseup
        /delay 8 ${FindItemCount[=Diamond Coin]} < ${beforeInvDC} || ${Me.AltCurrency[20]} > ${beforeAltDC}
    }

    /declare afterInvDC int local ${FindItemCount[=Diamond Coin]}
    /declare reclaimedDC int local ${Math.Calc[${beforeInvDC}-${afterInvDC}].Int}
    /if (${reclaimedDC} > 0) {
        /echo ${tlTag} \ag[RECLAIM]\aw Reclaimed \ag${reclaimedDC}\aw Diamond Coin${If[${reclaimedDC}==1,,s]} to alt-currency.
    } else /if (${showDebug} || ${logToFile}) {
        /call LogDebug "[turboLoot] Auto reclaim attempted but inventory DC count did not change."
    }
    /if (!${invWasOpen} && ${Window[InventoryWindow].Open}) /windowstate InventoryWindow close
/return ${reclaimedDC}


| ---------------------------------------------------------------------
| GO LOOT (TurboGear) — navigate to one corpse and loot one item by name.
| Uses the same pause/nav/loot/confirm primitives as normal TurboLoot so we
| do not reimplement MQ timing in Lua.
| Item name lives in outer goItemName (joined from Main /mac Param2.. in Sub
| Main — never read ParamN here; /call replaces Param0.. with this Sub's args).
| ---------------------------------------------------------------------
Sub GoLootOneItem(int corpseId)
    /echo ${tlTag} [GOLOOT] starting ${goItemName} (ID: ${corpseId})
    /squelch /tgearbg golootdone starting ${corpseId} ${goItemName}
    /squelch /hidecorpse none
    /delay 20 ${Spawn[id ${corpseId}].ID} == ${corpseId}
    /if (${Spawn[id ${corpseId}].ID} != ${corpseId}) {
        /echo ${tlTag} [GOLOOT] failed corpse_gone (ID: ${corpseId})
        /squelch /tgearbg golootdone failed corpse_gone ${corpseId} ${goItemName}
        /return
    }

    /declare dist float local ${Spawn[id ${corpseId}].Distance3D}
    /if (${dist} > 400) {
        /echo ${tlTag} [GOLOOT] failed too_far (ID: ${corpseId})
        /squelch /tgearbg golootdone failed too_far ${corpseId} ${goItemName}
        /return
    }

    /target id ${corpseId}
    /delay 5 ${Target.ID} == ${corpseId}
    /if (${Target.ID} != ${corpseId}) {
        /echo ${tlTag} [GOLOOT] failed no_target (ID: ${corpseId})
        /squelch /tgearbg golootdone failed no_target ${corpseId} ${goItemName}
        /return
    }

    /if (${Target.Distance} > 15) {
        /if (${useNavForCorpses} && ${Navigation.MeshLoaded} && ${Navigation.PathExists[id ${corpseId}]}) {
            /nav id ${corpseId} distance=10
            /delay 450 ${Spawn[id ${corpseId}].Distance} <= 15 || !${Navigation.Active}
            /squelch /nav stop
        } else {
            /moveto id ${corpseId}
            /delay 450 ${Spawn[id ${corpseId}].Distance} <= 15
            /squelch /moveto off
        }
    }

    /target id ${corpseId}
    /delay 3 ${Target.ID} == ${corpseId}
    /if (${Target.ID} != ${corpseId} || ${Target.Distance} > 20) {
        /echo ${tlTag} [GOLOOT] failed timeout_move (ID: ${corpseId})
        /squelch /tgearbg golootdone failed timeout_move ${corpseId} ${goItemName}
        /return
    }

    /docommand /lootnodrop ${lootNoDropPrompt}
    /loot
    /delay 30 ${Window[LootWnd].Open}
    /declare itemWait int local 0
    /while (${Window[LootWnd].Open} && ${Corpse.Items} <= 0 && ${itemWait} < 20) {
        /delay 1
        /doevents
        /varcalc itemWait ${itemWait}+1
    }
    /if (!${Window[LootWnd].Open}) {
        /echo ${tlTag} [GOLOOT] failed no_window (ID: ${corpseId})
        /squelch /tgearbg golootdone failed no_window ${corpseId} ${goItemName}
        /return
    }
    /if (${Corpse.Items} <= 0) {
        /echo ${tlTag} [GOLOOT] failed empty_corpse (ID: ${corpseId})
        /squelch /tgearbg golootdone failed empty_corpse ${corpseId} ${goItemName}
        /call TryCloseLootWindow
        /return
    }

    /declare slot int local 0
    /declare i int local 0
    /declare scanMax int local ${Corpse.Items}
    /declare slotName string local
    /declare wantId int local 0
    /if (${scanMax} < 8) /varset scanMax 8
    /if (${Corpse.Item[=${goItemName}].ID}) /varset wantId ${Corpse.Item[=${goItemName}].ID}
    /if (!${wantId} && ${Corpse.Item[${goItemName}].ID}) /varset wantId ${Corpse.Item[${goItemName}].ID}

    /for i 1 to ${scanMax}
        /if (!${Corpse.Item[${i}].ID}) /goto :GoLootNextSlot
        /varset slotName ${Corpse.Item[${i}].Name}
        /if (${wantId} && ${Corpse.Item[${i}].ID} == ${wantId}) {
            /varset slot ${i}
            /goto :GoLootHaveSlot
        }
        /if (${slotName.Equal[${goItemName}]}) {
            /varset slot ${i}
            /goto :GoLootHaveSlot
        }
        :GoLootNextSlot
    /next i

    :GoLootHaveSlot
    /if (${slot} <= 0) {
        /echo ${tlTag} [GOLOOT] failed not_found ${goItemName} (ID: ${corpseId})
        /squelch /tgearbg golootdone failed not_found ${corpseId} ${goItemName}
        /call TryCloseLootWindow
        /return
    }

    /varset _skipCorpseID ${corpseId}
    /varset LoreBlocked FALSE
    /call LootTheItem ${slot} "${goItemName}" 999999 KEEP
    /doevents

    /if (!${Corpse.Item[${slot}].ID}) {
        /echo ${tlTag} [GOLOOT] looted ${goItemName} (ID: ${corpseId})
        /squelch /tgearbg golootdone looted ${corpseId} ${goItemName}
        | Turbo Review: drop the skip row once loot is confirmed (bind no-ops if hub is down).
        /squelch /turboreviewgoloot looted ${corpseId} ${goItemName}
    } else /if (${LoreBlocked}) {
        /echo ${tlTag} [GOLOOT] failed lore (ID: ${corpseId})
        /squelch /tgearbg golootdone failed lore ${corpseId} ${goItemName}
    } else {
        /echo ${tlTag} [GOLOOT] failed loot_failed (ID: ${corpseId})
        /squelch /tgearbg golootdone failed loot_failed ${corpseId} ${goItemName}
    }

    /call TryCloseLootWindow
    /if (${corpseHideMode.Equal[ALL]} || ${corpseHideMode.Equal[SELF]} || ${corpseHideMode.Equal[LOOTED]}) /squelch /hidecorpse looted
/return

| ---------------------------------------------------------------------
| CLEANUP (end-of-run cleanup)
| ---------------------------------------------------------------------
Sub Cleanup
    | Omit "starting cleanup" — runs often; use skip/corpse DBG lines for real issues
    /call FlushSkipJournalBatch
    /call PrintPerfSummary
    /if (${Window[QuantityWnd].Open} && !${abortingMacro}) {
        /squelch /notify QuantityWnd AcceptButton leftmouseup
        /squelch /notify QuantityWnd QTYW_Accept_Button leftmouseup
        /keypress ENTER
        /delay 1
    }
    /call ClearCursor
    /varset modeCheck ${restoreFollowMode.Upper.Replace[ ,]}
    /if (${modeCheck.NotEqual[NONE]} && ${modeCheck.Length} && ${modeCheck.NotEqual[NULL]} && ${modeCheck.NotEqual[0]}) {
        /call StopFollowAndMovement
    }
    /call TryCloseLootWindow
    /if (${Defined[safetyNoResume]} && ${safetyNoResume}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cleanup: safety abort active; leaving E3/follow paused."
    } else {
        /call UnpauseAFollow
        /e3p off
    }
    /docommand /lootnodrop ${lootNoDropPromptReset}
    /call SetTurboLootActive OFF
/return


Sub SetTurboLootActive(string value)
    /if (!${value.Length}) /return
    /squelch /e3varset TurboLootActive ${value}
    /squelch /e3varset TurboLootActiveChar ${Me.CleanName}
    /if (${value.Equal[ON]}) {
        /squelch /lua parse local mq=require('mq'); mq.cmd('/e3varset TurboLootActiveAt '..os.time())
    } else {
        /squelch /e3varset TurboLootActiveAt 0
    }
/return


Sub StopFollowAndMovement
    /squelch /stick off
    /call PauseAFollow
    /squelch /moveto off
    /squelch /nav stop
    /squelch /keypress forward
    /delay 1
/return


Sub StopChaseForUtility
    /if (${showDebug}) /call LogDebug "StopChaseForUtility: sending /chaseme off before utility movement"
    /squelch /chaseme off
    /delay 1
/return


|| ---------------------------------------------------------------------
|| PAUSE/UNPAUSE AFOLLOW
|| ---------------------------------------------------------------------
Sub PauseAFollow
    /if (${Plugin[MQ2AdvPath].Name.Length}) {
        /if (${AdvPath.Following}) {
            /if (${showDebug}) /call LogDebug "PauseAFollow: Pausing /afollow (was active)"
            /varset afollowWasPaused TRUE
        } else {
            | Quiet when not following — runs many times per loot session
            /varset afollowWasPaused FALSE
        }
    } else {
        | Plugin not loaded - assume /afollow might be active and track it
        /if (${showDebug}) /call LogDebug "PauseAFollow: MQ2AdvPath not loaded, assuming /afollow might be active"
        /varset afollowWasPaused TRUE
    }
    /if (${afollowWasPaused}) /squelch /afollow pause
    /delay 1
/return


Sub UnpauseAFollow
    /if (${Me.Feigning}) {
        /if (${showDebug}) /call LogDebug "UnpauseAFollow: Skipping (currently FD)"
        /varset afollowWasPaused FALSE
        /return
    }
    
    /if (${afollowWasPaused}) {
        /if (${showDebug}) /call LogDebug "UnpauseAFollow: Resuming /afollow unpause (was paused by macro)"
        | /afollow unpause restores exact previous state - no retargeting needed
        /squelch /afollow unpause
        /varset afollowWasPaused FALSE
        /delay 2
    }
    | else: afollow was not active — no message (would spam every Cleanup)
/return


Sub ClearCursor
    /if (!${Cursor.ID}) /return
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cursor item detected during cleanup: ${Cursor.Name} (attempting /autoinventory)"

    /autoinventory
    /delay 10 !${Cursor.ID}
    /if (${Cursor.ID}) {
        /autoi
        /delay 10 !${Cursor.ID}
        /if (${Cursor.ID}) {
            /autoinventory
            /delay 10 !${Cursor.ID}
        }
    }

    /if (${Cursor.ID}) /echo [turboLoot] WARNING: Item still on cursor after cleanup: ${Cursor.Name}. You may need to manually clear it.
/return

Sub ForceClearCursor
    /declare clearTries int local 0
    /while (${Cursor.ID} && ${clearTries} < 5) {
        /varcalc clearTries ${clearTries}+1
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Cursor has item: ${Cursor.Name} - clearing (attempt ${clearTries})"
        /autoinventory
        /if (${lootPerfLog}) /varcalc perfCursorClearWaits ${perfCursorClearWaits}+1
        /delay ${cursorClearDelay} !${Cursor.ID}
        /if (${Cursor.ID}) {
            /autoi
            /if (${lootPerfLog}) /varcalc perfCursorClearWaits ${perfCursorClearWaits}+1
            /delay ${cursorClearDelay} !${Cursor.ID}
        }
    }
/return


Sub TryCloseLootWindow
    /if (!${Window[LootWnd].Open}) /return
    /squelch /notify LootWnd DoneButton leftmouseup
    /delay 1
    /if (${Window[LootWnd].Open}) {
        /keypress ESC
        /delay 1
    }
    /if (${Window[LootWnd].Open}) {
        /squelch /notify LootWnd DoneButton leftmouseup
        /delay 1
    }
    /if (${Window[LootWnd].Open}) /squelch /windowstate LootWnd close
/return


Sub EchoLoadedIniProfile
    /declare iniOverrideDbg string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /if (${iniOverrideDbg.Length} && !${iniOverrideDbg.Equal[NULL]} && !${iniOverrideDbg.Equal[turboloot.ini]}) {
        /echo [turboLoot] Using profile: ${iniOverrideDbg}
    } else {
        /echo [turboLoot] Using INI: ${iniFile}
    }
/return


Sub LogDebug(string msg)
    /if (!${showDebug} && !${logToFile}) /return
    /call StripColorCodes "${msg}"
    /declare _ldBody string local ${Macro.Return}
    | Chat: single gray tag + plain text (avoids colored wall of [turboLoot] noise)
    /if (${showDebug}) /echo \aw[TL DBG]\ax ${_ldBody}
    | File: one tag; omit extra timestamp (log sink usually stamps lines already)
    /if (${logToFile} && ${logLevel} <= 0) /mqlog [DEBUG] ${_ldBody}
/return

| LogDebugFileOnly: mqlog at DEBUG level only — no chat (startup/profile dumps; use /mac turboloot doctor for chat)
Sub LogDebugFileOnly(string msg)
    /if (!${logToFile}) /return
    /if (!${Defined[logLevel]} || ${logLevel} > 0) /return
    /call StripColorCodes "${msg}"
    /declare _df string local ${Macro.Return}
    /mqlog [DEBUG] ${_df}
/return

| LogInfo: informational; echo when showDebug, file when logToFile and logLevel<=INFO
Sub LogInfo(string msg)
    /if (!${showDebug} && !${logToFile}) /return
    /call StripColorCodes "${msg}"
    /declare _liBody string local ${Macro.Return}
    /if (${showDebug}) /echo \at[TL INFO]\ax ${_liBody}
    /if (${logToFile} && ${logLevel} <= 1) /mqlog [INFO] ${_liBody}
/return

| LogWarn: always echo (yellow); file when logToFile and logLevel<=WARN
Sub LogWarn(string msg)
    /echo ${tlTag} \ay${msg}
    /if (${logToFile} && ${logLevel} <= 2) {
        /call StripColorCodes "${msg}"
        /mqlog [WARN] ${Macro.Return}
    }
/return

| LogError: always echo (red); file when logToFile and logLevel<=ERROR
Sub LogError(string msg)
    /echo ${tlTag} \ar${msg}
    /if (${logToFile} && ${logLevel} <= 3) {
        /call StripColorCodes "${msg}"
        /mqlog [ERROR] ${Macro.Return}
    }
/return

| Skip list: lua/Turbo/skip_log.lua — SESSION banner + per-skip journal rows.
| 3.8.40+: durable path is a timed /lua parse append per skipped item.
| Avoid one giant SkipBatch string and avoid relying on /lua run argv passing
| from macro context.
| [Settings] logSkipListForIni=ON (default ON when absent) — Skip Review panel in Turbo GUI
Sub SkipIniLogSessionStart
    /if (!${logSkipListForIni}) /return
    /squelch /lua parse local mq=require('mq'); local base=(mq.TLO.MacroQuest.Path() or ''); local paths={base..'\\\\lua\\\\Turbo\\\\skip_log.lua',base..'\\\\lua\\\\turbo\\\\skip_log.lua',base..'\\\\Macros\\\\lua\\\\Turbo\\\\skip_log.lua',base..'\\\\Macros\\\\lua\\\\turbo\\\\skip_log.lua'}; local m=nil; for i=1,#paths do local f=loadfile(paths[i]); if f then local ok,r=pcall(f); if ok and type(r)=='table' and r.write_session then m=r; break end end end; if m then m.write_session([[${skipJournalIniDir}]]) end
/return

| Immediate per-skip journal append (best effort only; some installs still
| ignore /lua parse deep in the loot stack).
Sub TryImmediateSkipLogAppend(string tlSkItem, string tlSkReason, string tlSkId)
    /if (!${logSkipListForIni}) /return
    /if (!${tlSkItem.Length}) /return
    /declare _id string local ${tlSkId}
    /if (!${_id.Length}) /varset _id "0"
    /declare _nm string local ${tlSkItem.Replace[|,/]}
    /varset _nm ${_nm.Replace[~,_]}
    /varset _nm ${_nm.Replace[@,_]}
    /declare _rs string local ${tlSkReason.Replace[|,/]}
    /varset _rs ${_rs.Replace[~,_]}
    /varset _rs ${_rs.Replace[@,_]}
    /declare _src string local ${Me.Name}
    /declare _dir string local ${RefreshSkipJournalDir}
    | Use explicit loadfile path probing here. /lua parse + require('Turbo/skip_log')
    | can fail silently in macro context on some installs, which drops all
    | immediate journaling. loadfile() against known MQ paths is more reliable.
    /squelch /lua parse local mq=require('mq'); local base=(mq.TLO.MacroQuest.Path() or ''); local paths={base..'\\\\lua\\\\Turbo\\\\skip_log.lua',base..'\\\\lua\\\\turbo\\\\skip_log.lua',base..'\\\\Macros\\\\lua\\\\Turbo\\\\skip_log.lua',base..'\\\\Macros\\\\lua\\\\turbo\\\\skip_log.lua'}; local m=nil; for i=1,#paths do local f=loadfile(paths[i]); if f then local ok,r=pcall(f); if ok and type(r)=='table' and r.append_event then m=r; break end end end; if m then m.append_event([[${_nm}]],[[${_rs}]],'',[[${_id}]],'NULL',[[${_src}]],[[${_dir}]],true) end
    /if (!${SkipIniQueuedHintShown}) {
        /varset SkipIniQueuedHintShown TRUE
        /if (${showDebug}) /echo ${tlTag} \atReview\ax active - skipped items appear in \ayTurbo GUI -> Review\ax
    }
    /if (${showDebug}) /echo ${tlTag} \atskip list\ax \at${tlSkItem}\ax \ay${tlSkReason}\ax
/return

| LogSkipForCorpseItem — same Corpse.Item[slot] context as AnnounceSkipped (item is never on cursor).
| Journals item name + item ID for Skip Review. Clickable text uses MQ2LinkDB in the GUI (see below).
| Param name skipLogSlot avoids case-folding collisions with outer /for lootslot in some MQ builds.
| Do NOT require Corpse.Item[].ID — some clients report 0/false while Name/ItemLink still work; skipping then would journal nothing.
| NOTE: Corpse.Item[slot].ItemLink[CLICKABLE] cannot be forwarded through /e3bc or /lua run "..." without corruption| (binary + quotes + line length). Chat skip lines still use ItemLink for gsay; Skip Review uses LinkDB + item name.
Sub LogSkipForCorpseItem(int skipLogSlot, string tlSkItem, string tlSkReason)
    | Params MUST NOT be named itemName/reason — outer /declare itemName exists; MQ can bind ${itemName} to outer in subs (skip batch never grows; journal empty).
    /if (!${logSkipListForIni}) /return
    /declare _logName string local ${Corpse.Item[${skipLogSlot}].Name}
    /if (!${_logName.Length} || ${_logName.Equal[NULL]} || ${_logName.Equal[null]}) {
        /varset _logName ${tlSkItem}
    }
    /if (!${_logName.Length} || ${_logName.Equal[NULL]} || ${_logName.Equal[null]}) /return
    /call LogSkipListIniLine "${_logName}" "${tlSkReason}" "${Corpse.Item[${skipLogSlot}].ID}" "${_skipCorpseID}"
/return

| Flush queued skips (legacy fallback path).
| 3.8.40+: normal skips schedule per-item skip_append calls in LogSkipListIniLine.
| SkipBatch is kept only for compatibility / older paths.
Sub FlushSkipJournalBatch
    /if (!${logSkipListForIni}) /return
    /if (!${Defined[SkipBatch]}) /return
    /if (${SkipBatch.Equal[NULL]} || ${SkipBatch.Equal[null]}) /return
    /if (!${SkipBatch.Length}) /return
    | 3.8.5 guard: MQ2 /varset at line 5279 leaves SkipBatch as the 2-char
    | string "\"\"" after the first flush, so PrintSummary + Cleanup both
    | re-fire FlushSkipJournalBatch with no real records. Every valid record
    | contains '@' (name@reason@id) — absence means there's nothing to flush.
    | Reset to empty and return instead of spawning a wasted /lua run.
    /if (!${SkipBatch.Find[@]}) {
        /varset SkipBatch ""
        /return
    }
    | Debug only: batch flush traces are useful when validating journal writes,
    | but they should not spam normal loot runs.
    /if (${showDebug}) /echo [turboLoot] SkipReview: FLUSH batch len=${SkipBatch.Length} (first 120 chars follow)
    /if (${showDebug} && ${SkipBatch.Length} && ${SkipBatch.Length} <= 120) /echo [turboLoot] SkipReview: "${SkipBatch}"
    /if (${showDebug} && ${SkipBatch.Length} > 120) /echo [turboLoot] SkipReview: "${SkipBatch.Left[120]}..."
    | 3.8.40: flush in smaller chunks so long loot runs do not exceed MQ /lua arg limits.
    /declare flushMaxLen int local 900
    /declare flushRest string local ${SkipBatch}
    /declare flushChunk string local ""
    /declare flushCarry string local ""
    /declare flushRec string local ""
    /declare flushPos int local 0
    /declare flushQueued int local 0
    /declare flushChunkCount int local 0
    /if (${flushRest.Left[1].Equal[~]}) /varset flushRest ${flushRest.Right[-1]}
:skipFlushBuild
    /if (!${flushRest.Length}) /goto :skipFlushSend
    /varset flushPos ${flushRest.Find[~]}
    /if (${flushPos}) {
        /varset flushRec ~${flushRest.Left[${Math.Calc[${flushPos}-1]}]}
        /varset flushRest ${flushRest.Mid[${Math.Calc[${flushPos}+1]},32767]}
    } else {
        /varset flushRec ~${flushRest}
        /varset flushRest
    }
    /varcalc flushQueued ${flushQueued}+1
    /if (!${flushChunk.Length}) {
        /varset flushChunk ${flushRec}
        /goto :skipFlushBuild
    }
    /if (${Math.Calc[${flushChunk.Length}+${flushRec.Length}]} > ${flushMaxLen}) {
        /varset flushCarry ${flushRec}
        /goto :skipFlushSend
    }
    /varset flushChunk ${flushChunk}${flushRec}
    /goto :skipFlushBuild
:skipFlushSend
    /if (${flushChunk.Length}) {
        /varcalc flushChunkCount ${flushChunkCount}+1
        /if (${showDebug}) /echo [turboLoot] SkipReview: FLUSH chunk=${flushChunkCount} queued=${flushQueued} len=${flushChunk.Length}
        /lua run Turbo/skip_append "${flushChunk}"
        /varset flushChunk ""
        /if (${flushCarry.Length}) {
            /varset flushChunk ${flushCarry}
            /varset flushCarry ""
        }
        /if (${flushRest.Length}) /goto :skipFlushBuild
    }
    /varset SkipBatch ""
/return

| LogSkipListIniLine — schedule one top-level /lua parse append immediately.
|   Sanitize | ~ @ in names/reason.
| Link always NULL — MQ2LinkDB handles inspect in Turbo GUI.
Sub LogSkipListIniLine(string tlSkItem, string tlSkReason, string tlSkId, string tlSkCorpseId)
    | Params MUST NOT be itemName/reason — outer /declare itemName collides in MQ (${itemName} may read outer, not this arg).
    /if (!${logSkipListForIni}) /return
    /if (!${tlSkItem.Length}) /return
    /declare _id string local ${tlSkId}
    /if (!${_id.Length}) /varset _id "0"
    /declare _corpse string local ${tlSkCorpseId}
    /if (!${_corpse.Length} || ${_corpse.Equal[NULL]} || ${_corpse.Equal[null]}) /varset _corpse "0"
    /declare _nm string local ${tlSkItem.Replace[|,/]}
    /varset _nm ${_nm.Replace[~,_]}
    /varset _nm ${_nm.Replace[@,_]}
    /declare _rs string local ${tlSkReason.Replace[|,/]}
    /varset _rs ${_rs.Replace[~,_]}
    /varset _rs ${_rs.Replace[@,_]}
    /declare _src string local ${Me.Name}
    /declare _dir string local ${skipJournalIniDir.Replace[|,/]}
    /declare _qsec string local Queue_${_src}
    /if (${skipQueueNextId} < 1) /varset skipQueueNextId 1
    /ini "${skipQueueFile}" "${_qsec}" "${skipQueueNextId}" "${_nm}|${_rs}|${_id}|${_src}|${_dir}|${_corpse}"
    /varcalc skipQueueWrites ${skipQueueWrites}+1
    /varcalc skipQueueNextId ${skipQueueNextId}+1
    /ini "${skipQueueFile}" "${_qsec}" "NextID" "${skipQueueNextId}"
    /if (!${SkipIniQueuedHintShown}) {
        /varset SkipIniQueuedHintShown TRUE
        /if (${showDebug}) /echo ${tlTag} \atReview\ax active - skipped items appear in \ayTurbo GUI -> Review\ax
    }
    /if (${showDebug}) /echo ${tlTag} \atskip list\ax \at${tlSkItem}\ax \ay${tlSkReason}\ax
/return

Sub StripColorCodes(string msg)
    /declare result string local ${msg}
    | Known MQ chat color tokens (strip whole code)
    /varset result ${result.Replace[\at,]}
    /varset result ${result.Replace[\ao,]}
    /varset result ${result.Replace[\ag,]}
    /varset result ${result.Replace[\ar,]}
    /varset result ${result.Replace[\am,]}
    /varset result ${result.Replace[\au,]}
    /varset result ${result.Replace[\aw,]}
    /varset result ${result.Replace[\ax,]}
    /varset result ${result.Replace[\ay,]}
    /varset result ${result.Replace[\ap,]}
    | /echo parses any \\a + next char as a code; e3bc and KEEP can render wrong (doneTo= 3bc, INI shows odd first letter of KEEP).
    | Collapse remaining \\aX -> X for A-Z and leftover a-z (t,o,g,r,m,u,w,x,y,p already handled above).
    /varset result ${result.Replace[\aA,A]}
    /varset result ${result.Replace[\aB,B]}
    /varset result ${result.Replace[\aC,C]}
    /varset result ${result.Replace[\aD,D]}
    /varset result ${result.Replace[\aE,E]}
    /varset result ${result.Replace[\aF,F]}
    /varset result ${result.Replace[\aG,G]}
    /varset result ${result.Replace[\aH,H]}
    /varset result ${result.Replace[\aI,I]}
    /varset result ${result.Replace[\aJ,J]}
    /varset result ${result.Replace[\aK,K]}
    /varset result ${result.Replace[\aL,L]}
    /varset result ${result.Replace[\aM,M]}
    /varset result ${result.Replace[\aN,N]}
    /varset result ${result.Replace[\aO,O]}
    /varset result ${result.Replace[\aP,P]}
    /varset result ${result.Replace[\aQ,Q]}
    /varset result ${result.Replace[\aR,R]}
    /varset result ${result.Replace[\aS,S]}
    /varset result ${result.Replace[\aT,T]}
    /varset result ${result.Replace[\aU,U]}
    /varset result ${result.Replace[\aV,V]}
    /varset result ${result.Replace[\aW,W]}
    /varset result ${result.Replace[\aX,X]}
    /varset result ${result.Replace[\aY,Y]}
    /varset result ${result.Replace[\aZ,Z]}
    /varset result ${result.Replace[\aa,a]}
    /varset result ${result.Replace[\ab,b]}
    /varset result ${result.Replace[\ac,c]}
    /varset result ${result.Replace[\ad,d]}
    /varset result ${result.Replace[\ae,e]}
    /varset result ${result.Replace[\af,f]}
    /varset result ${result.Replace[\ah,h]}
    /varset result ${result.Replace[\ai,i]}
    /varset result ${result.Replace[\aj,j]}
    /varset result ${result.Replace[\ak,k]}
    /varset result ${result.Replace[\al,l]}
    /varset result ${result.Replace[\an,n]}
    /varset result ${result.Replace[\aq,q]}
    /varset result ${result.Replace[\as,s]}
    /varset result ${result.Replace[\av,v]}
    /varset result ${result.Replace[\az,z]}
/return ${result}

Sub FormatMessage(string msg, string method)
    /declare methodUpper string local ${method.Upper}
    /declare result string local ${msg}
    /if (${methodUpper.Equal[ECHO]} || ${methodUpper.Equal[E3BC]}) {
        /return ${result}
    }
    /call StripColorCodes "${result}"
    /varset result ${Macro.Return}
    /varset result ${result.Replace[[turboLoot] ,]}
    /varset result ${result.Replace[[turboLoot],]}
/return ${result}

Sub StripIniComment(string v)
    /declare result string local ${v}
    /if (${result.Find[;]}) /varset result ${result.Left[${Math.Calc[${result.Find[;]}-1]}]}
/return ${result}

Sub TrimSpaces(string v)
    /declare result string local ${v}
:trimLeft
    /if (${result.Length} && (${result.Left[1].Equal[" "]} || ${result.Left[1].Equal["	"]})) {
        /varset result ${result.Right[-1]}
        /goto :trimLeft
    }
:trimRight
    /if (${result.Length} && (${result.Right[1].Equal[" "]} || ${result.Right[1].Equal["	"]})) {
        /varset result ${result.Left[${Math.Calc[${result.Length}-1]}]}
        /goto :trimRight
    }
:trimQuotesLeft
    /if (${result.Length} && ${result.Left[1].Equal["\""]}) {
        /varset result ${result.Right[-1]}
        /goto :trimQuotesLeft
    }
:trimQuotesRight
    /if (${result.Length} && ${result.Right[1].Equal["\""]}) {
        /varset result ${result.Left[${Math.Calc[${result.Length}-1]}]}
        /goto :trimQuotesRight
    }
/return ${result}

Sub NormalizeAnnounceMethod(string v)
    | /call trims whole string; ${TrimSpaces[${v}]} splits \"t Name\" at the space into two params
    /call TrimSpaces "${v}"
    /declare result string local ${Macro.Return}
    /if (${result.Length} && ${result.Left[1].Equal[/]}) /varset result ${result.Right[-1]}
    /declare upper string local ${result.Upper}
    /if (${upper.Left[4].Equal[E3BC]}) /return e3bc
    /if (${upper.Left[4].Equal[ECHO]}) /return echo
    /if (${upper.Left[3].Equal[SAY]}) /return say
    /if ((${upper.Length} == 1 && ${upper.Equal[G]}) || ${upper.Left[4].Equal[GSAY]}) /return gsay
    /if ((${upper.Length} == 2 && ${upper.Equal[RS]}) || ${upper.Left[4].Equal[RSAY]}) /return rsay
    | t CharName or tell CharName - preserve for explicit /tell handling in Announce
    /if (${result.Length} >= 3 && (${upper.Left[2].Equal[T ]} || ${upper.Left[5].Equal[TELL ]})) /return ${result}
    /return ${result}

Sub IniGetStringOrEmpty(string section, string key)
    /declare raw string local ${Ini[${iniFile},${section},${key}]}
    /if (!${raw.Length} || ${raw.Equal[NULL]} || ${raw.Equal[Null]} || ${raw.Equal[null]}) /return ""
    /call StripIniComment "${raw}"
    /declare cleaned string local ${Macro.Return}
    /call TrimSpaces "${cleaned}"
    /declare trimmed string local ${Macro.Return}
/return ${trimmed}

Sub LoadRightClickLootSetting
    /varset allowLeftClickLoot FALSE
    /declare allowLeftClickSetting string local ${IniGetStringOrEmpty[Settings,AllowLeftClickLoot]}
    /if (${allowLeftClickSetting.Length}) {
        /declare allowLeftClickCheck string local ${allowLeftClickSetting.Upper.Replace[ ,]}
        /if (${allowLeftClickCheck.Equal[ON]} || ${allowLeftClickCheck.Equal[TRUE]} || ${allowLeftClickCheck.Equal[YES]} || ${allowLeftClickCheck.Equal[1]}) /varset allowLeftClickLoot TRUE
    }

    /declare rightClickSetting string local ${IniGetStringOrEmpty[Settings,RightClickLoot]}
    /if (${rightClickSetting.Length}) {
        /declare rcCheck string local ${rightClickSetting.Upper.Replace[ ,]}
        /if (${rcCheck.Equal[OFF]} || ${rcCheck.Equal[FALSE]} || ${rcCheck.Equal[NO]} || ${rcCheck.Equal[0]}) {
            /if (${allowLeftClickLoot}) {
                /varset RightClickLoot FALSE
                /call LogWarn "[turboLoot] Legacy left-click looting enabled by RightClickLoot=OFF and AllowLeftClickLoot=ON. This mode is less reliable."
            } else {
                /varset RightClickLoot TRUE
                /call LogWarn "[turboLoot] RightClickLoot=OFF ignored for safety. Set AllowLeftClickLoot=ON to use legacy left-click looting."
            }
        } else {
            /varset RightClickLoot TRUE
        }
    } else {
        /varset RightClickLoot TRUE
    }
/return

Sub LoadHuntingSettings
    /varset huntingTargetName ""
    /varset huntingTargets ""
    /varset huntingEnabled FALSE
    /varset huntingBeep TRUE
    /varset huntingAnnounceTo ""
    /varset HuntingAnnouncedKeys ""

    /declare rawEnabled string local ${Ini[${huntingFile},Settings,enabled]}
    /declare rawTarget string local ${Ini[${huntingFile},Settings,targetName]}
    /declare rawBeep string local ${Ini[${huntingFile},Settings,beep]}
    /declare rawAnnounce string local ${Ini[${huntingFile},Settings,announceTo]}
    /declare rawCount string local ${Ini[${huntingFile},Items,count]}
    /declare huntCount int local 0
    /declare huntIdx int local 1
    /declare rawItem string local
    /declare cleanItem string local
    /declare cleanUpper string local

    /if (${rawTarget.Length} && !${rawTarget.Equal[NULL]} && !${rawTarget.Equal[Null]} && !${rawTarget.Equal[null]}) {
        /call TrimSpaces "${rawTarget}"
        /varset huntingTargetName ${Macro.Return}
    }
    /if (${rawCount.Length} && !${rawCount.Equal[NULL]} && !${rawCount.Equal[Null]} && !${rawCount.Equal[null]}) /varset huntCount ${Int[${rawCount}]}

    /while (${huntIdx} <= ${huntCount}) {
        /varset rawItem ${Ini[${huntingFile},Items,${huntIdx}]}
        /if (${rawItem.Length} && !${rawItem.Equal[NULL]} && !${rawItem.Equal[Null]} && !${rawItem.Equal[null]}) {
            /call TrimSpaces "${rawItem}"
            /varset cleanItem ${Macro.Return}
            /if (${cleanItem.Length}) {
                /varset cleanUpper ${cleanItem.Upper}
                /if (!${huntingTargets.Find[|${cleanUpper}|]}) /varset huntingTargets "${huntingTargets}|${cleanUpper}|"
                /if (!${huntingTargetName.Length}) /varset huntingTargetName ${cleanItem}
            }
        }
        /varcalc huntIdx ${huntIdx} + 1
    }

    | Backward compatibility for single-target runtime files.
    /if (!${huntingTargets.Length} && ${huntingTargetName.Length}) {
        /varset cleanUpper ${huntingTargetName.Upper}
        /varset huntingTargets "|${cleanUpper}|"
    }

    /declare enabledUpper string local ${rawEnabled.Upper.Replace[ ,]}
    /if (${enabledUpper.Equal[TRUE]} || ${enabledUpper.Equal[ON]} || ${enabledUpper.Equal[1]} || ${enabledUpper.Equal[YES]}) /varset huntingEnabled TRUE

    /declare beepUpper string local ${rawBeep.Upper.Replace[ ,]}
    /if (${beepUpper.Equal[FALSE]} || ${beepUpper.Equal[OFF]} || ${beepUpper.Equal[0]} || ${beepUpper.Equal[NO]}) /varset huntingBeep FALSE

    /if (${rawAnnounce.Length} && !${rawAnnounce.Equal[NULL]} && !${rawAnnounce.Equal[Null]} && !${rawAnnounce.Equal[null]}) {
        /call TrimSpaces "${rawAnnounce}"
        /varset huntingAnnounceTo ${Macro.Return}
    }

    /if (${huntingEnabled} && ${huntingTargets.Length}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[HUNTING] Watch list loaded: ${huntingTargets}"
    }
/return

Sub CheckHuntingItem(int huntSlot, string huntName)
    /if (!${huntingEnabled} || !${huntingTargets.Length} || !${huntName.Length}) /return
    /if (!${huntingTargets.Find[|${huntName.Upper}|]}) /return

    /declare huntKey string local ${Target.ID}:${huntName}
    /if (${HuntingAnnouncedKeys.Length} > 2000) /varset HuntingAnnouncedKeys ""
    /if (${HuntingAnnouncedKeys.Length} && ${HuntingAnnouncedKeys.Find[|${huntKey}|]}) /return
    /varset HuntingAnnouncedKeys "${HuntingAnnouncedKeys}|${huntKey}|"

    /declare huntLink string local ${Corpse.Item[${huntSlot}].ItemLink[CLICKABLE]}
    /if (!${huntLink.Length} || ${huntLink.Equal[NULL]} || ${huntLink.Equal[null]}) /varset huntLink ${huntName}

    /declare huntMethod string local ${huntingAnnounceTo}
    /if (!${huntMethod.Length} || ${huntMethod.Equal[NULL]} || ${huntMethod.Equal[null]}) /varset huntMethod ${announceSkippedMethod}
    /if (!${huntMethod.Length} || ${huntMethod.Equal[NULL]} || ${huntMethod.Equal[null]}) /varset huntMethod ${announceDefaultTo}
    /call NormalizeAnnounceMethod "${huntMethod}"
    /varset huntMethod ${Macro.Return}
    /if (!${huntMethod.Length}) /varset huntMethod echo

    /call Announce "${huntMethod}" "${tlTag} \ay[HUNTING]\aw Found ${huntLink} \at(ID: ${Target.ID})"
    /if (${huntingBeep}) /beep

    /ini "${huntingFile}" "Alert" "active" "TRUE"
    /ini "${huntingFile}" "Alert" "itemName" "${huntName}"
    /ini "${huntingFile}" "Alert" "foundAt" "${Time}"
    /ini "${huntingFile}" "Alert" "corpseId" "${Target.ID}"
    /ini "${huntingFile}" "Alert" "source" "${Me.Name}"
/return


Sub AnnounceBankSell(string msg)
    /if (!${Defined[announceBankSell]} || !${announceBankSell.Length} || ${announceBankSell.Equal[NULL]} || ${announceBankSell.Equal[null]}) {
        /varset announceBankSell "echo"
    }
    /call NormalizeAnnounceMethod "${announceBankSell}"
    /declare bankSellMethod string local ${Macro.Return}
    /if (!${bankSellMethod.Length}) /varset bankSellMethod "echo"
    /declare bankSellUpper string local ${bankSellMethod.Upper.Replace[ ,]}
    /if (${bankSellUpper.Equal[0]} || ${bankSellUpper.Equal[OFF]}) /return
    /if (${bankSellMethod.Upper.Equal[ECHO]} || ${bankSellMethod.Upper.Equal[E3BC]}) {
        | /squelch hides the "command received:/e3bc ..." spam while still outputting the message.
        /docommand /squelch /${bankSellMethod} ${msg}
    } else /if (${bankSellMethod.Length} >= 3 && (${bankSellMethod.Left[2].Upper.Equal[T ]} || ${bankSellMethod.Left[5].Upper.Equal[TELL ]})) {
        /declare bankTellTarget string local
        /if (${bankSellMethod.Left[2].Upper.Equal[T ]}) {
            /varset bankTellTarget ${TrimSpaces[${bankSellMethod.Mid[3,500]}]}
        } else {
            /varset bankTellTarget ${TrimSpaces[${bankSellMethod.Mid[6,500]}]}
        }
        /if (${bankTellTarget.Length}) {
            /call FormatMessage "${msg}" tell
            /declare formattedMsg string local ${Macro.Return}
            /tell ${bankTellTarget} ${formattedMsg}
        }
    } else {
        /call FormatMessage "${msg}" "${bankSellMethod}"
        /declare formattedMsg string local ${Macro.Return}
        /docommand /${bankSellMethod} ${formattedMsg}
    }
/return

Sub AnnounceBankSellProgress(string msg)
    /if (${announceBankSellProgress} != 0) {
        /call AnnounceBankSell "${msg}"
    } else /if (${showDebug}) {
        /echo [turboLoot] DBG(progress) ${msg}
    }
/return

Sub AnnounceBankSellPerItem(string msg)
    /call AnnounceBankSell "${msg}"
/return

Sub AnnounceSkipped(string key, string msg)
    | Raised from 2000 (~40 keys) to 12000 (~200 keys). A full wipe mid-pull
    | re-emitted [ANNOUNCE] for items still on corpses the loop revisited.
    /if (${SkippedAnnouncedKeys.Length} > 12000) /varset SkippedAnnouncedKeys ""
    /if (${SkippedAnnouncedKeys.Length} && ${SkippedAnnouncedKeys.Find[|${key}|]}) /return
    /varset SkippedAnnouncedKeys "${SkippedAnnouncedKeys}|${key}|"
    /declare corpseIdFromKey int local 0
    /declare itemNameFromKey string local
    /if (${key.Find[:]}) {
        /varset corpseIdFromKey ${key.Left[${Math.Calc[${key.Find[:]}-1]}]}
        /varset itemNameFromKey ${key.Right[-${key.Find[:]}]}
        /if (${itemNameFromKey.Find[:]}) {
            /varset itemNameFromKey ${itemNameFromKey.Right[-${itemNameFromKey.Find[:]}]}
        }
    }
    /varcalc itemsSkipped ${itemsSkipped}+1
    /declare hasItemLink bool local FALSE
    /if (${msg.Find[ItemLink]} || ${msg.Find[\ax]} || ${msg.Length} > 200) {
        /varset hasItemLink TRUE
    }
    /if (!${hasItemLink}) {
        /varset msg ${msg.Replace[NULL,${itemNameFromKey}]}
        /varset msg ${msg.Replace[null,${itemNameFromKey}]}
    }
    | Structured TurboGear handoff for corpse-left loot messages. Chat still
    | prints below, but linked-needs reliability should not depend on parsing it.
    | Call /tgearbg (looters typically run bg only) and /tgear (UI boxes). Pass
    | corpse id so Go-loot buttons work on the driver panel.
    /if (${itemNameFromKey.Length} && (${msg.Find[SKIP]} || ${msg.Find[ANNOUNCE]})) {
        /squelch /tgearbg lootseenquiet "${itemNameFromKey}" 0 ${_skipCorpseID}
        /squelch /tgear lootseenquiet "${itemNameFromKey}" 0 ${_skipCorpseID}
    }
    /declare skipMethodUpper string local ${announceSkippedMethod.Upper}
    /declare effectiveMethod string local ${announceSkippedMethod}
    /if (!${effectiveMethod.Length}) /varset effectiveMethod echo
    /if ((${skipMethodUpper.Equal[GSAY]} || ${skipMethodUpper.Equal[G]}) && !${Me.Grouped}) {
        /varset effectiveMethod echo
    }
    /if ((${skipMethodUpper.Equal[GSAY]} || ${skipMethodUpper.Equal[G]}) && ${Me.Grouped}) {
        /declare groupMsg string local ${msg}
        /varset groupMsg ${groupMsg.Replace[\at,]}
        /varset groupMsg ${groupMsg.Replace[\ao,]}
        /varset groupMsg ${groupMsg.Replace[\ag,]}
        /varset groupMsg ${groupMsg.Replace[\ar,]}
        /varset groupMsg ${groupMsg.Replace[\am,]}
        /varset groupMsg ${groupMsg.Replace[\au,]}
        /varset groupMsg ${groupMsg.Replace[\aw,]}
        /varset groupMsg ${groupMsg.Replace[\ay,]}
        /varset groupMsg ${groupMsg.Replace[\ap,]}
        /varset groupMsg ${groupMsg.Replace[[turboLoot] ,]}
        /varset groupMsg ${groupMsg.Replace[[turboLoot],]}
        /call GsayOnce "${key}" "${groupMsg}"
    } else {
        /call FormatMessage "${msg}" "${effectiveMethod}"
        /declare formattedMsg string local ${Macro.Return}
        /docommand /${effectiveMethod} ${formattedMsg}
    }
    | AnnounceSkipped handles only the human-readable channel output above.
    | Review refresh comes from the journal writer/poller path, not a chat broadcast.
/return

Sub GsayOnce(string key, string msg)
    /if (!${Me.Grouped}) /return
    /if (${SkipGsayKeys.Length} > 2000) /varset SkipGsayKeys ""
    /if (${SkipGsayKeys.Length} && ${SkipGsayKeys.Find[|${key}|]}) /return
    /varset SkipGsayKeys "${SkipGsayKeys}|${key}|"
    /gsay ${msg}
/return


Sub PerfLogLine(string msg)
    /if (!${lootPerfLog}) /return
    /squelch /lua parse local mq=require('mq'); local base=tostring(mq.TLO.MacroQuest.Path()); if base=='nil' then base='.' end; local sep='/'; if base:match('[\\/]$') then sep='' end; local cfg=base..sep..'Config'; local logdir=cfg..sep..'Turbo'..sep..'logs'; local path=logdir..sep..'TurboLoot_perf_${Me.CleanName}.txt'; local f=io.open(path,'a'); if not f then path=cfg..sep..'TurboLoot_perf_${Me.CleanName}.txt'; f=io.open(path,'a') end; if f then f:write(os.date('%Y-%m-%d %H:%M:%S')..' | '..[[${msg}]]..'\n'); f:close() else mq.cmd('/echo [turboLoot] PERF LOG WRITE FAILED: '..path) end
/return


Sub PerfLogPath
    /if (!${lootPerfLog}) /return
    | File-only perf logging — no chat echo (path is in Config\Turbo\logs, with legacy Config fallback).
/return


Sub PrintPerfSummary
    /if (!${lootPerfLog}) /return
    /if (${lootPerfLogged}) /return
    /varset lootPerfLogged TRUE
    /call PerfLogPath
    /call PerfLogLine "Char=${Me.CleanName} Zone=${Zone.ShortName} Runtime=${Macro.RunTime}s Corpses=${corpsesProcessed} Looted=${itemsLooted} Skipped=${itemsSkipped} Ignored=${itemsIgnored} Destroyed=${itemsDestroyed}"
    /call PerfLogLine "loops main=${perfMainLoops} item=${perfItemLoops} close=${perfCloseLoops} corpsefix=${perfCorpsefixCalls} corpseRefresh=${perfTargetRefreshes}"
    /call PerfLogLine "waits lootWindow=${perfLootWindowWaits} item=${perfItemWaits} emptyCorpse=${perfEmptyCorpseWaits} cursorClear=${perfCursorClearWaits} move=${perfMoveLoops}"
    /call PerfLogLine "retries openFail=${perfOpenFailures} reopen=${perfReopenAttempts} tooFar=${perfTooFarRetries} moveFail=${perfMoveFailures}"
    /call PerfLogLine "checks abort=${perfAbortChecks} hunting=${perfHuntingChecks} iniLookups=${perfIniLookups} skipQueueRows=${skipQueueWrites}"
    /call PerfLogLine "stall stuck=${perfStuckEvents} longItemWaits=${perfLongItemWaits} maxItemWait=${perfMaxItemWaitTries} maxEmptyCorpseWait=${perfMaxEmptyCorpseWaits} maxMoveTries=${perfMaxMoveTries}"
    /call PerfLogLine "settings moveLoopDelay=${moveLoopDelay} cursorClearDelay=${cursorClearDelay} lootWindowDelay=${lootWindowDelay} itemLootWaitDelay=${itemLootWaitDelay} useNav=${useNavForCorpses} rightClick=${RightClickLoot} allowLeftClick=${allowLeftClickLoot}"
/return


| ---------------------------------------------------------------------
| PRINT SUMMARY (telemetry)
| ---------------------------------------------------------------------
Sub PrintSummary
    /call FlushSkipJournalBatch
    /if (${announceSummary} == 0) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] SkipReview queue writes this run: ${skipQueueWrites} item rows, ${Math.Calc[${skipQueueWrites}*2]} /ini writes"
        /if (${minFreeSlotsDuringLoot} <= ${announceInventoryAlmostFull}) {
            /echo ${tlTag} \arWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})
        } else /if (${minFreeSlotsDuringLoot} <= ${Math.Calc[2 * ${announceInventoryAlmostFull}]}) {
            /echo ${tlTag} \aoWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})
        } else /if (${minFreeSlotsDuringLoot} <= ${Math.Calc[3 * ${announceInventoryAlmostFull}]}) {
            /echo ${tlTag} \ayWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})
        }
        /call PrintPerfSummary
        /return
    }
    
    /call Announce "${announceSummaryMethod}" "${tlTag} \agLooted: ${itemsLooted}"
    /call Announce "${announceSummaryMethod}" "${tlTag} \arDestroyed: ${itemsDestroyed}"
    /call Announce "${announceSummaryMethod}" "${tlTag} \awSkipped: ${itemsSkipped} Ignored: ${itemsIgnored}"
    /call Announce "${announceSummaryMethod}" "${tlTag} \aoDuration: ${Macro.RunTime}s"
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] SkipReview queue writes this run: ${skipQueueWrites} item rows, ${Math.Calc[${skipQueueWrites}*2]} /ini writes"
    /if (${minFreeSlotsDuringLoot} <= ${announceInventoryAlmostFull}) {
        /call Announce "${announceSummaryMethod}" "${tlTag} \arWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})"
    } else /if (${minFreeSlotsDuringLoot} <= ${Math.Calc[2 * ${announceInventoryAlmostFull}]}) {
        /call Announce "${announceSummaryMethod}" "${tlTag} \aoWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})"
    } else /if (${minFreeSlotsDuringLoot} <= ${Math.Calc[3 * ${announceInventoryAlmostFull}]}) {
        /call Announce "${announceSummaryMethod}" "${tlTag} \ayWARNING: ${minFreeSlotsDuringLoot} spaces remaining (threshold: ${announceInventoryAlmostFull})"
    }
    /if (${showDebug} && ${logSkipListForIni} && ${itemsSkipped} > 0) /echo ${tlTag} \atReview:\ax \ay${itemsSkipped}\ax item(s) skipped this run - review in \atTurbo GUI -> Review\ax or \at/lua run Turbo/skips_show\ax
    /call PrintPerfSummary
/return

| ---------------------------------------------------------------------
| PRINT UNLOAD SUMMARY (BANK -> TRIBUTE -> SELL)
| ---------------------------------------------------------------------
Sub PrintUnloadSummary
    /declare soldPP int local ${Int[${Math.Calc[${sellTotalCopper}/1000]}]}
    /declare soldGP int local ${Int[${Math.Calc[(${sellTotalCopper}%1000)/100]}]}
    /declare soldSP int local ${Int[${Math.Calc[(${sellTotalCopper}%100)/10]}]}
    /declare soldCP int local ${Int[${Math.Calc[${sellTotalCopper}%10]}]}

    /call AnnounceBankSell "${tlTag} \au[\ao===== \amTURBOUNLOAD \ao=====\au]\ax"
    /call AnnounceBankSell "${tlTag} \ap[BANKED TOTAL]\aw --> \ag${itemsBanked}"
    /call AnnounceBankSell "${tlTag} \ay[TRIBUTED TOTAL]\aw --> \ag${tributeItemsMoved}\aw (\at+${tributePointsGained}\aw TP)"
    /call AnnounceBankSell "${tlTag} \ag[SOLD TOTAL]\aw --> \ag${itemsSold}\aw (\ag${soldPP}\awpp \ag${soldGP}\awgp \ag${soldSP}\awsp \ag${soldCP}\awcp)"
/return

| ---------------------------------------------------------------------
| TURBO DOCTOR (read-only diagnostics)
| ---------------------------------------------------------------------
Sub TurboDoctor
    /declare doctorTag string local \at[TurboDoctor]\ax
    /declare tlVersion string local
    /declare profile string local ${MQ2Mono.Query[e3,TurboLootIni]}
    /declare cfgIni string local "../Config/turboloot.ini"
    /declare macIni string local "../Macros/turboloot.ini"
    /declare activeIni string local ""

    /if (!${profile.Length} || ${profile.Equal[NULL]} || ${profile.Equal[null]}) /varset profile "turboloot.ini"
    /call TurboLootVersion
    /varset tlVersion ${Macro.Return}

    /echo ${doctorTag} \au===== TurboLoot Doctor: quick check =====\ax
    /echo ${doctorTag} \awVersion: \agTurboLoot ${tlVersion}\aw Char: \ag${Me.Name}\aw (\ay${Me.Class.ShortName}\aw) Zone: \at${Zone.ShortName}\ax

    /if (${profile.NotEqual[turboloot.ini]}) {
        /if (${Ini.File[../Config/${profile}].Exists}) {
            /varset activeIni "../Config/${profile}"
        } else /if (${Ini.File[../Macros/${profile}].Exists}) {
            /varset activeIni "../Macros/${profile}"
        }
    }

    /if (!${activeIni.Length}) {
        /if (${Ini.File[${cfgIni}].Exists}) {
            /varset activeIni ${cfgIni}
        } else /if (${Ini.File[${macIni}].Exists}) {
            /varset activeIni ${macIni}
        }
    }

    /if (${activeIni.Length}) {
        /echo ${doctorTag} \awActive INI for \ag${Me.Name}\aw: \ay${profile}\aw -> \ag${activeIni}\ax
    } else {
        /echo ${doctorTag} \arINI missing.\aw Checked \ay../Config/${profile}\aw, \ay../Macros/${profile}\aw, default Config/Macros.\ax
    }

    /echo ${doctorTag} \aw--- \atLoot rules snapshot \aw(from INI; same as old startup chat) ---\ax
    /echo ${doctorTag} \awTips:\ax Only \at[ItemLimits]\ax + wildcards/high-value/stackable drive looting.
    /echo ${doctorTag} \awTips:\ax \atKEEP\ax/\at#\ax keep; \atSELL\ax/\atBANK\ax/\atTRIBUTE\ax/\atDESTROY\ax act; \atIGNORE\ax skips; \atANNOUNCE\ax skips + announces.
    /if (${activeIni.Length}) {
        /if (!${Defined[iniFile]}) /declare iniFile string global
        /varset iniFile ${activeIni}
        /if (!${Defined[wildcardPrefixes]}) /declare wildcardPrefixes string outer ""
        /if (!${Defined[wildcardFirstChars]}) /declare wildcardFirstChars string outer ""
        /call LoadWildcards
        /if (${wildcardPrefixes.Length}) {
            /echo ${doctorTag} \awWildcards active:\ax ${wildcardPrefixes}
        } else {
            /echo ${doctorTag} \awWildcards:\ax \ay(none loaded — check [Wildcards] in INI)\ax
        }
        /declare docAnn string local ${Ini[${activeIni},Settings,announceDefaultTo]}
        /if (${docAnn.Length} && !${docAnn.Equal[NULL]} && !${docAnn.Equal[null]}) {
            /echo ${doctorTag} \awannounceDefaultTo:\ax ${docAnn}
        }
        /declare docHide string local ${Ini[${activeIni},Settings,corpseHideMode]}
        /if (${docHide.Length} && !${docHide.Equal[NULL]} && !${docHide.Equal[null]}) {
            /echo ${doctorTag} \awcorpseHideMode (INI):\ax ${docHide}
        } else {
            /echo ${doctorTag} \awcorpseHideMode (INI):\ax \ay(empty — macro defaults LOOTED; set ALL|GROUP|SELF|LOOTED|OFF)\ax
        }
    }

    /echo ${doctorTag} \awFull DBG announce + thresholds:\ax mqlog with \atlogToFile=ON\ax, \atlogLevel=DEBUG\ax, then run loot once.

    /echo ${doctorTag} \awE3 vars: Turbo=\ay${MQ2Mono.Query[e3,Turbo]}\aw CombatLoot=\ay${MQ2Mono.Query[e3,CombatLoot]}\aw LootAll=\ay${MQ2Mono.Query[e3,GrpLootAll]}\ax
    /echo ${doctorTag} \awE3 vars: Looter=\ay${MQ2Mono.Query[e3,GrpMainLooter]}\aw Radius=\ay${MQ2Mono.Query[e3,LootRadius]}\ax

    /echo ${doctorTag} \awCore: TurboLoot ${If[${Ini.File[../Macros/TurboLoot.mac].Exists},\agOK,\arMISSING]}\aw, Auto-Loot ${If[${Ini.File[../Macros/Turbo.mac].Exists},\agOK,\arMISSING]}\ax
    /echo ${doctorTag} \awTools: TurboGive ${If[${Ini.File[../Macros/TurboGive.mac].Exists},\agOK,\arMISSING]}\aw, TurboKey ${If[${Ini.File[../Macros/TurboKey.mac].Exists},\agOK,\arMISSING]}\ax
    /echo ${doctorTag} \awHelpers: XTanks ${If[${Ini.File[../Macros/turbo_xtar_heal.mac].Exists},\agOK,\arMISSING]}\aw, Reclaim/Lotto ${If[${Ini.File[../lua/turbo_reclaim_lotto.lua].Exists},\agOK,\arMISSING]}\aw, CollectDC ${If[${Ini.File[../lua/turbo_collect_dc.lua].Exists},\agOK,\arMISSING]}\ax
    /echo ${doctorTag} \awLua UI: ${If[${Ini.File[../lua/Turbo/init.lua].Exists},\ag../lua/Turbo/init.lua OK,\ar../lua/Turbo/init.lua MISSING]}\ax

    /echo ${doctorTag} \awGroup: grouped=\ay${Me.Grouped}\aw members=\ay${Group.Members}\aw Raid members=\ay${Raid.Members}\ax
    /echo ${doctorTag} \awFull install/version scan: \ag/lua run Turbo doctor\ax

    /if (${Window[InventoryWindow].Open} || ${Window[BigBankWnd].Open} || ${Window[MerchantWnd].Open} || ${Window[TributeMasterWnd].Open}) {
        /echo ${doctorTag} \ayOpen windows:\aw Inventory=\ay${Window[InventoryWindow].Open}\aw Bank=\ay${Window[BigBankWnd].Open}\aw Merchant=\ay${Window[MerchantWnd].Open}\aw Tribute=\ay${Window[TributeMasterWnd].Open}\ax
    }
    /echo ${doctorTag} \au===== Doctor complete: read-only, no changes made. =====\ax
/return

||| ---------------------------------------------------------------------
||| DISPLAY DRY RUN SELL ITEM (mirrors SellItem output format)
||| ---------------------------------------------------------------------
Sub DisplayDryRunSellItem(int bagNum, int slotNum, string itemName, string classification)
    /declare sellItemLink string local
    /declare stackCount int local 1
    /declare perItemCopper int local 0
    /declare totalStackCopper int local 0
    /declare p int local 0
    /declare g int local 0
    /declare s int local 0
    /declare c int local 0
    
    /if (${bagNum} == 0) {
        | Main inventory slot (23-32)
        /varset sellItemLink ${Me.Inventory[${slotNum}].ItemLink[CLICKABLE]}
        /if (${Me.Inventory[${slotNum}].Stackable}) /varset stackCount ${Me.Inventory[${slotNum}].Stack}
        /varset perItemCopper ${Me.Inventory[${slotNum}].Value}
    } else {
        | Bag slot
        /varset sellItemLink ${Me.Inventory[pack${bagNum}].Item[${slotNum}].ItemLink[CLICKABLE]}
        /if (${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stackable}) /varset stackCount ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Stack}
        /varset perItemCopper ${Me.Inventory[pack${bagNum}].Item[${slotNum}].Value}
    }
    
    /if (!${sellItemLink.Length} || ${sellItemLink.Equal[NULL]}) {
        /varset sellItemLink ${itemName}
    }
    
    /if (${perItemCopper} <= 0) /return
    
    /varset totalStackCopper ${Math.Calc[${perItemCopper}*${stackCount}]}
    
    /varset p ${Int[${Math.Calc[${totalStackCopper}/1000]}]}
    /varset g ${Int[${Math.Calc[(${totalStackCopper}%1000)/100]}]}
    /varset s ${Int[${Math.Calc[(${totalStackCopper}%100)/10]}]}
    /varset c ${Int[${Math.Calc[${totalStackCopper}%10]}]}
    
    /call AnnounceBankSell "${tlTag} ${classification} ${sellItemLink} \aw(x${stackCount}) \awfor \ag${p}pp ${g}gp ${s}sp ${c}cp\ag"
    
    /varcalc dryRunSellCount ${dryRunSellCount}+1
    /varcalc dryRunSellTotalCopper ${dryRunSellTotalCopper}+${totalStackCopper}
/return

||| ---------------------------------------------------------------------
||| PRINT DRY RUN SELL SUMMARY
||| ---------------------------------------------------------------------
Sub PrintDryRunSellSummary
    /declare soldPP int local ${Int[${Math.Calc[${dryRunSellTotalCopper}/1000]}]}
    /declare soldGP int local ${Int[${Math.Calc[(${dryRunSellTotalCopper}%1000)/100]}]}
    /declare soldSP int local ${Int[${Math.Calc[(${dryRunSellTotalCopper}%100)/10]}]}
    /declare soldCP int local ${Int[${Math.Calc[${dryRunSellTotalCopper}%10]}]}
    
    /if (${dryRunSellCount} > 0) {
        /call AnnounceBankSell "${tlTag} \agTotal: ${dryRunSellCount} items, \ag${soldPP}pp ${soldGP}gp ${soldSP}sp ${soldCP}cp"
    } else {
        /call AnnounceBankSell "${tlTag} \aoNo items would be sold."
        /call AnnounceBankSell "${tlTag} \awCheck your \ayturboLoot.ini \aw[ItemLimits] section."
    }
    
    /call AnnounceBankSell "${tlTag} \au-------------------------------------------------------"
    /call AnnounceBankSell "${tlTag} \at==== \ayCURRENT SETTINGS \at===="
    /call AnnounceBankSell "${tlTag} \aw  SellUnlistedStackable : ${If[${enableSellStackable},\agON,\arOFF]}"
    /call AnnounceBankSell "${tlTag} \aw  SellUnlistedItems     : ${If[${enableSellUnlistedValue},\agON,\arOFF]}"
    /call AnnounceBankSell "${tlTag} \aw  SellWildcards         : ${If[${sellWildcards},\agON,\arOFF]}"
    /if (${wildcardPrefixes.Length}) {
        /call AnnounceBankSell "${tlTag} \aw  Active wildcards      : \ay${wildcardPrefixes}"
    } else {
        /call AnnounceBankSell "${tlTag} \aw  Active wildcards      : \ao(none)"
    }
    /call AnnounceBankSell "${tlTag} \aw  INI file              : \at${iniFile}"
    /call AnnounceBankSell "${tlTag} \au======================================================="
    /call AnnounceBankSell "${tlTag} \aoDRY RUN COMPLETE - Run \ag/mac turboloot sell\ao (without 'dryrun') to execute"
    /call AnnounceBankSell "${tlTag} \au======================================================="
/return

| ---------------------------------------------------------------------
| PRINT COMMANDS / TOGGLES (help)
| ---------------------------------------------------------------------
Sub GetHelpAnnounceMethod
    /declare method string local "echo"
    /declare cfgIni string local "../Config/turboloot.ini"
    /declare macIni string local "../Macros/turboloot.ini"
    /declare chosenIni string local ""

    /if (${Ini.File[${cfgIni}].Exists}) {
        /varset chosenIni ${cfgIni}
    } else /if (${Ini.File[${macIni}].Exists}) {
        /varset chosenIni ${macIni}
    }

    /if (${chosenIni.Length}) {
        /declare raw string local ${Ini[${chosenIni},Settings,announceDefaultTo]}
        /if (${raw.Length} && !${raw.Equal[NULL]} && !${raw.Equal[Null]} && !${raw.Equal[null]}) {
            /call StripIniComment "${raw}"
            /declare cleaned string local ${Macro.Return}
            /call TrimSpaces "${cleaned}"
            /varset cleaned ${Macro.Return}
            /if (${cleaned.Length}) {
                /call NormalizeAnnounceMethod "${cleaned}"
                /declare normalized string local ${Macro.Return}
                /if (${normalized.Length}) /varset method ${normalized}
            }
        }
    }

    /declare methodUpper string local ${method.Upper.Replace[ ,]}
    /if (${methodUpper.Equal[0]} || ${methodUpper.Equal[OFF]}) /varset method "echo"
/return ${method}

Sub HelpAnnounce(string method, string msg)
    /call NormalizeAnnounceMethod "${method}"
    /declare m string local ${Macro.Return}
    /if (!${m.Length}) /varset m "echo"
    /declare mUpper string local ${m.Upper}

    /if (${mUpper.Equal[ECHO]} || ${mUpper.Equal[E3BC]}) {
        | Keep colors in MQ window / E3BC, and squelch command spam
        /docommand /squelch /${m} ${msg}
    } else {
        | Strip MQ color codes for chat channels
        /call StripColorCodes "${msg}"
        /declare plain string local ${Macro.Return}
        /docommand /${m} ${plain}
    }
/return

Sub PrintCommandsAndToggles
    /declare helpMethod string local "echo"
    /declare tlVersion string local
    /call GetHelpAnnounceMethod
    /if (${Macro.Return.Length}) /varset helpMethod ${Macro.Return}
    /if (!${helpMethod.Length}) /varset helpMethod "echo"
    /call TurboLootVersion
    /varset tlVersion ${Macro.Return}

    /call HelpAnnounce "${helpMethod}" "\au<<< \ar--------------- \atTurboLoot Commands \ar--------------- \au>>>\ax"
    /call HelpAnnounce "${helpMethod}" "\awVersion: \ag${tlVersion}\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\at==== \aySUITE MAP \at====\ax"
    /call HelpAnnounce "${helpMethod}" "\aw  \agTurboLoot.mac\ax — loot/sell/bank/tribute/destroy by INI rules\ax"
    /call HelpAnnounce "${helpMethod}" "\aw  \ag/lua run Turbo\ax or \ag/mac Turbo\ax — auto-loot controller and looter picker\ax"
    /call HelpAnnounce "${helpMethod}" "\aw  \agTurboKey.mac\ax — tag cursor item into turboloot.ini\ax"
    /call HelpAnnounce "${helpMethod}" "\aw  \agTurboGive.mac\ax — share/collect/hand items and coin between characters\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\at==== \ayLOOT \at====\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot\ax — loot nearby corpses (default mode)\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot go <corpseId> <Item Name>\ax — TurboGear Go-loot one item\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\at==== \aySELL / BANK / TRIBUTE \at====\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot sell\ax — sell items marked \agSELL\aw in inventory\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot report\ax \aw(or \agsell dryrun\aw)\ax — preview sell, no changes\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ap/mac turboloot bank\ax — bank items marked \apBANK\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ay/mac turboloot tribute\ax — tribute items marked \ayTRIBUTE\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ar/mac turboloot destroy\ax — destroy items marked \arDESTROY\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot unload\ax — \apBANK\aw -> \ayTRIBUTE\aw -> \agSELL\aw -> \arDESTROY\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turboloot doctor\ax — read-only diagnostics (INI, E3 vars, helper macros)\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\at==== \ayITEM RULES \at====\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/mac turbokey RULE\ax — add cursor item to INI (\ag/mac turbokey help\aw for rules)\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\at==== \ayINI / SETTINGS \at====\ax"
    /call HelpAnnounce "${helpMethod}" "\aw    \ag/turbosnapshot\ax — active settings + descriptions (Lua GUI must be running)\ax"
    /call HelpAnnounce "${helpMethod}" "\aw \ax"
    /call HelpAnnounce "${helpMethod}" "\aw  \aohttps://github.com/drel-git/TurboLoot\ax"
/return

| ---------------------------------------------------------------------
| Done-looting: grouped = any channel; solo = echo, t/tell, say, rsay (not gsay/e3bc)
| ---------------------------------------------------------------------
Sub ShouldAnnounceDoneLooting
    | Returns 1/0 for /if (${Macro.Return})- TRUE/FALSE strings are unreliable here
    /if (!${DidLoot}) /return 0
    /if (${Me.Grouped}) /return 1
    /call NormalizeAnnounceMethod "${announceDoneLootingTo}"
    /declare doneLootMethod string local ${Macro.Return}
    | Tab between t/tell and name breaks Left[2]==\"T \" matching; normalize
    /varset doneLootMethod ${doneLootMethod.Replace[	, ]}
    /declare doneU string local ${doneLootMethod.Upper}
    /if (${doneLootMethod.Length} >= 3 && ${doneLootMethod.Left[2].Upper.Equal[T ]}) /return 1
    /if (${doneLootMethod.Length} >= 6 && ${doneLootMethod.Left[5].Upper.Equal[TELL ]}) /return 1
    | Solo: MQ /echo + in-game say/rsay; gsay/e3bc still need Me.Grouped
    /if (${doneU.Equal[ECHO]}) /return 1
    /if (${doneU.Equal[SAY]}) /return 1
    /if (${doneU.Equal[RSAY]} || (${doneLootMethod.Length} == 2 && ${doneU.Equal[RS]})) /return 1
/return 0

| ---------------------------------------------------------------------
| ANNOUNCE (logging wrapper)
| ---------------------------------------------------------------------
Sub Announce(string method, string msg)
    /call NormalizeAnnounceMethod "${method}"
    /declare methodTrim string local ${Macro.Return}
    /if (!${methodTrim.Length}) /varset methodTrim "echo"
    | t<TAB>Name breaks tell detection (INI / paste)
    /varset methodTrim ${methodTrim.Replace[	, ]}
    /declare mUpper string local ${methodTrim.Upper}
    /declare final string local ${msg}

    /if (${mUpper.Equal[ECHO]} || ${mUpper.Equal[E3BC]}) {
        | /squelch hides the "command received:/e3bc ..." spam while still outputting the message.
        /docommand /squelch /${methodTrim} ${final}
        /return
    }

    | Explicit /tell handling for t CharName or tell CharName (avoids /docommand parse issues)
    /declare tellTarget string local
    /if (${methodTrim.Length} >= 3 && ${methodTrim.Left[2].Upper.Equal[T ]}) {
        /varset tellTarget ${TrimSpaces[${methodTrim.Mid[3,500]}]}
    } else /if (${methodTrim.Length} >= 6 && ${methodTrim.Left[5].Upper.Equal[TELL ]}) {
        /varset tellTarget ${TrimSpaces[${methodTrim.Mid[6,500]}]}
    }
    /if (${tellTarget.Length}) {
        /call FormatMessage "${final}" tell
        /declare formatted string local ${Macro.Return}
        /tell ${tellTarget} ${formatted}
        /return
    }

    | /call avoids ${FormatMessage[${final},x]} splitting on commas/spaces inside ${final}
    /call FormatMessage "${final}" "${methodTrim}"
    /declare formatted string local ${Macro.Return}
    /docommand /${methodTrim} ${formatted}
/return

Sub OnExit
    /call Cleanup
/return

| ---------------------------------------------------------------------
| DOOR HELP: open nearby doors (best-effort)
| ---------------------------------------------------------------------
Sub TryOpenNearbyDoor(int radius)
    /declare r int local ${radius}
    /if (${r} <= 0) /varset r 35

    /if (${SpawnCount[door radius ${r}]} == 0) /return FALSE

    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Door nearby (within ${r}) - attempting to open..."
    /doortarget
    /delay 2

    /if (${DoorTarget.ID}) {
        /click left door
        /delay 10
        /return TRUE
    }
/return FALSE

| ---------------------------------------------------------------------
| NAV TO ID WITH DOORS + NUDGES (NO MQ2MOVEUTILS)
| - Reissues /nav if it stops early
| - If stuck (no movement / no distance progress), tries to open doors and nudge
| Args:
|   targetID   = spawn ID to nav to
|   stopDist   = desired distance to stop
|   maxTicks   = max loop ticks (10 ticks ~= 1 second if delay 1 used)
| ---------------------------------------------------------------------
Sub NavToIDWithDoorsAndNudges(int targetID, float stopDist, int maxTicks)
    /declare tid int local ${targetID}
    /declare distGoal float local ${stopDist}
    /declare limit int local ${maxTicks}

    /declare navTicks int local 0
    /declare lastDist float local 999999
    /declare stuckCount int local 0
    /declare lastX float local ${Me.X}
    /declare lastY float local ${Me.Y}
    /declare nudgeFlip bool local FALSE

    /squelch /nav stop
    /if (${Navigation.PathExists[id ${tid}]}) {
        /nav id ${tid} distance=${distGoal}
    } else {
        | Still try nav id anyway (some builds will attempt even if PathExists lies)
        /nav id ${tid} distance=${distGoal}
    }

    :NavIDLoop
    /doevents
    /delay 1
    /varcalc navTicks ${navTicks} + 1

    /if (!${Target.ID} || ${Target.ID} != ${tid}) {
        /squelch /nav stop
        /return
    }

    /if (${Target.Distance} <= ${distGoal}) {
        /squelch /nav stop
        /return
    }

    /if (${Math.Abs[${Target.Distance} - ${lastDist}]} < 0.5 && ${Math.Abs[${Me.X}-${lastX}]} < 0.5 && ${Math.Abs[${Me.Y}-${lastY}]} < 0.5) {
        /varcalc stuckCount ${stuckCount} + 1
    } else {
        /varset stuckCount 0
    }
    /varset lastDist ${Target.Distance}
    /varset lastX ${Me.X}
    /varset lastY ${Me.Y}

    /if (!${Navigation.Active} && ${Target.Distance} > (${distGoal} + 2)) {
        /nav id ${tid} distance=${distGoal}
    }

    /if (${stuckCount} >= 30) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] Nav stuck (dist=${Target.Distance}) - trying door + nudge..."
        /squelch /nav stop
        /call TryOpenNearbyDoor 40
        /face fast
        /delay 1

        | Nudge: forward + alternating strafe
        /keypress forward hold
        /delay 2
        /keypress forward

        /if (!${nudgeFlip}) {
            /keypress strafe_left hold
            /delay 2
            /keypress strafe_left
            /varset nudgeFlip TRUE
        } else {
            /keypress strafe_right hold
            /delay 2
            /keypress strafe_right
            /varset nudgeFlip FALSE
        }

        /varset stuckCount 0
        /nav id ${tid} distance=${distGoal}
    }

    /if (${Math.Calc[${navTicks}%20]} == 0) {
        /call TryOpenNearbyDoor 40
    }

    /if (${navTicks} >= ${limit}) {
        /squelch /nav stop
        /return
    }

    /goto :NavIDLoop

| ---------------------------------------------------------------------
| NAV BACK TO GROUP LEADER
| Called after sell/bank/tribute/unload to return bot to leader
| Requires MQ2Nav. Skips if: not grouped, no leader, leader is self,
|   leader out of range/zone, or nav path doesn't exst
| ---------------------------------------------------------------------
Sub NavBackToGroupLeader
    /if (!${Me.Grouped}) /return
    /if (${Me.Feigning}) /return
    /if (!${Group.Leader.ID}) /return
    /if (${Group.Leader.ID} == ${Me.ID}) /return
    /if (!${Group.Leader.Present}) /return

    /declare navDist float local 30

    /if (${Group.Leader.Distance} <= ${navDist}) {
        /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] NavBackToGroupLeader: Already within ${navDist} units of ${Group.Leader.Name}, skipping."
        /return
    }

    /call AnnounceBankSellProgress "${tlTag} \ayNavigating back to group leader: ${Group.Leader.Name}..."

    /target id ${Group.Leader.ID}
    /delay 5 ${Target.ID}
    /if (!${Target.ID}) /return

    /call NavToIDWithDoorsAndNudges ${Group.Leader.ID} ${navDist} 600

    /squelch /nav stop
    /squelch /target clear
    /if (${showDebug} || ${logToFile}) /call LogDebug "[turboLoot] NavBackToGroupLeader: Done."
/return

| ---------------------------------------------------------------------
| LOAD WILDCARDS FROM INI [Wildcards] SECTION
| Reads prefixes from [Wildcards] and builds a pipe-delimited string
| for IsWildcardItem to check against
| Format: |6:SPELL:||5:SONG:||8:TOME OF |
| ---------------------------------------------------------------------
Sub LoadWildcards
    /if (${Defined[wildcardPrefixes]}) /varset wildcardPrefixes ""
    /if (${Defined[wildcardFirstChars]}) /varset wildcardFirstChars ""

    | --- Built-in default prefixes (checked as keys in [Wildcards] section) ---
    /declare wcVal string local
    /declare wcUpper string local
    /declare wcLen int local

    /varset wcVal ${Ini[${iniFile},Wildcards,Spell:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes "${wildcardPrefixes}|6:SPELL:"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Skill:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes "${wildcardPrefixes}|6:SKILL:"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Song:]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes "${wildcardPrefixes}|5:SONG:"
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Tome ]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes "${wildcardPrefixes}|5:TOME "
        }
    }

    /varset wcVal ${Ini[${iniFile},Wildcards,Tome of ]}
    /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
        /varset wcUpper ${wcVal.Upper.Replace[ ,]}
        /if (${wcUpper.Equal[ON]} || ${wcUpper.Equal[TRUE]} || ${wcUpper.Equal[YES]} || ${wcUpper.Equal[1]}) {
            /varset wildcardPrefixes "${wildcardPrefixes}|8:TOME OF "
        }
    }

    | --- User-added custom wildcards: Wildcard1 through Wildcard20 ---
    /declare i int local
    /declare rawPrefix string local
    /for i 1 to 20
        /varset wcVal ${Ini[${iniFile},Wildcards,Wildcard${i}]}
        /if (${wcVal.Length} && !${wcVal.Equal[NULL]} && !${wcVal.Equal[Null]} && !${wcVal.Equal[null]}) {
            /call StripIniComment "${wcVal}"
            /varset rawPrefix ${Macro.Return}
            /if (${rawPrefix.Length}) {
                /varset wcLen ${rawPrefix.Length}
                /varset wildcardPrefixes "${wildcardPrefixes}|${wcLen}:${rawPrefix.Upper}"
            }
        }
    /next i

    /if (${wildcardPrefixes.Length}) {
        /varset wildcardPrefixes "${wildcardPrefixes}|"
        /if (${logToFile} && ${Defined[logLevel]} && ${logLevel} <= 0) /call LogDebugFileOnly "[turboLoot] Wildcards active: ${wildcardPrefixes}"

        | Unique first characters of each prefix- quick reject in IsWildcardItem (FastLoot ON/OFF safe)
        /varset wildcardFirstChars |
        /declare fcPos int local 1
        /declare fcChunk string local
        /declare fcPipe int local
        /declare fcEntry string local
        /declare fcColon int local
        /declare fcPrefixText string local
:nextFCWildcard
        /varset fcPos ${Math.Calc[${fcPos}+1]}
        /if (${fcPos} >= ${wildcardPrefixes.Length}) /goto :doneFCWildcard
        /varset fcChunk ${wildcardPrefixes.Mid[${fcPos},500]}
        /if (!${fcChunk.Length}) /goto :doneFCWildcard
        /varset fcPipe ${fcChunk.Find[|]}
        /if (!${fcPipe} || ${fcPipe} < 3) /goto :doneFCWildcard
        /varset fcEntry ${fcChunk.Left[${Math.Calc[${fcPipe}-1]}]}
        /varset fcPos ${Math.Calc[${fcPos}+${fcPipe}-1]}
        /varset fcColon ${fcEntry.Find[:]}
        /if (!${fcColon}) /goto :nextFCWildcard
        /varset fcPrefixText ${fcEntry.Mid[${Math.Calc[${fcColon}+1]},1]}
        /if (${fcPrefixText.Length} && !${wildcardFirstChars.Find[|${fcPrefixText}|]}) {
            /varset wildcardFirstChars ${wildcardFirstChars}${fcPrefixText}|
        }
        /goto :nextFCWildcard
:doneFCWildcard
    } else /if (${logToFile} && ${Defined[logLevel]} && ${logLevel} <= 0) {
        /call LogDebugFileOnly "No wildcards loaded from [Wildcards] section."
    }
/return
